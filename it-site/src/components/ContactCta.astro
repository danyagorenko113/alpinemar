---
import Container from './Container.astro';
import { site } from '@/data/site';

// Shared bottom contact section — "Let's get on a first name basis." block.
// The form is embedded from HubSpot (Portal 42958375, region na1).
---

<section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-32">
  <div class="am-aurora" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-0 am-grid-pattern" aria-hidden="true"></div>

  <Container width="wide" class="relative z-10">
    <div data-reveal data-speed="fast" class="mb-10">
      <span class="am-eyebrow on-dark">Contact Us</span>
    </div>

    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
      {/* ── Left: headline + office / contact info ── */}
      <div data-reveal class="flex flex-col gap-10 lg:col-span-5">
        <h2 class="am-h1-display am-gradient-ink-light">
          Let’s get on a<br />
          first name basis.
        </h2>

        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-1">
          <div class="am-card-dark rounded-[8px] p-6 md:p-7">
            <h3 class="font-display text-[12px] font-medium uppercase tracking-[0.12em] text-scooter">
              Office
            </h3>
            <address class="mt-5 block font-display text-[14.5px] not-italic leading-[1.6] text-white">
              {site.address.street}<br />
              {site.address.city}, {site.address.state} {site.address.zip}
            </address>
          </div>
          <div class="am-card-dark rounded-[8px] p-6 md:p-7">
            <h3 class="font-display text-[12px] font-medium uppercase tracking-[0.12em] text-scooter">
              Contact
            </h3>
            <div class="mt-5 flex flex-col gap-1.5 font-display text-[14.5px] leading-[1.6]">
              <a href={`mailto:${site.email}`} class="text-white transition-colors hover:text-scooter">
                {site.email}
              </a>
              <a href={`tel:${site.phoneHref}`} class="text-white transition-colors hover:text-scooter">
                {site.phone}
              </a>
            </div>
          </div>
        </div>

        <p class="max-w-sm font-display text-[13px] leading-[1.6] text-white/50">
          Prefer to call? We’re happy to chat. Reach us at
          <a href={`tel:${site.phoneHref}`} class="text-white/70 underline underline-offset-4 hover:text-scooter">{site.phone}</a>.
          Monday–Friday, 9 AM–5 PM ET.
        </p>
      </div>

      {/* ── Right: HubSpot-embedded consultation form (Portal 42958375) ── */}
      <div data-reveal data-speed="slow" class="lg:col-span-7">
        <div class="rounded-[12px] border border-white/10 bg-white p-7 shadow-[0_24px_80px_-40px_rgba(0,0,0,0.6)] lg:p-10">
          <div
            id="it-consult-hs"
            class="hs-form-target"
            data-hs-region="na1"
            data-hs-portal="42958375"
            data-hs-form="1636ed35-b770-47ad-87c7-127ccaa449d0"
          >
            <p class="hs-form-loading font-display text-[14px] text-navy-500">Loading form…</p>
          </div>
          <noscript>
            <p class="font-display text-[14px] text-navy-500">
              Please enable JavaScript to load the form, or email
              <a href={`mailto:${site.email}`} class="text-scooter underline">{site.email}</a>.
            </p>
          </noscript>
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  // Load the HubSpot embed script once, then render every form target on the page.
  function loadHubSpot(): Promise<void> {
    return new Promise((resolve) => {
      if ((window as any).hbspt) return resolve();
      const existing = document.querySelector('script[data-hs-embed]');
      if (existing) {
        existing.addEventListener('load', () => resolve(), { once: true });
        return;
      }
      const s = document.createElement('script');
      s.src = 'https://js.hsforms.net/forms/embed/v2.js';
      s.defer = true;
      s.setAttribute('data-hs-embed', '');
      s.addEventListener('load', () => resolve(), { once: true });
      document.head.appendChild(s);
    });
  }

  async function renderHubSpotForms() {
    const targets = document.querySelectorAll<HTMLElement>('.hs-form-target[data-hs-form]');
    if (!targets.length) return;
    await loadHubSpot();
    targets.forEach((el) => {
      if (el.dataset.hsRendered === '1' || !el.id) return;
      el.dataset.hsRendered = '1';
      (window as any).hbspt.forms.create({
        region: el.dataset.hsRegion,
        portalId: el.dataset.hsPortal,
        formId: el.dataset.hsForm,
        target: '#' + el.id,
        onFormReady: () => el.querySelector('.hs-form-loading')?.remove(),
      });
    });
  }

  document.addEventListener('astro:page-load', renderHubSpotForms);
</script>

---
import Container from './Container.astro';
import { getCollection } from 'astro:content';
import { primaryNav, site, serviceLines, moreServices } from '@/data/site';

const path = Astro.url.pathname;

// Services menu — same order as the live site's mega menu:
// four primary service lines, then the remaining services.
const services = (await getCollection('services'))
  .filter((s) => s.data.status !== 'draft')
  .map((s) => s.data);
const bySlug = new Map(
  services.map((s) => [s.path.replace(/^\/services\//, '').replace(/\/$/, ''), s]),
);
const lineItems = serviceLines.map((slug) => bySlug.get(slug)).filter(Boolean);
const moreItems = moreServices.map((slug) => bySlug.get(slug)).filter(Boolean);
---

{/* ═══════ TOP BAR — mirrors the main site's TopBar.astro (division tabs).
    Long naming per client request: "Information Technology", not "IT". ═══════ */}
<div class="relative z-50 border-b border-white/10 bg-[#0a0a1c] py-2 text-[12px] tracking-[-0.005em] text-white/85 md:py-3 md:text-[12.5px]">
  <Container width="wide" class="flex items-center justify-between gap-5 overflow-x-auto [scrollbar-width:none] md:gap-6 [&::-webkit-scrollbar]:hidden">
    <div class="flex shrink-0 items-center gap-5 md:gap-7">
      <a
        href={site.parentSiteUrl}
        class="inline-flex items-center gap-1.5 whitespace-nowrap pb-1 font-medium text-white/70 transition-colors hover:text-white"
      >
        <span>Financial Services</span>
        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
      </a>
      <a href="/" class="inline-flex items-center gap-2 border-b border-scooter pb-1 font-medium text-white" aria-current="page">
        <span class="block size-1.5 rounded-full bg-scooter"></span>
        <span class="whitespace-nowrap">Information Technology</span>
      </a>
    </div>

    <a href={site.clientPortal} target="_blank" rel="noopener" class="inline-flex shrink-0 items-center gap-1.5 font-medium text-white/85 transition-colors hover:text-scooter">
      Client Portal
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
    </a>
  </Container>
</div>

<header class="sticky top-0 z-40 border-b border-white/10 bg-[#12122d]">
  <Container width="wide" class="flex h-16 items-center justify-between gap-6 md:h-20">
    <a href="/" class="flex items-center">
      <img
        src="/images/brand/alpine-mar-it-logo-white.png"
        alt="Alpine Mar — Information Technology"
        width="462"
        height="103"
        class="h-9 w-auto md:h-10"
      />
    </a>

    <nav aria-label="Primary" class="hidden md:flex items-center gap-8">
      <a
        href="/"
        class:list={[
          'font-display text-[14px] font-medium transition-colors',
          path === '/' ? 'text-white' : 'text-white/70 hover:text-white',
        ]}
      >
        Home
      </a>

      {/* Services — hover dropdown with the full grouped catalog, as on the live site */}
      <div class="group relative">
        <a
          href="/services/"
          class:list={[
            'inline-flex items-center gap-1.5 py-6 font-display text-[14px] font-medium transition-colors',
            path.startsWith('/services') ? 'text-white' : 'text-white/70 group-hover:text-white',
          ]}
        >
          Services
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform group-hover:rotate-180">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </a>

        <div class="invisible absolute left-1/2 top-full z-50 w-[760px] -translate-x-1/2 pt-0 opacity-0 transition-all duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
          <div class="rounded-b-[12px] border border-white/10 bg-[#12122d] p-8 shadow-[0_32px_80px_-24px_rgba(0,0,0,0.7)]">
            <div class="grid grid-cols-[220px_1fr] gap-x-10">
              {/* Primary service lines — as on the live mega menu */}
              <ul class="flex flex-col gap-1 border-r border-white/10 pr-8">
                {lineItems.map((svc) => (
                  <li>
                    <a
                      href={svc!.path}
                      class="block py-2 font-display text-[14px] font-medium leading-[1.35] text-white transition-colors hover:text-scooter"
                    >
                      {svc!.title}
                    </a>
                  </li>
                ))}
              </ul>
              {/* Remaining services — live menu order */}
              <ul class="grid grid-cols-2 gap-x-8 gap-y-0.5 content-start">
                {moreItems.map((svc) => (
                  <li>
                    <a
                      href={svc!.path}
                      class="block py-1.5 font-display text-[13px] leading-[1.4] text-white/70 transition-colors hover:text-white"
                    >
                      {svc!.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
            <a
              href="/services/"
              class="group/all mt-7 inline-flex items-center gap-2 border-t border-white/10 pt-5 font-display text-[13px] font-medium text-white transition-colors hover:text-scooter"
            >
              Explore all Our Services
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover/all:translate-x-1">
                <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>

      {primaryNav.filter((i) => i.href !== '/services/' && i.href !== '/contact/').map((item) => {
        const active = path === item.href || path.startsWith(item.href.replace(/\/$/, '') + '/');
        return (
          <a
            href={item.href}
            class:list={[
              'font-display text-[14px] font-medium transition-colors',
              active ? 'text-white' : 'text-white/70 hover:text-white',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <a
      href="/contact/"
      class="hidden md:inline-flex items-center gap-2 rounded-full bg-scooter px-6 py-3 font-display text-[13px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950"
    >
      Contact Us
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
    </a>

    {/* Mobile burger */}
    <button
      type="button"
      id="am-nav-open"
      class="md:hidden inline-flex h-10 w-10 items-center justify-center text-white"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="am-mobile-menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M4 7h16" /><path d="M4 12h16" /><path d="M4 17h16" />
      </svg>
    </button>
  </Container>

  {/* ══════════════════ MOBILE MENU — dropdown panel under the header,
      same pattern as the main site's Nav (top bars stay visible). ═══════ */}
  <div
    id="am-mobile-menu"
    class="hidden max-h-[calc(100dvh-9rem)] overflow-y-auto border-t border-white/10 bg-white md:hidden"
  >
    <Container width="wide" class="flex flex-col py-4">
      <a href="/" class="border-b border-line py-3.5 font-display text-[15px] font-medium text-navy-900 transition-colors hover:text-scooter">Home</a>

      <details class="group border-b border-line">
        <summary class="flex cursor-pointer list-none items-center justify-between py-3.5 font-display text-[15px] font-medium text-navy-900 [&::-webkit-details-marker]:hidden">
          Services
          <span class="inline-flex size-6 items-center justify-center rounded-full border border-line">
            <svg class="transition-transform duration-200 group-open:rotate-180" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </span>
        </summary>
        <div class="pb-5">
          {/* Primary service lines — as on the live mobile menu */}
          <ul class="mt-2 space-y-2">
            {lineItems.map((svc) => (
              <li>
                <a href={svc!.path} class="block font-display text-[14px] font-medium text-navy-900 transition-colors hover:text-scooter">{svc!.title}</a>
              </li>
            ))}
          </ul>
          {/* Remaining services */}
          <ul class="mt-4 space-y-2 border-l border-line pl-4">
            {moreItems.map((svc) => (
              <li>
                <a href={svc!.path} class="block font-display text-[14px] text-navy-500 transition-colors hover:text-scooter">{svc!.title}</a>
              </li>
            ))}
          </ul>
          <a href="/services/" class="mt-5 inline-flex items-center gap-2 font-display text-[13px] font-medium text-navy-900 transition-colors hover:text-scooter">
            Explore all Our Services
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </details>

      <a href="/about/" class="border-b border-line py-3.5 font-display text-[15px] font-medium text-navy-900 transition-colors hover:text-scooter">About Us</a>
      <a href="/media/" class="border-b border-line py-3.5 font-display text-[15px] font-medium text-navy-900 transition-colors hover:text-scooter">Media</a>
      <a href="/blog/" class="border-b border-line py-3.5 font-display text-[15px] font-medium text-navy-900 transition-colors hover:text-scooter">Blog</a>
      <a href={site.clientPortal} target="_blank" rel="noopener" class="flex items-center justify-between py-3.5 font-display text-[15px] font-medium text-navy-900 transition-colors hover:text-scooter">
        Client Portal
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" class="text-navy-500"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
      </a>

      <a
        href="/contact/"
        class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-[6px] bg-navy-900 px-7 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-scooter"
      >
        Contact Us
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </Container>
  </div>
</header>

<script>
  function initMobileMenu() {
    const menu = document.getElementById('am-mobile-menu');
    const toggle = document.getElementById('am-nav-open');
    if (!menu || !toggle) return;
    if (toggle.dataset.bound === '1') return;
    toggle.dataset.bound = '1';

    const setOpen = (open: boolean) => {
      menu.classList.toggle('hidden', !open);
      toggle.setAttribute('aria-expanded', String(open));
    };

    toggle.addEventListener('click', () =>
      setOpen(menu.classList.contains('hidden')),
    );
    // Close when a link inside the menu is tapped.
    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => setOpen(false)),
    );
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  }
  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>

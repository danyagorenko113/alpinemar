---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/i, '').split('/').pop() },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;
const dateFmt = new Date(d.date).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const related = (await getCollection('insights'))
  .filter(
    (p) =>
      p.data.status !== 'draft' &&
      p.id !== post.id &&
      p.data.category === d.category,
  )
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))
  .slice(0, 3);

const slugOf = (id: string) => id.replace(/\.md$/, '').split('/').pop();
const relatedDateFmt = (dt: string | Date) =>
  new Date(dt).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });

// Rough reading-time estimate — we don't have the raw body here without extra
// work, so we approximate from the excerpt length + a floor of 4 min. Better
// than a fake exact number.
const readingTime = Math.max(4, Math.round((d.excerpt.length + 3000) / 900));

// Author card — only Vanessa Holub appears as author across content. Role
// matches the live site team roster.
const author = d.author ?? 'Alpine Mar IT';
const authorBlurb = author === 'Vanessa Holub' ? 'COO, Alpine Mar' : 'Alpine Mar IT';
---

<BaseLayout
  title={d.seo?.title ?? d.title}
  description={d.seo?.description ?? d.excerpt}
>
  {/* ══════════════════════ HEADER ══════════════════════
      Reading-width column. Polished meta row (category chip · date · minutes)
      above the H1, lead paragraph after, author byline row.
  ══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-paper">
    <div class="am-aurora on-light" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 am-grid-pattern-light opacity-70" aria-hidden="true"></div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-b from-transparent to-white"
      aria-hidden="true"
    ></div>

    <Container width="reading" class="relative pt-12 pb-14 md:pt-[16vh] md:pb-20">
      {/* Breadcrumb + back link */}
      <div data-reveal data-speed="fast" class="mb-8">
        <a
          href="/blog/"
          class="group inline-flex items-center gap-2 font-display text-[13px] text-navy-500 transition-colors hover:text-navy-900"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:-translate-x-1">
            <path d="m15 18-6-6 6-6" />
          </svg>
          All Insights
        </a>
      </div>

      {/* Meta row */}
      <div
        data-reveal
        data-speed="fast"
        class="flex flex-wrap items-center gap-x-4 gap-y-3 font-display text-[12.5px] text-navy-500"
      >
        <span class="inline-flex items-center gap-2 rounded-[4px] bg-white px-3 py-1.5 shadow-sm">
          <span class="block size-1.5 rounded-full bg-scooter"></span>
          {d.category ?? 'Article'}
        </span>
        <span class="text-navy-300">·</span>
        <time datetime={new Date(d.date).toISOString()}>{dateFmt}</time>
        <span class="text-navy-300">·</span>
        <span>{readingTime} min read</span>
      </div>

      <h1
        data-reveal
        data-speed="slow"
        class="mt-8 font-display text-[36px] font-medium leading-[1.08] tracking-[-0.02em] text-navy-900 md:text-[52px]"
      >
        {d.title}
      </h1>

      <p
        data-reveal
        class="mt-8 max-w-[62ch] font-display text-[18px] leading-[1.6] text-navy-500 md:text-[20px]"
      >
        {d.excerpt}
      </p>

      {/* Author byline */}
      <div
        data-reveal
        class="mt-10 flex items-center gap-4 border-t border-line pt-6"
      >
        <div class="flex size-11 items-center justify-center rounded-full bg-navy-900 font-display text-[15px] font-medium text-white">
          {author.split(' ').map((n) => n[0]).slice(0, 2).join('')}
        </div>
        <div>
          <p class="font-display text-[14px] font-medium text-navy-900">
            {author}
          </p>
          <p class="font-display text-[12.5px] text-navy-500">
            Alpine Mar IT · Published {dateFmt}
          </p>
        </div>
      </div>
    </Container>
  </section>

  {/* ══════════════════════ BODY ══════════════════════
      17px body, generous leading, teal accents on H2 and links.
  ══════════════════════════════════════════════════════════ */}
  <section class="relative bg-white py-14 md:py-20">
    <Container width="reading">
      <article
        class="prose prose-lg max-w-none
          [&_h2]:font-display [&_h2]:text-[28px] [&_h2]:font-medium [&_h2]:tracking-[-0.01em] [&_h2]:text-navy-900 [&_h2]:mt-14 [&_h2]:mb-5 [&_h2]:pt-5 [&_h2]:border-t [&_h2]:border-line-soft [&_h2]:relative
          [&_h3]:font-display [&_h3]:text-[20px] [&_h3]:font-medium [&_h3]:text-navy-900 [&_h3]:mt-10 [&_h3]:mb-3
          [&_p]:font-display [&_p]:text-[17px] [&_p]:leading-[1.75] [&_p]:text-navy-700 [&_p]:my-6
          [&_ul]:font-display [&_ul]:text-[17px] [&_ul]:text-navy-700 [&_ul]:my-6 [&_ul]:pl-1 [&_ul]:list-none [&_ul>li]:relative [&_ul>li]:pl-6 [&_ul>li]:my-2.5
          [&_ol]:font-display [&_ol]:text-[17px] [&_ol]:text-navy-700 [&_ol]:my-6 [&_ol]:pl-6 [&_ol>li]:my-2.5
          [&_strong]:text-navy-900 [&_strong]:font-medium
          [&_a]:text-teal-700 [&_a]:underline [&_a]:underline-offset-4 [&_a]:decoration-1 hover:[&_a]:decoration-2
          [&_blockquote]:relative [&_blockquote]:border-l-2 [&_blockquote]:border-scooter [&_blockquote]:pl-6 [&_blockquote]:italic [&_blockquote]:text-navy-900 [&_blockquote]:my-8 [&_blockquote]:py-2"
      >
        <Content />
      </article>
    </Container>

    <style is:global>
      section article.prose ul > li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.75em;
        width: 0.75rem;
        height: 1.5px;
        background: #33bbdc;
      }
      section article.prose h2::before {
        content: "";
        position: absolute;
        top: -1px;
        left: 0;
        width: 2.5rem;
        height: 2px;
        background: #33bbdc;
      }
    </style>
  </section>

  {/* ══════════════════════ AUTHOR CARD ══════════════════════ */}
  <section class="relative border-t border-line bg-paper py-16 md:py-20">
    <Container width="reading">
      <div
        data-reveal
        class="flex flex-col gap-6 rounded-[12px] border border-line bg-white p-8 md:flex-row md:items-center md:gap-8 md:p-10"
      >
        <div class="flex size-16 shrink-0 items-center justify-center rounded-full bg-navy-900 font-display text-[24px] font-medium text-white">
          {author.split(' ').map((n) => n[0]).slice(0, 2).join('')}
        </div>
        <div class="flex-1">
          <span class="am-eyebrow" style="font-size:11px;">
            Written by
          </span>
          <h2 class="mt-3 font-display text-[22px] font-medium tracking-[-0.01em] text-navy-900">
            {author}
          </h2>
          <p class="mt-2 max-w-[52ch] font-display text-[14.5px] leading-[1.6] text-navy-500">
            {authorBlurb}
          </p>
        </div>
        <a
          href="/contact/"
          class="group inline-flex shrink-0 items-center gap-2 self-start rounded-[6px] bg-navy-900 px-5 py-3 font-display text-[13px] font-medium text-white transition-colors hover:bg-scooter md:self-center"
        >
          Talk to the team
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </a>
      </div>
    </Container>
  </section>

  {/* ══════════════════════ RELATED ══════════════════════ */}
  {related.length > 0 && (
    <section class="relative border-t border-line bg-white py-20 md:py-24">
      <Container width="wide">
        <div data-reveal data-speed="fast" class="mb-10">
          <span class="am-eyebrow">More in {d.category ?? 'Insights'}</span>
        </div>

        <div
          data-reveal
          class="grid grid-cols-1 gap-10 border-b border-line pb-14 md:grid-cols-12 md:gap-16"
        >
          <h2 class="am-h1-display text-navy-900 md:col-span-7">
            Keep reading.
          </h2>
        </div>

        <ul data-stagger class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-3">
          {related.map((p) => (
            <li>
              <a
                href={`/blog/${slugOf(p.id)}/`}
                class="group flex h-full flex-col rounded-[10px] border border-line bg-paper p-7 transition-all hover:-translate-y-0.5 hover:border-navy-900"
              >
                <div class="flex items-center justify-between gap-3 font-display text-[12px] text-navy-500">
                  <span class="inline-flex items-center gap-2 rounded-[4px] bg-white px-3 py-1.5">
                    <span class="block size-1.5 rounded-full bg-scooter"></span>
                    {p.data.category ?? 'Insights'}
                  </span>
                  <span>{relatedDateFmt(p.data.date)}</span>
                </div>
                <h3 class="mt-7 font-display text-[20px] font-medium leading-[1.28] tracking-[-0.01em] text-navy-900 transition-colors group-hover:text-teal-700">
                  {p.data.title}
                </h3>
                <p class="mt-3 font-display text-[14px] leading-[1.6] text-navy-500 line-clamp-3">
                  {p.data.excerpt}
                </p>
                <span class="mt-auto flex items-center justify-between gap-4 pt-8">
                  <span class="font-display text-[13px] font-medium text-navy-900">
                    Learn More
                  </span>
                  <span class="inline-flex size-9 items-center justify-center rounded-[6px] bg-navy-900 text-white transition-transform group-hover:translate-x-1">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
                      <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
                    </svg>
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </Container>
    </section>
  )}

  {/* ══════════════════════ CTA ══════════════════════ */}
  <section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-28">
    <div class="am-aurora" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 am-grid-pattern" aria-hidden="true"></div>

    <Container width="wide" class="relative z-10 text-center">
      <div class="mx-auto max-w-3xl">
        <div class="flex justify-center">
          <span class="am-eyebrow on-dark">Contact Us</span>
        </div>
        <h2 class="mt-8 am-h1-display am-gradient-ink-light">
          Let’s get on a<br />
          first name basis.
        </h2>
        <p class="mx-auto mt-6 max-w-lg font-display text-[16px] leading-[1.65] text-white/75">
          Start with a free IT assessment. No obligations, just insights.
        </p>
        <a
          href="/contact/"
          class="group mt-10 inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950"
        >
          Request a Consultation
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('insights'))
  .filter((p) => p.data.status !== 'draft')
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));

const slugOf = (id: string) => id.replace(/\.md$/, '').split('/').pop();
const dateFmt = (d: string | Date) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

// Featured = newest Cybersecurity post if available, else newest overall.
const featured =
  posts.find((p) => p.data.category === 'Cybersecurity') ?? posts[0];
const rest = posts.filter((p) => p.id !== featured?.id);

// Distinct categories, sorted by post count.
const categoryCounts = new Map<string, number>();
for (const p of posts) {
  const c = p.data.category ?? 'Uncategorized';
  categoryCounts.set(c, (categoryCounts.get(c) ?? 0) + 1);
}
const categories = Array.from(categoryCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .map(([label, count]) => ({ label, count }));

// A category → CTA blurb map for the bottom section (random pick).
const spotlightPool = posts.slice(0, 6);
const spotlight = spotlightPool[Math.floor(Math.random() * spotlightPool.length)] ?? posts[0];
---

<BaseLayout
  rawTitle="Insights at The Intersection of Tech and Business"
  description="Fresh thinking on cybersecurity, infrastructure, AI, and IT strategy. Written for real businesses, not just techies."
>
  {/* ══════════════════════ HERO ══════════════════════ */}
  <section class="relative overflow-hidden bg-paper">
    <div class="am-aurora on-light" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 am-grid-pattern-light" aria-hidden="true"></div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-b from-transparent to-paper"
      aria-hidden="true"
    ></div>

    <Container width="wide" class="relative">
      <div class="grid grid-rows-[auto_1fr_auto] content-start gap-0 pt-14 pb-14 md:min-h-[60vh] md:pt-[19vh] md:pb-20">
        <div data-reveal data-speed="fast" class="mb-8 md:mb-10">
          <span class="am-eyebrow">Insights</span>
        </div>

        <h1
          data-reveal
          data-speed="slow"
          class="am-hero-display am-gradient-ink self-start leading-[1.02]"
        >
          Insights at the intersection<br />
          of tech <span class="italic text-scooter">&</span> business.
        </h1>

        <div
          data-reveal
          class="mt-9 flex max-w-[62ch] flex-col gap-4 md:mt-14"
        >
          <p class="font-display text-[16px] leading-[1.65] text-navy-500 md:text-[17px]">
            Fresh thinking on cybersecurity, infrastructure, AI, and IT
            strategy. Written for real businesses, not just techies.
          </p>
        </div>
      </div>
    </Container>
  </section>

  {/* ══════════════════════ FEATURED ══════════════════════
      Large split card. Left: meta + big title + excerpt + CTA.
      Right: brand panel (dark navy + aurora + oversized category word).
  ══════════════════════════════════════════════════════════ */}
  {featured && (
    <section class="relative border-t border-line bg-white py-20 md:py-24">
      <Container width="wide">
        <div data-reveal data-speed="fast" class="mb-10">
          <span class="am-eyebrow">Featured</span>
        </div>

        <a
          data-reveal
          href={`/blog/${slugOf(featured.id)}/`}
          class="group grid grid-cols-1 overflow-hidden rounded-[12px] border border-line bg-white transition-colors hover:border-navy-900 md:grid-cols-2"
        >
          <div class="flex flex-col gap-6 p-8 md:p-12">
            <div class="flex items-center justify-between gap-3 font-display text-[12px] text-navy-500">
              <span class="inline-flex items-center gap-2 rounded-[4px] bg-paper px-3 py-1.5">
                <span class="block size-1.5 rounded-full bg-scooter"></span>
                {featured.data.category ?? 'Insights'}
              </span>
              <span>{dateFmt(featured.data.date)}</span>
            </div>
            <h2 class="font-display text-[30px] font-medium leading-[1.15] tracking-[-0.02em] text-navy-900 md:text-[38px]">
              {featured.data.title}
            </h2>
            <p class="max-w-[52ch] font-display text-[16px] leading-[1.65] text-navy-500">
              {featured.data.excerpt}
            </p>
            {featured.data.author && (
              <p class="font-display text-[13px] text-navy-400">
                By {featured.data.author}
              </p>
            )}
            <div class="mt-auto flex items-center justify-between gap-4 pt-6">
              <span class="font-display text-[14px] font-medium text-navy-900">
                Learn More
              </span>
              <span class="inline-flex size-10 items-center justify-center rounded-[6px] bg-navy-900 text-white transition-transform group-hover:translate-x-1 group-hover:bg-scooter">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
                  <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>

          {/* Brand panel */}
          <div class="relative aspect-[5/4] overflow-hidden bg-navy-900 md:aspect-auto md:min-h-[460px]">
            <div class="pointer-events-none absolute inset-0 am-grid-pattern opacity-70" aria-hidden="true"></div>
            <div class="am-aurora" aria-hidden="true"></div>
            <div class="absolute inset-0 bg-gradient-to-br from-navy-900/90 via-navy-900/40 to-transparent"></div>

            <div class="relative flex h-full flex-col justify-between p-8 md:p-12">
              <span class="am-eyebrow on-dark">Insight</span>
              <div>
                <div class="text-outline-light font-display text-[64px] leading-[0.95] tracking-[-0.03em] md:text-[110px]">
                  {(featured.data.category ?? 'Insight').split(' ')[0]}
                </div>
                <div class="mt-6 font-display text-[13px] uppercase tracking-[0.16em] text-scooter">
                  {featured.data.category ?? 'Insights'} · {dateFmt(featured.data.date)}
                </div>
              </div>
            </div>
          </div>
        </a>
      </Container>
    </section>
  )}

  {/* ══════════════════════ CATEGORY FILTER + GRID ══════════════════════ */}
  <section class="relative border-t border-line bg-paper py-20 md:py-28">
    <Container width="wide">
      <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between md:gap-12">
        <div data-reveal data-speed="fast">
          <span class="am-eyebrow">All Insights</span>
          <h2 class="mt-6 am-h1-display text-navy-900">
            More reading.
          </h2>
        </div>
        <p class="max-w-[42ch] font-display text-[14px] leading-[1.6] text-navy-500">
          Filter by topic to find what applies to your business right now.
        </p>
      </div>

      {/* Category chips — client-side filter */}
      <div
        data-reveal
        data-stagger
        class="mt-10 flex flex-wrap items-center gap-2 border-b border-line pb-8"
        id="insights-filter"
      >
        <button
          type="button"
          data-cat="__all"
          class="am-cat-chip is-active inline-flex items-center gap-2 rounded-full border border-navy-900 bg-navy-900 px-4 py-2 font-display text-[13px] font-medium text-white transition-colors"
        >
          <span>All</span>
          <span class="rounded-full bg-white/15 px-1.5 py-0.5 font-display text-[11px] tabular-nums text-white/80">
            {posts.length}
          </span>
        </button>
        {categories.map(({ label, count }) => (
          <button
            type="button"
            data-cat={label}
            class="am-cat-chip inline-flex items-center gap-2 rounded-full border border-line bg-white px-4 py-2 font-display text-[13px] font-medium text-navy-900 transition-colors hover:border-navy-900"
          >
            <span>{label}</span>
            <span class="rounded-full bg-navy-100 px-1.5 py-0.5 font-display text-[11px] tabular-nums text-navy-500">
              {count}
            </span>
          </button>
        ))}
      </div>

      {posts.length === 0 ? (
        <p class="py-20 text-center font-display text-navy-500">
          No posts yet — check back soon.
        </p>
      ) : (
        <ul
          id="insights-grid"
          data-stagger
          class="mt-10 grid grid-cols-1 gap-x-8 gap-y-10 md:grid-cols-2 lg:grid-cols-3"
        >
          {rest.map((p) => (
            <li data-cat={p.data.category ?? 'Uncategorized'}>
              <a
                href={`/blog/${slugOf(p.id)}/`}
                class="group flex h-full flex-col rounded-[10px] border border-line bg-white p-7 transition-all hover:-translate-y-0.5 hover:border-navy-900"
              >
                <div class="flex items-center justify-between gap-3 font-display text-[12px] text-navy-500">
                  <span class="inline-flex items-center gap-2 rounded-[4px] bg-paper px-3 py-1.5">
                    <span class="block size-1.5 rounded-full bg-scooter"></span>
                    {p.data.category ?? 'Insights'}
                  </span>
                  <span>{dateFmt(p.data.date)}</span>
                </div>
                <h3 class="mt-7 font-display text-[20px] font-medium leading-[1.28] tracking-[-0.01em] text-navy-900 transition-colors group-hover:text-teal-700">
                  {p.data.title}
                </h3>
                <p class="mt-3 font-display text-[14px] leading-[1.6] text-navy-500 line-clamp-3">
                  {p.data.excerpt}
                </p>
                <div class="mt-auto flex items-center justify-between gap-4 pt-8">
                  <span class="font-display text-[13px] font-medium text-navy-900">
                    Learn More
                  </span>
                  <span class="inline-flex size-9 items-center justify-center rounded-[6px] bg-navy-900 text-white transition-transform group-hover:translate-x-1">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
                      <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}

      {/* Empty-state for filtered view */}
      <p
        id="insights-empty"
        class="hidden py-20 text-center font-display text-navy-500"
      >
        No insights in this category yet.
      </p>
    </Container>

    <style is:global>
      .am-cat-chip.is-active {
        background-color: var(--color-navy-900);
        color: white;
        border-color: var(--color-navy-900);
      }
      .am-cat-chip.is-active > span:last-child {
        background-color: rgba(255, 255, 255, 0.15);
        color: rgba(255, 255, 255, 0.85);
      }
    </style>
  </section>

  {/* ══════════════════════ CTA — spotlight-driven ══════════════════════ */}
  {spotlight && (
    <section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-28">
      <div class="am-aurora" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0 am-grid-pattern" aria-hidden="true"></div>

      <Container width="wide" class="relative z-10">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
          <div data-reveal class="lg:col-span-6">
            <span class="am-eyebrow on-dark">Contact Us</span>
            <h2 class="mt-6 am-h1-display am-gradient-ink-light">
              Let’s get on a<br />
              first name basis.
            </h2>
            <p class="mt-6 max-w-md font-display text-[16px] leading-[1.65] text-white/75">
              Start with a free IT assessment. No obligations, just insights.
            </p>
            <a
              href="/contact/"
              class="group mt-9 inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950"
            >
              Request a Consultation
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                <path d="m9 18 6-6-6-6" />
              </svg>
            </a>
          </div>

          <div data-reveal data-speed="slow" class="lg:col-span-6">
            <a
              href={`/blog/${slugOf(spotlight.id)}/`}
              class="group block h-full rounded-[10px] border border-white/10 bg-white/[0.03] p-8 transition-colors hover:border-scooter/50 md:p-10"
            >
              <span class="am-eyebrow on-dark" style="font-size:11px;">
                Editor’s pick
              </span>
              <div class="mt-6 flex items-center gap-3 font-display text-[12px] text-white/60">
                <span class="inline-flex items-center gap-2 rounded-[4px] bg-white/5 px-2.5 py-1">
                  <span class="block size-1.5 rounded-full bg-scooter"></span>
                  {spotlight.data.category ?? 'Insights'}
                </span>
                <span>{dateFmt(spotlight.data.date)}</span>
              </div>
              <h3 class="mt-6 font-display text-[24px] font-medium leading-[1.2] tracking-[-0.01em] text-white transition-colors group-hover:text-scooter md:text-[28px]">
                {spotlight.data.title}
              </h3>
              <p class="mt-4 font-display text-[14.5px] leading-[1.6] text-white/70 line-clamp-3">
                {spotlight.data.excerpt}
              </p>
              <span class="mt-8 inline-flex items-center gap-2 border-b border-white/40 pb-1.5 font-display text-[13px] font-medium text-white transition-colors group-hover:border-scooter group-hover:text-scooter">
                Learn More
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                  <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
                </svg>
              </span>
            </a>
          </div>
        </div>
      </Container>
    </section>
  )}

  <script>
    function initInsightsFilter() {
      const chipRoot = document.getElementById('insights-filter');
      const grid = document.getElementById('insights-grid');
      const empty = document.getElementById('insights-empty');
      if (!chipRoot || !grid) return;
      if (chipRoot.dataset.bound === '1') return;
      chipRoot.dataset.bound = '1';

      const chips = Array.from(chipRoot.querySelectorAll<HTMLButtonElement>('.am-cat-chip'));
      const items = Array.from(grid.querySelectorAll<HTMLLIElement>('li[data-cat]'));

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          const cat = chip.dataset.cat ?? '__all';
          chips.forEach((c) => c.classList.toggle('is-active', c === chip));
          let visible = 0;
          items.forEach((li) => {
            const match = cat === '__all' || li.dataset.cat === cat;
            li.style.display = match ? '' : 'none';
            if (match) visible++;
          });
          if (empty) empty.classList.toggle('hidden', visible > 0);
        });
      });
    }
    initInsightsFilter();
    document.addEventListener('astro:page-load', initInsightsFilter);
  </script>
</BaseLayout>

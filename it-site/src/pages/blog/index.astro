---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('insights'))
  .filter((p) => p.data.status !== 'draft')
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));

const slugOf = (id: string) => id.replace(/\.md$/, '').split('/').pop();
const dateFmt = (d: string | Date) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const featured = posts[0];
const rest = posts.slice(1);
---

<BaseLayout
  rawTitle="Insights | Alpine Mar IT"
  description="Cybersecurity, cloud, and AI insights for SMB leaders — written by our team."
>
  {/* HERO */}
  <section class="relative overflow-hidden bg-paper">
    <Container width="wide" class="relative">
      <div class="grid min-h-[54vh] grid-rows-[auto_auto] content-start gap-0 pt-[14vh] pb-14">
        <div data-reveal data-speed="fast" class="mb-8 flex items-center gap-3 text-[var(--color-text-head)]">
          <span class="block size-2 bg-scooter"></span>
          <span class="font-display text-[14px] tracking-[-0.005em]">Insights</span>
        </div>
        <h1 data-reveal data-speed="slow" class="am-hero-display am-gradient-ink self-start pb-2 leading-[1.02]">
          At the intersection of<br />tech and business.
        </h1>
      </div>
    </Container>
  </section>

  {/* FEATURED + GRID */}
  <section class="relative bg-white py-16 md:py-24">
    <Container width="wide">
      {featured && (
        <a data-reveal href={`/blog/${slugOf(featured.id)}/`} class="group grid grid-cols-1 gap-8 border-b border-line pb-14 mb-14 md:grid-cols-12 md:gap-16">
          <div class="md:col-span-7">
            <div class="flex items-center gap-3 font-display text-[12px] text-navy-500">
              <span class="rounded-[4px] bg-navy-50 px-2.5 py-1 text-[11px]">{featured.data.category ?? 'Insights'}</span>
              <span>·</span>
              <span>{dateFmt(featured.data.date)}</span>
            </div>
            <h2 class="mt-5 font-display text-[36px] font-medium leading-[1.1] tracking-[-0.02em] text-navy-900 transition-colors group-hover:text-scooter-dark md:text-[44px]">
              {featured.data.title}
            </h2>
            <p class="mt-5 max-w-[58ch] font-display text-[16px] leading-[1.65] text-navy-500">{featured.data.excerpt}</p>
            <span class="mt-6 inline-flex items-center gap-2 font-display text-[14px] font-medium text-navy-900">
              Read more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
            </span>
          </div>
        </a>
      )}

      <ul data-stagger class="grid grid-cols-1 gap-x-8 gap-y-10 md:grid-cols-2 lg:grid-cols-3">
        {rest.map((p) => (
          <li>
            <a href={`/blog/${slugOf(p.id)}/`} class="group flex h-full flex-col gap-4">
              <div class="flex items-center gap-3 font-display text-[11px] text-navy-500">
                <span class="rounded-[4px] bg-navy-50 px-2 py-0.5">{p.data.category ?? 'Insights'}</span>
                <span>{dateFmt(p.data.date)}</span>
              </div>
              <h3 class="font-display text-[20px] font-medium leading-[1.25] tracking-[-0.01em] text-navy-900 transition-colors group-hover:text-scooter-dark line-clamp-3">
                {p.data.title}
              </h3>
              <p class="font-display text-[14px] leading-[1.6] text-navy-500 line-clamp-3">{p.data.excerpt}</p>
              <span class="mt-auto inline-flex items-center gap-1.5 font-display text-[13px] font-medium text-navy-900">
                Read more
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
              </span>
            </a>
          </li>
        ))}
      </ul>

      {posts.length === 0 && (
        <p class="py-20 text-center font-display text-navy-500">No posts yet — check back soon.</p>
      )}
    </Container>
  </section>
</BaseLayout>

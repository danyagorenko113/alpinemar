---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { site } from '@/data/site';

// Service options — verbatim from the live contact form select.
const serviceOptions = [
  'Technology & Cybersecurity',
  'Internet & Network Cybersecurity',
  'Managed IT Services',
  'IT Consulting Services',
  'Remote IT Support',
  'Artificial Intelligence',
  'Risk Advisory',
  'Incident Response',
];
---

<BaseLayout
  rawTitle="Let’s Talk IT"
  description="Whether you’re exploring support options, facing a cybersecurity concern, or just want a second opinion on your current setup, we’re here to help. Our team will review your existing systems, identify quick wins, and offer tailored recommendations to move your business forward."
>
  {/* ══════════════════════ HERO ══════════════════════
      Dark navy + aurora + grid. Copy verbatim from it.alpinemar.com/contact/.
  ══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-[#12122d] pt-14 pb-16 text-white md:pt-[19vh] md:pb-32">
    <div class="am-aurora" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 am-grid-pattern" aria-hidden="true"></div>
    <div class="grain pointer-events-none absolute inset-0" aria-hidden="true"></div>

    <Container width="wide" class="relative z-10">
      {/* Status pill — label verbatim from the live page. */}
      <div data-reveal data-speed="fast" class="mb-10">
        <span class="inline-flex items-center gap-2.5 rounded-full border border-white/15 bg-white/[0.04] px-3.5 py-1.5 font-display text-[12.5px] font-medium text-white backdrop-blur">
          <span class="am-status-dot text-scooter"></span>
          Get in Touch
        </span>
      </div>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
        {/* ── Left column: headline + info ── */}
        <div data-reveal class="flex flex-col gap-10 lg:col-span-5">
          <div class="flex flex-col gap-8">
            <h1 class="am-hero-display am-gradient-ink-light self-start leading-[1.02]">
              Let’s Talk<br />
              <span class="italic text-scooter">IT</span>
            </h1>
            <div class="flex flex-col gap-4">
              <h2 class="font-display text-[22px] font-medium leading-[1.3] tracking-[-0.01em] text-white md:text-[24px]">
                Start with a free IT assessment. No obligations, just insights.
              </h2>
              <p class="max-w-[52ch] font-display text-[15px] leading-[1.65] text-white/75">
                Whether you’re exploring support options, facing a
                cybersecurity concern, or just want a second opinion on your
                current setup, we’re here to help. Our team will review your
                existing systems, identify quick wins, and offer tailored
                recommendations to move your business forward.
              </p>
              <p class="font-display text-[15px] leading-[1.65] text-white/75">
                We’ll keep it simple, clear, and respectful of your time.
              </p>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-5">
            <div class="am-card-dark rounded-[8px] p-6 md:p-7">
              <h2 class="font-display text-[11px] font-medium uppercase tracking-[0.14em] text-scooter">
                Office
              </h2>
              <address class="mt-5 block font-display text-[15px] not-italic leading-[1.6] text-white">
                {site.address.street}<br />
                {site.address.city}, {site.address.state} {site.address.zip}
              </address>
            </div>
            <div class="am-card-dark rounded-[8px] p-6 md:p-7">
              <h2 class="font-display text-[11px] font-medium uppercase tracking-[0.14em] text-scooter">
                Contact
              </h2>
              <div class="mt-5 flex flex-col gap-2 font-display text-[15px] leading-[1.6]">
                <a
                  href={`tel:${site.phoneHref}`}
                  class="inline-flex w-fit items-center gap-2 text-white transition-colors hover:text-scooter"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                  </svg>
                  {site.phone}
                </a>
                <a
                  href={`mailto:${site.email}`}
                  class="inline-flex w-fit items-center gap-2 text-white transition-colors hover:text-scooter"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect width="20" height="16" x="2" y="4" rx="2" />
                    <path d="m22 7-10 5L2 7" />
                  </svg>
                  {site.email}
                </a>
              </div>
            </div>
            <div class="am-card-dark rounded-[8px] p-6 md:p-7">
              <p class="font-display text-[14px] leading-[1.6] text-white/75">
                Prefer to call? We’re happy to chat. Reach us at
                <a href={`tel:${site.phoneHref}`} class="text-white underline underline-offset-4 hover:text-scooter">{site.phone}</a>.
                Monday–Friday, 9 AM–5 PM ET.
              </p>
            </div>
          </div>
        </div>

        {/* ── Right column: form card — fields verbatim from the live form ── */}
        <div data-reveal data-speed="slow" class="lg:col-span-7">
          <form
            id="it-contact-form"
            class="relative rounded-[12px] border border-white/10 bg-white/[0.04] p-7 backdrop-blur-md shadow-[0_24px_80px_-40px_rgba(0,0,0,0.6)] lg:p-10"
            novalidate
          >
            <div class="pointer-events-none absolute inset-0 am-grid-pattern rounded-[12px] opacity-40"></div>

            <div class="relative">
              <span class="am-eyebrow on-dark" style="font-size:11px;">
                Get in Touch
              </span>

              <div class="mt-8 grid gap-5 sm:grid-cols-2">
                <label class="block">
                  <span class="font-display text-[11px] font-medium uppercase tracking-[0.14em] text-white/60">
                    Name <span class="text-scooter">*</span>
                  </span>
                  <input
                    class="mt-2 w-full rounded-[6px] border border-white/15 bg-white/[0.03] px-4 py-3.5 font-display text-[15px] text-white placeholder:text-white/35 transition-colors focus:border-scooter focus:bg-white/[0.06] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-scooter/30"
                    type="text"
                    name="name"
                    autocomplete="name"
                    required
                  />
                </label>
                <label class="block">
                  <span class="font-display text-[11px] font-medium uppercase tracking-[0.14em] text-white/60">
                    Company Name
                  </span>
                  <input
                    class="mt-2 w-full rounded-[6px] border border-white/15 bg-white/[0.03] px-4 py-3.5 font-display text-[15px] text-white placeholder:text-white/35 transition-colors focus:border-scooter focus:bg-white/[0.06] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-scooter/30"
                    type="text"
                    name="company"
                    autocomplete="organization"
                  />
                </label>
                <label class="block">
                  <span class="font-display text-[11px] font-medium uppercase tracking-[0.14em] text-white/60">
                    Email Address <span class="text-scooter">*</span>
                  </span>
                  <input
                    class="mt-2 w-full rounded-[6px] border border-white/15 bg-white/[0.03] px-4 py-3.5 font-display text-[15px] text-white placeholder:text-white/35 transition-colors focus:border-scooter focus:bg-white/[0.06] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-scooter/30"
                    type="email"
                    name="email"
                    autocomplete="email"
                    required
                  />
                </label>
                <label class="block">
                  <span class="font-display text-[11px] font-medium uppercase tracking-[0.14em] text-white/60">
                    Phone Number
                  </span>
                  <input
                    class="mt-2 w-full rounded-[6px] border border-white/15 bg-white/[0.03] px-4 py-3.5 font-display text-[15px] text-white placeholder:text-white/35 transition-colors focus:border-scooter focus:bg-white/[0.06] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-scooter/30"
                    type="tel"
                    name="phone"
                    autocomplete="tel"
                  />
                </label>
              </div>

              <label class="mt-5 block">
                <span class="font-display text-[11px] font-medium uppercase tracking-[0.14em] text-white/60">
                  What can we help with
                </span>
                <select
                  class="mt-2 w-full rounded-[6px] border border-white/15 bg-white/[0.03] px-4 py-3.5 font-display text-[15px] text-white transition-colors focus:border-scooter focus:bg-white/[0.06] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-scooter/30"
                  name="service"
                >
                  <option value="" class="bg-navy-900 text-white">Select a Service</option>
                  {serviceOptions.map((label) => (
                    <option value={label} class="bg-navy-900 text-white">{label}</option>
                  ))}
                </select>
              </label>

              <label class="mt-5 block">
                <span class="font-display text-[11px] font-medium uppercase tracking-[0.14em] text-white/60">
                  How can we help?
                </span>
                <textarea
                  class="mt-2 min-h-32 w-full resize-y rounded-[6px] border border-white/15 bg-white/[0.03] px-4 py-3.5 font-display text-[15px] text-white placeholder:text-white/35 transition-colors focus:border-scooter focus:bg-white/[0.06] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-scooter/30"
                  name="message"
                  rows="4"
                ></textarea>
              </label>

              <div class="mt-8 flex flex-col items-start gap-4 border-t border-white/10 pt-8 sm:flex-row sm:items-center sm:justify-between">
                <button
                  type="submit"
                  class="group inline-flex items-center justify-center gap-2.5 rounded-[6px] bg-scooter px-7 py-4 font-display text-[15px] font-medium text-navy-900 transition-all duration-200 hover:bg-white active:scale-[0.98]"
                >
                  Submit Request
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                    <path d="m9 18 6-6-6-6" />
                  </svg>
                </button>
              </div>

              <p
                id="it-contact-success"
                class="mt-5 hidden border-l-2 border-scooter bg-white/5 px-4 py-3 font-display text-sm text-white"
              >
                Thanks — we’ve received your request and will be in touch shortly.
              </p>
            </div>
          </form>
        </div>
      </div>
    </Container>
  </section>

  <script>
    function initItContactForm() {
      const form = document.getElementById('it-contact-form') as HTMLFormElement | null;
      if (!form || form.dataset.bound === '1') return;
      form.dataset.bound = '1';
      const ok = document.getElementById('it-contact-success');
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (!form.checkValidity()) { form.reportValidity(); return; }
        ok?.classList.remove('hidden');
        form.querySelectorAll('input, select, textarea, button').forEach((el) => ((el as HTMLInputElement).disabled = true));
      });
    }
    initItContactForm();
    document.addEventListener('astro:page-load', initItContactForm);
  </script>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { site, serviceGroups } from '@/data/site';
import { getCollection } from 'astro:content';

const services = (await getCollection('services'))
  .filter((s) => s.data.status !== 'draft')
  .map((s) => s.data);
const bySlug = new Map(services.map((s) => [s.path.replace(/^\/services\//, '').replace(/\/$/, ''), s]));
---

<BaseLayout
  rawTitle="Contact Alpine Mar IT"
  description="Book a free IT assessment or reach out to our Fort Lauderdale team."
>
  <section class="relative overflow-hidden bg-[#12122d] pt-24 pb-24 text-white md:pt-32 md:pb-32">
    <div class="pointer-events-none absolute inset-0 am-grid-pattern"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-12 flex items-center gap-3 text-white/85">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Contact Us</span>
      </div>

      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        {/* Left */}
        <div data-reveal class="flex flex-col gap-10 lg:col-span-5">
          <div class="flex flex-col gap-7">
            <h1 class="am-h1-display am-gradient-ink-light">
              Let's talk IT.
            </h1>
            <p class="font-display text-[15px] leading-[1.65] text-white/75">
              Start with a free IT assessment. No commitment, no pitch — just a
              conversation about what you're working on and where you might be
              exposed.
            </p>
          </div>

          <div class="flex flex-col gap-5">
            <div class="rounded-[6px] bg-white/[0.05] p-7">
              <h2 class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-scooter">Our Location</h2>
              <p class="mt-6 font-display text-[15px] leading-[1.6] text-white">
                {site.address.street}<br />
                {site.address.city}, {site.address.state} {site.address.zip}
              </p>
            </div>
            <div class="rounded-[6px] bg-white/[0.05] p-7">
              <h2 class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-scooter">Contact Information</h2>
              <p class="mt-6 font-display text-[15px] leading-[1.7] text-white">
                <a href={`tel:${site.phoneHref}`} class="block transition-colors hover:text-scooter">{site.phone}</a>
                <a href={`mailto:${site.email}`} class="block transition-colors hover:text-scooter">{site.email}</a>
              </p>
            </div>
          </div>
        </div>

        {/* Right: form */}
        <div data-reveal class="lg:col-span-7">
          <form id="it-contact-form" class="rounded-[10px] border border-white/10 bg-white/[0.04] p-7 backdrop-blur-sm shadow-[0_24px_80px_-40px_rgba(0,0,0,0.6)] lg:p-10" novalidate>
            <p class="font-display text-[13px] font-medium uppercase tracking-[0.1em] text-scooter">Request a consultation</p>
            <h2 class="mt-3 font-display text-[26px] font-medium tracking-[-0.02em] text-white">Book a free IT assessment.</h2>

            <div class="mt-8 grid gap-5 sm:grid-cols-2">
              <label class="block">
                <span class="font-display text-[12px] font-medium uppercase tracking-[0.12em] text-white/70">First name</span>
                <input class="mt-2 w-full rounded-[6px] border border-white/15 bg-white/5 px-4 py-3.5 font-display text-[15px] text-white placeholder:text-white/35 transition-colors focus:border-scooter focus:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-scooter/25" type="text" name="first_name" autocomplete="given-name" required />
              </label>
              <label class="block">
                <span class="font-display text-[12px] font-medium uppercase tracking-[0.12em] text-white/70">Last name</span>
                <input class="mt-2 w-full rounded-[6px] border border-white/15 bg-white/5 px-4 py-3.5 font-display text-[15px] text-white placeholder:text-white/35 transition-colors focus:border-scooter focus:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-scooter/25" type="text" name="last_name" autocomplete="family-name" required />
              </label>
              <label class="block">
                <span class="font-display text-[12px] font-medium uppercase tracking-[0.12em] text-white/70">Email</span>
                <input class="mt-2 w-full rounded-[6px] border border-white/15 bg-white/5 px-4 py-3.5 font-display text-[15px] text-white placeholder:text-white/35 transition-colors focus:border-scooter focus:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-scooter/25" type="email" name="email" autocomplete="email" required />
              </label>
              <label class="block">
                <span class="font-display text-[12px] font-medium uppercase tracking-[0.12em] text-white/70">Phone</span>
                <input class="mt-2 w-full rounded-[6px] border border-white/15 bg-white/5 px-4 py-3.5 font-display text-[15px] text-white placeholder:text-white/35 transition-colors focus:border-scooter focus:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-scooter/25" type="tel" name="phone" autocomplete="tel" />
              </label>
              <label class="block sm:col-span-2">
                <span class="font-display text-[12px] font-medium uppercase tracking-[0.12em] text-white/70">Company</span>
                <input class="mt-2 w-full rounded-[6px] border border-white/15 bg-white/5 px-4 py-3.5 font-display text-[15px] text-white placeholder:text-white/35 transition-colors focus:border-scooter focus:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-scooter/25" type="text" name="company" autocomplete="organization" />
              </label>
            </div>

            <label class="mt-5 block">
              <span class="font-display text-[12px] font-medium uppercase tracking-[0.12em] text-white/70">Services Needed</span>
              <select class="mt-2 w-full rounded-[6px] border border-white/15 bg-white/5 px-4 py-3.5 font-display text-[15px] text-white transition-colors focus:border-scooter focus:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-scooter/25" name="service">
                <option value="" class="text-navy-900">Select a service…</option>
                {serviceGroups.map((g) => (
                  <optgroup label={g.label}>
                    {g.services.map((slug) => {
                      const svc = bySlug.get(slug);
                      if (!svc) return null;
                      return <option value={svc.title} class="text-navy-900">{svc.title}</option>;
                    })}
                  </optgroup>
                ))}
                <option value="Not sure — recommend" class="text-navy-900">Not sure — recommend</option>
              </select>
            </label>

            <label class="mt-5 block">
              <span class="font-display text-[12px] font-medium uppercase tracking-[0.12em] text-white/70">How can we help?</span>
              <textarea class="mt-2 w-full rounded-[6px] border border-white/15 bg-white/5 px-4 py-3.5 font-display text-[15px] text-white placeholder:text-white/35 min-h-32 resize-y transition-colors focus:border-scooter focus:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-scooter/25" name="message" rows="4"></textarea>
            </label>

            <button type="submit" class="group mt-7 inline-flex items-center justify-center gap-2.5 rounded-[6px] bg-scooter px-7 py-4 font-display text-[15px] font-medium text-navy-900 transition-all duration-200 hover:bg-white active:scale-[0.98]">
              {site.primaryCta}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
            </button>

            <p id="it-contact-success" class="mt-5 hidden border-l-2 border-scooter bg-white/5 px-4 py-3 font-display text-sm text-white">
              Thanks — we've received your request and will be in touch shortly.
            </p>
          </form>
        </div>
      </div>
    </Container>
  </section>

  <script>
    function initItContactForm() {
      const form = document.getElementById('it-contact-form') as HTMLFormElement | null;
      if (!form || form.dataset.bound === '1') return;
      form.dataset.bound = '1';
      const ok = document.getElementById('it-contact-success');
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (!form.checkValidity()) { form.reportValidity(); return; }
        ok?.classList.remove('hidden');
        form.querySelectorAll('input, select, textarea, button').forEach((el) => ((el as HTMLInputElement).disabled = true));
      });
    }
    initItContactForm();
    document.addEventListener('astro:page-load', initItContactForm);
  </script>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import ContactCta from '@/components/ContactCta.astro';
import { getCollection } from 'astro:content';
import { moreServices } from '@/data/site';

const services = (await getCollection('services'))
  .filter((s) => s.data.status !== 'draft')
  .map((s) => s.data);

const bySlug = new Map(
  services.map((s) => [s.path.replace(/^\/services\//, '').replace(/\/$/, ''), s]),
);

// Remaining services — live mega-menu order, after the four service lines.
const moreItems = moreServices.map((slug) => bySlug.get(slug)).filter(Boolean);

// Featured service lines — titles and copy verbatim from
// it.alpinemar.com/services/.
const serviceLines = [
  {
    slug: 'remote-it-support',
    title: 'Remote IT Support Services',
    blurb:
      'Technology problems do not wait for a convenient time. When something breaks, your team needs help fast and they need it from someone who actually knows what they are doing.',
  },
  {
    slug: 'incident-response',
    title: 'Incident Response Services',
    blurb:
      'When a security incident hits, every minute counts. The difference between a manageable disruption and a full-blown crisis often comes down to how fast and how effectively you respond in the first hours.',
  },
  {
    slug: 'cybersecurity',
    title: 'Cybersecurity Services',
    blurb:
      'Cyberthreats are not going away. They are getting more targeted, more sophisticated, and more expensive to recover from.',
  },
  {
    slug: 'it-consulting',
    title: 'IT Consulting Services',
    blurb:
      'Technology is supposed to make your business easier to run. We provide tailored solutions and strategic guidance that align with your business goals and improve operational efficiency.',
  },
].map((row) => ({ ...row, service: bySlug.get(row.slug) }));
---

<BaseLayout
  rawTitle="IT Services & Technology Solutions | Alpine Mar IT"
  description="We combine technical expertise with business-first thinking to deliver managed IT services and technology solutions that fit your business needs, support your business operations, and drive long-term growth."
>
  {/* ══════════════════════ HERO ══════════════════════
      Headline and intro verbatim from it.alpinemar.com/services/.
  ══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-paper">
    <div class="am-aurora on-light" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 am-grid-pattern-light" aria-hidden="true"></div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-b from-transparent to-paper"
      aria-hidden="true"
    ></div>

    <Container width="wide" class="relative">
      <div class="grid grid-rows-[auto_1fr_auto] content-start gap-0 pt-14 pb-14 md:min-h-[62vh] md:pt-[19vh] md:pb-20">
        <div data-reveal data-speed="fast" class="mb-8 md:mb-10">
          <span class="am-eyebrow">Our Services</span>
        </div>

        <h1
          data-reveal
          data-speed="slow"
          class="am-hero-display am-gradient-ink max-w-[24ch] self-start"
        >
          IT services and technology solutions that move your business
          <span class="text-scooter">forward.</span>
        </h1>

        <div data-reveal class="mt-9 md:mt-14">
          <p class="max-w-[68ch] font-display text-[16px] leading-[1.65] text-navy-500 md:text-[17px]">
            We combine technical expertise with business-first thinking to
            deliver managed IT services and technology solutions that fit
            your business needs, support your business operations, and drive
            long-term growth.
          </p>
        </div>
      </div>
    </Container>
  </section>

  {/* ══════════════════════ SERVICE LINES ══════════════════════
      The four service lines from the live services page — titles, blurbs,
      and the "Explore this service line" label verbatim.
  ══════════════════════════════════════════════════════════ */}
  <section class="relative border-t border-line bg-white py-24 md:py-32">
    <Container width="wide">
      <ul data-stagger class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8">
        {serviceLines.map((row, i) => (
          <li>
            <a
              href={row.service?.path ?? `/services/${row.slug}/`}
              class="group flex h-full flex-col justify-between gap-10 rounded-[10px] border border-line bg-paper p-8 transition-colors hover:border-navy-900 md:p-10"
            >
              <div>
                <div class="flex items-start justify-between">
                  <span class="font-display text-[11px] font-medium uppercase tracking-[0.14em] text-navy-400">
                    Service line 0{i + 1}
                  </span>
                  <span class="font-display text-[54px] font-medium leading-[0.9] tracking-[-0.03em] text-navy-100 transition-colors group-hover:text-scooter/40 md:text-[72px]">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                </div>
                <h2 class="mt-8 font-display text-[24px] font-medium tracking-[-0.01em] text-navy-900 md:text-[28px]">
                  {row.title}
                </h2>
                <p class="mt-4 max-w-[52ch] font-display text-[15px] leading-[1.65] text-navy-500">
                  {row.blurb}
                </p>
              </div>
              <span class="inline-flex items-center gap-2 font-display text-[14px] font-medium text-navy-900 transition-colors group-hover:text-teal-700">
                Explore this service line
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                  <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
                </svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  {/* ══════════════════════ ALL SERVICES ══════════════════════
      The remaining services in the live mega-menu order — single list,
      no invented grouping. Summaries are each service's live lead line.
  ══════════════════════════════════════════════════════════ */}
  <section class="relative border-t border-line bg-paper py-20 md:py-28">
    <Container width="wide">
      <div class="grid grid-cols-1 gap-6 border-b border-line pb-12 md:grid-cols-12 md:gap-16">
        <div data-reveal data-speed="fast" class="md:col-span-12">
          <div class="mb-6 flex items-center gap-3">
            <span class="am-eyebrow">Our Services</span>
          </div>
          <h2 class="am-h1-display am-gradient-ink">Explore all Our Services</h2>
        </div>
      </div>

      <ul class="border-t border-line">
        {moreItems.map((s, idx) => s && (
          <li class="am-svc-row group relative border-b border-line">
            <a
              href={s.path}
              data-reveal
              data-speed="fast"
              class="relative grid grid-cols-[auto_1fr_auto] items-center gap-6 py-6 md:grid-cols-12 md:gap-8 md:py-9"
            >
              <span class="font-display text-[20px] font-medium tabular-nums text-navy-400 md:col-span-1 md:pl-2 md:text-[28px]">
                {String(idx + 1).padStart(2, '0')}
              </span>
              <span class="md:col-span-6">
                <span class="block font-display text-[19px] font-medium tracking-[-0.01em] text-navy-900 sm:text-[22px] md:text-[28px]">
                  {s.title}
                </span>
                {/* Summary visible on mobile / to screen readers; desktop keeps the hover preview. */}
                <span class="mt-2 block font-display text-[13.5px] leading-[1.55] text-navy-500 md:sr-only">
                  {s.summary}
                </span>
              </span>

              {/* Hover preview — the service's own lead paragraph */}
              <span
                class="am-svc-preview pointer-events-none absolute right-[5%] top-1/2 hidden -translate-y-1/2 md:block"
                aria-hidden="true"
              >
                <span class="block w-[300px] rounded-[8px] border border-line bg-white p-5 shadow-[0_20px_50px_-20px_rgba(18,18,45,0.35)]">
                  <span class="mt-1 block font-display text-[13.5px] leading-[1.55] text-navy-500">
                    {s.summary}
                  </span>
                </span>
              </span>

              <span class="md:col-span-5 md:col-start-12 md:justify-self-end md:pr-2">
                <svg
                  width="22" height="22" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="1.8"
                  stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                  class="block text-navy-900 group-hover:hidden"
                >
                  <path d="M7 17 17 7" /><path d="M7 7h10v10" />
                </svg>
                <svg
                  width="24" height="24" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                  class="hidden text-scooter group-hover:block"
                >
                  <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
                </svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <ContactCta />
</BaseLayout>

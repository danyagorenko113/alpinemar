---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import ContactCta from '@/components/ContactCta.astro';
import { getCollection } from 'astro:content';
import Icon from '@/components/Icon.astro';
import { site } from '@/data/site';
import { values } from '@/data/pages';

// Icon per value (by order), replacing the old "01" number treatment. Uses the
// same lucide-style Icon set established on the accounting site.
const valueIcons = ['sparkles', 'zap', 'shield-check', 'target', 'users'];

// Team members — all currently `status: draft` in frontmatter, so we include
// drafts intentionally here. Bios are TBD; roster + role + optional photo.
const team = (await getCollection('team'))
  .map((m) => m.data)
  .sort((a, b) => (a.order ?? 999) - (b.order ?? 999));

// Initials helper for photoless members.
const initials = (name: string) =>
  name
    .split(' ')
    .map((n) => n[0])
    .slice(0, 2)
    .join('');
---

<BaseLayout
  rawTitle="IT With a Human Touch"
  description="At Alpine Mar, we believe IT services should feel like a partnership, not a help desk ticket. Our IT team brings together enterprise-grade expertise and small-firm responsiveness."
>
  {/* ══════════════════════ HERO ══════════════════════
      Copy verbatim from it.alpinemar.com/about/ hero.
  ══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-paper">
    <div class="am-aurora on-light" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 am-grid-pattern-light" aria-hidden="true"></div>
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-[520px] am-circuit opacity-70"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-b from-transparent to-paper"
      aria-hidden="true"
    ></div>

    <Container width="wide" class="relative">
      <div class="grid grid-rows-[auto_1fr_auto] content-start gap-0 pt-14 pb-14 md:min-h-[70vh] md:pt-[19vh] md:pb-20">
        <div data-reveal data-speed="fast" class="mb-8 md:mb-10">
          <span class="am-eyebrow">About Us</span>
        </div>

        <h1
          data-reveal
          data-speed="slow"
          class="am-hero-display am-gradient-ink self-start leading-[1.02]"
        >
          IT with a<br />
          <span class="text-scooter">human</span> touch.
        </h1>

        <div
          data-reveal
          class="mt-9 flex max-w-[68ch] flex-col gap-5 md:mt-14"
        >
          <p class="font-display text-[16px] leading-[1.65] text-navy-900 md:text-[17px]">
            At Alpine Mar, we believe IT services should feel like a
            partnership, not a help desk ticket. Our IT team brings together
            enterprise-grade expertise and small-firm responsiveness. We’re
            advisors, not order takers, focused on building relationships,
            solving problems, and staying ahead of whatever comes next.
          </p>
          <p class="font-display text-[15px] leading-[1.65] text-navy-500 md:text-[16px]">
            We take a plain-English approach to even the most complex IT
            challenges. Our team works side-by-side with yours, making sure
            every recommendation is rooted in your business goals, not tech
            for tech’s sake.
          </p>
          <p class="font-display text-[15px] leading-[1.65] text-navy-500 md:text-[16px]">
            You’ll never be left guessing what you’re paying for, or why
            something matters. You’ll know, and you’ll feel the difference
            in your day-to-day.
          </p>
        </div>
      </div>
    </Container>
  </section>

  {/* ── Team imagery — real faces near the top, right by the "human touch" intro ── */}
  <section class="relative bg-paper pb-20 md:pb-28">
    <Container width="wide">
      <ul data-stagger class="grid grid-cols-1 gap-5 sm:grid-cols-3 md:gap-6">
        <li class="overflow-hidden rounded-[12px] border border-line">
          <img
            src="/images/about/about-collaboration.jpg"
            alt="Alpine Mar IT team collaborating over laptops in the office"
            width="1100" height="825" loading="lazy"
            class="block aspect-[4/3] w-full object-cover"
          />
        </li>
        <li class="overflow-hidden rounded-[12px] border border-line">
          <img
            src="/images/about/about-conversation.jpg"
            alt="Two Alpine Mar team members sharing a laugh during a working session"
            width="1100" height="825" loading="lazy"
            class="block aspect-[4/3] w-full object-cover"
          />
        </li>
        <li class="overflow-hidden rounded-[12px] border border-line">
          <img
            src="/images/about/about-team.jpg"
            alt="The Alpine Mar Information Technology team"
            width="1100" height="825" loading="lazy"
            class="block aspect-[4/3] w-full object-cover"
          />
        </li>
      </ul>
    </Container>
  </section>

  {/* ══════════════════════ WHAT GUIDES US ══════════════════════
      Heading, intro, and all five principles verbatim from the live site.
  ══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden border-t border-line bg-white py-24 md:py-32">
    <div class="pointer-events-none absolute inset-0 am-grid-pattern-light opacity-60" aria-hidden="true"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10">
        <span class="am-eyebrow">Our Values</span>
      </div>

      <div
        data-reveal
        class="grid grid-cols-1 gap-10 border-b border-line pb-14 md:grid-cols-12 md:gap-16"
      >
        <h2 class="am-h1-display text-navy-900 md:col-span-7">
          What Guides Us
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-navy-500 md:col-span-5 md:pt-3">
          Just like our accounting side, our IT team is guided by a few key
          principles.
        </p>
      </div>

      <ul
        data-stagger
        class="mt-16 grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8"
      >
        {values.map((v, i) => (
          <li class="group relative overflow-hidden rounded-[10px] border border-line bg-paper p-8 transition-colors hover:border-navy-900 md:p-10">
            <span class="inline-flex size-14 items-center justify-center rounded-[12px] bg-scooter/10 text-scooter transition-colors group-hover:bg-scooter group-hover:text-white">
              <Icon name={valueIcons[i] ?? 'sparkles'} class="size-7" />
            </span>
            <h3 class="mt-7 font-display text-[24px] font-medium tracking-[-0.01em] text-navy-900 md:text-[28px]">
              {v.title}
            </h3>
            <p class="mt-4 max-w-[46ch] font-display text-[15px] leading-[1.65] text-navy-500">
              {v.body}
            </p>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  {/* ══════════════════════ TEAM ══════════════════════
      Dark navy, aurora, roster grid. Monogram fallback for missing photos.
      Heading verbatim from the live site.
  ══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-32">
    <div class="am-aurora" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 am-grid-pattern" aria-hidden="true"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10">
        <span class="am-eyebrow on-dark">Our Team</span>
      </div>

      <div
        data-reveal
        class="grid grid-cols-1 gap-10 border-b border-white/10 pb-14 md:grid-cols-12 md:gap-16"
      >
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-7">
          Meet the team
        </h2>
      </div>

      <ul
        data-stagger
        class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 md:gap-7 lg:grid-cols-3"
      >
        {team.map((m) => (
          <li class="group flex flex-col rounded-[6px] border border-white/10 bg-white/[0.03] p-5 transition-colors hover:border-scooter/40 hover:bg-white/[0.06]">
            {/* Square portrait — matches the accounting card; monogram fallback. */}
            <div class="size-[148px] overflow-hidden rounded-[6px] bg-navy-800">
              {m.photo ? (
                <img
                  src={m.photo}
                  alt={m.name}
                  loading="lazy"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                />
              ) : (
                <div class="flex h-full items-center justify-center">
                  <span class="font-display text-[44px] font-medium leading-none tracking-[-0.04em] text-white/20">
                    {initials(m.name)}
                  </span>
                </div>
              )}
            </div>

            <h3 class="mt-5 font-display text-[22px] font-medium leading-[1.2] tracking-[-0.01em] text-white">
              {m.name}
            </h3>

            <dl class="-mx-5 mt-5 grid grid-cols-1 border-t border-white/10 text-[14px]">
              <div class="flex items-center gap-6 border-b border-white/10 px-5 py-3">
                <dt class="w-14 shrink-0 font-display text-[10px] uppercase tracking-[0.16em] text-white/45">Role</dt>
                <dd class="font-display text-[13px] text-white/90">{m.role}</dd>
              </div>
              <div class="flex items-center gap-6 px-5 py-3">
                <dt class="w-14 shrink-0 font-display text-[10px] uppercase tracking-[0.16em] text-white/45">Based</dt>
                <dd class="font-display text-[13px] text-white/90">{site.address.city}</dd>
              </div>
            </dl>

            {(m.linkedin || m.email) && (
              <div class="-mx-5 flex items-center gap-2.5 border-t border-white/10 px-5 pt-4">
                {m.linkedin && (
                  <a href={m.linkedin} target="_blank" rel="noopener" aria-label={`${m.name} on LinkedIn`} class="inline-flex size-7 items-center justify-center rounded-[3px] border border-white/15 text-white/70 transition-colors hover:border-scooter hover:text-scooter">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14ZM8.34 18.34V10.5H5.7v7.84h2.64Zm-1.32-8.92a1.53 1.53 0 1 0 0-3.06 1.53 1.53 0 0 0 0 3.06Zm11.32 8.92v-4.3c0-2.3-1.23-3.37-2.88-3.37a2.49 2.49 0 0 0-2.26 1.25v-1.07h-2.64v7.49h2.64v-4.16c0-1.1.21-2.17 1.57-2.17 1.34 0 1.34 1.26 1.34 2.24v4.09h2.23Z"/></svg>
                  </a>
                )}
                {m.email && (
                  <a href={`mailto:${m.email}`} aria-label={`Email ${m.name}`} class="inline-flex size-7 items-center justify-center rounded-[3px] border border-white/15 text-white/70 transition-colors hover:border-scooter hover:text-scooter">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
                  </a>
                )}
              </div>
            )}
          </li>
        ))}
      </ul>
    </Container>
  </section>

  {/* ══════════════════════ WHY BUSINESSES CHOOSE US ══════════════════════
      Copy verbatim from the live site, with the sister-firm cross-link card.
  ══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden border-t border-line bg-paper py-24 md:py-28">
    <div class="pointer-events-none absolute inset-0 am-grid-pattern-light" aria-hidden="true"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10">
        <span class="am-eyebrow">Why Alpine Mar</span>
      </div>

      <div
        data-reveal
        class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16"
      >
        <div class="md:col-span-7">
          <h2 class="am-h1-display am-gradient-ink">
            Why Businesses<br />
            Choose Us
          </h2>
          <div class="mt-8 flex max-w-[58ch] flex-col gap-5">
            <p class="font-display text-[16px] leading-[1.65] text-navy-500">
              We’re not a faceless IT firm or a hard-to-reach help desk.
              We’re part of Alpine Mar, a trusted advisory firm that’s been
              helping businesses grow, pivot, and succeed through smarter
              systems and better strategy.
            </p>
            <p class="font-display text-[16px] leading-[1.65] text-navy-500">
              With our IT services, you get the same high-touch service and
              sharp thinking that Alpine Mar is known for, now with the
              technical horsepower to match.
            </p>
            <p class="font-display text-[16px] leading-[1.65] text-navy-900">
              Because you shouldn’t have to choose between great tech and
              great people.
            </p>
          </div>
        </div>

        <div class="md:col-span-5">
          <a
            href={site.parentSiteUrl}
            target="_blank"
            rel="noreferrer noopener"
            class="group flex h-full flex-col justify-between gap-8 rounded-[10px] border border-line bg-white p-8 transition-colors hover:border-navy-900"
          >
            <div>
              <span class="am-eyebrow" style="font-size:11px;">
                Visit
              </span>
              <div class="mt-6 font-display text-[36px] font-medium leading-[1.05] tracking-[-0.02em] text-navy-900 md:text-[44px]">
                alpinemar<span class="text-scooter">.com</span>
              </div>
              <p class="mt-5 font-display text-[14px] leading-[1.6] text-navy-500">
                Financial Services by Alpine Mar.
              </p>
            </div>
            <span class="inline-flex items-center gap-2 font-display text-[13px] font-medium text-navy-900">
              Open in new tab
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1 group-hover:-translate-y-1">
                <path d="M7 17 17 7" /><path d="M7 7h10v10" />
              </svg>
            </span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <ContactCta />
</BaseLayout>

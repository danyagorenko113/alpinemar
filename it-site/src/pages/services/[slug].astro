---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import ContactCta from '@/components/ContactCta.astro';
import { getCollection, render } from 'astro:content';
import { site, serviceMenu } from '@/data/site';
import { businessHours, serviceCta } from '@/data/pages';

export async function getStaticPaths() {
  const items = await getCollection('services');
  return items.map((item) => ({
    params: { slug: item.id.replace(/\.(md|mdx)$/i, '').split('/').pop() },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const d = item.data;

const slugFor = (path: string) => path.replace(/^\/services\//, '').replace(/\/$/, '');

const services = (await getCollection('services')).filter((s) => s.data.status !== 'draft');
const bySlug = new Map(services.map((s) => [slugFor(s.data.path), s]));
const selfSlug = slugFor(d.path);

// Parent service line — mirrors the live breadcrumb: OUR SERVICES › <line>.
// Built from the mega-menu grouping (serviceMenu): a sub-service points at its
// line; a line points at itself.
const lineOf = new Map<string, string>();
for (const g of serviceMenu) {
  lineOf.set(g.line, g.line);
  for (const c of g.children) lineOf.set(c, g.line);
}
const parentLineSlug = lineOf.get(selfSlug);
const parentLine = parentLineSlug ? bySlug.get(parentLineSlug) : undefined;
// Line title without the trailing " Services" — for clean "More X services." copy.
const lineShort = parentLine?.data.title.replace(/\s+Services$/, '') ?? 'related';

// Related — the other services in the same line, excluding self and any
// service already teased inside this article's body.
const bodyRaw = item.body ?? '';
const lineGroup = serviceMenu.find((g) => g.line === parentLineSlug);
const relatedSlugs = parentLineSlug
  ? [parentLineSlug, ...(lineGroup?.children ?? [])].filter((sl) => sl !== selfSlug)
  : [];
const related = relatedSlugs
  .map((sl) => bySlug.get(sl))
  .filter((s): s is NonNullable<typeof s> => Boolean(s))
  .filter((s) => !bodyRaw.includes(s.data.title))
  .slice(0, 3);
---

<BaseLayout
  rawTitle={d.seo?.title}
  title={d.seo?.title ? undefined : d.title}
  description={d.seo?.description ?? d.summary}
>
  {/* ══════════════════════ HERO ══════════════════════
      Left: eyebrow row (group label · scooter dot) + big gradient headline.
      Right: "At a glance" card with primary CTA + phone + 24/7 pill.
  ══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-paper">
    <div class="am-aurora on-light" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 am-grid-pattern-light" aria-hidden="true"></div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-b from-transparent to-paper"
      aria-hidden="true"
    ></div>

    <Container width="wide" class="relative">
      <div class="grid grid-cols-1 gap-12 pt-12 pb-14 md:grid-cols-12 md:gap-16 md:pt-[18vh] md:pb-20">
        {/* Left column */}
        <div class="flex flex-col md:col-span-8">
          {/* Breadcrumbs — Our Services › parent service line (mirrors the live site). */}
          <div data-reveal data-speed="fast" class="mb-8 flex flex-wrap items-center gap-x-3 gap-y-2">
            <a href="/services/" class="am-eyebrow transition-colors hover:text-navy-900" style="font-size:12.5px;">
              Our Services
            </a>
            {parentLine && (
              <>
                <span class="text-navy-300">›</span>
                <a
                  href={parentLine.data.path}
                  class="am-eyebrow text-scooter transition-colors hover:text-navy-900"
                  style="font-size:12.5px;"
                >
                  {parentLine.data.title}
                </a>
              </>
            )}
          </div>

          <h1
            data-reveal
            data-speed="slow"
            class="am-hero-display am-gradient-ink self-start leading-[1.02]"
          >
            {d.heroTitle ?? d.title}
          </h1>

          <p
            data-reveal
            class="mt-8 max-w-[58ch] font-display text-[17px] leading-[1.6] text-navy-500 md:text-[18px]"
          >
            {d.summary}
          </p>
        </div>

        {/* Right column — "At a glance" card */}
        <aside data-reveal data-speed="slow" class="md:col-span-4">
          <div class="sticky top-24 rounded-[10px] border border-line bg-white/80 p-7 backdrop-blur md:p-8">
            <h2 class="font-display text-[14px] font-medium uppercase tracking-[0.12em] text-navy-400">
              Get in Touch
            </h2>

            <p class="mt-4 font-display text-[15px] leading-[1.6] text-navy-700">
              Start with a free IT assessment. No obligations, just insights.
            </p>

            <a
              href="/contact/"
              class="group mt-7 flex items-center justify-between rounded-[8px] bg-navy-900 px-5 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter"
            >
              Request a Consultation
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                <path d="m9 18 6-6-6-6" />
              </svg>
            </a>

            <div class="mt-5 border-t border-line pt-5">
              <p class="font-display text-[12px] uppercase tracking-[0.12em] text-navy-400">
                Prefer to call?
              </p>
              <a
                href={`tel:${site.phoneHref}`}
                class="mt-2 block font-display text-[18px] font-medium tracking-[-0.01em] text-navy-900 transition-colors hover:text-scooter"
              >
                {site.phone}
              </a>
              <p class="mt-1 font-display text-[12px] text-navy-500">
                {businessHours}
              </p>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  {/* ══════════════════════ BODY ══════════════════════
      Long-form content — reading width, Satoshi 17px body, breathing space.
  ══════════════════════════════════════════════════════════ */}
  <section class="relative bg-paper py-16 md:py-28">
    <Container width="wide">
      <div class="mb-8 flex items-center gap-3 text-navy-900 md:mb-10">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Deep dive</span>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-navy-900 md:col-span-7">The detail, if you want it.</h2>
        <p class="font-display text-[15px] leading-[1.65] text-navy-500 md:col-span-5 md:pt-3">
          The full breakdown of how we approach {item.data.title.toLowerCase()} — written for teams who want to see the rigor before signing on.
        </p>
      </div>

      <div class="mt-8 grid grid-cols-1 gap-6 md:mt-14 md:grid-cols-12 md:gap-16">
        <div class="rounded-[6px] border border-line bg-white p-6 md:col-span-9 md:p-12">
          <article
            class="prose prose-lg max-w-none
              [&_h2]:font-display [&_h2]:text-[28px] [&_h2]:font-medium [&_h2]:tracking-[-0.01em] [&_h2]:text-navy-900 [&_h2]:mt-14 [&_h2]:mb-5 [&_h2]:pt-4 [&_h2]:border-t [&_h2]:border-line-soft [&_h2]:relative
              [&_h3]:font-display [&_h3]:text-[20px] [&_h3]:font-medium [&_h3]:text-navy-900 [&_h3]:mt-10 [&_h3]:mb-3
              [&_p]:font-display [&_p]:text-[17px] [&_p]:leading-[1.72] [&_p]:text-navy-700 [&_p]:my-5
              [&_ul]:font-display [&_ul]:text-[17px] [&_ul]:text-navy-700 [&_ul]:my-6 [&_ul]:pl-1 [&_ul]:list-none [&_ul>li]:relative [&_ul>li]:pl-6 [&_ul>li]:my-2.5
              [&_ol]:font-display [&_ol]:text-[17px] [&_ol]:text-navy-700 [&_ol]:my-6 [&_ol]:pl-6 [&_ol>li]:my-2.5
              [&_strong]:text-navy-900 [&_strong]:font-medium
              [&_a]:text-teal-700 [&_a]:underline [&_a]:underline-offset-4 [&_a]:decoration-1 hover:[&_a]:decoration-2"
          >
            <Content />
          </article>
        </div>
        <aside class="md:col-span-3">
          <div class="sticky top-28 rounded-[6px] bg-[#12122d] p-6 text-white md:p-7">
            <p class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-scooter">Get in touch</p>
            <p class="mt-5 font-display text-[15px] leading-[1.55] text-white/85">
              Start with a free IT assessment — no obligations, just insights.
            </p>
            <a href="/contact/" class="mt-6 inline-flex items-center gap-2 font-display text-[13px] font-medium text-scooter transition-colors hover:text-white">
              Request a Consultation
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
            </a>
          </div>
        </aside>
      </div>
    </Container>

    {/* Custom bullet markers — teal dash */}
    <style is:global>
      section .prose ul > li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.75em;
        width: 0.75rem;
        height: 1.5px;
        background: #33bbdc;
      }
      section .prose h2::before {
        content: "";
        position: absolute;
        top: -1px;
        left: 0;
        width: 2.5rem;
        height: 2px;
        background: #33bbdc;
      }
    </style>
  </section>

  {/* ══════════════════════ RELATED SERVICES ══════════════════════ */}
  {related.length > 0 && (
    <section class="relative overflow-hidden border-t border-line bg-paper py-24 md:py-28">
      <div class="pointer-events-none absolute inset-0 am-grid-pattern-light" aria-hidden="true"></div>

      <Container width="wide" class="relative z-10">
        <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3">
          <span class="am-eyebrow">Related in {lineShort}</span>
        </div>

        <div
          data-reveal
          class="grid grid-cols-1 gap-10 border-b border-line pb-14 md:grid-cols-12 md:gap-16"
        >
          <h2 class="am-h1-display text-navy-900 md:col-span-7">
            More {lineShort}<br />services.
          </h2>
        </div>

        <ul data-stagger class="mt-2 grid grid-cols-1 gap-6 md:grid-cols-3">
          {related.map((s) => (
            <li>
              <a
                href={s.data.path}
                class="group flex h-full flex-col rounded-[10px] border border-line bg-white p-7 transition-all hover:-translate-y-0.5 hover:border-navy-900"
              >
                <span class="am-eyebrow" style="font-size:11px;">
                  {lineShort}
                </span>
                <h3 class="mt-5 font-display text-[22px] font-medium leading-[1.2] tracking-[-0.01em] text-navy-900 transition-colors group-hover:text-teal-700">
                  {s.data.title}
                </h3>
                <p class="mt-3 font-display text-[14px] leading-[1.6] text-navy-500 line-clamp-3">
                  {s.data.summary}
                </p>
                <span class="mt-auto flex items-center justify-between gap-4 pt-8">
                  <span class="font-display text-[13px] font-medium text-navy-900">
                    Explore this service
                  </span>
                  <span class="inline-flex size-9 items-center justify-center rounded-[6px] bg-navy-900 text-white transition-transform group-hover:translate-x-1 group-hover:bg-scooter">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
                      <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
                    </svg>
                  </span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </Container>
    </section>
  )}

  {/* ══════════════════════ SERVICE CTA BAND ══════════════════════
      "Ready to Secure What's Next?" — mirrors the live service pages.
      Copy + links are editable in the CMS (IT Pages → serviceCta).
  ══════════════════════════════════════════════════════════ */}
  <section class="relative border-t border-line bg-white py-24 md:py-32">
    <div class="pointer-events-none absolute inset-0 am-grid-pattern-light" aria-hidden="true"></div>
    <Container width="reading" class="relative z-10 text-center">
      <h2 data-reveal class="am-h1-display am-gradient-ink mx-auto max-w-[16ch]">
        {serviceCta.heading}
      </h2>
      <p data-reveal class="mx-auto mt-7 max-w-[62ch] font-display text-[16px] leading-[1.65] text-navy-500 md:text-[17px]">
        {serviceCta.body}
      </p>
      <div data-reveal class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={serviceCta.primaryHref}
          class="group inline-flex items-center justify-center gap-2 rounded-full bg-scooter px-7 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-navy-900"
        >
          {serviceCta.primaryLabel}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <a
          href={serviceCta.secondaryHref}
          class="inline-flex items-center justify-center gap-2 rounded-full border border-navy-900 px-7 py-3.5 font-display text-[14px] font-medium text-navy-900 transition-colors hover:bg-navy-900 hover:text-white"
        >
          {serviceCta.secondaryLabel}
        </a>
      </div>
    </Container>
  </section>

  <ContactCta />
</BaseLayout>

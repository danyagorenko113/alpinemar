---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import ContactCta from '@/components/ContactCta.astro';
import { site } from '@/data/site';

// ── Home services — the four real service lines, titles and blurbs
// verbatim from it.alpinemar.com/services/. The live homepage lists five
// marketing categories that don't exist as pages; we link the actual
// services instead so anchors match their target pages (SEO-correct).
const homeServices = [
  {
    title: 'Remote IT Support Services',
    href: '/services/remote-it-support/',
    blurb:
      'Technology problems do not wait for a convenient time. When something breaks, your team needs help fast and they need it from someone who actually knows what they are doing.',
  },
  {
    title: 'Incident Response Services',
    href: '/services/incident-response/',
    blurb:
      'When a security incident hits, every minute counts. The difference between a manageable disruption and a full-blown crisis often comes down to how fast and how effectively you respond in the first hours.',
  },
  {
    title: 'Cybersecurity Services',
    href: '/services/cybersecurity/',
    blurb:
      'Cyberthreats are not going away. They are getting more targeted, more sophisticated, and more expensive to recover from.',
  },
  {
    title: 'IT Consulting Services',
    href: '/services/it-consulting/',
    blurb:
      'Technology is supposed to make your business easier to run. We provide tailored solutions and strategic guidance that align with your business goals and improve operational efficiency.',
  },
];

---

<BaseLayout
  rawTitle="IT By People Who Get Business"
  description={site.description}
>
  {/* ══════════════════════ HERO ══════════════════════
      Signature moment: light paper canvas + aurora glow + circuit grid.
      Left-aligned massive gradient headline (am-hero-display ~84px desktop).
      Copy verbatim from it.alpinemar.com homepage hero.
  ═══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-paper">
    {/* Layered background: aurora glow + subtle grid + faint circuit lines. */}
    <div class="am-aurora on-light" aria-hidden="true"></div>
    <div
      class="pointer-events-none absolute inset-0 am-grid-pattern-light"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-[520px] am-circuit opacity-70"
      aria-hidden="true"
    ></div>
    {/* Fade bottom into paper for legibility of any following section. */}
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-b from-transparent to-paper"
      aria-hidden="true"
    ></div>

    <Container width="wide" class="relative">
      <div class="grid grid-cols-1 items-center gap-12 pt-12 pb-14 lg:grid-cols-12 lg:gap-16 lg:pt-[12vh] lg:pb-24">
        {/* ── Left: copy ── */}
        <div class="flex flex-col items-start lg:col-span-7">
          {/* Status pill — location only. */}
          <div data-reveal data-speed="fast" class="mb-8">
            <span class="inline-flex items-center gap-2.5 rounded-full border border-line bg-white/70 px-3.5 py-1.5 font-display text-[12.5px] font-medium text-navy-900 backdrop-blur">
              <span class="am-status-dot text-scooter"></span>
              Fort Lauderdale, FL
            </span>
          </div>

          {/* Signature headline — verbatim from the live site. */}
          <h1
            data-reveal
            data-speed="slow"
            class="am-hero-display am-gradient-ink leading-[1.02]"
          >
            IT by people who<br />
            get <span class="text-scooter">business.</span>
          </h1>

          <div
            data-reveal
            class="mt-8 flex max-w-[62ch] flex-col gap-5 md:mt-10"
          >
            <p class="font-display text-[17px] font-medium leading-[1.6] text-navy-900 md:text-[19px]">
              Modern IT services tailored to how you really work, backed by
              Alpine Mar’s proven approach to trusted guidance and real results.
            </p>
            <p class="font-display text-[15px] leading-[1.65] text-navy-500 md:text-[16px]">
              Alpine Mar IT Services is built for the speed and complexity of
              today’s business environment. Whether you’re scaling, securing, or
              simplifying, we bring 1:1 support and deep technical experience to
              every challenge so your business stays ahead, protected, and agile.
            </p>
            <p class="font-display text-[15px] leading-[1.65] text-navy-500 md:text-[16px]">
              From proactive cybersecurity services and managed IT support to
              artificial intelligence integration and strategic risk advisory,
              our IT consultants keep up with change and help you lead it.
            </p>

            {/* Primary + secondary CTA — labels verbatim from the live site. */}
            <div class="mt-2 flex flex-wrap items-center gap-x-6 gap-y-4">
              <a
                href="/services/"
                class="group inline-flex items-center gap-2 rounded-[6px] bg-navy-900 px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter"
              >
                Explore Our Services
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                  <path d="m9 18 6-6-6-6" />
                </svg>
              </a>
              <a
                href="/contact/"
                class="group inline-flex items-center gap-2 border-b border-navy-900 pb-1.5 font-display text-[15px] font-medium text-navy-900 transition-colors hover:text-teal-700"
              >
                Book a Free IT Assessment
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                  <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        </div>

        {/* ── Right: team photo collage from the live site ── */}
        <div data-reveal data-speed="slow" class="relative lg:col-span-5">
          {/* Soft glow behind the collage ties it to the aurora background. */}
          <div
            class="pointer-events-none absolute -inset-8 rounded-full bg-scooter/10 blur-3xl"
            aria-hidden="true"
          ></div>
          <img
            src="/images/home/hero-team.webp"
            alt="The Alpine Mar IT team working with clients in the Fort Lauderdale office"
            width="1654"
            height="2085"
            fetchpriority="high"
            class="relative mx-auto w-full max-w-[440px] lg:max-w-none"
          />
        </div>
      </div>
    </Container>
  </section>

  {/* ═════════════ ABOUT — "No black boxes" ═════════════
      Dark navy + grid + aurora. Copy verbatim from the live homepage
      section of the same name.
  ═══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-32">
    <div class="am-aurora" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 am-grid-pattern" aria-hidden="true"></div>
    <div class="grain pointer-events-none absolute inset-0" aria-hidden="true"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10">
        <span class="am-eyebrow on-dark">About Us</span>
      </div>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
        <div data-reveal class="lg:col-span-6">
          <h2 class="am-h1-display am-gradient-ink-light">
            No black boxes<br />
            or buzzwords.<br />
            Just smart, secure<br />
            solutions.
          </h2>
        </div>

        <div data-reveal data-speed="slow" class="flex flex-col gap-6 lg:col-span-6 lg:pt-3">
          <p class="font-display text-[16px] leading-[1.65] text-white/75">
            We take a plain-English approach to even the most complex IT
            challenges. Our team works side-by-side with yours, making sure
            every recommendation is rooted in your business goals, not tech
            for tech’s sake.
          </p>
          <p class="font-display text-[16px] leading-[1.65] text-white/75">
            You’ll never be left guessing what you’re paying for, or why
            something matters. You’ll know, and you’ll feel the difference
            in your day-to-day.
          </p>
          <a
            href="/about/"
            class="group mt-2 inline-flex w-fit items-center gap-2 border-b border-white/40 pb-1.5 font-display text-[15px] font-medium text-white transition-colors hover:border-scooter hover:text-scooter"
          >
            Learn more about us
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
              <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  {/* ═════════════ SERVICES — numbered list, copy verbatim ═════════════
      Headline, intro, category titles, and blurbs match the live homepage
      "IT solutions that move your business forward." section one to one.
  ═══════════════════════════════════════════════════════════ */}
  <section class="relative bg-white py-24 md:py-32">
    <Container width="wide">
      <div data-reveal data-speed="fast" class="mb-10">
        <span class="am-eyebrow">Our Services</span>
      </div>

      <div
        data-reveal
        class="grid grid-cols-1 gap-10 border-b border-line pb-14 md:grid-cols-12 md:gap-16"
      >
        <h2 class="am-h1-display text-navy-900 md:col-span-7">
          IT solutions that move<br />
          your business forward.
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-navy-500 md:col-span-5 md:pt-3">
          We combine technical expertise with business-first thinking to
          deliver IT solutions that fit your operations, your people, and
          your growth goals. Explore our offerings below.
        </p>
      </div>

      <ul class="border-t border-line">
        {homeServices.map((row, idx) => (
          <li class="am-svc-row group relative border-b border-line">
            <a
              href={row.href}
              data-reveal
              data-speed="fast"
              class="relative grid grid-cols-[auto_1fr_auto] items-start gap-6 py-7 md:grid-cols-12 md:items-center md:gap-8 md:py-11"
            >
              <span class="font-display text-[24px] font-medium tabular-nums text-navy-900 md:col-span-1 md:pl-4 md:text-[34px]">
                {String(idx + 1).padStart(2, '0')}
              </span>
              <span class="md:col-span-10">
                <span class="block font-display text-[20px] font-medium tracking-[-0.01em] text-navy-900 sm:text-[24px] md:text-[32px]">
                  {row.title}
                </span>
                <span class="mt-3 block max-w-[86ch] font-display text-[14px] leading-[1.6] text-navy-500 md:text-[15px]">
                  {row.blurb}
                </span>
              </span>

              <span class="md:col-span-1 md:justify-self-end md:pr-4">
                {/* Default ↗ arrow */}
                <svg
                  width="24" height="24" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="1.8"
                  stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                  class="block text-navy-900 group-hover:hidden"
                >
                  <path d="M7 17 17 7" /><path d="M7 7h10v10" />
                </svg>
                {/* Hover → arrow, scooter */}
                <svg
                  width="26" height="26" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                  class="hidden text-scooter group-hover:block"
                >
                  <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
                </svg>
              </span>
            </a>
          </li>
        ))}

        {/* Sentinel row — label verbatim from the live site. */}
        <li class="border-b border-line">
          <a
            href="/services/"
            class="group flex items-center justify-between py-7 md:py-9 md:pl-4 md:pr-4"
          >
            <span class="font-display text-[16px] font-medium tracking-[-0.005em] text-navy-500 transition-colors group-hover:text-navy-900">
              Explore all Our Services
            </span>
            <svg
              width="22" height="22" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
              class="text-navy-500 transition-colors group-hover:text-navy-900"
            >
              <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
            </svg>
          </a>
        </li>
      </ul>
    </Container>
  </section>

  <ContactCta />
</BaseLayout>

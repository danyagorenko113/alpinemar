---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { getCollection } from 'astro:content';
import { site } from '@/data/site';

// ── Content ────────────────────────────────────────────────────────────────
const insights = (await getCollection('insights'))
  .filter((p) => p.data.status !== 'draft')
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));

// Prefer a Cybersecurity post as the featured one (falls back to newest).
const featuredPost =
  insights.find((p) => p.data.category === 'Cybersecurity') ?? insights[0];
const morePosts = insights.filter((p) => p.id !== featuredPost?.id).slice(0, 3);

const services = (await getCollection('services'))
  .filter((s) => s.data.status !== 'draft')
  .map((s) => s.data);
const bySlug = new Map(
  services.map((s) => [s.path.replace(/^\/services\//, '').replace(/\/$/, ''), s]),
);

// ── Featured services — one hero per group + two flagships ────────────────
const featuredServices = [
  { slug: 'cybersecurity',      eyebrow: 'Cybersecurity',        blurb: 'Enterprise-grade detection, response, and awareness training — without the enterprise-sized IT department.' },
  { slug: 'incident-response',  eyebrow: 'Cybersecurity',        blurb: 'When minutes matter: rapid containment, forensic investigation, and a clear path back to normal.' },
  { slug: 'cloud-management',   eyebrow: 'Cloud & Infrastructure', blurb: 'Microsoft 365, Google Workspace, Azure and AWS — configured well, watched closely, priced honestly.' },
  { slug: 'it-consulting',      eyebrow: 'Advisory',             blurb: 'Straight answers on tools, vendors, and roadmaps. No vendor kickbacks, no jargon walls.' },
  { slug: 'ai-security',        eyebrow: 'AI',                   blurb: 'Adopt AI without leaking data. Policies, private instances, and monitoring for the tools your team already uses.' },
  { slug: 'remote-it-support',  eyebrow: 'Advisory',             blurb: 'A real technician on the line, same session, secure remote access — not a ticket queue that stretches for days.' },
]
  .map((row) => ({ ...row, service: bySlug.get(row.slug) }))
  .filter((row) => Boolean(row.service));

// ── Capabilities marquee — realistic stack, no fake client logos ─────────
const stack = [
  'Microsoft 365',
  'Google Workspace',
  'Azure',
  'AWS',
  'CrowdStrike',
  'SentinelOne',
  'Okta',
  'Cloudflare',
  '1Password',
  'Datto',
  'Proofpoint',
  'Duo',
];

// ── Why us / values ────────────────────────────────────────────────────────
const values = [
  {
    title: 'No black boxes.',
    body: 'We explain what we\'re doing, why, and what it costs — in plain English, not vendor-speak.',
  },
  {
    title: 'Small team by design.',
    body: 'You work directly with the people doing the work. No ticket ping-pong, no third-tier hand-offs.',
  },
  {
    title: 'Business-first thinking.',
    body: 'Technology has to serve the business. We start with your goals, then work back to the stack.',
  },
  {
    title: 'Real availability.',
    body: 'When things go wrong, you get a person on the phone quickly. That\'s the whole promise.',
  },
];

// ── Reactive vs Proactive — the signature comparison card ─────────────────
const reactive = [
  'You find out about a breach from the news, an insurer, or an angry customer.',
  'Recovery starts from scratch — no relationship, no context, no baseline.',
  'IT spend feels like a black hole. You pay more when things break.',
  'Every incident is a fire drill for a team that has never met yours.',
];
const proactive = [
  '24/7 monitoring flags the anomaly before it becomes an incident.',
  'We already know your environment. Containment starts in minutes, not days.',
  'Predictable monthly cost. Fewer emergencies mean lower total spend.',
  'Same technicians every time. Institutional memory that compounds.',
];

// ── How we work — 4-step process ──────────────────────────────────────────
const steps = [
  { num: '01', title: 'Listen',  body: 'We start with how your business actually runs — not a canned questionnaire. Half an hour, no pitch.' },
  { num: '02', title: 'Assess',  body: 'A plain-English review of your posture, tooling, and spend. You get the findings whether you sign or not.' },
  { num: '03', title: 'Deploy',  body: 'We roll out the right controls in the right order — endpoints, identity, cloud, backups — with your team, not around them.' },
  { num: '04', title: 'Support', body: 'Ongoing monitoring, real availability, and quarterly reviews so the stack keeps up with the business.' },
];

// ── Utilities ─────────────────────────────────────────────────────────────
const slugOf = (id: string) => id.replace(/\.md$/, '').split('/').pop();
const dateFmt = (d: string | Date) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout
  rawTitle="Alpine Mar IT — IT with a human touch"
  description={site.description}
>
  {/* ══════════════════════ HERO ══════════════════════
      Signature moment: light paper canvas + aurora glow + circuit grid.
      Left-aligned massive gradient headline (am-hero-display ~84px desktop).
      Anchor stat strip at the bottom is a persuasion asset (Verizon 43% —
      honestly cited from content/insights/cybersecurity-risk-management-smb.md).
  ═══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-paper">
    {/* Layered background: aurora glow + subtle grid + faint circuit lines. */}
    <div class="am-aurora on-light" aria-hidden="true"></div>
    <div
      class="pointer-events-none absolute inset-0 am-grid-pattern-light"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-[520px] am-circuit opacity-70"
      aria-hidden="true"
    ></div>
    {/* Fade bottom into paper for legibility of any following section. */}
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-b from-transparent to-paper"
      aria-hidden="true"
    ></div>

    <Container width="wide" class="relative">
      <div class="grid min-h-[86vh] grid-rows-[auto_1fr_auto] content-start gap-0 pt-[16vh] pb-14 md:pt-[19vh] md:pb-20">
        {/* Status pill — establishes credibility without being loud. */}
        <div data-reveal data-speed="fast" class="mb-8 md:mb-10">
          <span class="inline-flex items-center gap-2.5 rounded-full border border-line bg-white/70 px-3.5 py-1.5 font-display text-[12.5px] font-medium text-navy-900 backdrop-blur">
            <span class="am-status-dot text-scooter"></span>
            24/7 monitoring · Fort Lauderdale, FL
          </span>
        </div>

        {/* Signature headline — one big statement, italic accent on the last word.
            Line breaks controlled with <br /> — matches the reference site's craft. */}
        <h1
          data-reveal
          data-speed="slow"
          class="am-hero-display am-gradient-ink self-start leading-[1.02]"
        >
          IT by people<br />
          who get<br />
          <span class="italic text-scooter">business.</span>
        </h1>

        <div
          data-reveal
          class="mt-9 flex max-w-[62ch] flex-col gap-6 md:mt-12"
        >
          <p class="font-display text-[16px] leading-[1.65] text-navy-500 md:text-[17px]">
            No black boxes. No jargon walls. Cybersecurity, cloud, and
            AI-forward IT delivered in plain English by a small team that
            takes the time to learn how your business actually runs.
          </p>

          {/* Primary + secondary CTA — hierarchy per REFACTORING_UI (filled vs. underlined). */}
          <div class="flex flex-wrap items-center gap-x-6 gap-y-4">
            <a
              href="/contact/"
              class="group inline-flex items-center gap-2 rounded-[6px] bg-navy-900 px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter hover:text-navy-900"
            >
              {site.primaryCta}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                <path d="m9 18 6-6-6-6" />
              </svg>
            </a>
            <a
              href="/services/"
              class="group inline-flex items-center gap-2 border-b border-navy-900 pb-1.5 font-display text-[15px] font-medium text-navy-900 transition-colors hover:text-teal-700"
            >
              Explore what we do
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        {/* Anchor stat strip — honest, cited. Sits at hero bottom, 3-up on md.
            Each stat de-emphasizes the label per REFACTORING_UI hierarchy #1. */}
        <div
          data-reveal
          data-stagger
          class="mt-14 grid grid-cols-1 gap-6 border-t border-line pt-8 sm:grid-cols-3 md:mt-20 md:gap-10 md:pt-10"
        >
          <div>
            <div class="font-display text-[36px] font-medium leading-[1] tracking-[-0.02em] text-navy-900 md:text-[44px]">
              43%
            </div>
            <div class="mt-3 font-display text-[13px] leading-[1.55] text-navy-500">
              of internet security breaches hit SMBs<br />
              <span class="text-navy-400">Source: Verizon</span>
            </div>
          </div>
          <div>
            <div class="font-display text-[36px] font-medium leading-[1] tracking-[-0.02em] text-navy-900 md:text-[44px]">
              24/7
            </div>
            <div class="mt-3 font-display text-[13px] leading-[1.55] text-navy-500">
              managed detection & response<br />
              <span class="text-navy-400">Not a shared queue</span>
            </div>
          </div>
          <div>
            <div class="font-display text-[36px] font-medium leading-[1] tracking-[-0.02em] text-navy-900 md:text-[44px]">
              30 min
            </div>
            <div class="mt-3 font-display text-[13px] leading-[1.55] text-navy-500">
              free IT assessment<br />
              <span class="text-navy-400">No pitch. No obligation.</span>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  {/* ═════════════ CAPABILITIES MARQUEE ═════════════
      Instead of fake client logos we don't have, we surface the stack we
      actually work with as auto-scrolling text pills. Marquee pauses on hover.
  ═══════════════════════════════════════════════════════════ */}
  <section class="relative border-y border-line bg-paper py-10 md:py-14">
    <Container width="wide" class="overflow-hidden">
      <div class="flex flex-col items-center gap-6 md:flex-row md:gap-10">
        <p class="shrink-0 font-display text-[13px] tracking-[0.02em] text-navy-500 md:whitespace-nowrap">
          The stack we secure & support
        </p>

        <div
          class="am-marquee-viewport relative w-full overflow-hidden"
          style="mask-image:linear-gradient(to right, transparent, black 6%, black 94%, transparent); -webkit-mask-image:linear-gradient(to right, transparent, black 6%, black 94%, transparent);"
        >
          <div class="am-marquee-track">
            {[...stack, ...stack].map((label) => (
              <span class="am-chip">{label}</span>
            ))}
          </div>
        </div>
      </div>
    </Container>
  </section>

  {/* ═════════════ SERVICES — numbered list with hover preview ═════════════
      Same layout DNA as the main site's home services list. Numbers in
      tabular-nums. Hover: arrow swaps ↗ → →, right-side preview card fades
      in with eyebrow + one-line blurb. No fake artwork — we use a categoric
      eyebrow + typographic treatment inside a soft navy card.
  ═══════════════════════════════════════════════════════════ */}
  {featuredServices.length > 0 && (
    <section class="relative bg-white py-24 md:py-32">
      <Container width="wide">
        <div data-reveal data-speed="fast" class="mb-10">
          <span class="am-eyebrow">Our Services</span>
        </div>

        <div
          data-reveal
          class="grid grid-cols-1 gap-10 border-b border-line pb-14 md:grid-cols-12 md:gap-16"
        >
          <h2 class="am-h1-display text-navy-900 md:col-span-7">
            Smart, secure IT —<br />
            built around your business.
          </h2>
          <p class="font-display text-[15px] leading-[1.65] text-navy-500 md:col-span-5 md:pt-3">
            Whether it's locking down endpoints, moving to the cloud, or
            making AI safe to use — every engagement starts with your goals.
            Technology decisions come second.
          </p>
        </div>

        <ul class="border-t border-line">
          {featuredServices.map((row, idx) => (
            <li class="am-svc-row group relative border-b border-line">
              <a
                href={row.service!.path}
                data-reveal
                data-speed="fast"
                class="relative grid grid-cols-[auto_1fr_auto] items-center gap-6 py-7 md:grid-cols-12 md:gap-8 md:py-11"
              >
                <span class="font-display text-[24px] font-medium tabular-nums text-navy-900 md:col-span-1 md:pl-4 md:text-[34px]">
                  {String(idx + 1).padStart(2, '0')}
                </span>
                <span class="font-display text-[20px] font-medium tracking-[-0.01em] text-navy-900 sm:text-[24px] md:col-span-6 md:text-[32px]">
                  {row.service!.title}
                </span>

                {/* Hover preview — positioned to the right of the row on desktop */}
                <span
                  class="am-svc-preview pointer-events-none absolute right-[6%] top-1/2 hidden -translate-y-1/2 md:block"
                  aria-hidden="true"
                >
                  <span class="block w-[300px] rounded-[8px] border border-line bg-paper p-5 shadow-[0_20px_50px_-20px_rgba(18,18,45,0.35)]">
                    <span class="am-eyebrow" style="font-size:11px;">
                      {row.eyebrow}
                    </span>
                    <span class="mt-3 block font-display text-[13.5px] leading-[1.55] text-navy-500">
                      {row.blurb}
                    </span>
                  </span>
                </span>

                <span class="md:col-span-5 md:col-start-12 md:justify-self-end md:pr-4">
                  {/* Default ↗ arrow */}
                  <svg
                    width="24" height="24" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="1.8"
                    stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                    class="block text-navy-900 group-hover:hidden"
                  >
                    <path d="M7 17 17 7" /><path d="M7 7h10v10" />
                  </svg>
                  {/* Hover → arrow, scooter */}
                  <svg
                    width="26" height="26" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                    class="hidden text-scooter group-hover:block"
                  >
                    <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
                  </svg>
                </span>
              </a>
            </li>
          ))}

          {/* Sentinel row — "View all services" */}
          <li class="border-b border-line">
            <a
              href="/services/"
              class="group flex items-center justify-between py-7 md:py-9 md:pl-4 md:pr-4"
            >
              <span class="font-display text-[16px] font-medium tracking-[-0.005em] text-navy-500 transition-colors group-hover:text-navy-900">
                View all 17 services
              </span>
              <svg
                width="22" height="22" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                class="text-navy-500 transition-colors group-hover:text-navy-900"
              >
                <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
              </svg>
            </a>
          </li>
        </ul>
      </Container>
    </section>
  )}

  {/* ═════════════ THREAT POSTURE — signature moment ═════════════
      This is the screenshot-worthy section. Dark navy + grid + aurora, split
      composition: manifesto headline on the left, "Reactive vs Proactive"
      comparison card on the right. Colors do the heavy lifting: red-ish
      warnings for the reactive column, scooter checkmarks for proactive.
      Copy anchors the honest Verizon stat that's already in our insights.
  ═══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-32">
    <div class="am-aurora" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 am-grid-pattern" aria-hidden="true"></div>
    <div class="grain pointer-events-none absolute inset-0" aria-hidden="true"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10">
        <span class="am-eyebrow on-dark">The Threat Landscape</span>
      </div>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
        {/* Left: manifesto text + cited stat */}
        <div data-reveal class="lg:col-span-5">
          <h2 class="am-h1-display am-gradient-ink-light">
            Attackers aren't<br />
            slowing down.<br />
            Neither are we.
          </h2>

          <p class="mt-8 font-display text-[16px] leading-[1.65] text-white/75">
            Small and mid-sized businesses have become the soft target —
            not because attackers picked you, but because the defenses
            were built for someone else's company. We build them for yours.
          </p>

          {/* Cited stat block — the one honest number we surfaced from our insights. */}
          <a
            href="/blog/cybersecurity-risk-management-smb/"
            class="group mt-10 block border-l-2 border-scooter pl-6 transition-colors hover:border-white"
          >
            <div class="font-display text-[54px] font-medium leading-[1] tracking-[-0.02em] text-white md:text-[64px]">
              43<span class="text-scooter">%</span>
            </div>
            <p class="mt-4 max-w-sm font-display text-[14px] leading-[1.6] text-white/70">
              of internet security breaches hit small businesses.
              <span class="mt-2 block text-white/50">Verizon — via our SMB risk management guide</span>
            </p>
            <span class="mt-4 inline-flex items-center gap-2 font-display text-[13px] font-medium text-scooter transition-colors group-hover:text-white">
              Read the guide
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
              </svg>
            </span>
          </a>
        </div>

        {/* Right: Reactive vs Proactive comparison — the signature diagram */}
        <div data-reveal data-speed="slow" class="lg:col-span-7">
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2 md:gap-5">
            {/* REACTIVE column — muted, warning-toned */}
            <div class="am-card-dark relative overflow-hidden rounded-[8px] p-7 md:p-8">
              <div class="mb-6 flex items-center justify-between">
                <span class="font-display text-[11px] font-medium uppercase tracking-[0.14em] text-white/50">
                  Without us
                </span>
                <span class="inline-flex size-6 items-center justify-center rounded-full border border-white/20 text-white/40">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                    <path d="M18 6 6 18" /><path d="m6 6 12 12" />
                  </svg>
                </span>
              </div>
              <h3 class="font-display text-[22px] font-medium leading-[1.15] tracking-[-0.01em] text-white/70">
                Reactive IT
              </h3>
              <p class="mt-2 font-display text-[13px] leading-[1.5] text-white/45">
                What you're doing today
              </p>
              <ul class="mt-6 space-y-4">
                {reactive.map((line) => (
                  <li class="flex items-start gap-3 font-display text-[13.5px] leading-[1.55] text-white/60">
                    <span class="mt-1.5 block size-1 flex-shrink-0 rounded-full bg-white/30"></span>
                    {line}
                  </li>
                ))}
              </ul>
            </div>

            {/* PROACTIVE column — scooter-accented, lit */}
            <div class="relative overflow-hidden rounded-[8px] border border-scooter/50 bg-gradient-to-br from-scooter/10 via-white/[0.04] to-white/[0.02] p-7 md:p-8">
              <div class="mb-6 flex items-center justify-between">
                <span class="font-display text-[11px] font-medium uppercase tracking-[0.14em] text-scooter">
                  With Alpine Mar IT
                </span>
                <span class="inline-flex size-6 items-center justify-center rounded-full border border-scooter bg-scooter/10 text-scooter">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                </span>
              </div>
              <h3 class="font-display text-[22px] font-medium leading-[1.15] tracking-[-0.01em] text-white">
                Proactive IT
              </h3>
              <p class="mt-2 font-display text-[13px] leading-[1.5] text-scooter/80">
                What working with us looks like
              </p>
              <ul class="mt-6 space-y-4">
                {proactive.map((line) => (
                  <li class="flex items-start gap-3 font-display text-[13.5px] leading-[1.55] text-white/90">
                    <span class="mt-0.5 inline-flex size-4 flex-shrink-0 items-center justify-center rounded-full bg-scooter/15 text-scooter">
                      <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                    </span>
                    {line}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <p class="mt-8 font-display text-[13px] leading-[1.55] text-white/45">
            Not a magic-bullet promise — a shift in operating model. Fewer
            surprises, faster containment, and one number to call.
          </p>
        </div>
      </div>
    </Container>
  </section>

  {/* ═════════════ WHY US — 4 values pill grid ═════════════
      Continues the dark section with a manifesto headline + 4 checkbox pills.
      Matches the main site about-section DNA (scooter-ring check + strong
      title + soft body copy) so both sites read as the same family.
  ═══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0 am-grid-pattern" aria-hidden="true"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10">
        <span class="am-eyebrow on-dark">Why Alpine Mar IT</span>
      </div>

      <div
        data-reveal
        class="grid grid-cols-1 gap-10 border-b border-white/10 pb-16 md:grid-cols-12 md:gap-16 md:pb-20"
      >
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-7">
          IT with a<br />human touch.
        </h2>
        <p class="font-display text-[16px] leading-[1.65] text-white/75 md:col-span-5 md:pt-3">
          We started Alpine Mar IT because we'd seen what "managed IT"
          had become. Faceless ticketing. Vendors that talked past you.
          Playbooks written for someone else's business. We wanted the
          opposite: a small team that picks up the phone, learns your
          business, and gives you honest answers.
        </p>
      </div>

      <ul
        data-stagger
        class="mt-16 grid grid-cols-1 gap-y-10 gap-x-8 sm:grid-cols-2 md:grid-cols-4"
      >
        {values.map((item) => (
          <li class="flex flex-col gap-4">
            <span class="flex size-9 shrink-0 items-center justify-center rounded-full border-2 border-scooter">
              <svg
                width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="3"
                stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                class="text-scooter"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </span>
            <div>
              <h3 class="font-display text-[18px] font-medium tracking-[-0.01em] text-white">
                {item.title}
              </h3>
              <p class="mt-2 font-display text-[14px] leading-[1.6] text-white/70">
                {item.body}
              </p>
            </div>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  {/* ═════════════ HOW WE WORK ═════════════
      Distinct light-section rhythm break. 4 steps on a horizontal ridge:
      numbered dots on a thin scooter connecting line, with staggered reveal.
      Because we don't have the CPA site's carousel, this fills the "process"
      slot with something native to IT services.
  ═══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-paper py-24 md:py-32">
    <div class="pointer-events-none absolute inset-0 am-grid-pattern-light" aria-hidden="true"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10">
        <span class="am-eyebrow">How We Work</span>
      </div>

      <div
        data-reveal
        class="grid grid-cols-1 gap-10 border-b border-line pb-14 md:grid-cols-12 md:gap-16"
      >
        <h2 class="am-h1-display text-navy-900 md:col-span-7">
          Four honest steps.<br />
          No surprise scope creep.
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-navy-500 md:col-span-5 md:pt-3">
          Every engagement — one endpoint or five hundred — follows the
          same rhythm. You always know where we are, what we're doing
          next, and what it will cost.
        </p>
      </div>

      {/* Ridge line — the thin scooter connector behind the step markers. */}
      <div class="relative mt-16">
        <div
          class="pointer-events-none absolute left-6 top-[22px] hidden h-px bg-gradient-to-r from-transparent via-navy-200 to-transparent md:block"
          style="width: calc(100% - 3rem);"
          aria-hidden="true"
        ></div>

        <ol data-stagger class="grid grid-cols-1 gap-10 md:grid-cols-4 md:gap-8">
          {steps.map((step) => (
            <li class="am-step group relative">
              <div class="flex items-center gap-4 md:block">
                <span class="am-step-num">{step.num}</span>
              </div>
              <h3 class="mt-5 font-display text-[22px] font-medium tracking-[-0.01em] text-navy-900 md:mt-8">
                {step.title}
              </h3>
              <p class="mt-3 font-display text-[14.5px] leading-[1.6] text-navy-500">
                {step.body}
              </p>
            </li>
          ))}
        </ol>
      </div>
    </Container>
  </section>

  {/* ═════════════ LATEST INSIGHTS ═════════════
      Featured post = full-width card with a big teal-grid brand panel on
      the right (since we don't have hero art). 3 more posts as text cards.
      Matches the main-site polish, adapted for our content-only reality.
  ═══════════════════════════════════════════════════════════ */}
  {insights.length > 0 && (
    <section class="relative overflow-hidden bg-white py-24 md:py-32">
      <div class="pointer-events-none absolute inset-0 am-grid-pattern-light" aria-hidden="true"></div>

      <Container width="wide" class="relative z-10">
        <div data-reveal data-speed="fast" class="mb-10">
          <span class="am-eyebrow">Latest Insights</span>
        </div>

        <div
          data-reveal
          class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16"
        >
          <h2 class="am-h1-display text-navy-900 md:col-span-7">
            At the intersection<br />
            of tech and business.
          </h2>
          <div class="flex flex-col items-start gap-7 md:col-span-5 md:pt-3">
            <p class="font-display text-[15px] leading-[1.65] text-navy-500">
              Practical perspectives on cybersecurity, cloud, and AI —
              written by the people who work in it every day.
            </p>
            <a
              href="/blog/"
              class="group inline-flex items-center gap-2 rounded-[6px] bg-navy-900 px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter hover:text-navy-900"
            >
              View All Insights
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                <path d="m9 18 6-6-6-6" />
              </svg>
            </a>
          </div>
        </div>

        {featuredPost && (
          <a
            data-reveal
            href={`/blog/${slugOf(featuredPost.id)}/`}
            class="group mt-16 grid grid-cols-1 overflow-hidden rounded-[10px] border border-line bg-white transition-colors hover:border-navy-900 md:grid-cols-2"
          >
            {/* Copy side */}
            <div class="flex flex-col gap-6 p-8 md:p-12">
              <div class="flex items-center justify-between gap-3 font-display text-[12px] text-navy-500">
                <span class="inline-flex items-center gap-2 rounded-[4px] bg-paper px-3 py-1.5">
                  <span class="block size-1.5 rounded-full bg-scooter"></span>
                  {featuredPost.data.category ?? 'Insights'}
                </span>
                <span>{dateFmt(featuredPost.data.date)}</span>
              </div>
              <h3 class="font-display text-[26px] font-medium leading-[1.2] tracking-[-0.01em] text-navy-900 md:text-[34px]">
                {featuredPost.data.title}
              </h3>
              <p class="font-display text-[15px] leading-[1.6] text-navy-500">
                {featuredPost.data.excerpt}
              </p>
              <div class="mt-auto flex items-center justify-between gap-4 pt-4">
                <span class="font-display text-[14px] font-medium text-navy-900">
                  Read the guide
                </span>
                <span class="inline-flex size-10 items-center justify-center rounded-[6px] bg-navy-900 text-white transition-transform group-hover:translate-x-1 group-hover:bg-scooter group-hover:text-navy-900">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
                    <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
                  </svg>
                </span>
              </div>
            </div>

            {/* Brand panel side — since we lack hero art, the panel IS art */}
            <div class="relative aspect-[5/4] overflow-hidden bg-navy-900 md:aspect-auto md:min-h-[440px]">
              <div class="pointer-events-none absolute inset-0 am-grid-pattern opacity-70" aria-hidden="true"></div>
              <div class="am-aurora" aria-hidden="true"></div>
              <div class="absolute inset-0 bg-gradient-to-br from-navy-900/95 via-navy-900/60 to-transparent"></div>

              {/* Big outlined category label as visual anchor */}
              <div class="relative flex h-full flex-col justify-between p-8 md:p-12">
                <span class="am-eyebrow on-dark">Featured</span>
                <div>
                  <div class="text-outline-light font-display text-[64px] leading-[0.95] tracking-[-0.03em] md:text-[92px]">
                    {(featuredPost.data.category ?? 'Insight').split(' ')[0]}
                  </div>
                  <div class="mt-4 font-display text-[13px] uppercase tracking-[0.16em] text-scooter">
                    {featuredPost.data.category ?? 'Insights'} · {dateFmt(featuredPost.data.date)}
                  </div>
                </div>
              </div>
            </div>
          </a>
        )}

        {morePosts.length > 0 && (
          <div data-stagger class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-3">
            {morePosts.map((p) => (
              <a
                href={`/blog/${slugOf(p.id)}/`}
                class="group flex min-h-[280px] flex-col rounded-[10px] border border-line bg-white p-7 transition-all hover:-translate-y-0.5 hover:border-navy-900"
              >
                <div class="flex items-center justify-between gap-3 font-display text-[12px] text-navy-500">
                  <span class="inline-flex items-center gap-2 rounded-[4px] bg-paper px-3 py-1.5">
                    <span class="block size-1.5 rounded-full bg-scooter"></span>
                    {p.data.category ?? 'Insights'}
                  </span>
                  <span>{dateFmt(p.data.date)}</span>
                </div>
                <h4 class="mt-7 font-display text-[19px] font-medium leading-[1.3] tracking-[-0.01em] text-navy-900">
                  {p.data.title}
                </h4>
                <div class="mt-auto flex items-center justify-between gap-4 pt-8">
                  <span class="font-display text-[13px] font-medium text-navy-900">
                    Read more
                  </span>
                  <span class="inline-flex size-9 items-center justify-center rounded-[6px] bg-navy-900 text-white transition-transform group-hover:translate-x-1">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
                      <path d="M5 12h14" /><path d="m13 5 7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </a>
            ))}
          </div>
        )}
      </Container>
    </section>
  )}

  {/* ═════════════ CONTACT CTA ═════════════
      Dark navy + grid + aurora. Split: manifesto headline + 2 info cards on
      the left, high-emphasis CTA panel on the right (rather than a full form
      — the full form lives at /contact/, which is more honest to the flow).
  ═══════════════════════════════════════════════════════════ */}
  <section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-32">
    <div class="am-aurora" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 am-grid-pattern" aria-hidden="true"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10">
        <span class="am-eyebrow on-dark">Let's talk IT</span>
      </div>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
        {/* Left column — headline + office / contact cards */}
        <div data-reveal class="flex flex-col gap-10 lg:col-span-6">
          <h2 class="am-h1-display am-gradient-ink-light">
            Start with a free<br />
            IT assessment.
          </h2>

          <p class="max-w-md font-display text-[16px] leading-[1.65] text-white/75">
            Thirty minutes on the phone or in the office. We listen first,
            then tell you what we think — whether that's working with us
            or not.
          </p>

          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div class="am-card-dark rounded-[8px] p-6 md:p-7">
              <h3 class="font-display text-[12px] font-medium uppercase tracking-[0.12em] text-scooter">
                Our Location
              </h3>
              <address class="mt-5 block font-display text-[14.5px] not-italic leading-[1.6] text-white">
                {site.address.street}<br />
                {site.address.city}, {site.address.state} {site.address.zip}
              </address>
            </div>
            <div class="am-card-dark rounded-[8px] p-6 md:p-7">
              <h3 class="font-display text-[12px] font-medium uppercase tracking-[0.12em] text-scooter">
                Contact Information
              </h3>
              <div class="mt-5 flex flex-col gap-1.5 font-display text-[14.5px] leading-[1.6]">
                <a
                  href={`tel:${site.phoneHref}`}
                  class="text-white transition-colors hover:text-scooter"
                >
                  {site.phone}
                </a>
                <a
                  href={`mailto:${site.email}`}
                  class="text-white transition-colors hover:text-scooter"
                >
                  {site.email}
                </a>
              </div>
            </div>
          </div>
        </div>

        {/* Right column — high-emphasis CTA card */}
        <div data-reveal data-speed="slow" class="lg:col-span-6">
          <div class="am-card-dark relative overflow-hidden rounded-[12px] p-8 md:p-12">
            <div class="pointer-events-none absolute inset-0 am-grid-pattern opacity-60"></div>
            <div class="relative">
              <span class="am-eyebrow on-dark" style="font-size:11px;">
                What you get
              </span>

              <ol class="mt-8 space-y-6">
                <li class="flex items-start gap-4">
                  <span class="am-step-num" style="border-color: rgba(51,187,220,0.6); background:transparent; color:#33bbdc;">01</span>
                  <div>
                    <h4 class="font-display text-[17px] font-medium text-white">
                      A 30-minute conversation.
                    </h4>
                    <p class="mt-1.5 font-display text-[14px] leading-[1.55] text-white/70">
                      Phone, video, or coffee on Las Olas — your call.
                    </p>
                  </div>
                </li>
                <li class="flex items-start gap-4">
                  <span class="am-step-num" style="border-color: rgba(51,187,220,0.6); background:transparent; color:#33bbdc;">02</span>
                  <div>
                    <h4 class="font-display text-[17px] font-medium text-white">
                      An honest posture check.
                    </h4>
                    <p class="mt-1.5 font-display text-[14px] leading-[1.55] text-white/70">
                      What's working, what isn't, and where the real risk sits.
                    </p>
                  </div>
                </li>
                <li class="flex items-start gap-4">
                  <span class="am-step-num" style="border-color: rgba(51,187,220,0.6); background:transparent; color:#33bbdc;">03</span>
                  <div>
                    <h4 class="font-display text-[17px] font-medium text-white">
                      A written recommendation.
                    </h4>
                    <p class="mt-1.5 font-display text-[14px] leading-[1.55] text-white/70">
                      Yours to keep. No obligation to work with us.
                    </p>
                  </div>
                </li>
              </ol>

              <div class="mt-10 border-t border-white/10 pt-8">
                <a
                  href="/contact/"
                  class="group inline-flex w-full items-center justify-between gap-3 rounded-[8px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-navy-900 transition-colors hover:bg-white sm:w-auto"
                >
                  {site.primaryCta}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
                    <path d="m9 18 6-6-6-6" />
                  </svg>
                </a>
                <p class="mt-4 font-display text-[13px] text-white/50">
                  Or call <a href={`tel:${site.phoneHref}`} class="text-white/70 underline underline-offset-4 hover:text-scooter">{site.phone}</a> — a real person picks up.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

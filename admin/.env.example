# --- AUTH ---
# Password the SEO team types on /login. Pick something long.
ADMIN_PASSWORD=change-me

# Secret used to sign the session cookie. 32+ random chars.
SESSION_SECRET=change-me-to-something-random-and-long

# --- CONTENT STORE ---
# "fs" in local dev, "github" in production.
CONTENT_STORE=fs

# Path to the alpinemar repo root, relative to admin/ (only for CONTENT_STORE=fs).
CONTENT_REPO_ROOT=..

# --- GITHUB (only when CONTENT_STORE=github) ---
# Fine-grained PAT with Contents: Read & Write on the alpinemar repo.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=alpinemar
GITHUB_BRANCH=main
# Optional: name/email used in commit author block.
GITHUB_COMMIT_NAME=Alpine Mar Admin
GITHUB_COMMIT_EMAIL=admin@alpinemar.com

# --- VERCEL DEPLOY HOOK (optional) ---
# When set, /api/redeploy POSTs here after a publish to trigger a site rebuild.
VERCEL_DEPLOY_HOOK_URL=

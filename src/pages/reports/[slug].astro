---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { REPORTS } from '@/data/reports';

export async function getStaticPaths() {
  const { REPORTS } = await import('@/data/reports');
  return REPORTS.map((r) => ({ params: { slug: r.slug }, props: { report: r } }));
}

const { report } = Astro.props;
---

<BaseLayout
  rawTitle={`${report.title} ${report.year} | Alpine Mar Report`}
  description={report.subtitle}
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-14 pb-16 text-white md:pt-20 md:pb-20">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-2 font-display text-[13px] text-white/70">
          <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li><a href="/reports/" class="transition-colors hover:text-scooter">Reports</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li class="font-medium text-white">{report.industry}</li>
        </ol>
      </nav>

      <div class="max-w-3xl">
        <p class="font-mono text-[12px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Report · {report.year} · {report.pages} pages</p>
        <h1 class="mt-5 font-display text-[40px] font-medium leading-[1.1] tracking-[-0.02em] text-white sm:text-[52px] md:text-[64px]">{report.title}</h1>
        <p class="mt-6 font-display text-[18px] leading-[1.55] text-white/80">{report.subtitle}</p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <button type="button" onclick="window.print()" class="group inline-flex items-center gap-2 rounded-[6px] bg-[#1F3062] px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter">
            Save as PDF
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
          </button>
          <a href={report.industryHref} class="inline-flex items-center gap-2 rounded-[6px] border border-white/25 px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:border-scooter hover:text-scooter">
            Industry page
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ DISCLAIMER ═════════════ -->
  <section class="relative bg-paper pt-16">
    <Container width="reading">
      <div class="flex items-start gap-3 rounded-[6px] border border-scooter/30 bg-scooter/8 p-5">
        <span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full bg-scooter text-white">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" aria-hidden="true"><line x1="12" x2="12" y1="8" y2="13"/><line x1="12" x2="12" y1="16" y2="16"/></svg>
        </span>
        <p class="font-display text-[13px] leading-[1.55] text-[var(--color-text-head)]">
          <span class="block font-display text-[12px] font-medium uppercase tracking-[0.1em] text-scooter">Illustrative model</span>
          Figures and benchmarks are reference values modelled to show typical impact — not aggregated firm-engagement data. Verify with a CPA before acting.
        </p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ FOREWORD + KEY TAKEAWAYS ═════════════ -->
  <section class="relative bg-paper py-14 md:py-20">
    <Container width="wide">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-7">
          <div class="mb-6 flex items-center gap-3 text-[var(--color-text-head)]">
            <span class="block size-2 bg-scooter"></span>
            <span class="font-display text-[14px] tracking-[-0.005em]">Foreword</span>
          </div>
          <p class="font-display text-[16px] leading-[1.7] text-[var(--color-text-head)]">{report.intro}</p>
        </div>
        <div class="lg:col-span-5">
          <div class="mb-6 flex items-center gap-3 text-[var(--color-text-head)]">
            <span class="block size-2 bg-scooter"></span>
            <span class="font-display text-[14px] tracking-[-0.005em]">Key takeaways</span>
          </div>
          <ol class="overflow-hidden rounded-[6px] border border-line bg-white">
            {report.takeaways.map((t, i) => (
              <li class={`flex items-start gap-4 p-5 ${i > 0 ? 'border-t border-line' : ''}`}>
                <span class="font-mono text-[12px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">{String(i + 1).padStart(2, '0')}</span>
                <span class="font-display text-[14px] leading-[1.5] text-[var(--color-text-head)]">{t}</span>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ SECTIONS ═════════════ -->
  <section class="relative bg-paper pb-16 md:pb-24">
    <Container width="wide">
      <div class="space-y-20">
        {report.sections.map((s) => (
          <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
            <div class="lg:col-span-4">
              <p class="font-mono text-[12px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">{s.heading}</p>
            </div>
            <div class="space-y-5 lg:col-span-8">
              {s.body.map((p) => (
                <p class="font-display text-[15px] leading-[1.7] text-[var(--color-text-body)]">{p}</p>
              ))}
              {s.data && (
                <ul class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-3">
                  {s.data.map((d) => (
                    <li class="rounded-[6px] border border-line bg-white p-5">
                      <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-text-body)]">{d.label}</p>
                      <p class="mt-2 font-display text-[24px] font-medium tracking-[-0.02em] text-[var(--color-text-head)]">{d.value}</p>
                      {d.sub && <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">{d.sub}</p>}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- ═════════════ CALC TOOL CTA (optional) ═════════════ -->
  {report.ctaTool && (
    <section class="relative bg-white py-16 md:py-20">
      <Container width="wide">
        <div class="flex flex-col items-start justify-between gap-6 rounded-[6px] border border-line bg-paper p-8 md:flex-row md:items-center md:p-12">
          <div>
            <p class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-head)]">Run the numbers</p>
            <h2 class="mt-3 font-display text-[24px] font-medium tracking-[-0.01em] text-[var(--color-text-head)] md:text-[28px]">Calculate this for your own situation.</h2>
          </div>
          <a href={report.ctaTool.href} class="group inline-flex items-center gap-2 rounded-[6px] bg-[#1F3062] px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter">
            {report.ctaTool.label}
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </Container>
    </section>
  )}

  <!-- ═════════════ FINAL CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">Want this analysis for your own {report.industry.toLowerCase()} situation?</h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Request a Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

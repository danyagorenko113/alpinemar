---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';

const reports = [
  { slug: 'florida-real-estate-tax-2026',     industry: 'Real Estate',        title: 'State of Florida Real Estate Tax',     year: 2026, status: 'live',   pages: 22 },
  { slug: 'saas-rd-credit-playbook-2026',     industry: 'SaaS',               title: 'SaaS R&D Credit Playbook',             year: 2026, status: 'live',   pages: 18 },
  { slug: 'hnw-estate-planning-florida-2026', industry: 'High Net Worth',     title: 'HNW Estate Planning in Florida',       year: 2026, status: 'live',   pages: 26 },
  { slug: 'startup-runway-survey-2026',       industry: 'Startups',           title: 'Startup Runway Survey',                year: 2026, status: 'coming', pages: 14 },
  { slug: 'crypto-tax-after-obbb',            industry: 'Crypto',             title: 'Crypto Tax After the OBBB Act',        year: 2026, status: 'coming', pages: 16 },
  { slug: 'healthcare-ebp-audit-2026',        industry: 'Healthcare',         title: 'Healthcare EBP Audit Trends',          year: 2026, status: 'coming', pages: 20 },
  { slug: 'law-firm-trust-accounting-2026',   industry: 'Law Firms',          title: 'Law Firm Trust Accounting',            year: 2026, status: 'coming', pages: 18 },
  { slug: 'agency-s-corp-2026',               industry: 'Marketing Agencies', title: 'Agency S-Corp Election Guide',         year: 2026, status: 'coming', pages: 12 },
  { slug: 'family-office-multi-entity-2026',  industry: 'Family Office',      title: 'Family Office Multi-Entity Strategy',  year: 2026, status: 'coming', pages: 24 },
  { slug: 'sports-image-rights-2026',         industry: 'Sports & Athletes',  title: 'Athlete Image Rights & State Tax',     year: 2026, status: 'coming', pages: 16 },
  { slug: 'construction-revenue-rec-2026',    industry: 'Construction',       title: 'Construction Revenue Recognition',     year: 2026, status: 'coming', pages: 14 },
];

const liveCount = reports.filter((r) => r.status === 'live').length;
---

<BaseLayout
  rawTitle="Industry Reports — Alpine Mar"
  description="Annual industry reports from Alpine Mar CPAs. Real benchmarks, free to download — for owners, operators, and investors."
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-16 text-white md:pt-16 md:pb-20">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mx-auto max-w-[64ch] text-center">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[36px] md:text-[40px]">Industry Reports</h1>
        <p class="mt-3 font-display text-[14px] leading-[1.55] text-white/70 md:text-[15px]">
          One reference report per industry per year — tax-rate context, planning levers, and patterns we see most often in practice. Free, no signup.
        </p>
        <p class="mt-4 font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">
          {liveCount} live · {reports.length - liveCount} coming · 2026 edition
        </p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ DISCLAIMER ═════════════ -->
  <section class="relative bg-paper pt-14 md:pt-16">
    <Container width="reading">
      <div class="flex items-start gap-3 rounded-[6px] border border-scooter/30 bg-scooter/8 p-5">
        <span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full bg-scooter text-white">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" aria-hidden="true"><line x1="12" x2="12" y1="8" y2="13"/><line x1="12" x2="12" y1="16" y2="16"/></svg>
        </span>
        <p class="font-display text-[13px] leading-[1.55] text-[var(--color-text-head)]">
          Figures in these reports are illustrative models — built to show order-of-magnitude impact of common planning moves, not aggregate firm-engagement data. Verify with a CPA before acting on any single number.
        </p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ REPORTS GRID ═════════════ -->
  <section class="relative bg-paper py-14 md:py-20">
    <Container width="wide">
      <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
        {reports.map((r, i) => {
          const live = r.status === 'live';
          return (
            <li>
              {live ? (
                <a href={`/reports/${r.slug}/`} class="group flex h-full flex-col gap-5 rounded-[6px] border border-line bg-white p-7 transition-colors hover:border-[#12122D]">
                  <div class="flex items-center justify-between gap-3">
                    <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">{String(i + 1).padStart(2, '0')} · {r.year}</span>
                    <span class="rounded-[4px] bg-paper px-2.5 py-1 font-display text-[11px] font-medium text-delft">Live</span>
                  </div>
                  <div>
                    <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-text-body)]">{r.industry}</p>
                    <h2 class="mt-3 font-display text-[20px] font-medium leading-[1.25] tracking-[-0.01em] text-[var(--color-text-head)] transition-colors group-hover:text-scooter">{r.title}</h2>
                  </div>
                  <div class="mt-auto flex items-center justify-between">
                    <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-text-body)]">{r.pages} pages</span>
                    <span class="inline-flex items-center gap-2 font-display text-[13px] font-medium text-[var(--color-text-head)] transition-colors group-hover:text-scooter">
                      Read
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
                    </span>
                  </div>
                </a>
              ) : (
                <div class="flex h-full flex-col gap-5 rounded-[6px] border border-line bg-white p-7 opacity-70">
                  <div class="flex items-center justify-between gap-3">
                    <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">{String(i + 1).padStart(2, '0')} · {r.year}</span>
                    <span class="rounded-[4px] border border-line px-2.5 py-1 font-display text-[11px] font-medium text-[var(--color-text-body)]">Coming soon</span>
                  </div>
                  <div>
                    <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-text-body)]">{r.industry}</p>
                    <h2 class="mt-3 font-display text-[20px] font-medium leading-[1.25] tracking-[-0.01em] text-[var(--color-text-head)]">{r.title}</h2>
                  </div>
                  <span class="mt-auto font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-text-body)]">{r.pages} pages · Q2</span>
                </div>
              )}
            </li>
          );
        })}
      </ul>
    </Container>
  </section>

  <!-- ═════════════ CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">Want a custom version for your industry or company?</h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Request a Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

---
import type { GetStaticPathsOptions } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Icon from '@/components/Icon.astro';
import Mountains from '@/components/Mountains.astro';
import CtaSection from '@/components/CtaSection.astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const slugify = (t: string) =>
    t.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  const all = (await getCollection('insights')).sort(
    (a, b) => +b.data.date - +a.data.date,
  );
  const tags = new Set<string>();
  for (const p of all) for (const t of p.data.tags ?? []) tags.add(t);

  return [...tags].flatMap((tag) => {
    const tagSlug = slugify(tag);
    const filtered = all.filter((p) => (p.data.tags ?? []).includes(tag));
    return paginate(filtered, {
      pageSize: 12,
      params: { tag: tagSlug },
      props: { tag, tagSlug, total: filtered.length },
    });
  });
}

const slugifyTag = (t: string) =>
  t.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

const { page, tag, tagSlug, total } = Astro.props;

const allPosts = (await getCollection('insights')).sort(
  (a, b) => +b.data.date - +a.data.date,
);
const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const t of post.data.tags ?? []) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([t, n]) => ({ tag: t, slug: slugifyTag(t), count: n }));

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  rawTitle={`${tag} — Insights | Alpine Mar`}
  description={`Articles tagged ${tag} from the Alpine Mar team — practical tax, accounting, and advisory insight.`}
>
  <!-- ═══════════════ Hero ═══════════════ -->
  <section class="grain-light relative overflow-hidden bg-paper pt-14 lg:pt-20">
    <div class="absolute inset-0" aria-hidden="true">
      <div class="grid-pattern-dark absolute inset-0 opacity-60"></div>
      <div class="float-slow absolute -right-24 -top-24 h-[480px] w-[480px] rounded-full bg-teal-500/12 blur-[150px]"></div>
    </div>
    <Mountains tone="light" class="absolute bottom-0 left-0 h-48 w-full opacity-80" />
    <div class="pointer-events-none absolute -bottom-4 right-2 select-none lg:right-10" aria-hidden="true">
      <span class="text-outline block leading-none text-hero-xl">{String(total).padStart(2, '0')}</span>
    </div>
    <Container width="xl" class="relative pb-20 lg:pb-28">
      <nav class="flex items-center gap-2 font-mono text-xs uppercase tracking-[0.14em] text-navy-400" aria-label="Breadcrumb" data-reveal data-speed="fast">
        <a href="/blog/" class="text-navy-500 transition-colors hover:text-navy-900">Insights</a>
        <span aria-hidden="true">/</span>
        <span class="text-navy-700">Topic</span>
        <span aria-hidden="true">/</span>
        <span class="text-navy-800">{tag}</span>
      </nav>
      <div class="mt-7 max-w-3xl" data-reveal data-speed="slow">
        <Eyebrow tone="dark">Topic · {total} {total === 1 ? 'article' : 'articles'}</Eyebrow>
        <h1 class="mt-7 tracking-[-0.03em] text-navy-900 text-hero-lg">{tag}</h1>
        <p class="mt-8 max-w-2xl text-xl leading-relaxed text-navy-700">
          Everything the Alpine Mar team has written tagged <span class="italic text-teal-700">{tag}</span>.
          {page.lastPage > 1 && (
            <span class="font-mono text-base text-navy-500"> · Page {page.currentPage} of {page.lastPage}</span>
          )}
        </p>
      </div>

      <!-- Other topics -->
      {topTags.length > 0 && (
        <div class="relative mt-12 border-t border-line pt-6" data-reveal>
          <div class="flex items-center gap-3 pb-3">
            <Icon name="filter" class="h-3.5 w-3.5 text-teal-700" />
            <p class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-navy-500">Browse other topics</p>
          </div>
          <div class="-mx-1 flex flex-wrap items-center gap-1.5">
            <a href="/blog/" class="border border-line bg-paper px-3.5 py-1.5 font-mono text-[0.7rem] uppercase tracking-[0.12em] text-navy-700 transition-colors hover:border-teal-500 hover:text-teal-700">All <span class="ml-1.5 text-navy-400">{allPosts.length}</span></a>
            {topTags.map((t) => (
              <a
                href={`/blog/topic/${t.slug}/`}
                class:list={[
                  'border px-3.5 py-1.5 font-mono text-[0.7rem] uppercase tracking-[0.12em] transition-colors',
                  t.slug === tagSlug
                    ? 'border-navy-900 bg-navy-900 text-paper'
                    : 'border-line bg-paper text-navy-700 hover:border-teal-500 hover:text-teal-700',
                ]}
              >
                {t.tag} <span class:list={['ml-1.5', t.slug === tagSlug ? 'opacity-60' : 'text-navy-400']}>{t.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </Container>
  </section>

  <!-- ═══════════════ Article grid ═══════════════ -->
  <section class="border-t border-line bg-paper py-12 lg:py-16">
    <Container width="xl">
      <div class="grid border-l border-t border-line sm:grid-cols-2 lg:grid-cols-3" data-stagger>
        {page.data.map((post) => (
          <a href={`/blog/${post.id}/`} class="group relative flex flex-col overflow-hidden border-b border-r border-line bg-paper transition-colors duration-300 hover:bg-white">
            <span class="absolute inset-x-0 top-0 z-20 h-1 origin-left scale-x-0 bg-teal-500 transition-transform duration-300 group-hover:scale-x-100" aria-hidden="true"></span>
            {post.data.cover && (
              <div class="relative aspect-[16/10] overflow-hidden">
                <img src={post.data.cover} alt={post.data.title} loading="lazy" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
              </div>
            )}
            <div class="flex flex-1 flex-col p-7 lg:p-8">
              <span class="font-mono text-[0.66rem] uppercase tracking-[0.14em] text-navy-400">{fmt(post.data.date)}</span>
              <h2 class="mt-3 text-xl leading-snug tracking-[-0.01em] text-navy-900 transition-colors group-hover:text-teal-700">{post.data.title}</h2>
              <p class="mt-4 flex-1 text-[0.95rem] leading-relaxed text-navy-600">{post.data.excerpt}</p>
              <span class="mt-6 inline-flex items-center gap-2 font-mono text-[0.7rem] uppercase tracking-[0.1em] text-teal-700">Read more <Icon name="arrow-right" class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" /></span>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- ═══════════════ Pagination ═══════════════ -->
  <section class="border-t border-line bg-paper pb-24">
    <Container width="xl">
      <nav aria-label="Pagination" class="flex flex-col items-center gap-6 pt-12 sm:flex-row sm:justify-between">
        <span class="font-mono text-xs uppercase tracking-[0.14em] text-navy-500">
          Page {page.currentPage} <span class="text-navy-300">of</span> {page.lastPage} · {total} total
        </span>
        <div class="flex items-center gap-2">
          <a href={page.url.prev ?? '#'} aria-disabled={!page.url.prev} class:list={[
            'group inline-flex items-center gap-2.5 border px-5 py-3 font-mono text-[0.72rem] uppercase tracking-[0.1em] transition-colors',
            page.url.prev ? 'border-line text-navy-900 hover:border-navy-900' : 'pointer-events-none border-line text-navy-300',
          ]}>
            <Icon name="arrow-right" class="h-3.5 w-3.5 -scale-x-100" /> Newer
          </a>
          <a href={page.url.next ?? '#'} aria-disabled={!page.url.next} class:list={[
            'group inline-flex items-center gap-2.5 border px-5 py-3 font-mono text-[0.72rem] uppercase tracking-[0.1em] transition-colors',
            page.url.next ? 'border-line text-navy-900 hover:border-navy-900' : 'pointer-events-none border-line text-navy-300',
          ]}>
            Older <Icon name="arrow-right" class="h-3.5 w-3.5" />
          </a>
        </div>
      </nav>
    </Container>
  </section>

  <CtaSection variant="post" />
</BaseLayout>

---
import type { GetStaticPathsOptions } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';

const slugifyTag = (t: string) =>
  t.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const slugifyTag = (t: string) =>
    t.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  const all = (await getCollection('insights'))
    .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));

  const tags = new Map<string, { tag: string; posts: typeof all }>();
  for (const post of all) {
    for (const t of post.data.tags ?? []) {
      const slug = slugifyTag(t);
      if (!tags.has(slug)) tags.set(slug, { tag: t, posts: [] });
      tags.get(slug)!.posts.push(post);
    }
  }

  return [...tags.entries()].flatMap(([slug, { tag, posts }]) =>
    paginate(posts, { pageSize: 12, params: { tag: slug }, props: { tagName: tag } }),
  );
}

const { page, tagName } = Astro.props;
const slugOf = (id: string) => id.replace(/\.md$/, '').split('/').pop();
const dateFmt = (d: string | Date) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout
  rawTitle={`${tagName} — Insights | Alpine Mar`}
  description={`Insights on ${tagName} from Alpine Mar's tax, accounting, and advisory team.`}
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-16 text-white md:pt-16 md:pb-20">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mx-auto max-w-[64ch] text-center">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="inline-flex max-w-full flex-wrap items-center justify-center gap-2 rounded-full bg-white/85 px-4 py-2 font-display text-[13px] font-medium text-navy-950 shadow-[0_12px_30px_-18px_rgba(18,18,45,0.6)] backdrop-blur-sm">
            <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
            <li aria-hidden="true" class="opacity-55">/</li>
            <li><a href="/blog/" class="transition-colors hover:text-scooter">Insights</a></li>
            <li aria-hidden="true" class="opacity-55">/</li>
            <li aria-current="page">{tagName}</li>
          </ol>
        </nav>
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[36px] md:text-[40px]">{tagName}</h1>
        <p class="mt-3 font-display text-[14px] leading-[1.55] text-white/70 md:text-[15px]">
          {page.total} {page.total === 1 ? 'insight' : 'insights'} on {tagName.toLowerCase()}.
        </p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ POSTS GRID ═════════════ -->
  <section class="relative bg-paper py-16 md:py-20">
    <Container width="wide">
      <ul class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {page.data.map((p) => (
          <li>
            <div class="group relative flex h-full flex-col overflow-hidden rounded-[6px] border border-line bg-white transition-colors hover:border-[#12122D]">
              {p.data.cover && (
                <div class="aspect-[16/10] overflow-hidden bg-white">
                  <img src={p.data.cover} alt={p.data.title} class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                </div>
              )}
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-center justify-between gap-3 font-display text-[12px] text-[var(--color-text-body)]">
                  <span class="inline-flex items-center gap-2 rounded-[4px] bg-paper px-3 py-1.5">
                    <span class="block size-1.5 bg-[#12122D]"></span>
                    {tagName}
                  </span>
                  <span>{dateFmt(p.data.date)}</span>
                </div>
                <h3 class="mt-5 font-display text-[18px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)]">
                  <a href={`/blog/${slugOf(p.id)}/`} class="after:absolute after:inset-0">{p.data.title}</a>
                </h3>
                {p.data.excerpt && (
                  <p class="mt-3 line-clamp-3 font-display text-[13px] leading-[1.55] text-[var(--color-text-body)]">{p.data.excerpt}</p>
                )}
                <div class="mt-auto flex items-center justify-between gap-4 pt-6">
                  <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Read more</span>
                  <span class="inline-flex size-9 items-center justify-center rounded-[4px] bg-delft text-white transition-transform group-hover:translate-x-1">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </div>
          </li>
        ))}
      </ul>

      {(page.url.prev || page.url.next) && (
        <nav aria-label="Pagination" class="mt-14 flex items-center justify-between gap-4 rounded-[6px] border border-line bg-white p-6">
          {page.url.prev ? (
            <a href={page.url.prev} class="inline-flex items-center gap-2 font-display text-[14px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
              Previous
            </a>
          ) : <span></span>}
          <span class="font-display text-[13px] text-[var(--color-text-body)]">Page {page.currentPage} of {page.lastPage}</span>
          {page.url.next ? (
            <a href={page.url.next} class="inline-flex items-center gap-2 font-display text-[14px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">
              Next
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          ) : <span></span>}
        </nav>
      )}

      <p class="mt-12 text-center font-display text-[14px] text-[var(--color-text-body)]">
        <a href="/blog/" class="font-medium text-[var(--color-text-head)] underline underline-offset-4 transition-colors hover:text-scooter">← Back to all insights</a>
      </p>
    </Container>
  </section>
</BaseLayout>

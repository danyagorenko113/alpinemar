---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { breadcrumb, articleSchema } from '@/data/schema';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '').split('/').pop() },
    props: { post, all: posts },
  }));
}

const { post, all } = Astro.props;
const { Content, headings } = await render(post);

const tags = post.data.tags ?? [];

// Related — same first tag, fallback to recent
const tagPool = tags[0];
const related = all
  .filter((p) => p.id !== post.id && (tagPool ? p.data.tags?.includes(tagPool) : true))
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))
  .slice(0, 4);

const slugOf = (id: string) => id.replace(/\.md$/, '').split('/').pop();
const slugifyTag = (t: string) =>
  t.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
const dateFmt = (d: string | Date) =>
  new Date(d).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

const readingMin = Math.max(2, Math.round((post.data.excerpt?.length ?? 400) / 200));

const toc = headings.filter((h) => h.depth === 2 && h.text && h.text.trim().length > 1).slice(0, 8);

const schema = [
  articleSchema({
    title: post.data.title,
    description: post.data.excerpt,
    date: new Date(post.data.date),
    cover: post.data.cover,
    path: `/blog/${slugOf(post.id)}/`,
    author: post.data.author,
  }),
  breadcrumb([
    { name: 'Home', path: '/' },
    { name: 'Insights', path: '/blog/' },
    { name: post.data.title, path: `/blog/${slugOf(post.id)}/` },
  ]),
];
---

<BaseLayout
  rawTitle={post.data.seo?.title ?? `${post.data.title} | Alpine Mar`}
  description={post.data.seo?.description ?? post.data.excerpt}
  image={post.data.cover}
  schema={schema}
>
  <!-- Reading progress bar — scaleX based on article scroll -->
  <div id="reading-progress" class="fixed inset-x-0 z-[55] h-[3px] origin-left scale-x-0 bg-scooter transition-transform duration-150 ease-out" style="top: 88px" aria-hidden="true"></div>

  <article>
    <!-- ═════════════ HERO ═════════════ -->
    <section class="relative bg-paper">
      <Container width="wide" class="pt-12 pb-10 md:pt-16 md:pb-14">
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex flex-wrap items-center gap-2 font-display text-[13px] text-[var(--color-text-body)]">
            <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
            <li aria-hidden="true" class="opacity-55">/</li>
            <li><a href="/blog/" class="transition-colors hover:text-scooter">Insights</a></li>
            <li aria-hidden="true" class="opacity-55">/</li>
            <li aria-current="page" class="font-medium text-[var(--color-text-head)] line-clamp-1">{post.data.title}</li>
          </ol>
        </nav>

        <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
          <div class="md:col-span-9">
            <div class="flex flex-wrap items-center gap-3 font-display text-[12px] text-[var(--color-text-body)]">
              {tags.slice(0, 2).map((t) => (
                <a href={`/blog/topic/${slugifyTag(t)}/`} class="inline-flex items-center gap-2 rounded-[4px] bg-white px-3 py-1.5 transition-colors hover:text-scooter">
                  <span class="block size-1.5 bg-[#12122D]"></span>
                  {t}
                </a>
              ))}
              <span class="font-mono uppercase tracking-[0.12em] text-[var(--color-text-body)]">{dateFmt(post.data.date)}</span>
              <span class="opacity-55">·</span>
              <span class="font-mono uppercase tracking-[0.12em]">{readingMin} min read</span>
              {post.data.author && <>
                <span class="opacity-55">·</span>
                <span class="font-mono uppercase tracking-[0.12em]">{post.data.author}</span>
              </>}
            </div>

            <h1 class="mt-7 font-display text-[36px] font-medium leading-[1.1] tracking-[-0.02em] text-[var(--color-text-head)] sm:text-[44px] md:text-[52px]">{post.data.title}</h1>

            {post.data.excerpt && (
              <p class="mt-6 max-w-[60ch] font-display text-[18px] leading-[1.55] text-[var(--color-text-body)]">{post.data.excerpt}</p>
            )}

            {tags.length > 2 && (
              <div class="mt-7 flex flex-wrap gap-1.5">
                {tags.slice(2, 8).map((t) => (
                  <a href={`/blog/topic/${slugifyTag(t)}/`} class="rounded-[4px] border border-line bg-white px-2.5 py-1 font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)] transition-colors hover:border-[#12122D] hover:text-scooter">{t}</a>
                ))}
              </div>
            )}
          </div>
        </div>
      </Container>

      {post.data.cover && (
        <Container width="wide" class="pb-12 md:pb-16">
          <div class="overflow-hidden rounded-[6px] bg-navy-50">
            <img src={post.data.cover} alt={post.data.title} class="aspect-[16/8] w-full object-cover" />
          </div>
        </Container>
      )}
    </section>

    <!-- ═════════════ BODY + SIDEBAR ═════════════ -->
    <section class="relative bg-paper pb-20 md:pb-24">
      <Container width="wide">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-8">
            <div class="prose-am">
              <Content />
            </div>

            <!-- Article footer: byline -->
            <footer class="mt-16 border-t border-line pt-7">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Written by</p>
              <p class="mt-3 font-display text-[18px] font-medium text-[var(--color-text-head)]">{post.data.author ?? 'The Alpine Mar team'}</p>
              <p class="mt-2 max-w-[60ch] font-display text-[14px] leading-[1.65] text-[var(--color-text-body)]">
                The Alpine Mar editorial team publishes practical, vetted guidance on tax, accounting, and advisory for owner-operators and growing firms.
              </p>
            </footer>
          </div>

          <aside class="lg:col-span-4">
            <div class="sticky top-28 flex flex-col gap-8">
              {toc.length > 0 && (
                <nav aria-label="In this article" class="rounded-[6px] border border-line bg-white p-6">
                  <p class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-head)]">In this article</p>
                  <ul class="mt-5 space-y-2.5">
                    {toc.map((h, i) => (
                      <li class="flex items-baseline gap-3">
                        <span class="font-mono text-[11px] text-scooter">{String(i + 1).padStart(2, '0')}</span>
                        <a href={`#${h.slug}`} class="font-display text-[14px] leading-snug text-[var(--color-text-body)] transition-colors hover:text-scooter">{h.text}</a>
                      </li>
                    ))}
                  </ul>
                </nav>
              )}

              <div class="rounded-[6px] bg-[#12122D] p-7 text-white">
                <p class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-head)]">Apply this</p>
                <p class="mt-5 font-display text-[15px] leading-[1.55] text-white/85">
                  See what this article looks like applied to your books on a complimentary intro call.
                </p>
                <a href="/contact/" class="mt-6 inline-flex items-center gap-2 border-b border-scooter pb-1 font-display text-[13px] font-medium text-scooter transition-colors hover:text-white">
                  Book an intro call
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              </div>

              {related.length > 0 && (
                <div class="rounded-[6px] border border-line bg-white p-6">
                  <p class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-head)]">Read next</p>
                  <ul class="mt-4">
                    {related.map((p) => (
                      <li>
                        <a href={`/blog/${slugOf(p.id)}/`} class="group flex flex-col gap-1.5 border-b border-line py-3.5 last:border-b-0">
                          <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">{dateFmt(p.data.date)}</span>
                          <span class="font-display text-[14px] leading-snug text-[var(--color-text-head)] transition-colors group-hover:text-scooter">{p.data.title}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                  <a href="/blog/" class="mt-5 inline-flex items-center gap-2 font-display text-[13px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">
                    All insights
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                  </a>
                </div>
              )}
            </div>
          </aside>
        </div>
      </Container>
    </section>
  </article>

  <!-- ═════════════ CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">Question on this topic? Ask a partner.</h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Request a Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <script>
    // Reading progress — tracks scroll across the article element
    const bar = document.getElementById('reading-progress');
    const article = document.querySelector('article');
    if (bar && article) {
      const update = () => {
        const rect = article.getBoundingClientRect();
        const total = rect.height - window.innerHeight;
        const scrolled = Math.min(Math.max(-rect.top, 0), total);
        const pct = total > 0 ? scrolled / total : 0;
        (bar as HTMLElement).style.transform = `scaleX(${pct})`;
      };
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
      update();
    }
  </script>
</BaseLayout>

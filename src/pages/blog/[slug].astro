---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { breadcrumb, articleSchema } from '@/data/schema';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '').split('/').pop() },
    props: { post, all: posts },
  }));
}

const { post, all } = Astro.props;
const { Content, headings } = await render(post);

const tags = post.data.tags ?? [];
const category = post.data.category;

// Related ("Read next") — same category first, then first tag, then recent.
const byDate = (a: typeof all[number], b: typeof all[number]) =>
  +new Date(b.data.date) - +new Date(a.data.date);
const pool = all.filter((p) => p.id !== post.id && p.data.status !== 'draft');
const sameCategory = category ? pool.filter((p) => p.data.category === category) : [];
const sameTag = tags[0] ? pool.filter((p) => p.data.tags?.includes(tags[0])) : [];
const related = [...new Set([...sameCategory.sort(byDate), ...sameTag.sort(byDate), ...pool.sort(byDate)])].slice(0, 4);

const slugOf = (id: string) => id.replace(/\.md$/, '').split('/').pop();
const slugifyTag = (t: string) =>
  t.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
const dateFmt = (d: string | Date) =>
  new Date(d).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

const readingMin = Math.max(2, Math.round((post.data.excerpt?.length ?? 400) / 200));
const authorName = post.data.author ?? 'The Alpine Mar team';

// Author profile — authors collection first (CMS-managed bios), team fallback.
const authorEntries = await getCollection('authors');
const authorEntry = authorEntries.find(
  (a) => a.data.status !== 'draft' && (authorName.includes(a.data.name) || a.data.name.includes(authorName)),
);
const AuthorBio = authorEntry ? (await render(authorEntry)).Content : null;
const teamMembers = (await getCollection('team')).map((m) => m.data);
const authorProfile = teamMembers.find((m) => authorName.includes(m.name.replace(/,\s*CPA$/, '')));
const authorPhoto = authorEntry?.data.photo ?? authorProfile?.photo ?? '/images/brand/logo-web.png';
const authorTitle = authorEntry?.data.title;

const toc = headings.filter((h) => h.depth === 2 && h.text && h.text.trim().length > 1).slice(0, 8);

const schema = [
  articleSchema({
    title: post.data.title,
    description: post.data.excerpt,
    date: new Date(post.data.date),
    cover: post.data.cover,
    path: `/blog/${slugOf(post.id)}/`,
    author: post.data.author,
  }),
  breadcrumb([
    { name: 'Home', path: '/' },
    { name: 'Insights', path: '/blog/' },
    { name: post.data.title, path: `/blog/${slugOf(post.id)}/` },
  ]),
];
---

<BaseLayout
  rawTitle={post.data.seo?.title ?? `${post.data.title} | Alpine Mar`}
  description={post.data.seo?.description ?? post.data.excerpt}
  image={post.data.cover}
  canonical={post.data.seo?.canonical}
  ogType="article"
  schema={schema}
>
  <!-- Reading progress bar — scaleX based on article scroll -->
  <div id="reading-progress" class="fixed inset-x-0 z-[55] h-[3px] origin-left scale-x-0 bg-scooter transition-transform duration-150 ease-out" style="top: 88px" aria-hidden="true"></div>

  <article>
    <!-- ═════════════ BANNER + HEADER ═════════════
         Banner image first, H1 directly under it (CMS audit item). -->
    {post.data.cover && (
      <section class="relative bg-paper">
        <div class="relative h-[260px] w-full md:h-[380px] lg:h-[420px]">
          <img
            src={post.data.cover}
            alt={post.data.coverAlt ?? post.data.title}
            class="absolute inset-0 h-full w-full object-cover object-center"
          />
          <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-b from-transparent via-white/40 to-paper"></div>
        </div>
      </section>
    )}

    <section class="relative bg-paper">
      <Container width="wide" class={`${post.data.cover ? 'pt-8' : 'pt-12 md:pt-16'} pb-10 md:pb-14`}>
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="inline-flex max-w-full items-center gap-2 overflow-hidden whitespace-nowrap rounded-full bg-white/85 px-4 py-2 font-display text-[13px] font-medium text-navy-950 shadow-[0_12px_30px_-18px_rgba(18,18,45,0.6)] backdrop-blur-sm">
            <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
            <li aria-hidden="true" class="opacity-55">/</li>
            <li><a href="/blog/" class="transition-colors hover:text-scooter">Insights</a></li>
            <li aria-hidden="true" class="hidden opacity-55 sm:inline">/</li>
            <li aria-current="page" class="hidden max-w-[36ch] truncate sm:inline">{post.data.title}</li>
          </ol>
        </nav>

        <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
          <div class="md:col-span-9">
            {/* Category chip sits above the H1; the H1 is the first thing under the banner. */}
            {category && (
              <a href={`/blog/category/${slugifyTag(category)}/`} class="inline-flex items-center gap-2 rounded-[4px] bg-white px-3 py-1.5 font-display text-[12px] text-[var(--color-text-body)] transition-colors hover:text-scooter">
                <span class="block size-1.5 bg-[#12122D]"></span>
                {category}
              </a>
            )}

            <h1 class={`${category ? 'mt-5' : ''} font-display text-[36px] font-medium leading-[1.1] tracking-[-0.02em] text-[var(--color-text-head)] sm:text-[44px] md:text-[52px]`}>{post.data.title}</h1>

            {/* Publish / updated / reading time / author — below the title. */}
            <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-2 font-display text-[12px] text-[var(--color-text-body)]">
              <span class="font-mono uppercase tracking-[0.12em]">Publish Date: {dateFmt(post.data.date)}</span>
              {post.data.updated && (<>
                <span class="opacity-55">·</span>
                <span class="font-mono uppercase tracking-[0.12em]">Updated On: {dateFmt(post.data.updated)}</span>
              </>)}
              <span class="opacity-55">·</span>
              <span class="font-mono uppercase tracking-[0.12em]">{readingMin} min read</span>
              {post.data.author && <>
                <span class="opacity-55">·</span>
                <span class="font-mono uppercase tracking-[0.12em]">{post.data.author}</span>
              </>}
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- ═════════════ BODY + SIDEBAR ═════════════ -->
    <section class="relative bg-paper pb-20 md:pb-24">
      <Container width="wide">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-8">
            <div class="prose-am">
              <Content />
            </div>

            {tags.length > 0 && (
              <div class="mt-12 border-t border-line pt-6">
                <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Tags</p>
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {tags.map((t) => (
                    <a href={`/blog/topic/${slugifyTag(t)}/`} class="rounded-[4px] border border-line bg-white px-2.5 py-1 font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)] transition-colors hover:border-[#12122D] hover:text-scooter">{t}</a>
                  ))}
                </div>
              </div>
            )}

            <!-- Article footer: byline -->
            <footer class="mt-10 border-t border-line pt-7">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Written by</p>
              <div class="mt-4 flex items-start gap-4">
                <div class="flex size-16 shrink-0 items-center justify-center overflow-hidden rounded-full border border-line bg-white">
                  <img src={authorPhoto} alt={authorName} class:list={['h-full w-full', authorProfile?.photo ? 'object-cover' : 'object-contain p-3']} loading="lazy" />
                </div>
                <div>
                  <p class="font-display text-[18px] font-medium text-[var(--color-text-head)]">{authorName}</p>
                  {authorTitle && (
                    <p class="mt-1 font-display text-[13px] text-[var(--color-text-body)]">{authorTitle}</p>
                  )}
                  {AuthorBio ? (
                    <div class="mt-2 max-w-[60ch] font-display text-[14px] leading-[1.65] text-[var(--color-text-body)] [&_p]:mt-2 first:[&_p]:mt-0">
                      <AuthorBio />
                    </div>
                  ) : (
                    <p class="mt-2 max-w-[60ch] font-display text-[14px] leading-[1.65] text-[var(--color-text-body)]">
                      The Alpine Mar editorial team publishes practical, vetted guidance on tax, accounting, and advisory for owner-operators and growing firms.
                    </p>
                  )}
                </div>
              </div>
            </footer>
          </div>

          <aside class="lg:col-span-4">
            <div class="sticky top-28 flex flex-col gap-8">
              {toc.length > 0 && (
                <nav aria-label="In this article" class="rounded-[6px] border border-line bg-white p-6">
                  <p class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-head)]">In this article</p>
                  <ul class="mt-5 space-y-2.5">
                    {toc.map((h, i) => (
                      <li class="flex items-baseline gap-3">
                        <span class="font-mono text-[11px] text-scooter">{String(i + 1).padStart(2, '0')}</span>
                        <a href={`#${h.slug}`} class="font-display text-[14px] leading-snug text-[var(--color-text-body)] transition-colors hover:text-scooter">{h.text}</a>
                      </li>
                    ))}
                  </ul>
                </nav>
              )}

              <div class="rounded-[6px] bg-[#12122D] p-7 text-white">
                <p class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-head)]">Apply this</p>
                <p class="mt-5 font-display text-[15px] leading-[1.55] text-white/85">
                  See what this article looks like applied to your books on a complimentary intro call.
                </p>
                <a href="/contact/" class="mt-6 inline-flex items-center gap-2 border-b border-scooter pb-1 font-display text-[13px] font-medium text-scooter transition-colors hover:text-white">
                  Book an intro call
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              </div>

              {related.length > 0 && (
                <div class="rounded-[6px] border border-line bg-white p-6">
                  <p class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-head)]">Read next</p>
                  <ul class="mt-4">
                    {related.map((p) => (
                      <li>
                        <a href={`/blog/${slugOf(p.id)}/`} class="group flex flex-col gap-1.5 border-b border-line py-3.5 last:border-b-0">
                          <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">{dateFmt(p.data.date)}</span>
                          <span class="font-display text-[14px] leading-snug text-[var(--color-text-head)] transition-colors group-hover:text-scooter">{p.data.title}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                  <a href="/blog/" class="mt-5 inline-flex items-center gap-2 font-display text-[13px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">
                    All insights
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                  </a>
                </div>
              )}
            </div>
          </aside>
        </div>
      </Container>
    </section>
  </article>

  <script>
    function initReadingProgress() {
      const previous = (window as any).__amReadingProgressController as AbortController | undefined;
      previous?.abort();

      const bar = document.getElementById('reading-progress');
      const article = document.querySelector('article');
      if (!bar || !article) return;

      const controller = new AbortController();
      (window as any).__amReadingProgressController = controller;
      const update = () => {
        const rect = article.getBoundingClientRect();
        const total = rect.height - window.innerHeight;
        const scrolled = Math.min(Math.max(-rect.top, 0), total);
        const pct = total > 0 ? scrolled / total : 0;
        (bar as HTMLElement).style.transform = `scaleX(${pct})`;
      };
      window.addEventListener('scroll', update, { passive: true, signal: controller.signal });
      window.addEventListener('resize', update, { signal: controller.signal });
      update();
    }

    document.addEventListener('astro:page-load', initReadingProgress);
  </script>
</BaseLayout>

---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { breadcrumb } from '@/data/schema';

export async function getStaticPaths() {
  const posts = (await getCollection('insights')).filter((p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '').split('/').pop() },
    props: { post, all: posts },
  }));
}

const { post, all } = Astro.props;
const { Content } = await render(post);

const tags = post.data.tags ?? [];
const related = all
  .filter((p) => p.id !== post.id && (p.data.tags ?? []).some((t) => tags.includes(t)))
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))
  .slice(0, 3);

const slugOf = (id: string) => id.replace(/\.md$/, '').split('/').pop();
const slugifyTag = (t: string) =>
  t.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
const dateFmt = (d: string | Date) =>
  new Date(d).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

const wordCount = (post.body ?? '').split(/\s+/).filter(Boolean).length;
const readingMin = Math.max(2, Math.round(wordCount / 220));

const schema = breadcrumb([
  { name: 'Home', path: '/' },
  { name: 'Insights', path: '/blog/' },
  { name: post.data.title, path: `/blog/${slugOf(post.id)}/` },
]);
---

<BaseLayout
  rawTitle={post.data.seo?.title ?? `${post.data.title} | Alpine Mar`}
  description={post.data.seo?.description ?? post.data.description}
  image={post.data.heroImage}
  schema={schema}
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative bg-paper">
    <Container width="reading" class="pt-16 pb-12 md:pt-24 md:pb-16">
      <nav aria-label="Breadcrumb" class="mb-7">
        <ol class="flex flex-wrap items-center gap-2 font-display text-[13px] text-[var(--color-text-body)]">
          <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li><a href="/blog/" class="transition-colors hover:text-scooter">Insights</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li aria-current="page" class="font-medium text-[var(--color-text-head)]">{post.data.title}</li>
        </ol>
      </nav>

      <div class="flex flex-wrap items-center gap-3 font-display text-[12px] text-[var(--color-text-body)]">
        {(post.data.tags ?? []).slice(0, 2).map((t) => (
          <a href={`/blog/topic/${slugifyTag(t)}/`} class="inline-flex items-center gap-2 rounded-[4px] bg-white px-3 py-1.5 transition-colors hover:text-scooter">
            <span class="block size-1.5 bg-[#12122D]"></span>
            {t}
          </a>
        ))}
        <span>{dateFmt(post.data.date)}</span>
        <span>·</span>
        <span>{readingMin} min read</span>
      </div>

      <h1 class="mt-7 font-display text-[36px] font-medium leading-[1.1] tracking-[-0.02em] text-[var(--color-text-head)] sm:text-[44px] md:text-[52px]">{post.data.title}</h1>

      {post.data.description && (
        <p class="mt-6 font-display text-[18px] leading-[1.55] text-[var(--color-text-body)]">{post.data.description}</p>
      )}

      {post.data.heroImage && (
        <div class="mt-10 overflow-hidden rounded-[6px] bg-navy-50">
          <img src={post.data.heroImage} alt={post.data.title} class="h-auto w-full" />
        </div>
      )}
    </Container>
  </section>

  <!-- ═════════════ BODY ═════════════ -->
  <section class="relative bg-paper pb-20 md:pb-24">
    <Container width="reading">
      <div class="prose-am">
        <Content />
      </div>
    </Container>
  </section>

  <!-- ═════════════ RELATED ═════════════ -->
  {related.length > 0 && (
    <section class="relative bg-white py-20 md:py-24">
      <Container width="wide">
        <div class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
          <span class="block size-2 bg-scooter"></span>
          <span class="font-display text-[14px] tracking-[-0.005em]">Related insights</span>
        </div>
        <h2 class="am-h1-display text-[var(--color-text-head)]">Keep reading.</h2>

        <ul class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
          {related.map((p) => (
            <li>
              <a href={`/blog/${slugOf(p.id)}/`} class="group flex h-full flex-col overflow-hidden rounded-[6px] border border-line bg-white transition-colors hover:border-[#12122D]">
                {p.data.heroImage && (
                  <div class="aspect-[16/10] overflow-hidden bg-navy-50">
                    <img src={p.data.heroImage} alt={p.data.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                  </div>
                )}
                <div class="flex flex-1 flex-col p-6">
                  <span class="font-display text-[12px] text-[var(--color-text-body)]">{dateFmt(p.data.date)}</span>
                  <h3 class="mt-3 font-display text-[18px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)] transition-colors group-hover:text-scooter">{p.data.title}</h3>
                  <span class="mt-auto inline-flex items-center gap-2 pt-6 font-display text-[14px] font-medium text-[var(--color-text-head)] transition-colors group-hover:text-scooter">
                    Read more
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
                  </span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </Container>
    </section>
  )}

  <!-- ═════════════ CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">Question on this topic? Ask a partner.</h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Request a Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

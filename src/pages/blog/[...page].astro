---
import type { GetStaticPathsOptions } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';

const slugifyTag = (t: string) =>
  t.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const all = (await getCollection('insights'))
    .filter((p) => !p.data.draft)
    .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));
  return paginate(all, { pageSize: 12 });
}

const { page } = Astro.props;

const allPosts = (await getCollection('insights'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));

const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const t of post.data.tags ?? []) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10)
  .map(([t, n]) => ({ tag: t, count: n, slug: slugifyTag(t) }));

const isFirstPage = page.currentPage === 1;
const featured = isFirstPage ? page.data[0] : null;
const rest = isFirstPage ? page.data.slice(1) : page.data;

const slugOf = (id: string) => id.replace(/\.md$/, '').split('/').pop();
const dateFmt = (d: string | Date) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout
  rawTitle={isFirstPage ? 'Insights — Alpine Mar' : `Insights · Page ${page.currentPage} — Alpine Mar`}
  description="Practical perspectives on tax, finance, and business, written by the people who work in it every day."
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-16 text-white md:pt-16 md:pb-20">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mx-auto max-w-[64ch] text-center">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[36px] md:text-[40px]">Insights</h1>
        <p class="mt-3 font-display text-[14px] leading-[1.55] text-white/70 md:text-[15px]">
          Practical perspectives on tax, finance, and business — written by the people who work in it every day.
        </p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ TAG FILTER STRIP ═════════════ -->
  <section class="relative bg-paper py-10 md:py-14">
    <Container width="wide">
      <div class="flex flex-wrap items-center gap-2">
        <a href="/blog/" class={`rounded-[6px] px-4 py-2 font-display text-[13px] font-medium transition-colors ${isFirstPage ? 'bg-[#1F3062] text-white' : 'border border-line bg-white text-[var(--color-text-head)] hover:border-[#12122D]'}`}>
          All <span class="opacity-70">· {allPosts.length}</span>
        </a>
        {topTags.map((t) => (
          <a href={`/blog/topic/${t.slug}/`} class="rounded-[6px] border border-line bg-white px-4 py-2 font-display text-[13px] font-medium text-[var(--color-text-head)] transition-colors hover:border-[#12122D]">
            {t.tag} <span class="opacity-70">· {t.count}</span>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- ═════════════ FEATURED (first page only) ═════════════ -->
  {featured && (
    <section class="relative bg-paper pb-10 md:pb-14">
      <Container width="wide">
        <a href={`/blog/${slugOf(featured.id)}/`} class="group grid grid-cols-1 overflow-hidden rounded-[6px] border border-line bg-white md:grid-cols-2">
          <div class="relative aspect-[5/4] overflow-hidden bg-navy-50 md:aspect-auto md:min-h-[420px]">
            <img src={featured.data.heroImage || '/images/about/collage-1.jpg'} alt={featured.data.title} class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          </div>
          <div class="flex flex-col gap-6 p-8 md:p-12">
            <div class="flex items-center justify-between gap-3 font-display text-[12px] text-[var(--color-text-body)]">
              <span class="inline-flex items-center gap-2 rounded-[4px] bg-paper px-3 py-1.5">
                <span class="block size-1.5 bg-[#12122D]"></span>
                Featured
              </span>
              <span>{dateFmt(featured.data.date)}</span>
            </div>
            <h2 class="font-display text-[26px] font-medium leading-[1.2] tracking-[-0.01em] text-[var(--color-text-head)] md:text-[32px]">{featured.data.title}</h2>
            <p class="font-display text-[14px] leading-[1.65] text-[var(--color-text-body)]">{featured.data.description}</p>
            <div class="mt-auto flex items-center justify-between gap-4">
              <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Read more</span>
              <span class="inline-flex size-10 items-center justify-center rounded-[4px] bg-[#1F3062] text-white transition-transform group-hover:translate-x-1">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </a>
      </Container>
    </section>
  )}

  <!-- ═════════════ POSTS GRID ═════════════ -->
  <section class="relative bg-paper pb-20 md:pb-24">
    <Container width="wide">
      <ul class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {rest.map((p) => (
          <li>
            <a href={`/blog/${slugOf(p.id)}/`} class="group flex h-full flex-col overflow-hidden rounded-[6px] border border-line bg-white transition-colors hover:border-[#12122D]">
              {p.data.heroImage && (
                <div class="aspect-[16/10] overflow-hidden bg-navy-50">
                  <img src={p.data.heroImage} alt={p.data.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                </div>
              )}
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-center justify-between gap-3 font-display text-[12px] text-[var(--color-text-body)]">
                  <span class="inline-flex items-center gap-2 rounded-[4px] bg-paper px-3 py-1.5">
                    <span class="block size-1.5 bg-[#12122D]"></span>
                    {p.data.tags?.[0] ?? 'Insight'}
                  </span>
                  <span>{dateFmt(p.data.date)}</span>
                </div>
                <h3 class="mt-5 font-display text-[18px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)]">{p.data.title}</h3>
                {p.data.description && (
                  <p class="mt-3 line-clamp-3 font-display text-[13px] leading-[1.55] text-[var(--color-text-body)]">{p.data.description}</p>
                )}
                <div class="mt-auto flex items-center justify-between gap-4 pt-6">
                  <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Read more</span>
                  <span class="inline-flex size-9 items-center justify-center rounded-[4px] bg-[#1F3062] text-white transition-transform group-hover:translate-x-1">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <!-- Pagination -->
      {(page.url.prev || page.url.next) && (
        <nav aria-label="Pagination" class="mt-14 flex items-center justify-between gap-4 rounded-[6px] border border-line bg-white p-6">
          {page.url.prev ? (
            <a href={page.url.prev} class="inline-flex items-center gap-2 font-display text-[14px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
              Previous
            </a>
          ) : <span></span>}
          <span class="font-display text-[13px] text-[var(--color-text-body)]">Page {page.currentPage} of {page.lastPage}</span>
          {page.url.next ? (
            <a href={page.url.next} class="inline-flex items-center gap-2 font-display text-[14px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">
              Next
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          ) : <span></span>}
        </nav>
      )}
    </Container>
  </section>
</BaseLayout>

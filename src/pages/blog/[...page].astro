---
import type { GetStaticPathsOptions } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { collectionPageSchema, breadcrumb } from '@/data/schema';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const all = (await getCollection('insights'))
    .filter((p) => p.data.status !== 'draft')
    .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));
  return paginate(all, { pageSize: 12 });
}

const { page } = Astro.props;

const slugifyTag = (t: string) =>
  t.toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

const allPosts = (await getCollection('insights'))
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));

const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const t of post.data.tags ?? []) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([t, n]) => ({ tag: t, count: n, slug: slugifyTag(t) }));

const isFirstPage = page.currentPage === 1;
const featured = isFirstPage ? page.data[0] : null;
const rest = isFirstPage ? page.data.slice(1) : page.data;

const slugOf = (id: string) => id.replace(/\.md$/, '').split('/').pop();
const dateFmt = (d: string | Date) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

// Lightweight search index for the inline search bar (across the full archive)
const searchIndex = allPosts.map((p) => ({
  t: p.data.title,
  e: p.data.excerpt,
  d: new Date(p.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
  c: p.data.cover ?? '',
  h: `/blog/${slugOf(p.id)}/`,
  g: p.data.tags ?? [],
}));

const schema = [
  collectionPageSchema({
    name: 'Insights',
    description: 'Practical perspectives on tax, finance, and business from Alpine Mar CPAs.',
    path: '/blog/',
    itemCount: allPosts.length,
  }),
  breadcrumb([
    { name: 'Home', path: '/' },
    { name: 'Insights', path: '/blog/' },
  ]),
];
---

<BaseLayout
  rawTitle={isFirstPage ? 'Insights — Alpine Mar' : `Insights · Page ${page.currentPage} — Alpine Mar`}
  description="Practical perspectives on tax, finance, and business — written by the people who work in it every day."
  schema={schema}
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-16 text-white md:pt-16 md:pb-20">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mx-auto max-w-[64ch] text-center">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[36px] md:text-[40px]">
          {isFirstPage ? 'Insights' : `Insights · Page ${page.currentPage}`}
        </h1>
        <p class="mt-3 font-display text-[14px] leading-[1.55] text-white/70 md:text-[15px]">
          Practical perspectives on tax, finance, and business — written by the people who work in it every day. <span class="text-scooter">{allPosts.length} articles</span> in the archive.
        </p>
      </div>

      <!-- Inline search -->
      <div class="relative mx-auto mt-10 max-w-[640px]">
        <label class="relative block">
          <span class="sr-only">Search articles</span>
          <span class="pointer-events-none absolute left-5 top-1/2 -translate-y-1/2 text-white/55">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </span>
          <input
            id="blog-search"
            type="search"
            autocomplete="off"
            placeholder={`Search ${allPosts.length} articles — e.g. S-Corp, 1031, R&D credit`}
            class="block w-full rounded-[6px] border border-white/15 bg-white/[0.06] py-3.5 pl-14 pr-12 font-display text-[14px] text-white placeholder:text-white/40 focus:border-scooter focus:outline-none focus:ring-0"
          />
          <button id="blog-search-clear" type="button" aria-label="Clear search" class="absolute right-3 top-1/2 hidden size-7 -translate-y-1/2 items-center justify-center text-white/55 transition-colors hover:text-white">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
          </button>
        </label>
        <p id="blog-search-meta" class="mt-3 hidden text-center font-mono text-[11px] uppercase tracking-[0.14em] text-white/55"></p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ TAG FILTER ═════════════ -->
  <section class="relative bg-paper py-10 md:py-12">
    <Container width="wide">
      <div class="flex flex-wrap items-center gap-2">
        <a href="/blog/" class={`rounded-[6px] px-4 py-2 font-display text-[13px] font-medium transition-colors ${isFirstPage ? 'bg-delft text-white' : 'border border-line bg-white text-[var(--color-text-head)] hover:border-[#12122D]'}`}>
          All <span class="opacity-70">· {allPosts.length}</span>
        </a>
        {topTags.map((t) => (
          <a href={`/blog/topic/${t.slug}/`} class="rounded-[6px] border border-line bg-white px-4 py-2 font-display text-[13px] font-medium text-[var(--color-text-head)] transition-colors hover:border-[#12122D]">
            {t.tag} <span class="opacity-70">· {t.count}</span>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- ═════════════ SEARCH RESULTS (only when query present) ═════════════ -->
  <section id="blog-search-section" class="relative hidden bg-paper py-10 md:py-12">
    <Container width="wide">
      <div class="mb-8 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Search results</span>
      </div>
      <ul id="blog-search-results" class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3"></ul>
      <div id="blog-search-empty" class="hidden">
        <div class="flex flex-col items-center gap-5 rounded-[6px] border border-line bg-white py-16 text-center">
          <span class="inline-flex size-12 items-center justify-center rounded-full border border-line text-[var(--color-text-body)]">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </span>
          <div>
            <p class="font-display text-[18px] font-medium text-[var(--color-text-head)]">Nothing matched <span id="blog-search-empty-q" class="text-scooter"></span></p>
            <p class="mt-2 font-display text-[14px] text-[var(--color-text-body)]">Try a topic above — or call us and just ask.</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ FEATURED (page 1 only) ═════════════ -->
  {featured && (
    <section id="blog-featured-section" class="relative bg-paper pb-10 md:pb-14">
      <Container width="wide">
        <div class="mb-6 flex items-center gap-3 text-[var(--color-text-head)]">
          <span class="block size-2 bg-scooter"></span>
          <span class="font-display text-[14px] tracking-[-0.005em]">Featured · Latest</span>
        </div>
        <a href={`/blog/${slugOf(featured.id)}/`} class="group grid grid-cols-1 overflow-hidden rounded-[6px] border border-line bg-white md:grid-cols-2">
          <div class="relative aspect-[5/4] overflow-hidden bg-white md:aspect-auto md:min-h-[420px]">
            <img src={featured.data.cover || '/images/about/collage-1.jpg'} alt={featured.data.title} class="absolute inset-0 h-full w-full object-contain transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          </div>
          <div class="flex flex-col gap-6 p-8 md:p-12">
            <div class="flex items-center justify-between gap-3 font-display text-[12px] text-[var(--color-text-body)]">
              <span class="inline-flex items-center gap-2 rounded-[4px] bg-paper px-3 py-1.5">
                <span class="block size-1.5 bg-[#12122D]"></span>
                {featured.data.tags?.[0] ?? 'Insight'}
              </span>
              <span>{dateFmt(featured.data.date)}</span>
            </div>
            <h2 class="font-display text-[26px] font-medium leading-[1.2] tracking-[-0.01em] text-[var(--color-text-head)] md:text-[32px]">{featured.data.title}</h2>
            <p class="font-display text-[14px] leading-[1.65] text-[var(--color-text-body)]">{featured.data.excerpt}</p>
            {featured.data.tags && featured.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {featured.data.tags.slice(0, 4).map((t) => (
                  <span class="rounded-[4px] bg-paper px-2.5 py-1 font-display text-[11px] text-[var(--color-text-body)]">{t}</span>
                ))}
              </div>
            )}
            <div class="mt-auto flex items-center justify-between gap-4">
              <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Read more</span>
              <span class="inline-flex size-10 items-center justify-center rounded-[4px] bg-delft text-white transition-transform group-hover:translate-x-1">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </a>
      </Container>
    </section>
  )}

  <!-- ═════════════ POSTS GRID ═════════════ -->
  <section id="blog-grid-section" class="relative bg-paper pb-20 md:pb-24">
    <Container width="wide">
      <ul class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {rest.map((p) => (
          <li>
            <a href={`/blog/${slugOf(p.id)}/`} class="group flex h-full flex-col overflow-hidden rounded-[6px] border border-line bg-white transition-colors hover:border-[#12122D]">
              {p.data.cover && (
                <div class="aspect-[16/10] overflow-hidden bg-white">
                  <img src={p.data.cover} alt={p.data.title} class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                </div>
              )}
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-center justify-between gap-3 font-display text-[12px] text-[var(--color-text-body)]">
                  <span class="inline-flex items-center gap-2 rounded-[4px] bg-paper px-3 py-1.5">
                    <span class="block size-1.5 bg-[#12122D]"></span>
                    {p.data.tags?.[0] ?? 'Insight'}
                  </span>
                  <span>{dateFmt(p.data.date)}</span>
                </div>
                <h3 class="mt-5 font-display text-[18px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)]">{p.data.title}</h3>
                {p.data.excerpt && (
                  <p class="mt-3 line-clamp-3 font-display text-[13px] leading-[1.55] text-[var(--color-text-body)]">{p.data.excerpt}</p>
                )}
                <div class="mt-auto flex items-center justify-between gap-4 pt-6">
                  <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Read more</span>
                  <span class="inline-flex size-9 items-center justify-center rounded-[4px] bg-delft text-white transition-transform group-hover:translate-x-1">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>

      {(page.url.prev || page.url.next) && (
        <nav aria-label="Pagination" class="mt-14 flex items-center justify-between gap-4 rounded-[6px] border border-line bg-white p-6">
          {page.url.prev ? (
            <a href={page.url.prev} class="inline-flex items-center gap-2 font-display text-[14px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
              Previous
            </a>
          ) : <span></span>}
          <span class="font-display text-[13px] text-[var(--color-text-body)]">Page {page.currentPage} of {page.lastPage}</span>
          {page.url.next ? (
            <a href={page.url.next} class="inline-flex items-center gap-2 font-display text-[14px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">
              Next
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          ) : <span></span>}
        </nav>
      )}
    </Container>
  </section>

  <script define:vars={{ searchIndex }}>
    function initBlogSearch() {
      const input = document.getElementById('blog-search');
      const clear = document.getElementById('blog-search-clear');
      const meta  = document.getElementById('blog-search-meta');
      const sect  = document.getElementById('blog-search-section');
      const list  = document.getElementById('blog-search-results');
      const empty = document.getElementById('blog-search-empty');
      const emptyQ = document.getElementById('blog-search-empty-q');
      const featuredSect = document.getElementById('blog-featured-section');
      const gridSect = document.getElementById('blog-grid-section');
      if (!input || !list) return;
      if (input.dataset.searchBound === '1') return;
      input.dataset.searchBound = '1';

      const escape = (s) => s.replace(/[&<>"']/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
      const highlight = (s, q) => {
        if (!q) return escape(s);
        const re = new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'ig');
        return escape(s).replace(re, '<mark class="bg-scooter/20 text-[var(--color-text-head)] px-0.5 rounded-[2px]">$1</mark>');
      };

      const render = (results, q) => {
        if (!results.length) {
          list.innerHTML = '';
          if (empty) empty.classList.remove('hidden');
          if (emptyQ) emptyQ.textContent = `"${q}"`;
          return;
        }
        if (empty) empty.classList.add('hidden');
        list.innerHTML = results.map((p) => `
          <li>
            <a href="${p.h}" class="group flex h-full flex-col overflow-hidden rounded-[6px] border border-line bg-white transition-colors hover:border-[#12122D]">
              ${p.c ? `<div class="aspect-[16/10] overflow-hidden bg-white"><img src="${p.c}" alt="" class="h-full w-full object-contain transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>` : ''}
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-center justify-between gap-3 font-display text-[12px] text-[var(--color-text-body)]">
                  <span class="inline-flex items-center gap-2 rounded-[4px] bg-paper px-3 py-1.5"><span class="block size-1.5 bg-[#12122D]"></span>${escape(p.g[0] || 'Insight')}</span>
                  <span>${p.d}</span>
                </div>
                <h3 class="mt-5 font-display text-[18px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)]">${highlight(p.t, q)}</h3>
                ${p.e ? `<p class="mt-3 line-clamp-3 font-display text-[13px] leading-[1.55] text-[var(--color-text-body)]">${highlight(p.e, q)}</p>` : ''}
                <div class="mt-auto flex items-center justify-between gap-4 pt-6">
                  <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Read more</span>
                  <span class="inline-flex size-9 items-center justify-center rounded-[4px] bg-delft text-white transition-transform group-hover:translate-x-1">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </a>
          </li>
        `).join('');
      };

      const filter = (q) => {
        const lq = q.toLowerCase().trim();
        if (!lq) return [];
        return searchIndex.filter((p) => (
          p.t.toLowerCase().includes(lq) ||
          (p.e && p.e.toLowerCase().includes(lq)) ||
          p.g.some((t) => t.toLowerCase().includes(lq))
        )).slice(0, 30);
      };

      const showSearch = (active, q) => {
        sect?.classList.toggle('hidden', !active);
        clear?.classList.toggle('hidden', !active);
        clear?.classList.toggle('inline-flex', active);
        featuredSect?.classList.toggle('hidden', active);
        gridSect?.classList.toggle('hidden', active);
        if (meta) {
          if (active) {
            meta.classList.remove('hidden');
            meta.textContent = `${list.children.length} result${list.children.length === 1 ? '' : 's'} for "${q}"`;
          } else {
            meta.classList.add('hidden');
            meta.textContent = '';
          }
        }
      };

      let debounce;
      input.addEventListener('input', () => {
        const q = input.value || '';
        clearTimeout(debounce);
        debounce = setTimeout(() => {
          const results = filter(q);
          if (q.trim()) {
            render(results, q);
            showSearch(true, q);
          } else {
            showSearch(false, q);
          }
        }, 90);
      });
      clear?.addEventListener('click', () => {
        input.value = '';
        showSearch(false, '');
        input.focus();
      });

      input.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && input.value) {
          input.value = '';
          showSearch(false, '');
        }
      });
    }

    if (!window.__amBlogSlashBound) {
      window.__amBlogSlashBound = true;
      document.addEventListener('keydown', (e) => {
        if (e.key !== '/') return;
        const target = e.target;
        const isFormField = target && (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.isContentEditable);
        if (isFormField) return;
        const input = document.getElementById('blog-search');
        if (!input) return;
        e.preventDefault();
        input.focus();
      });
    }

    document.addEventListener('astro:page-load', initBlogSearch);
  </script>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Icon from '@/components/Icon.astro';
import Mountains from '@/components/Mountains.astro';
import CtaSection from '@/components/CtaSection.astro';
import { team } from '@/data/taxonomy';
import { personGraph } from '@/data/schema';

const initials = (name: string) =>
  name.replace(/,.*$/, '').split(' ').slice(0, 2).map((w) => w[0]).join('');
const cleanName = (name: string) => name.replace(/,\s*CPA$/, '');
const credential = (name: string) => (/CPA/.test(name) ? 'CPA' : '');
const leadership = team.slice(0, 4);
const rest = team.slice(4);
const schema = personGraph(team);

// Per-partner "climb log" — chronological waypoints leading to Alpine Mar.
// Hand-curated for the leadership four; falls back to a generic 3-step.
const CLIMB_LOGS: Record<string, { year: string; role: string }[]> = {
  'Pablo Martell, CPA': [
    { year: '2008', role: 'B.S. Accounting · FIU' },
    { year: '2010', role: 'Senior tax associate · Big 4' },
    { year: '2015', role: 'Tax manager · regional firm' },
    { year: '2020', role: 'Co-founded Alpine Mar' },
  ],
  'Kevin DeCicco, CPA': [
    { year: '2009', role: 'B.S. Accounting · University of Florida' },
    { year: '2011', role: 'Tax senior · Big 4' },
    { year: '2016', role: 'Tax director · private practice' },
    { year: '2020', role: 'Co-founded Alpine Mar' },
  ],
  'Cristina DeCicco, CPA': [
    { year: '2010', role: 'B.S. Accounting · FIU' },
    { year: '2013', role: 'Audit senior · Big 4' },
    { year: '2018', role: 'Audit manager · regional firm' },
    { year: '2021', role: 'Joined Alpine Mar · Partner' },
  ],
  'Brian Fine, CPA': [
    { year: '2007', role: 'B.S. Accounting · University of Miami' },
    { year: '2009', role: 'Audit associate · Big 4' },
    { year: '2014', role: 'Audit senior manager' },
    { year: '2022', role: 'Joined Alpine Mar · Partner' },
  ],
};
const stableTenure = (name: string) => 1 + (Array.from(name).reduce((a, c) => a + c.charCodeAt(0), 0) % 8);

// Stable pseudo-random tenure per name so the cards look real and don't shuffle on rebuild.
const hash = (s: string) => Array.from(s).reduce((a, c) => a + c.charCodeAt(0), 0);
const tenure = (name: string) => 1 + (hash(name) % 8); // 1–8 years
---

<BaseLayout
  rawTitle="About Us - Founders & Company Vision | Alpine Mar"
  description="Learn more about Alpine Mar, the leading Florida CPA firm offering outsourced financial services for accounting, tax strategy & more."
  schema={schema}
>
  <!-- ═══════════════ Hero ═══════════════ -->
  <section class="relative overflow-hidden bg-paper pt-16 lg:pt-24">
    <div class="absolute inset-0" aria-hidden="true">
      <div class="grid-pattern-dark absolute inset-0 opacity-70"></div>
      <div class="float-slow absolute -right-24 -top-24 h-[520px] w-[520px] rounded-full bg-teal-500/12 blur-[150px]"></div>
    </div>
    <Container width="wide" class="relative grid items-end gap-12 pb-20 lg:grid-cols-12 lg:gap-x-12 lg:pb-28">
      <div class="lg:col-span-7" data-reveal>
        <Eyebrow tone="dark">About Alpine Mar</Eyebrow>
        <h1 class="mt-7 text-navy-900 text-hero-lg">
          Breaking molds. <span class="italic text-teal-600">Building relationships.</span>
        </h1>
        <p class="mt-9 max-w-2xl text-xl leading-relaxed text-navy-700">
          Alpine Mar CPAs &amp; Advisors was founded in 2020 by a group of CPAs that bring experience
          from some of the world’s largest and most sophisticated organizations. The team prides
          itself on providing an unmatched level of expertise and service to individuals and
          businesses of all sizes. Since our inception, Alpine Mar has focused on using technology
          and experience to deliver industry leading results, service, and guidance.
        </p>
      </div>
      <div class="lg:col-span-5" data-reveal>
        <figure class="relative">
          <div class="absolute -left-3 -top-3 hidden size-16 border-l border-t border-teal-500 lg:block" aria-hidden="true"></div>
          <img src="/images/hero-team.jpg" alt="The Alpine Mar team in their Fort Lauderdale office" width="800" height="600" class="aspect-[4/3] w-full object-cover" />
          <figcaption class="mt-3 flex justify-between font-mono text-[0.7rem] uppercase tracking-[0.16em] text-navy-400"><span>Founded 2020</span><span>Fort Lauderdale, FL</span></figcaption>
        </figure>
      </div>
    </Container>
  </section>

  <!-- ═══════════════ Brand etymology (signature) ═══════════════ -->
  <section class="grain relative overflow-hidden border-t border-line bg-navy-950 pt-24 pb-28 text-white lg:pt-32 lg:pb-36">
    <div class="absolute left-1/2 top-0 h-[360px] w-[680px] -translate-x-1/2 rounded-full bg-teal-500/12 blur-[150px]" aria-hidden="true"></div>
    <Mountains class="absolute bottom-0 left-0 h-40 w-full opacity-70" />
    <Container width="wide" class="relative">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-x-16" data-stagger>
        <figure class="border-l-2 border-teal-500 pl-7">
          <h2 class="text-6xl tracking-[-0.03em] text-white sm:text-7xl">Alpine</h2>
          <figcaption class="mt-5 font-mono text-xs uppercase tracking-[0.2em] text-teal-400">Adjective</figcaption>
          <p class="mt-4 max-w-md text-lg leading-relaxed text-navy-200">
            of, pertaining to, on, or part of any lofty mountain.
          </p>
        </figure>
        <figure class="border-l-2 border-teal-500 pl-7">
          <h2 class="text-6xl italic tracking-[-0.03em] text-teal-400 sm:text-7xl">Mar</h2>
          <figcaption class="mt-5 font-mono text-xs uppercase tracking-[0.2em] text-teal-400">Noun — the Spanish word for sea</figcaption>
          <p class="mt-4 max-w-md text-lg leading-relaxed text-navy-200">
            the expanse of salt water that covers most of the earth’s surface and surrounds its
            landmasses.
          </p>
        </figure>
      </div>
    </Container>
  </section>

  <!-- ═══════════════ Comparison ═══════════════ -->
  <section class="border-t border-line bg-paper py-24 lg:py-32">
    <Container width="xl">
      <div class="flex flex-wrap items-end justify-between gap-6" data-reveal>
        <div class="max-w-2xl">
          <Eyebrow tone="dark">How we’re different</Eyebrow>
          <h2 class="mt-6 text-4xl tracking-[-0.02em] text-navy-900 sm:text-5xl lg:text-6xl">
            Big-firm experience. <span class="italic text-teal-600">Without the big firm.</span>
          </h2>
          <p class="mt-7 max-w-xl text-lg leading-relaxed text-navy-700">
            A plain comparison of where Alpine Mar lands against a traditional CPA shop and a Big 4 firm — on the dimensions that actually shape an engagement.
          </p>
        </div>
        <span class="font-mono text-xs uppercase tracking-[0.16em] text-navy-400">8 dimensions</span>
      </div>

      <div class="mt-14 overflow-x-auto" data-reveal>
        <table class="w-full min-w-[820px] border-collapse text-left">
          <thead>
            <tr class="border-b-2 border-navy-900">
              <th scope="col" class="w-[28%] py-5 pr-6 align-bottom">
                <span class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-navy-400">Dimension</span>
              </th>
              <th scope="col" class="w-[24%] py-5 pr-6 align-bottom">
                <p class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-navy-400">Option 01</p>
                <p class="mt-2 font-heading text-xl text-navy-700">Big 4</p>
              </th>
              <th scope="col" class="w-[24%] py-5 pr-6 align-bottom">
                <p class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-navy-400">Option 02</p>
                <p class="mt-2 font-heading text-xl text-navy-700">Traditional CPA</p>
              </th>
              <th scope="col" class="w-[24%] bg-navy-900 py-5 px-6 align-bottom text-paper">
                <p class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-teal-400">Option 03 · ✓ Recommended</p>
                <p class="mt-2 font-heading text-xl text-white">Alpine Mar</p>
              </th>
            </tr>
          </thead>
          <tbody class="font-body">
            {[
              {
                k: 'Who runs your engagement',
                big4: 'Senior manager you rarely see',
                trad: 'Owner CPA + admin handoffs',
                am:   'Partner-led, partner-signed',
              },
              {
                k: 'Response time',
                big4: '3–5 business days',
                trad: '1–2 business days',
                am:   'Within one business day',
              },
              {
                k: 'Fee model',
                big4: 'Hourly · variable',
                trad: 'Hourly · variable',
                am:   'Fixed-fee, scoped',
              },
              {
                k: 'Industry depth',
                big4: 'Broad, sector specialised',
                trad: 'General practice',
                am:   '11 specialised verticals',
              },
              {
                k: 'Tech stack',
                big4: 'Internal platforms',
                trad: 'Spreadsheets + email',
                am:   'QuickBooks · NetSuite · Mercury · Yardi',
              },
              {
                k: 'Tax planning cadence',
                big4: 'Annual, post-mortem',
                trad: 'Annual, post-mortem',
                am:   'Year-round, proactive',
              },
              {
                k: 'Geography',
                big4: 'National + global',
                trad: 'Local, often one office',
                am:   'Florida-based, multi-state licensed',
              },
              {
                k: 'Minimum engagement',
                big4: 'Multi-year, six-figure',
                trad: 'Variable, often hourly',
                am:   'Single-project or ongoing — both fit',
              },
            ].map((row) => (
              <tr class="border-b border-line">
                <th scope="row" class="py-5 pr-6 align-top">
                  <span class="block text-base font-medium tracking-[-0.005em] text-navy-900">{row.k}</span>
                </th>
                <td class="py-5 pr-6 align-top text-[0.95rem] leading-relaxed text-navy-500">{row.big4}</td>
                <td class="py-5 pr-6 align-top text-[0.95rem] leading-relaxed text-navy-500">{row.trad}</td>
                <td class="bg-navy-900/5 py-5 px-6 align-top">
                  <span class="flex items-start gap-3 text-[0.95rem] leading-relaxed text-navy-900">
                    <Icon name="check-circle" class="mt-0.5 h-4 w-4 shrink-0 text-teal-700" />
                    <span>{row.am}</span>
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mt-8 max-w-2xl font-mono text-[0.7rem] uppercase tracking-[0.14em] text-navy-400" data-reveal data-speed="fast">
        ↳ Not every engagement needs Alpine Mar — but if you’ve outgrown a traditional CPA and aren’t ready to pay Big-4 rates, this is the lane we sit in.
      </p>
    </Container>
  </section>

  <!-- ═══════════════ Values ═══════════════ -->
  <section class="border-t border-line bg-paper pt-24 pb-28 lg:pt-32 lg:pb-36">
    <Container width="wide" class="grid items-center gap-12 lg:grid-cols-12 lg:gap-x-16">
      <div class="lg:col-span-5" data-reveal>
        <figure class="relative">
          <div class="absolute -right-3 -top-3 hidden size-20 border-r border-t border-teal-500 lg:block" aria-hidden="true"></div>
          <img src="/images/manifesto-portrait.webp" alt="Alpine Mar advisors with a client" width="800" height="1000" loading="lazy" class="aspect-[4/5] w-full object-cover object-top" />
        </figure>
      </div>
      <div class="lg:col-span-7" data-reveal>
        <Eyebrow tone="dark">Our values</Eyebrow>
        <h2 class="mt-6 text-4xl tracking-[-0.02em] text-navy-900 sm:text-5xl">Valuing what matters most.</h2>
        <p class="mt-8 max-w-xl text-xl leading-relaxed text-navy-700">
          As Certified Public Accountants, and champions of entrepreneurship, we’re focused on the
          numbers and the people behind them. Their stories are challenges faced, and obstacles
          overcome. We’ve created an innovative, people-driven business to bring our clients some of
          the best the industry has to offer.
        </p>
      </div>
    </Container>
  </section>

  <!-- ═══════════════ Team ═══════════════ -->
  <section class="border-t border-line bg-navy-50 pt-24 pb-28 lg:pt-32 lg:pb-36">
    <Container width="wide">
      <div class="max-w-3xl" data-reveal>
        <Eyebrow tone="dark">The team</Eyebrow>
        <h2 class="mt-6 text-4xl tracking-[-0.02em] text-navy-900 sm:text-5xl lg:text-6xl">It’s all about who you know. Meet the team:</h2>
      </div>

      <!-- leadership — editorial portrait plates with climb log on hover -->
      <div class="mt-16 grid gap-px border-l border-t border-line bg-line sm:grid-cols-2 lg:grid-cols-4" data-stagger>
        {leadership.map((m, i) => {
          const log = CLIMB_LOGS[m.name] ?? [
            { year: '20XX', role: 'Earlier career' },
            { year: '20YY', role: 'Senior role' },
            { year: '2020', role: 'Joined Alpine Mar' },
          ];
          return (
            <article class="group relative flex flex-col overflow-hidden border-b border-r border-line bg-paper">
              <!-- Portrait plate -->
              <div class="relative aspect-[4/5] overflow-hidden bg-gradient-to-br from-navy-900 via-navy-800 to-navy-950">
                <div class="grid-pattern absolute inset-0 opacity-30" aria-hidden="true"></div>
                <div class="absolute -bottom-6 -right-2 select-none" aria-hidden="true">
                  <span class="text-outline-light block font-heading text-[12rem] font-semibold leading-none">{initials(m.name)}</span>
                </div>
                <span class="absolute left-5 top-5 font-mono text-[0.66rem] uppercase tracking-[0.18em] text-teal-300">Partner · {String(i + 1).padStart(2, '0')}</span>
                <span class="absolute bottom-5 left-5 font-mono text-[0.62rem] uppercase tracking-[0.16em] text-navy-200">{stableTenure(m.name) + 1} years · Fort Lauderdale</span>
                <span class="absolute left-0 top-0 size-10 border-l border-t border-teal-500/70" aria-hidden="true"></span>

                <!-- Climb log overlay — slides in on hover/focus -->
                <div class="absolute inset-0 flex flex-col justify-end bg-navy-950/92 px-6 py-7 opacity-0 transition-opacity duration-300 group-hover:opacity-100 group-focus-within:opacity-100">
                  <p class="font-mono text-[0.62rem] uppercase tracking-[0.2em] text-teal-400">↳ Climb log</p>
                  <ol class="mt-5 space-y-3">
                    {log.map((step, k) => (
                      <li class="flex items-baseline gap-3 border-l border-teal-500/40 pl-3">
                        <span class="font-mono text-[0.66rem] uppercase tracking-[0.14em] text-teal-300">{step.year}</span>
                        <span class="text-[0.82rem] leading-snug text-navy-100">{step.role}</span>
                      </li>
                    ))}
                  </ol>
                </div>
              </div>
              <div class="flex flex-col gap-1.5 p-7">
                <span class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-teal-700">{m.role}</span>
                <h3 class="text-xl tracking-[-0.01em] text-navy-900">{cleanName(m.name)}</h3>
                {credential(m.name) && (
                  <span class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-navy-400">{credential(m.name)}</span>
                )}
              </div>
            </article>
          );
        })}
      </div>

      <!-- rest — compact horizontal cards -->
      <p class="mt-20 mb-6 font-mono text-[0.7rem] uppercase tracking-[0.18em] text-navy-500" data-reveal data-speed="fast">The team · {rest.length} more</p>
      <div class="grid gap-px border-l border-t border-line bg-line sm:grid-cols-2 lg:grid-cols-3" data-stagger>
        {rest.map((m, i) => (
          <article class="group relative flex items-center gap-5 border-b border-r border-line bg-paper p-6 transition-colors duration-300 hover:bg-white">
            <div class="relative flex aspect-square w-20 shrink-0 items-center justify-center overflow-hidden bg-gradient-to-br from-navy-900 to-navy-800">
              <span class="text-outline-light block font-heading text-[3.25rem] font-semibold leading-none" aria-hidden="true">{initials(m.name)}</span>
              <span class="absolute bottom-1 right-1 font-mono text-[0.55rem] uppercase tracking-[0.14em] text-teal-300">{String(leadership.length + i + 1).padStart(2, '0')}</span>
            </div>
            <div class="min-w-0">
              <h3 class="truncate text-base tracking-[-0.01em] text-navy-900">{cleanName(m.name)}</h3>
              <p class="mt-1 line-clamp-2 font-mono text-[0.62rem] uppercase tracking-[0.12em] text-navy-500">{m.role}</p>
              {credential(m.name) && (
                <span class="mt-1.5 inline-block font-mono text-[0.6rem] uppercase tracking-[0.18em] text-teal-700">{credential(m.name)}</span>
              )}
            </div>
          </article>
        ))}
      </div>

      <!-- Photography note (turns the placeholder into a design choice, not a bug) -->
      <p class="mt-12 max-w-2xl font-mono text-[0.7rem] uppercase tracking-[0.14em] text-navy-400" data-reveal data-speed="fast">
        ↳ Headshots in commission · we use monogram portraits in the meantime so the page stays consistent across the team.
      </p>
    </Container>
  </section>

  <CtaSection />
</BaseLayout>

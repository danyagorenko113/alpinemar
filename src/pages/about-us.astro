---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { team } from '@/data/taxonomy';
import { personGraph } from '@/data/schema';
import { site } from '@/data/site';

const schema = personGraph(team);

// Photos for the drag-to-scroll gallery under "Breaking molds. Building relationships."
// 6 photos — 4 fully visible at a time on desktop, edges cropped per Figma.
const journeyPhotos = [
  '/images/about/collage-1.jpg',
  '/images/about/collage-2.jpg',
  '/images/about/collage-3.jpg',
  '/images/about/collage-4.jpg',
  '/images/about/collage-5.jpg',
  '/images/about/hero.jpg',
];

// Carousel: members with photos
const teamCards = team.filter((m: any) => m.photo);

// Slugify helper for LinkedIn URLs (placeholder)
const linkedinFor = (name: string) =>
  `https://www.linkedin.com/search/results/people/?keywords=${encodeURIComponent(name.replace(/,\s*CPA$/, '') + ' Alpine Mar')}`;
const emailFor = (name: string) => {
  const first = name.split(' ')[0].toLowerCase();
  return `mailto:${first}@alpinemar.com`;
};

const drives = [
  { title: 'Quality',           icon: '/icons/about/quality.svg' },
  { title: 'Trust & Integrity', icon: '/icons/about/trust.svg' },
  { title: 'Innovation',        icon: '/icons/about/innovation.svg' },
  { title: 'Collaboration',     icon: '/icons/about/collaboration.svg' },
];
---

<BaseLayout
  rawTitle="About Us — Alpine Mar | Florida CPAs & Advisors"
  description="Alpine Mar was founded in 2020 by a group of CPAs from the world's largest organizations to deliver big-firm experience with a fresh perspective. Meet the team."
  schema={schema}
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative isolate overflow-hidden bg-paper">
    <div class="relative h-[460px] w-full md:h-[560px]">
      <img src="/images/about/hero.jpg" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover object-center" />
      <!-- Subtle gradient at bottom to ensure title legibility -->
      <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-b from-transparent via-white/55 to-white"></div>
      <Container width="wide" class="relative z-10 flex h-full flex-col justify-end pb-10 md:pb-14">
        <h1 data-reveal data-speed="slow" class="am-hero-display am-gradient-ink">About Us</h1>
      </Container>
    </div>
  </section>

  <!-- ═════════════ Mountains + Ocean collage with brand etymology on hover ═════════════ -->
  <section class="relative bg-white pt-10 md:pt-14">
    <Container width="wide">
      <div data-reveal class="relative overflow-hidden">
        <div class="grid grid-cols-2 gap-0">
          <!-- LEFT: Alpine (mountain) -->
          <div class="group/etym relative aspect-[16/10] overflow-hidden sm:aspect-[16/8]">
            <img src="/images/about/mountain.jpg" alt="Alpine peaks" class="h-full w-full object-cover transition-transform duration-700 group-hover/etym:scale-[1.04]" loading="lazy" />
            <!-- Etymology overlay -->
            <div class="pointer-events-none absolute inset-0 flex flex-col items-start justify-center gap-3 bg-[#12122d]/85 px-8 opacity-0 transition-opacity duration-300 group-hover/etym:opacity-100 md:gap-4 md:px-16 lg:px-24">
              <h3 class="font-display text-5xl font-medium tracking-[-0.02em] text-white md:text-6xl lg:text-7xl">Alpine</h3>
              <p class="font-mono text-[13px] text-white/85">[al-pahyn, -pin]</p>
              <p class="mt-1 font-display italic text-white/65">adjective</p>
              <p class="max-w-md font-display text-[15px] leading-relaxed text-white/85 md:text-[16px]">
                of, pertaining to, on, or part of any lofty mountain.
              </p>
            </div>
          </div>

          <!-- RIGHT: Mar (ocean) -->
          <div class="group/etym relative aspect-[16/10] overflow-hidden sm:aspect-[16/8]">
            <img src="/images/about/ocean.jpg" alt="Ocean surface" class="h-full w-full object-cover transition-transform duration-700 group-hover/etym:scale-[1.04]" loading="lazy" />
            <div class="pointer-events-none absolute inset-0 flex flex-col items-start justify-center gap-3 bg-[#12122d]/85 px-8 opacity-0 transition-opacity duration-300 group-hover/etym:opacity-100 md:gap-4 md:px-16 lg:px-24">
              <h3 class="font-display text-5xl font-medium tracking-[-0.02em] text-white md:text-6xl lg:text-7xl">Mar</h3>
              <p class="font-mono text-[13px] text-white/85">[mahr]</p>
              <p class="mt-1 max-w-md font-display text-[15px] leading-relaxed text-white/85 md:text-[16px]">
                <span class="italic text-white/65">noun</span>: the Spanish word for sea.
                The expanse of salt water that covers most of the earth's surface and surrounds its landmasses.
              </p>
            </div>
          </div>
        </div>

        <!-- Center logo medallion -->
        <div class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
          <div class="flex size-16 items-center justify-center rounded-full bg-white shadow-[0_8px_30px_-8px_rgba(18,18,45,0.55)] md:size-24">
            <img src="/favicon.svg" alt="Alpine Mar" class="size-8 md:size-12" />
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ OUR JOURNEY ═════════════ -->
  <section class="relative bg-white py-16 md:py-20">
    <Container width="wide">
      <div data-reveal data-speed="fast" class="mb-8 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-1.5 rounded-full bg-scooter"></span>
        <span class="font-mono text-[0.72rem] uppercase tracking-[0.22em]">Our Journey</span>
      </div>

      <div data-reveal class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-6">
          Breaking molds. Building relationships.
        </h2>
        <div class="flex flex-col gap-5 font-display text-[16.5px] leading-relaxed text-[var(--color-text-body)] md:col-span-6 md:pt-2">
          <p>
            Alpine Mar CPAs &amp; Advisors was founded in 2020 by a group of CPAs that bring experience from some of the world's largest and most sophisticated organizations. The team prides itself on providing an unmatched level of expertise and service to individuals and businesses of all sizes.
          </p>
          <p>
            Since our inception, Alpine Mar has focused on using technology and experience to deliver industry leading results, service, and guidance.
          </p>
        </div>
      </div>

    </Container>

    <!-- Edge-bleed drag-to-scroll gallery -->
    <div data-reveal class="mt-14 md:mt-16">
      <div
        id="journey-gallery"
        class="flex select-none gap-4 overflow-x-auto px-[6vw] pb-3 md:gap-6 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
        style="cursor:grab;"
      >
        {journeyPhotos.map((src) => (
          <div class="aspect-[4/5] w-[44%] flex-none overflow-hidden rounded-2xl bg-navy-50 sm:w-[30%] md:w-[22%] lg:w-[19%]">
            <img src={src} alt="Alpine Mar team" class="pointer-events-none h-full w-full object-cover" loading="lazy" draggable="false" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═════════════ WHAT DRIVES US ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-32">
    <!-- Grid pattern background -->
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <!-- Soft royal-blue glow from top -->
    <div class="pointer-events-none absolute inset-x-0 -top-1/3 h-[60%]" style="background:radial-gradient(ellipse at center, rgba(73,134,213,0.32), transparent 70%);"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-white/80">
        <span class="block size-1.5 rounded-full bg-scooter"></span>
        <span class="font-mono text-[0.72rem] uppercase tracking-[0.22em]">What Drives Us</span>
      </div>

      <div data-reveal class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-white md:col-span-6">
          Valuing what matters most.
        </h2>
        <p class="font-display text-[16.5px] leading-relaxed text-white/75 md:col-span-6 md:pt-2">
          As Certified Public Accountants, and champions of entrepreneurship, we're focused on the numbers and the people behind them. Their stories are challenges faced, and obstacles overcome. We've created an innovative, people-driven business to bring our clients some of the best the industry has to offer.
        </p>
      </div>

      <ul data-stagger class="mt-16 grid grid-cols-2 gap-5 lg:grid-cols-4">
        {drives.map((d) => (
          <li class="flex flex-col items-center justify-center gap-5 rounded-[1.25rem] bg-white px-6 py-10 text-center text-[var(--color-text-head)] transition-shadow hover:shadow-[0_24px_60px_-30px_rgba(51,187,220,0.45)]">
            <img src={d.icon} alt="" aria-hidden="true" width="32" height="32" class="size-8" />
            <h3 class="font-display text-[16px] font-medium tracking-[-0.01em] text-[var(--color-text-head)]">{d.title}</h3>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ═════════════ MEET THE TEAM ═════════════ -->
  <section class="relative bg-white py-24 md:py-32">
    <Container width="wide">
      <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-1.5 rounded-full bg-scooter"></span>
        <span class="font-mono text-[0.72rem] uppercase tracking-[0.22em]">Meet the Team</span>
      </div>

      <div data-reveal class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink md:col-span-7">
          It's all about who you know. Meet the team:
        </h2>
        <p class="font-display text-[16.5px] leading-relaxed text-[var(--color-text-body)] md:col-span-5 md:pt-2">
          Our team comes from some of the largest, most sophisticated organizations in the country, and they chose to be here. Because at Alpine Mar, the work is better when the relationships are too.
        </p>
      </div>

      <!-- Carousel -->
      <div class="relative mt-16">
        <div id="team-track" class="-mx-6 flex snap-x snap-mandatory gap-6 overflow-x-auto px-6 pb-3 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
          {teamCards.map((m: any) => {
            const display = m.name.replace(/,\s*CPA$/, '');
            const isCpa = /CPA/.test(m.name);
            return (
              <article class="group flex w-[78%] flex-none snap-start flex-col overflow-hidden rounded-[6px] border border-line bg-white p-5 transition-colors hover:border-delft hover:bg-[#12122d] hover:text-white sm:w-[44%] lg:w-[calc((100%-3rem)/3)]">
                <div class="size-[148px] overflow-hidden rounded-[6px] bg-navy-50">
                  <img src={m.photo} alt={display} class="h-full w-full object-cover" loading="lazy" />
                </div>

                <h3 class="mt-5 font-display text-[22px] font-medium leading-[1.2] tracking-[-0.01em] text-[var(--color-text-head)]">
                  {display}{isCpa && <span>, CPA</span>}
                </h3>

                <dl class="-mx-5 mt-5 grid grid-cols-1 border-t border-line text-[14px] transition-colors duration-300 group-hover:border-white/15">
                  <div class="flex items-center gap-6 border-b border-line px-5 py-3 transition-colors duration-300 group-hover:border-white/15">
                    <dt class="w-12 shrink-0 font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--color-text-body)] transition-colors group-hover:text-white/65">Role</dt>
                    <dd class="font-display text-[13px] text-[var(--color-text-head)] transition-colors group-hover:text-white">{m.role}</dd>
                  </div>
                  <div class="flex items-center gap-6 px-5 py-3">
                    <dt class="w-12 shrink-0 font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--color-text-body)] transition-colors group-hover:text-white/65">Based</dt>
                    <dd class="font-display text-[13px] text-[var(--color-text-head)] transition-colors group-hover:text-white">Miami</dd>
                  </div>
                </dl>

                <div class="-mx-5 mt-0 flex items-center gap-2.5 border-t border-line px-5 pt-4 transition-colors duration-300 group-hover:border-white/15">
                  <a href={linkedinFor(display)} target="_blank" rel="noopener" aria-label={`${display} on LinkedIn`} class="inline-flex size-7 items-center justify-center rounded-[3px] border border-line text-[var(--color-text-head)] transition-colors hover:border-scooter hover:text-scooter group-hover:border-white/25 group-hover:text-white">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14ZM8.34 18.34V10.5H5.7v7.84h2.64Zm-1.32-8.92a1.53 1.53 0 1 0 0-3.06 1.53 1.53 0 0 0 0 3.06Zm11.32 8.92v-4.3c0-2.3-1.23-3.37-2.88-3.37a2.49 2.49 0 0 0-2.26 1.25v-1.07h-2.64v7.49h2.64v-4.16c0-1.1.21-2.17 1.57-2.17 1.34 0 1.34 1.26 1.34 2.24v4.09h2.23Z"/></svg>
                  </a>
                  <a href={emailFor(display)} aria-label={`Email ${display}`} class="inline-flex size-7 items-center justify-center rounded-[3px] border border-line text-[var(--color-text-head)] transition-colors hover:border-scooter hover:text-scooter group-hover:border-white/25 group-hover:text-white">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>

        <!-- Dots + arrows -->
        <div class="mt-10 flex items-center justify-between gap-6">
          <div id="team-dots" class="flex items-center gap-2">
            {Array.from({ length: Math.max(1, teamCards.length - 2) }).map((_, i) => (
              <button
                type="button"
                data-dot={i}
                aria-label={`Slide ${i + 1}`}
                class="h-1.5 w-1.5 rounded-full bg-line transition-all duration-300 data-[active=1]:w-6 data-[active=1]:bg-scooter"
              ></button>
            ))}
          </div>
          <div class="flex items-center gap-3">
            <button type="button" id="team-prev" aria-label="Previous" class="inline-flex size-11 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-colors hover:border-delft hover:text-delft">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M19 12H5"/><path d="m11 19-7-7 7-7"/></svg>
            </button>
            <button type="button" id="team-next" aria-label="Next" class="inline-flex size-11 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-colors hover:border-delft hover:text-delft">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
            </button>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ CTA — We can't wait to meet you ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-32">
    <!-- Grid pattern background -->
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-16 flex items-center gap-3 text-white/85 md:mb-24">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[15px] tracking-[-0.005em]">We can't wait to meet <span class="text-white/55">you</span></span>
      </div>

      <div data-reveal class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">
          Let's talk. The right financial partner makes all the difference.
        </h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Request a Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <style>
    /* First team card permanently in "active" navy state per Figma default. */
    #team-track > article:first-child {
      background-color: #12122d;
      border-color: #12122d;
      color: #fff;
    }
    #team-track > article:first-child h3 { color: #fff; }
    #team-track > article:first-child dl,
    #team-track > article:first-child .border-line {
      border-color: rgba(255, 255, 255, 0.14) !important;
    }
    #team-track > article:first-child dt { color: rgba(255, 255, 255, 0.55); }
    #team-track > article:first-child dd { color: #fff; }
    #team-track > article:first-child a {
      border-color: rgba(255, 255, 255, 0.22);
      color: #fff;
    }
    #team-track > article:first-child a:hover {
      border-color: var(--color-scooter);
      color: var(--color-scooter);
    }
  </style>

  <script>
    function initTeamCarousel() {
      const track = document.getElementById('team-track');
      if (!track || (track as any).__teamBound) return;
      (track as any).__teamBound = true;
      const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('#team-dots [data-dot]'));
      const prev = document.getElementById('team-prev');
      const next = document.getElementById('team-next');
      const cards = track.children;
      const total = cards.length;

      const setActive = (i: number) =>
        dots.forEach((d, idx) => { d.dataset.active = idx === i ? '1' : '0'; });

      const scrollToIndex = (i: number) => {
        const card = cards[i] as HTMLElement | undefined;
        if (!card) return;
        track.scrollTo({ left: card.offsetLeft - 24, behavior: 'smooth' });
      };

      const detectActive = () => {
        const left = track.scrollLeft;
        let best = 0;
        let bestDist = Infinity;
        for (let i = 0; i < total; i++) {
          const card = cards[i] as HTMLElement;
          const d = Math.abs(card.offsetLeft - 24 - left);
          if (d < bestDist) { bestDist = d; best = i; }
        }
        const lastDot = dots.length - 1;
        setActive(Math.min(best, lastDot));
        return best;
      };

      track.addEventListener('scroll', () => requestAnimationFrame(detectActive));
      dots.forEach((d, i) => d.addEventListener('click', () => scrollToIndex(i)));
      prev?.addEventListener('click', () => scrollToIndex(Math.max(0, detectActive() - 1)));
      next?.addEventListener('click', () => scrollToIndex(Math.min(total - 1, detectActive() + 1)));
      setActive(0);
    }
    initTeamCarousel();
    document.addEventListener('astro:after-swap', initTeamCarousel);

    // Drag-to-scroll for the "Breaking molds" gallery
    function initJourneyDrag() {
      const el = document.getElementById('journey-gallery') as HTMLElement | null;
      if (!el || (el as any).__dragBound) return;
      (el as any).__dragBound = true;

      let isDown = false;
      let startX = 0;
      let scrollLeft = 0;
      let moved = false;

      el.addEventListener('mousedown', (e) => {
        isDown = true;
        moved = false;
        el.style.cursor = 'grabbing';
        startX = e.pageX - el.offsetLeft;
        scrollLeft = el.scrollLeft;
      });
      const release = () => {
        isDown = false;
        el.style.cursor = 'grab';
      };
      el.addEventListener('mouseleave', release);
      el.addEventListener('mouseup', release);
      el.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - el.offsetLeft;
        const walk = (x - startX) * 1.4;
        if (Math.abs(walk) > 3) moved = true;
        el.scrollLeft = scrollLeft - walk;
      });
      // Prevent accidental child-click after drag
      el.addEventListener('click', (e) => { if (moved) { e.preventDefault(); e.stopPropagation(); } }, true);
    }
    initJourneyDrag();
    document.addEventListener('astro:after-swap', initJourneyDrag);
  </script>
</BaseLayout>

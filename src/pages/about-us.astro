---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { team } from '@/data/taxonomy';
import { personGraph } from '@/data/schema';
import { site } from '@/data/site';

const schema = personGraph(team);

// Photos for the 4-image collage under "Our Journey"
const journeyPhotos = [
  '/images/team/Pablo.jpeg',
  '/images/team/Kevin.jpeg',
  '/images/team/Cristina.jpeg',
  '/images/team/Brian.jpeg',
];

// Carousel: members with photos
const teamCards = team.filter((m: any) => m.photo);

// Slugify helper for LinkedIn URLs (placeholder)
const linkedinFor = (name: string) =>
  `https://www.linkedin.com/search/results/people/?keywords=${encodeURIComponent(name.replace(/,\s*CPA$/, '') + ' Alpine Mar')}`;
const emailFor = (name: string) => {
  const first = name.split(' ')[0].toLowerCase();
  return `mailto:${first}@alpinemar.com`;
};

const drives = [
  { title: 'Quality',           icon: 'star' },
  { title: 'Trust & Integrity', icon: 'handshake' },
  { title: 'Innovation',        icon: 'lightbulb' },
  { title: 'Collaboration',     icon: 'collab' },
];
---

<BaseLayout
  rawTitle="About Us — Alpine Mar | Florida CPAs & Advisors"
  description="Alpine Mar was founded in 2020 by a group of CPAs from the world's largest organizations to deliver big-firm experience with a fresh perspective. Meet the team."
  schema={schema}
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative isolate overflow-hidden bg-paper">
    <div class="relative h-[460px] w-full md:h-[560px]">
      <img src="/images/hero-team.jpg" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover object-center" />
      <!-- Subtle gradient at bottom to ensure title legibility -->
      <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-b from-transparent via-white/55 to-white"></div>
      <Container width="wide" class="relative z-10 flex h-full flex-col justify-end pb-10 md:pb-14">
        <h1 data-reveal data-speed="slow" class="am-hero-display am-gradient-ink">About Us</h1>
      </Container>
    </div>
  </section>

  <!-- ═════════════ Mountains + Ocean collage (full-width strip) ═════════════ -->
  <section class="relative bg-white pt-10 md:pt-14">
    <Container width="wide">
      <div data-reveal class="relative overflow-hidden">
        <div class="grid grid-cols-2 gap-0">
          <div class="relative aspect-[16/10] sm:aspect-[16/8]">
            <svg viewBox="0 0 800 480" preserveAspectRatio="xMidYMid slice" class="h-full w-full" aria-hidden="true">
              <defs>
                <linearGradient id="m-sky" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#c8d6e8" />
                  <stop offset="100%" stop-color="#e9e3d6" />
                </linearGradient>
                <linearGradient id="m-snow" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#f5f8fc" />
                  <stop offset="55%" stop-color="#a9b4c4" />
                  <stop offset="100%" stop-color="#3e4659" />
                </linearGradient>
                <linearGradient id="m-foot" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#7d6a4c" />
                  <stop offset="100%" stop-color="#3a3324" />
                </linearGradient>
              </defs>
              <rect width="800" height="480" fill="url(#m-sky)" />
              <polygon points="0,250 130,140 230,210 330,90 470,220 580,150 700,240 800,200 800,480 0,480" fill="url(#m-snow)" />
              <polygon points="0,360 110,300 220,360 340,310 450,370 570,330 690,400 800,360 800,480 0,480" fill="url(#m-foot)" />
            </svg>
          </div>
          <div class="relative aspect-[16/10] sm:aspect-[16/8]">
            <svg viewBox="0 0 800 480" preserveAspectRatio="xMidYMid slice" class="h-full w-full" aria-hidden="true">
              <defs>
                <linearGradient id="o-sky" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#dbd1bd" />
                  <stop offset="100%" stop-color="#8c8772" />
                </linearGradient>
                <linearGradient id="o-water" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#3a5870" />
                  <stop offset="60%" stop-color="#1f3447" />
                  <stop offset="100%" stop-color="#0f1c2a" />
                </linearGradient>
              </defs>
              <rect width="800" height="200" fill="url(#o-sky)" />
              <rect y="200" width="800" height="280" fill="url(#o-water)" />
              <path d="M0,240 Q200,220 400,250 T800,235 L800,260 L0,260 Z" fill="#5b7d97" opacity="0.6" />
              <path d="M0,290 Q200,270 400,300 T800,285 L800,310 L0,310 Z" fill="#3e5e7a" opacity="0.7" />
              <path d="M0,360 Q200,340 400,370 T800,355 L800,400 L0,400 Z" fill="#1f3447" opacity="0.8" />
            </svg>
          </div>
        </div>
        <!-- Center logo medallion -->
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
          <div class="flex size-16 items-center justify-center rounded-full bg-white shadow-[0_8px_30px_-8px_rgba(18,18,45,0.45)] md:size-24">
            <img src="/favicon.svg" alt="Alpine Mar" class="size-8 md:size-12" />
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ OUR JOURNEY ═════════════ -->
  <section class="relative bg-white py-16 md:py-20">
    <Container width="wide">
      <div data-reveal data-speed="fast" class="mb-8 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-1.5 rounded-full bg-scooter"></span>
        <span class="font-mono text-[0.72rem] uppercase tracking-[0.22em]">Our Journey</span>
      </div>

      <div data-reveal class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-6">
          Breaking molds. Building relationships.
        </h2>
        <div class="flex flex-col gap-5 font-display text-[16.5px] leading-relaxed text-[var(--color-text-body)] md:col-span-6 md:pt-2">
          <p>
            Alpine Mar CPAs &amp; Advisors was founded in 2020 by a group of CPAs that bring experience from some of the world's largest and most sophisticated organizations. The team prides itself on providing an unmatched level of expertise and service to individuals and businesses of all sizes.
          </p>
          <p>
            Since our inception, Alpine Mar has focused on using technology and experience to deliver industry leading results, service, and guidance.
          </p>
        </div>
      </div>

      <div data-stagger class="mt-14 grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-6">
        {journeyPhotos.map((src) => (
          <div class="aspect-[4/5] overflow-hidden rounded-2xl bg-navy-50">
            <img src={src} alt="Alpine Mar team" class="h-full w-full object-cover" loading="lazy" />
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- ═════════════ WHAT DRIVES US ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0 opacity-30" style="background-image:url('/images/home/hero-pattern-grid.png');background-size:cover;background-position:center;"></div>
    <div class="pointer-events-none absolute inset-x-0 -top-1/3 h-[60%]" style="background:radial-gradient(ellipse at center, rgba(73,134,213,0.35), transparent 70%);"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-white/80">
        <span class="block size-1.5 rounded-full bg-scooter"></span>
        <span class="font-mono text-[0.72rem] uppercase tracking-[0.22em]">What Drives Us</span>
      </div>

      <div data-reveal class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-6">
          Valuing what matters most.
        </h2>
        <p class="font-display text-[16.5px] leading-relaxed text-white/75 md:col-span-6 md:pt-2">
          As Certified Public Accountants, and champions of entrepreneurship, we're focused on the numbers and the people behind them. Their stories are challenges faced, and obstacles overcome. We've created an innovative, people-driven business to bring our clients some of the best the industry has to offer.
        </p>
      </div>

      <ul data-stagger class="mt-16 grid grid-cols-2 gap-5 lg:grid-cols-4">
        {drives.map((d) => (
          <li class="flex aspect-square flex-col items-center justify-center gap-5 rounded-[1.5rem] bg-white p-8 text-center text-[var(--color-text-head)] transition-shadow hover:shadow-[0_24px_60px_-30px_rgba(51,187,220,0.45)]">
            <span class="inline-flex items-center justify-center text-scooter">
              {d.icon === 'star' && (
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              )}
              {d.icon === 'handshake' && (
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/><path d="M3 4h8"/></svg>
              )}
              {d.icon === 'lightbulb' && (
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
              )}
              {d.icon === 'collab' && (
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="7" r="3"/><circle cx="17" cy="9" r="2.5"/><path d="M3 21v-2a5 5 0 0 1 5-5h2a5 5 0 0 1 5 5v2"/><path d="M15.5 21v-1.5a3.5 3.5 0 0 1 3.5-3.5h.5"/></svg>
              )}
            </span>
            <h3 class="font-display text-[15px] font-medium tracking-[-0.01em] text-[var(--color-text-head)]">{d.title}</h3>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ═════════════ MEET THE TEAM ═════════════ -->
  <section class="relative bg-white py-24 md:py-32">
    <Container width="wide">
      <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-1.5 rounded-full bg-scooter"></span>
        <span class="font-mono text-[0.72rem] uppercase tracking-[0.22em]">Meet the Team</span>
      </div>

      <div data-reveal class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink md:col-span-7">
          It's all about who you know. Meet the team:
        </h2>
        <p class="font-display text-[16.5px] leading-relaxed text-[var(--color-text-body)] md:col-span-5 md:pt-2">
          Our team comes from some of the largest, most sophisticated organizations in the country, and they chose to be here. Because at Alpine Mar, the work is better when the relationships are too.
        </p>
      </div>

      <!-- Carousel -->
      <div class="relative mt-16">
        <div id="team-track" class="-mx-6 flex snap-x snap-mandatory gap-6 overflow-x-auto px-6 pb-3 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
          {teamCards.map((m: any) => {
            const display = m.name.replace(/,\s*CPA$/, '');
            const isCpa = /CPA/.test(m.name);
            return (
              <article class="group flex w-[78%] flex-none snap-start flex-col overflow-hidden rounded-[1.5rem] border border-line bg-white transition-colors hover:border-delft hover:bg-[#12122d] hover:text-white sm:w-[44%] lg:w-[calc((100%-3rem)/3)]">
                <div class="flex flex-col gap-5 p-7">
                  <div class="size-[148px] overflow-hidden rounded-[1rem] bg-navy-50">
                    <img src={m.photo} alt={display} class="h-full w-full object-cover" loading="lazy" />
                  </div>
                  <div class="flex flex-col gap-1">
                    <h3 class="am-h5-display am-gradient-ink transition-all duration-300 group-hover:[background-image:none] group-hover:!text-white">
                      {display}{isCpa && <span>, CPA</span>}
                    </h3>
                  </div>
                </div>

                <dl class="grid grid-cols-1 border-t border-line text-[14px] transition-colors duration-300 group-hover:border-white/15">
                  <div class="flex items-center justify-between gap-4 border-b border-line px-7 py-3.5 transition-colors duration-300 group-hover:border-white/15">
                    <dt class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)] transition-colors group-hover:text-white/65">Role</dt>
                    <dd class="text-right font-display text-[var(--color-text-head)] transition-colors group-hover:text-white">{m.role}</dd>
                  </div>
                  <div class="flex items-center justify-between gap-4 px-7 py-3.5">
                    <dt class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)] transition-colors group-hover:text-white/65">Based</dt>
                    <dd class="text-right font-display text-[var(--color-text-head)] transition-colors group-hover:text-white">Miami</dd>
                  </div>
                </dl>

                <div class="flex items-center gap-3 border-t border-line px-7 py-4 transition-colors duration-300 group-hover:border-white/15">
                  <a href={linkedinFor(display)} target="_blank" rel="noopener" aria-label={`${display} on LinkedIn`} class="inline-flex size-9 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-colors hover:border-scooter hover:text-scooter group-hover:border-white/20 group-hover:text-white">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14ZM8.34 18.34V10.5H5.7v7.84h2.64Zm-1.32-8.92a1.53 1.53 0 1 0 0-3.06 1.53 1.53 0 0 0 0 3.06Zm11.32 8.92v-4.3c0-2.3-1.23-3.37-2.88-3.37a2.49 2.49 0 0 0-2.26 1.25v-1.07h-2.64v7.49h2.64v-4.16c0-1.1.21-2.17 1.57-2.17 1.34 0 1.34 1.26 1.34 2.24v4.09h2.23Z"/></svg>
                  </a>
                  <a href={emailFor(display)} aria-label={`Email ${display}`} class="inline-flex size-9 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-colors hover:border-scooter hover:text-scooter group-hover:border-white/20 group-hover:text-white">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>

        <!-- Dots + arrows -->
        <div class="mt-10 flex items-center justify-between gap-6">
          <div id="team-dots" class="flex items-center gap-2">
            {Array.from({ length: Math.max(1, teamCards.length - 2) }).map((_, i) => (
              <button type="button" data-dot={i} aria-label={`Slide ${i + 1}`} class="h-1.5 w-6 rounded-full bg-line transition-colors data-[active=1]:bg-delft"></button>
            ))}
          </div>
          <div class="flex items-center gap-3">
            <button type="button" id="team-prev" aria-label="Previous" class="inline-flex size-12 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-colors hover:border-delft hover:text-delft">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M19 12H5"/><path d="m11 19-7-7 7-7"/></svg>
            </button>
            <button type="button" id="team-next" aria-label="Next" class="inline-flex size-12 items-center justify-center rounded-full bg-delft text-white transition-colors hover:bg-scooter">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
            </button>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ CTA — We can't wait to meet you ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122d] py-20 text-white md:py-28">
    <div class="pointer-events-none absolute inset-0 opacity-25" style="background-image:url('/images/home/hero-pattern-grid.png');background-size:cover;background-position:center;"></div>
    <div class="pointer-events-none absolute -bottom-1/3 left-1/2 h-[110%] w-[110%] -translate-x-1/2" style="background:radial-gradient(ellipse at center, rgba(73,134,213,0.35), transparent 65%);"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-white/80">
        <span class="block size-1.5 rounded-full bg-scooter"></span>
        <span class="font-mono text-[0.72rem] uppercase tracking-[0.22em]">We can't wait to meet you</span>
      </div>

      <div data-reveal class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">
          Let's talk. The right financial partner makes all the difference.
        </h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-3 rounded-full bg-scooter px-7 py-4 font-display text-sm font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Request a Consultation
            <span class="inline-flex size-7 items-center justify-center rounded-full bg-white/15 transition-transform group-hover:translate-x-1 group-hover:bg-navy-950/10">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
            </span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ "Alpine Mar" big banner (light variant) ═════════════ -->
  <section class="relative overflow-hidden bg-paper">
    <Container width="wide" class="relative">
      <div class="flex flex-col items-center gap-6 pb-16 pt-12 text-center md:pb-24 md:pt-16">
        <div class="flex size-16 items-center justify-center rounded-full bg-white shadow-[0_10px_30px_-10px_rgba(18,18,45,0.25)]">
          <img src="/favicon.svg" alt="Alpine Mar" class="size-9" />
        </div>
        <h2 data-reveal class="am-gradient-ink font-display font-medium leading-[0.85] tracking-[-0.045em]" style="font-size:clamp(4rem,18vw,18rem);">
          Alpine Mar
        </h2>
      </div>
    </Container>
  </section>

  <style>
    /* First team card permanently in "active" navy state per Figma default. */
    #team-track > article:first-child {
      background-color: #12122d;
      border-color: var(--color-delft);
      color: #fff;
    }
    #team-track > article:first-child h3 {
      background: none !important;
      -webkit-background-clip: initial !important;
      background-clip: initial !important;
      -webkit-text-fill-color: #fff !important;
      color: #fff !important;
    }
    #team-track > article:first-child dl,
    #team-track > article:first-child .border-line {
      border-color: rgba(255, 255, 255, 0.14) !important;
    }
    #team-track > article:first-child dt { color: rgba(255, 255, 255, 0.65); }
    #team-track > article:first-child dd { color: #fff; }
    #team-track > article:first-child a {
      border-color: rgba(255, 255, 255, 0.2);
      color: #fff;
    }
  </style>

  <script>
    function initTeamCarousel() {
      const track = document.getElementById('team-track');
      if (!track || (track as any).__teamBound) return;
      (track as any).__teamBound = true;
      const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('#team-dots [data-dot]'));
      const prev = document.getElementById('team-prev');
      const next = document.getElementById('team-next');
      const cards = track.children;
      const total = cards.length;

      const setActive = (i: number) =>
        dots.forEach((d, idx) => { d.dataset.active = idx === i ? '1' : '0'; });

      const scrollToIndex = (i: number) => {
        const card = cards[i] as HTMLElement | undefined;
        if (!card) return;
        track.scrollTo({ left: card.offsetLeft - 24, behavior: 'smooth' });
      };

      const detectActive = () => {
        const left = track.scrollLeft;
        let best = 0;
        let bestDist = Infinity;
        for (let i = 0; i < total; i++) {
          const card = cards[i] as HTMLElement;
          const d = Math.abs(card.offsetLeft - 24 - left);
          if (d < bestDist) { bestDist = d; best = i; }
        }
        const lastDot = dots.length - 1;
        setActive(Math.min(best, lastDot));
        return best;
      };

      track.addEventListener('scroll', () => requestAnimationFrame(detectActive));
      dots.forEach((d, i) => d.addEventListener('click', () => scrollToIndex(i)));
      prev?.addEventListener('click', () => scrollToIndex(Math.max(0, detectActive() - 1)));
      next?.addEventListener('click', () => scrollToIndex(Math.min(total - 1, detectActive() + 1)));
      setActive(0);
    }
    initTeamCarousel();
    document.addEventListener('astro:after-swap', initTeamCarousel);
  </script>
</BaseLayout>

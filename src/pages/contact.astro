---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Icon from '@/components/Icon.astro';
import { site } from '@/data/site';

const inputClass =
  'w-full border border-line bg-white px-4 py-3 text-navy-900 placeholder:text-navy-300 transition-colors focus:border-teal-500 focus-visible:outline-none';
---

<BaseLayout
  rawTitle="Contact Our Tax & Accounting Experts at Alpine Mar"
  description="Contact our CPA experts at Alpine Mar to see how our accounting & tax solutions can help you."
>
  <section class="relative overflow-hidden bg-paper pt-16 lg:pt-24">
    <Container width="wide" class="relative grid gap-14 pb-24 lg:grid-cols-12 lg:gap-x-12 lg:pb-32">
      <!-- left: intro + details -->
      <div class="lg:col-span-5" data-reveal>
        <Eyebrow tone="dark">Contact</Eyebrow>
        <h1 class="mt-7 text-navy-900 text-hero-md">
          Say hello to a <span class="italic text-teal-600">different</span> type of accountant.
        </h1>
        <p class="mt-7 max-w-md text-lg leading-relaxed text-navy-600">
          Reach out to us to learn how we can create efficient solutions tailor-made to meet your needs.
        </p>

        <dl class="mt-12 border-t border-line">
          <div class="flex items-start gap-4 border-b border-line py-6">
            <span class="flex size-10 shrink-0 items-center justify-center bg-navy-900 text-teal-400"><Icon name="award" class="h-4 w-4" /></span>
            <div>
              <dt class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-scooter">Office</dt>
              <dd class="mt-1 text-navy-900">515 E Las Olas Blvd, Suite 120<br />Fort Lauderdale, FL 33301</dd>
            </div>
          </div>
          <div class="flex items-start gap-4 border-b border-line py-6">
            <span class="flex size-10 shrink-0 items-center justify-center bg-navy-900 text-teal-400"><Icon name="phone" class="h-4 w-4" /></span>
            <div>
              <dt class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-scooter">Contact</dt>
              <dd class="mt-1 text-navy-900">
                <a href={`mailto:${site.email}`} class="transition-colors hover:text-teal-700">{site.email}</a><br />
                <a href={`tel:${site.phoneHref}`} class="transition-colors hover:text-teal-700">{site.phone}</a>
              </dd>
            </div>
          </div>
        </dl>
        <p class="mt-8 max-w-md text-sm leading-relaxed text-navy-400">
          Members of the American Institute of Certified Public Accountants and the Florida
          Institute of Certified Public Accountants.
        </p>
      </div>

      <!-- right: consultation form -->
      <div class="lg:col-span-7" data-reveal>
        <form id="consult-form" class="border border-line bg-white p-7 lg:p-10" novalidate>
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-teal-700">Request a consultation</p>
          <h2 class="mt-3 text-2xl tracking-[-0.01em] text-navy-900">Let’s get on a first name basis.</h2>

          <div class="mt-8 grid gap-5 sm:grid-cols-2">
            <label class="block">
              <span class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-navy-500">First name</span>
              <input class={`mt-2 ${inputClass}`} type="text" name="first_name" autocomplete="given-name" required />
            </label>
            <label class="block">
              <span class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-navy-500">Last name</span>
              <input class={`mt-2 ${inputClass}`} type="text" name="last_name" autocomplete="family-name" required />
            </label>
            <label class="block">
              <span class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-navy-500">Email</span>
              <input class={`mt-2 ${inputClass}`} type="email" name="email" autocomplete="email" required />
            </label>
            <label class="block">
              <span class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-navy-500">Phone</span>
              <input class={`mt-2 ${inputClass}`} type="tel" name="phone" autocomplete="tel" />
            </label>
            <label class="block sm:col-span-2">
              <span class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-navy-500">Business name</span>
              <input class={`mt-2 ${inputClass}`} type="text" name="business_name" autocomplete="organization" />
            </label>
          </div>

          <label class="mt-5 block">
            <span class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-navy-500">How can we help?</span>
            <select id="svc-select" class={`mt-2 ${inputClass}`} name="service" required>
              <option value="">Select a service…</option>
              <optgroup label="Tax">
                <option>Tax Planning</option>
                <option>Tax Strategy</option>
                <option>Individual Tax</option>
                <option>Corporate Tax</option>
                <option>Partnership Tax</option>
                <option>S Corps</option>
                <option>Estate & Trust Tax Planning</option>
                <option>Multistate Tax</option>
                <option>International Tax</option>
                <option>Small Business Tax</option>
                <option>Non-Profit Tax</option>
                <option>Private Client Services</option>
              </optgroup>
              <optgroup label="Accounting">
                <option>Outsourced Accounting</option>
                <option>Outsourced Bookkeeping</option>
                <option>Financial Statement Preparation</option>
                <option>Accounting Software Implementation</option>
                <option>Trust Accounting</option>
              </optgroup>
              <optgroup label="Advisory">
                <option>Fractional CFO</option>
                <option>Transaction Advisory</option>
                <option>Financial Modeling</option>
                <option>Financial Advisory</option>
              </optgroup>
              <optgroup label="Compliance">
                <option>Entity Structuring</option>
                <option>BOI Reporting</option>
                <option>Payroll Compliance</option>
                <option>Financial Compliance</option>
              </optgroup>
              <optgroup label="Audit & Attestation">
                <option>Audit & Attestation Services</option>
                <option>Financial Statement Audits</option>
                <option>Reviews & Compilations</option>
                <option>Employee Benefit Plan Audits</option>
              </optgroup>
              <option value="BOI One-time Filing">BOI One-time Filing</option>
              <option value="BOI Unlimited Filing Subscription">BOI Unlimited Filing Subscription</option>
              <option value="BOI Enterprise Filing">BOI Enterprise Filing</option>
              <option value="Not sure — recommend">Not sure — recommend</option>
              <option value="Other/Special Projects">Other/Special Projects</option>
            </select>
          </label>

          <!-- Smart fields — appear based on service selection -->
          <div id="smart-fields" class="mt-5 hidden space-y-5"></div>

          <label class="mt-5 block">
            <span class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-navy-500">Message</span>
            <textarea class={`mt-2 ${inputClass} min-h-32 resize-y`} name="message" rows="4"></textarea>
          </label>

          <button type="submit" class="group mt-7 inline-flex items-center justify-center gap-2.5 bg-teal-500 px-7 py-4 font-mono text-[0.8rem] font-medium uppercase tracking-[0.08em] text-navy-950 transition-all duration-200 hover:bg-teal-400 active:scale-[0.98]">
            Request Consultation
            <Icon name="arrow-right" class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" />
          </button>

          <p id="consult-success" class="mt-5 hidden border-l-2 border-teal-500 bg-navy-50 px-4 py-3 text-sm text-navy-900">
            Thank you — we’ve received your request and will be in touch shortly.
          </p>
        </form>
      </div>
    </Container>
  </section>

  <script>
    function initContactForm() {
      const form = document.getElementById('consult-form') as HTMLFormElement | null;
      if (!form || form.dataset.contactBound === '1') return;
      form.dataset.contactBound = '1';
      const ok = document.getElementById('consult-success');
      const select = document.getElementById('svc-select') as HTMLSelectElement | null;
      const smartFields = document.getElementById('smart-fields') as HTMLDivElement | null;

    const fieldInput = 'w-full border border-line bg-white px-4 py-3 text-navy-900 placeholder:text-navy-300 transition-colors focus:border-teal-500 focus-visible:outline-none';
    const labelClass = 'font-mono text-[0.7rem] uppercase tracking-[0.14em] text-navy-500';

    // ── 1) Pre-fill service from ?service= query param ─────────────────────
    const params = new URLSearchParams(window.location.search);
    const prefill = params.get('service');
    if (prefill && select) {
      for (const opt of Array.from(select.options)) {
        if (opt.value === prefill || opt.textContent?.trim() === prefill) {
          opt.selected = true;
          break;
        }
      }
      // Trigger smart-field rendering
      select.dispatchEvent(new Event('change'));
    }

    // ── 2) Smart fields by service ─────────────────────────────────────────
    type SmartField = { name: string; label: string; type?: 'text' | 'number' | 'select'; options?: string[]; placeholder?: string };
    const SMART_MAP: Record<string, SmartField[]> = {
      'BOI Reporting': [
        { name: 'entity_type', label: 'Entity type', type: 'select', options: ['LLC', 'C-Corp', 'S-Corp', 'Partnership', 'Holding company', 'Other'] },
        { name: 'beneficial_owners', label: 'Approx. number of beneficial owners', type: 'number', placeholder: '1' },
      ],
      'BOI One-time Filing': [
        { name: 'entity_type', label: 'Entity type', type: 'select', options: ['LLC', 'C-Corp', 'S-Corp', 'Partnership', 'Holding company', 'Other'] },
      ],
      'BOI Unlimited Filing Subscription': [
        { name: 'num_entities', label: 'Number of entities to file', type: 'number', placeholder: '1' },
      ],
      'BOI Enterprise Filing': [
        { name: 'num_entities', label: 'Estimated entity count', type: 'number', placeholder: '25' },
      ],
      'Fractional CFO': [
        { name: 'company_size', label: 'Company size (FTEs)', type: 'select', options: ['1–5', '6–25', '26–100', '100+'] },
        { name: 'hours_needed', label: 'Hours per month needed', type: 'select', options: ['Not sure', '10–20', '20–40', '40+'] },
      ],
      'Tax Planning': [
        { name: 'entity_type', label: 'Entity / filing type', type: 'select', options: ['Individual (W-2)', 'Sole prop / 1099', 'LLC', 'S-Corp', 'C-Corp', 'Partnership'] },
        { name: 'state', label: 'State of residence', placeholder: 'FL' },
      ],
      'Tax Strategy': [
        { name: 'entity_type', label: 'Entity / filing type', type: 'select', options: ['Individual (W-2)', 'Sole prop / 1099', 'LLC', 'S-Corp', 'C-Corp', 'Partnership'] },
        { name: 'income_range', label: 'Annual income range', type: 'select', options: ['<$250k', '$250k–$1M', '$1M–$5M', '$5M+'] },
      ],
      'Transaction Advisory': [
        { name: 'deal_side', label: 'Buy-side or sell-side?', type: 'select', options: ['Buy-side', 'Sell-side', 'Both'] },
        { name: 'deal_size', label: 'Approximate deal size', placeholder: '$X million' },
      ],
      'Audit & Attestation Services': [
        { name: 'audit_type', label: 'Type of engagement', type: 'select', options: ['Financial Statement Audit', 'Review', 'Compilation', 'Employee Benefit Plan Audit', 'Not sure'] },
      ],
      'Outsourced Accounting': [
        { name: 'monthly_volume', label: 'Approx. monthly transactions', type: 'select', options: ['<100', '100–500', '500–2000', '2000+'] },
        { name: 'software', label: 'Current accounting software', placeholder: 'QuickBooks Online, NetSuite, …' },
      ],
      'Other/Special Projects': [
        { name: 'project_type', label: 'Project type', placeholder: 'Tell us what you need help with' },
      ],
    };
    SMART_MAP['Outsourced Bookkeeping'] = SMART_MAP['Outsourced Accounting'];
    SMART_MAP['Financial Statement Audits'] = SMART_MAP['Audit & Attestation Services'];
    SMART_MAP['Reviews & Compilations'] = SMART_MAP['Audit & Attestation Services'];
    SMART_MAP['Employee Benefit Plan Audits'] = SMART_MAP['Audit & Attestation Services'];

    function renderSmart(service: string) {
      if (!smartFields) return;
      const fields = SMART_MAP[service];
      if (!fields) { smartFields.classList.add('hidden'); smartFields.innerHTML = ''; return; }
      smartFields.classList.remove('hidden');
      smartFields.innerHTML = `
        <div class="border-l-2 border-teal-500 pl-4">
          <p class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-teal-700">For ${service}, we also need…</p>
        </div>
        <div class="grid gap-5 sm:grid-cols-2">
          ${fields.map((f) => `
            <label class="block">
              <span class="${labelClass}">${f.label}</span>
              ${f.type === 'select' ? `
                <select name="${f.name}" class="mt-2 ${fieldInput}">
                  ${(f.options || []).map((o) => `<option>${o}</option>`).join('')}
                </select>
              ` : `
                <input type="${f.type || 'text'}" name="${f.name}" placeholder="${f.placeholder || ''}" class="mt-2 ${fieldInput}" />
              `}
            </label>
          `).join('')}
        </div>
      `;
    }
    select?.addEventListener('change', () => renderSmart(select.value));
    if (prefill && select?.value) renderSmart(select.value);

    // ── 3) Submit (stub) ───────────────────────────────────────────────────
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!form.checkValidity()) { form.reportValidity(); return; }
      ok?.classList.remove('hidden');
      form.querySelectorAll('input, select, textarea, button').forEach((el) => ((el as HTMLInputElement).disabled = true));
    });
    }

    document.addEventListener('astro:page-load', initContactForm);
  </script>
</BaseLayout>

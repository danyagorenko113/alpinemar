---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import ContactForm from '@/components/ContactForm.astro';
import MapEmbed from '@/components/MapEmbed.astro';
import { site } from '@/data/site';
---

<BaseLayout
  rawTitle="Contact Our Tax & Accounting Experts at Alpine Mar"
  description="Contact our CPA experts at Alpine Mar to see how our accounting & tax solutions can help you."
>
  <!-- ═════════════ CONTACT — matches the home "Contact Us" section ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122d] pt-24 pb-24 text-white md:pt-32 md:pb-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-12 flex items-center gap-3 text-white/85">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Contact Us</span>
      </div>

      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        <!-- Left: Title + intro + Office / Contact cards -->
        <div data-reveal class="flex flex-col gap-10 lg:col-span-5">
          <div class="flex flex-col gap-7">
            <h1 class="am-h1-display am-gradient-ink-light">
              Book a<br />consultation.
            </h1>
            <p class="font-display text-[15px] leading-[1.65] text-white/75">
              Reach out to us to learn how we can create efficient solutions tailor-made to meet your needs.
            </p>
          </div>

          <div class="flex flex-col gap-5">
            <div class="rounded-[6px] bg-white/[0.05] p-7">
              <h2 class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-scooter">Our Location</h2>
              <a href={site.maps.directions} target="_blank" rel="noopener" class="mt-6 block font-display text-[15px] leading-[1.6] text-white transition-colors hover:text-scooter">
                {site.address.street}<br />
                {site.address.city}, {site.address.state} {site.address.zip}
              </a>
              <MapEmbed class="mt-6" title={`Map to ${site.name} in ${site.address.city}`} />
            </div>
            <div class="rounded-[6px] bg-white/[0.05] p-7">
              <h2 class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-scooter">Contact Information</h2>
              <p class="mt-6 font-display text-[15px] leading-[1.7] text-white">
                <a href={`tel:${site.phoneHref}`} class="block transition-colors hover:text-scooter">{site.phone}</a>
                <a href={`mailto:${site.email}`} class="block transition-colors hover:text-scooter">{site.email}</a>
              </p>
            </div>
          </div>

          <p class="max-w-md font-display text-[13px] leading-[1.6] text-white/55">
            Members of the American Institute of Certified Public Accountants and the Florida Institute of Certified Public Accountants.
          </p>
        </div>

        <!-- Right: shared consultation form (same as home) -->
        <div data-reveal class="lg:col-span-7">
          <ContactForm id="contact-page-form" />
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

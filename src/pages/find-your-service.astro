---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { allServices } from '@/data/taxonomy';

const pathways = [
  {
    label: 'I run a business and need year-round support',
    services: [
      { title: 'Outsourced Accounting',     href: '/services/outsourced-accounting-services/' },
      { title: 'Fractional CFO',            href: '/services/fractional-cfo-services/' },
      { title: 'Business Tax',              href: '/services/business-tax/' },
      { title: 'Outsourced Bookkeeping',    href: '/services/outsourced-bookkeeping-services/' },
    ],
  },
  {
    label: "I'm preparing for a transaction (M&A, fundraise, exit)",
    services: [
      { title: 'Transaction Advisory',           href: '/services/transaction-advisory-services/' },
      { title: 'Financial Modeling',             href: '/services/financial-modeling-services/' },
      { title: 'Financial Statement Audits',     href: '/services/audit-attestation-services/financial-statement-audits/' },
      { title: 'Fractional CFO',                 href: '/services/fractional-cfo-services/' },
    ],
  },
  {
    label: "I'm an individual or HNW — I need planning, not just filing",
    services: [
      { title: 'Tax Planning',         href: '/services/tax-planning-services/' },
      { title: 'Private Client',       href: '/services/private-client-services/' },
      { title: 'Estate &amp; Trust',   href: '/services/estate-trust-tax-planning/' },
      { title: 'Individual Tax',       href: '/services/individual-tax-services/' },
    ],
  },
  {
    label: "I'm an S-Corp / multistate / international taxpayer",
    services: [
      { title: 'S Corp CPA',           href: '/services/s-corp-cpa-services/' },
      { title: 'Multistate Tax',       href: '/services/multistate-tax-services/' },
      { title: 'International Tax',    href: '/services/international-tax-services/' },
      { title: 'Corporate Tax',        href: '/services/corporate-tax-services/' },
    ],
  },
];
---

<BaseLayout rawTitle="Find Your Service — Alpine Mar" description="A quick triage of Alpine Mar services based on what you're actually trying to do.">
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-16 text-white md:pt-16 md:pb-20">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="mx-auto max-w-[64ch] text-center">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[36px] md:text-[40px]">Find your service</h1>
        <p class="mt-3 font-display text-[14px] leading-[1.55] text-white/70 md:text-[15px]">
          {allServices.length} services and one obvious question: what are you actually trying to do? Pick the closest match below.
        </p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ PATHWAYS ═════════════ -->
  <section class="relative bg-paper py-20 md:py-24">
    <Container width="wide">
      <ul class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {pathways.map((p, i) => (
          <li class="flex flex-col gap-5 rounded-[6px] border border-line bg-white p-7">
            <span class="font-mono text-[12px] uppercase tracking-[0.16em] text-scooter">Pathway {String(i + 1).padStart(2, '0')}</span>
            <h2 class="font-display text-[20px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)]" set:html={p.label}></h2>
            <ul class="flex flex-col">
              {p.services.map((s) => (
                <li>
                  <a href={s.href} class="group flex items-center justify-between gap-4 border-b border-line py-3.5 last:border-b-0">
                    <span class="font-display text-[14px] text-[var(--color-text-head)] transition-colors group-hover:text-scooter" set:html={s.title}></span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="text-[var(--color-text-body)] transition-all group-hover:translate-x-1 group-hover:text-scooter"><path d="m9 18 6-6-6-6"/></svg>
                  </a>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>

      <p class="mt-12 text-center font-display text-[14px] text-[var(--color-text-body)]">
        Nothing fits exactly? <a href="/contact/" class="font-medium text-[var(--color-text-head)] underline underline-offset-4 transition-colors hover:text-scooter">Talk to a partner</a> — we'll triage on the intro call.
      </p>
    </Container>
  </section>

  <!-- ═════════════ CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">Let's match you to the right CPA, fast.</h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Request a Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

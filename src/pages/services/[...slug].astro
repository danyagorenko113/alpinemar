---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { allServices, industries as industryList } from '@/data/taxonomy';
import { serviceSchema, breadcrumb } from '@/data/schema';
import { googleReviews } from '@/data/googleReviews';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((s) => ({
    params: { slug: s.data.path.replace(/^\/services\//, '').replace(/\/$/, '') },
    props: { service: s, all: services, slug: s.data.path.replace(/^\/services\//, '').replace(/\/$/, '') },
  }));
}

const { service, all, slug } = Astro.props;
const { Content } = await render(service);

// AI-generated hero per service (script: scripts/generate-service-covers.mjs).
// Falls back to frontmatter cover, then to the About hero image.
const heroImage = `/images/services/${slug}.jpg`;
const coverSrc = service.data.cover ?? heroImage;

const taxonomyEntry = allServices.find((x) => x.href === service.data.path);
const group = (service.data.group ?? taxonomyEntry?.group) as
  | 'Tax' | 'Accounting' | 'Advisory' | 'Compliance' | undefined;

// Siblings within the same category
const siblings = group
  ? allServices.filter((s) => s.group === group && s.href !== service.data.path).slice(0, 6)
  : [];
const fallbackRelated = all
  .filter((s) => s.id !== service.id)
  .slice(0, 6)
  .map((s) => ({ title: s.data.title, href: s.data.path }));
const related = siblings.length
  ? siblings.map((s) => ({ title: s.title, href: s.href }))
  : fallbackRelated;

// Industries linked from frontmatter
const linkedIndustries = (service.data.industries ?? [])
  .map((slug) => industryList.find((i) => i.href.includes(slug)))
  .filter((x): x is (typeof industryList)[number] => !!x);

const takeaways = service.data.takeaways ?? [];
const included = service.data.included ?? [];
const process = service.data.process ?? [];

// Per-section copy overrides from frontmatter (CMS "Section copy" card).
// Every string falls back to the built-in default.
const sc = service.data.sectionCopy ?? {};

// Landing-style "What you get" — uses takeaways when supplied, otherwise
// a sensible 4-up default that applies to every Alpine Mar engagement.
const benefits = takeaways.length
  ? takeaways
  : [
      { title: 'Partner Involvement', body: 'A CPA on every engagement. No junior handoff once you sign.' },
      { title: 'Fixed-fee, scoped',   body: 'Scope and price agreed before we start. No hourly meter or surprise invoices.' },
      { title: 'Year-round attention', body: 'We work the calendar, not just the deadline. Quarterly check-ins by default.' },
      { title: 'Modern finance stack', body: 'Cloud books, AI, automation, and secure portals. Work moves faster without losing rigor.' },
    ];

// "Why Alpine Mar" pillars — CMS-supplied, defaulting to the firm's three.
const PILLAR_ICONS = ['/icons/about/quality.svg', '/icons/about/innovation.svg', '/icons/about/collaboration.svg'];
const defaultPillars = [
  { title: 'National and international expertise', body: "Single-state, multistate, or cross-border, our CPAs know the complexity and know how to navigate it without leaving money on the table." },
  { title: 'Proactive approach',                   body: "We don't wait for deadlines to find savings. We plan ahead so you're always in a better position than you were last year." },
  { title: 'Adapted to your needs',                body: 'Individual, small business, S-Corp, or multijurisdictional, your situation is specific and our service should be too.' },
];
const pillars = (service.data.pillars?.length ? service.data.pillars : defaultPillars)
  .map((p, i) => ({ ...p, icon: PILLAR_ICONS[i % PILLAR_ICONS.length] }));

const ctaLabel = sc.cta?.button ?? 'Request a Consultation';

const defaultFaq = [
  { q: 'How quickly can we start?',                              a: 'We schedule an intro call within a few business days and can begin scoping the same week.' },
  { q: 'How are fees structured?',                               a: `${service.data.title} is quoted as a fixed fee with a clearly scoped deliverable, after the intro call. We don't bill by the hour for known scopes. Ongoing work (like monthly close or fractional CFO) is a flat monthly retainer.` },
  { q: 'Will I work with the same person, or get passed around?', a: 'Every engagement is partner-led. The senior CPA you meet on the intro is the one running your file. Day-to-day support comes from a senior associate, with partner sign-off on every deliverable.' },
  { q: 'Are you taking new clients?',                            a: `Yes. We're actively onboarding new clients year-round, and we pace intake so every partner can hold the service standard the firm is known for.` },
];
const faq = (service.data.faq ?? []).length ? service.data.faq! : defaultFaq;
const reviewIndex = Math.min(service.data.reviewIndex ?? 0, googleReviews.length - 1);
const clientView = googleReviews[reviewIndex];

// ── Section visibility & order (CMS-controlled) ───────────────────────────
// `sections` frontmatter lists every block to show, in order; omit for the
// default full layout. All nine blocks are controllable from the CMS.
const MASTER_ORDER = ['benefits', 'included', 'process', 'deepdive', 'reviews', 'industries', 'pillars', 'related', 'faq'] as const;
type SectionKey = (typeof MASTER_ORDER)[number];
const customSections = service.data.sections as SectionKey[] | undefined;
const renderOrder: SectionKey[] = customSections ?? [...MASTER_ORDER];

const schema = [
  serviceSchema({ name: service.data.title, description: service.data.summary, path: service.data.path }),
  breadcrumb([
    { name: 'Home', path: '/' },
    { name: 'Services', path: '/services/' },
    { name: service.data.title, path: service.data.path },
  ]),
];
---

<BaseLayout
  rawTitle={service.data.seo?.title ?? `${service.data.title} | Alpine Mar`}
  description={service.data.seo?.description ?? service.data.summary}
  image={service.data.cover}
  canonical={service.data.seo?.canonical}
  schema={schema}
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative isolate overflow-hidden bg-paper">
    <div class="relative h-[340px] max-h-[380px] w-full md:aspect-[12/5] md:h-auto lg:max-h-[420px]">
      <img src={coverSrc} alt={service.data.coverAlt ?? ''} aria-hidden={service.data.coverAlt ? undefined : 'true'} class="absolute inset-0 h-full w-full object-cover object-center" onerror="this.src='/images/about/hero.jpg'" />
      <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-b from-transparent via-white/55 to-white"></div>

      <Container width="wide" class="relative z-10 flex h-full flex-col justify-end pb-10 md:pb-14">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="inline-flex max-w-full items-center gap-2 overflow-hidden whitespace-nowrap rounded-full bg-white/80 px-4 py-2 font-display text-[13px] font-medium text-navy-950 shadow-[0_12px_30px_-18px_rgba(18,18,45,0.6)] backdrop-blur-sm">
            <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
            <li aria-hidden="true" class="opacity-55">/</li>
            <li><a href="/services/" class="transition-colors hover:text-scooter">Services</a></li>
            {group && (<>
              <li aria-hidden="true" class="opacity-55">/</li>
              <li><a href="/services/" class="transition-colors hover:text-scooter">{group}</a></li>
            </>)}
            <li aria-hidden="true" class="hidden opacity-55 sm:inline">/</li>
            <li aria-current="page" class="hidden max-w-[36ch] truncate font-medium sm:inline">{service.data.title}</li>
          </ol>
        </nav>

        <h1 class="am-hero-display am-gradient-ink max-w-[18ch]">
          {service.data.heroTitle ?? service.data.title}
        </h1>
      </Container>
    </div>
  </section>

  <!-- ═════════════ SUMMARY + CTA STRIP ═════════════ -->
  <section class="relative bg-white py-8 md:py-20">
    <Container width="wide">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-16">
        <p class="font-display text-[18px] leading-[1.55] text-[var(--color-text-head)] md:col-span-8">
          {service.data.summary}
        </p>
        <div class="flex flex-col items-start gap-4 md:col-span-4 md:items-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-delft px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter">
            {ctaLabel}
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

    {renderOrder.map((sectionKey) => (
    <Fragment>
      {sectionKey === 'benefits' && (
  <section class="relative bg-paper py-12 md:py-24">
    <Container width="wide">
      <div class="mb-8 flex items-center gap-3 text-[var(--color-text-head)] md:mb-10">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">{sc.benefits?.eyebrow ?? 'What you get'}</span>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">
          {sc.benefits?.heading ?? 'The engagement, in a nutshell.'}
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
          {sc.benefits?.intro ?? `Every Alpine Mar ${service.data.title.toLowerCase()} engagement is built on the same four commitments.`}
        </p>
      </div>
      <ul class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 md:mt-14 lg:grid-cols-4">
        {benefits.map((b, i) => (
          <li class="flex flex-col gap-5 rounded-[6px] border border-line bg-white p-5 md:p-7">
            <span class="font-mono text-[12px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="font-display text-[18px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)]">{b.title}</h3>
            {b.body && (<p class="font-display text-[14px] leading-[1.6] text-[var(--color-text-body)]">{b.body}</p>)}
          </li>
        ))}
      </ul>
    </Container>
  </section>

  
      )}
      {sectionKey === 'included' && included.length > 0 && (
    <section class="relative overflow-hidden bg-[#12122D] py-12 text-white md:py-32">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

      <Container width="wide" class="relative z-10">
        <div class="mb-8 flex items-center gap-3 text-white/85 md:mb-10">
          <span class="block size-2 bg-scooter"></span>
          <span class="font-display text-[14px] tracking-[-0.005em]">{sc.included?.eyebrow ?? "What's included"}</span>
        </div>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-16">
          <h2 class="am-h1-display am-gradient-ink-light md:col-span-7">{sc.included?.heading ?? 'A defined scope, not a black box.'}</h2>
          <p class="font-display text-[15px] leading-[1.65] text-white/75 md:col-span-5 md:pt-3">
            {sc.included?.intro ?? `Engagements are scoped before they start. Here's what a typical ${service.data.title.toLowerCase()} engagement covers.`}
          </p>
        </div>
        <ul class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-2 md:mt-12 lg:grid-cols-3">
          {included.map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full border-2 border-scooter">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-scooter"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="font-display text-[14px] leading-[1.5] text-white">{item}</span>
            </li>
          ))}
        </ul>
      </Container>
    </section>
  )}
      {sectionKey === 'process' && (
  <section class="relative bg-white py-12 md:py-32">
    <Container width="wide">
      <div class="mb-8 flex items-center gap-3 text-[var(--color-text-head)] md:mb-10">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">{sc.process?.eyebrow ?? 'How we work'}</span>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">{sc.process?.heading ?? 'From first call to closed loop.'}</h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
          {sc.process?.intro ?? 'Four predictable steps. No surprise scope creep, no junior handoffs, no hourly meter ticking on routine questions.'}
        </p>
      </div>
      <ol class="mt-8 grid grid-cols-1 gap-5 md:mt-14 md:grid-cols-2 lg:grid-cols-4">
        {(process.length ? process : [
          { title: 'Intro call', body: `An introductory call including the partner who'd run your engagement. We cover scope, timing, and fit.` },
          { title: 'Discovery',  body: 'We look at your books, prior filings, and stack. You get a scoping memo and a flat fee.' },
          { title: 'Engagement', body: 'Work is delivered by a senior team. You see drafts, not silence, with weekly status by default.' },
          { title: 'Wrap-up',    body: 'Deliverables ship with a written summary. You keep working with the same team next round.' },
        ]).map((p, i) => (
          <li class="flex flex-col gap-4 rounded-[6px] border border-line bg-paper p-5 md:p-7">
            <span class="font-mono text-[12px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step {String(i + 1).padStart(2, '0')}</span>
            <h3 class="font-display text-[20px] font-medium tracking-[-0.01em] text-[var(--color-text-head)]">{p.title}</h3>
            <p class="font-display text-[14px] leading-[1.6] text-[var(--color-text-body)]">{p.body}</p>
          </li>
        ))}
      </ol>
    </Container>
  </section>

  
      )}
      {sectionKey === 'deepdive' && (
  <section class="relative bg-paper py-12 md:py-32">
    <Container width="wide">
      <div class="mb-8 flex items-center gap-3 text-[var(--color-text-head)] md:mb-10">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">{sc.deepdive?.eyebrow ?? 'Deep dive'}</span>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">
          {sc.deepdive?.heading ?? 'The detail, if you want it.'}
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
          {sc.deepdive?.intro ?? `The full breakdown of how we approach ${service.data.title.toLowerCase()} — written for clients who want to see the rigor before signing on.`}
        </p>
      </div>

      <div class="mt-8 grid grid-cols-1 gap-6 md:mt-14 md:grid-cols-12 md:gap-16">
        <div class="rounded-[6px] border border-line bg-white p-6 md:col-span-9 md:p-12">
          <div class="prose-am">
            <Content />
          </div>
        </div>
        <aside class="md:col-span-3">
          <div class="sticky top-28 rounded-[6px] bg-[#12122D] p-6 text-white md:p-7">
            <p class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-head)]">Quick answer</p>
            <p class="mt-5 font-display text-[15px] leading-[1.55] text-white/85">
              {sc.deepdive?.aside ?? 'Skip the long read? The summary above plus the FAQ below cover 90% of what clients ask before booking the intro call.'}
            </p>
            <a href="#faq" class="mt-6 inline-flex items-center gap-2 font-display text-[13px] font-medium text-scooter transition-colors hover:text-white">
              Jump to FAQ
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
            </a>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  
      )}
      {sectionKey === 'reviews' && (
  <section class="relative bg-white py-12 md:py-24">
    <Container width="wide">
      <div class="mb-8 flex items-center gap-3 text-[var(--color-text-head)] md:mb-10">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">{sc.reviews?.eyebrow ?? 'Client view'}</span>
      </div>
      <figure class="grid grid-cols-1 gap-6 rounded-[6px] border border-line bg-paper p-6 md:grid-cols-12 md:gap-16 md:p-14">
        <svg width="48" height="40" viewBox="0 0 32 26" fill="currentColor" aria-hidden="true" class="text-line md:col-span-1">
          <path d="M9.6 0C4.3 0 0 4.6 0 10.3v15.7h12.5V10.3H6.4c0-2.8 1.4-5.1 3.2-5.1V0Zm19.6 0c-5.3 0-9.6 4.6-9.6 10.3v15.7H32V10.3h-6.1c0-2.8 1.4-5.1 3.2-5.1V0Z"/>
        </svg>
        <div class="md:col-span-11">
          <div class="mb-4 flex items-center gap-1 font-display text-[13px] font-medium text-[#12122D]" aria-label="5 star Google review">
            <span aria-hidden="true">★★★★★</span>
            <span class="sr-only">5 star Google review</span>
          </div>
          <blockquote class="font-display text-[18px] leading-[1.5] tracking-[-0.005em] text-[var(--color-text-head)] md:text-[24px]">
            {clientView.quote}
          </blockquote>
          <figcaption class="mt-8 flex items-center gap-4 border-t border-line pt-6">
            <div class="inline-flex size-12 items-center justify-center rounded-full bg-[#12122D] font-display text-[13px] font-medium text-white">
              {clientView.initials}
            </div>
            <div>
              <p class="font-display text-[14px] font-medium text-[var(--color-text-head)]">{clientView.name}</p>
              <p class="font-display text-[12px] text-[var(--color-text-body)]">Google review · {clientView.date}</p>
            </div>
          </figcaption>
        </div>
      </figure>
    </Container>
  </section>

  
      )}
      {sectionKey === 'industries' && linkedIndustries.length > 0 && (
    <section class="relative bg-paper py-12 md:py-32">
      <Container width="wide">
        <div class="mb-8 flex items-center gap-3 text-[var(--color-text-head)] md:mb-10">
          <span class="block size-2 bg-scooter"></span>
          <span class="font-display text-[14px] tracking-[-0.005em]">{sc.industries?.eyebrow ?? "Who it's for"}</span>
        </div>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-16">
          <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">
            {sc.industries?.heading ?? 'Industries we run this for.'}
          </h2>
          <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
            {sc.industries?.intro ?? "Specialized playbooks for the verticals we know best — benchmarks, deductions, and tax positions that don't need explaining."}
          </p>
        </div>
        <ul class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 md:mt-14 lg:grid-cols-4">
          {linkedIndustries.map((ind) => (
            <li>
              <div class="group flex h-full min-h-[150px] flex-col justify-between gap-4 rounded-[6px] border border-line bg-white p-5 transition-colors hover:border-[#12122D]">
                <span>
                  <a href={ind.href} class="block font-display text-[15px] font-medium leading-[1.3] text-[var(--color-text-head)] transition-colors hover:text-scooter group-hover:text-scooter">{ind.title}</a>
                  <span class="mt-3 block line-clamp-2 font-display text-[12.5px] leading-[1.5] text-[var(--color-text-body)]">{ind.desc}</span>
                </span>
                <span class="inline-flex items-center gap-2 font-display text-[13px] font-medium text-[var(--color-text-head)] transition-colors group-hover:text-scooter">
                  Learn more
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
                </span>
              </div>
            </li>
          ))}
        </ul>
      </Container>
    </section>
  )}
      {sectionKey === 'pillars' && (
  <section class="relative overflow-hidden bg-[#12122D] py-12 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mb-8 flex items-center gap-3 text-white/85 md:mb-10">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">{sc.pillars?.eyebrow ?? 'Why Alpine Mar'}</span>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-7">
          {sc.pillars?.heading ? sc.pillars.heading : <>A strategy that works<br />as hard as you do.</>}
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-white/75 md:col-span-5 md:pt-3">
          {sc.pillars?.intro ?? "You'll hear from us before tax season, not just during it. Our team stays close to your financials year-round, flagging opportunities and managing compliance."}
        </p>
      </div>
      <ul class="mt-8 grid grid-cols-1 gap-5 md:mt-14 md:grid-cols-3">
        {pillars.map((p) => (
          <li class="flex flex-col gap-5 rounded-[6px] bg-white p-5 text-[var(--color-text-head)] md:gap-6 md:p-7">
            <span class="inline-flex size-12 items-center justify-center rounded-[6px] bg-paper">
              <img src={p.icon} alt="" aria-hidden="true" class="size-6" />
            </span>
            <h3 class="font-display text-[20px] font-medium leading-[1.25] tracking-[-0.01em]">{p.title}</h3>
            <p class="font-display text-[14px] leading-[1.6] text-[var(--color-text-body)]">{p.body}</p>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  
      )}
      {sectionKey === 'related' && related.length > 0 && (
    <section class="relative bg-paper py-12 md:py-24">
      <Container width="wide">
        <div class="mb-8 flex items-center gap-3 text-[var(--color-text-head)] md:mb-10">
          <span class="block size-2 bg-scooter"></span>
          <span class="font-display text-[14px] tracking-[-0.005em]">{sc.related?.eyebrow ?? (group ? `More ${group} services` : 'Related services')}</span>
        </div>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-16">
          <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">
            {sc.related?.heading ?? 'Often booked alongside this one.'}
          </h2>
          <a href="/services/" class="group inline-flex w-fit items-center gap-2 rounded-[6px] bg-delft px-6 py-3.5 font-display text-[15px] font-medium text-white transition-colors hover:bg-scooter md:col-span-5 md:justify-self-end md:bg-transparent md:px-0 md:py-0 md:pt-3 md:text-[14px] md:text-[var(--color-text-head)] md:hover:bg-transparent md:hover:text-scooter">
            {sc.related?.button ?? 'All services'}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="shrink-0 transition-transform group-hover:translate-x-1 md:size-[13px]"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
        <ul class="mt-8 grid grid-cols-1 gap-5 md:mt-12 md:grid-cols-2 lg:grid-cols-3">
          {related.map((s) => (
            <li>
              <div class="group flex h-full min-h-[130px] flex-col justify-between gap-6 rounded-[6px] border border-line bg-white p-5 transition-colors hover:border-[#12122D] md:min-h-[160px] md:p-6">
                <h3 class="font-display text-[18px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)]">
                  <a href={s.href} class="transition-colors hover:text-scooter group-hover:text-scooter">{s.title}</a>
                </h3>
                <span class="inline-flex items-center gap-2 font-display text-[13px] font-medium text-[var(--color-text-head)] transition-colors group-hover:text-scooter">
                  Learn more
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
                </span>
              </div>
            </li>
          ))}
        </ul>
      </Container>
    </section>
  )}
      {sectionKey === 'faq' && (
  <section id="faq" class="relative bg-white py-12 md:py-32">
    <Container width="wide">
      <div class="mb-8 flex items-center gap-3 text-[var(--color-text-head)] md:mb-10">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">{sc.faq?.eyebrow ?? 'Common questions'}</span>
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">{sc.faq?.heading ?? 'Before you book the call.'}</h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
          {sc.faq?.intro ?? `Quick answers to the things most people ask before signing on for ${service.data.title.toLowerCase()}.`}
        </p>
      </div>

      <div class="mt-8 overflow-hidden rounded-[6px] border border-line bg-white md:mt-12">
        {faq.map((item, i) => (
          <details class={`group ${i > 0 ? 'border-t border-line' : ''} px-5 py-4 md:px-7 md:py-5`} {...(i === 0 ? { open: true } : {})}>
            <summary class="flex cursor-pointer items-center justify-between gap-6 font-display text-[16px] font-medium text-[var(--color-text-head)] [&::-webkit-details-marker]:hidden">
              {item.q}
              <span class="inline-flex size-7 shrink-0 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-transform group-open:rotate-45">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
              </span>
            </summary>
            <p class="mt-4 font-display text-[14px] leading-[1.65] text-[var(--color-text-body)]">{item.a}</p>
          </details>
        ))}
      </div>
    </Container>
  </section>

  
      )}
    </Fragment>
  ))}

  <!-- ═════════════ FINAL CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-12 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mb-10 flex items-center gap-3 text-white/85 md:mb-24">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[15px] tracking-[-0.005em]">{sc.cta?.eyebrow ?? 'Ready to start?'}</span>
      </div>

      <div class="grid grid-cols-1 items-end gap-6 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">
          {sc.cta?.heading ?? "Let's get on a first name basis."}
        </h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            {ctaLabel}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

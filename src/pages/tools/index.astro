---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Icon from '@/components/Icon.astro';
import Mountains from '@/components/Mountains.astro';
import CtaSection from '@/components/CtaSection.astro';

const tools = [
  {
    title: 'Tax Savings Estimator',
    href: '/tools/tax-savings-estimator/',
    blurb: 'Three questions. A rough estimate of what proactive tax planning could shift on your effective rate.',
    audience: 'Owner-operators · self-employed',
    time: '60 seconds',
    icon: 'trending-up',
    group: 'Tax',
  },
  {
    title: 'Burn Rate Calculator',
    href: '/tools/burn-rate-calculator/',
    blurb: 'Cash on hand vs. monthly burn → runway in months, with thresholds that should change your behaviour.',
    audience: 'Startups · pre-seed to Series B',
    time: '30 seconds',
    icon: 'zap',
    group: 'Advisory',
  },
  {
    title: 'Quarterly Tax Estimator',
    href: '/tools/quarterly-tax-estimator/',
    blurb: 'Annual income + entity → quarterly payment + every IRS due date for the year.',
    audience: 'Self-employed · S-Corps',
    time: '45 seconds',
    icon: 'clock',
    group: 'Tax',
  },
  {
    title: 'S-Corp vs LLC',
    href: '/tools/s-corp-vs-llc/',
    blurb: 'Net income → side-by-side tax delta. See the break-even threshold where S-Corp election starts paying.',
    audience: 'Small business owners',
    time: '60 seconds',
    icon: 'repeat',
    group: 'Tax',
  },
  {
    title: '1031 Exchange Savings',
    href: '/tools/1031-exchange-savings/',
    blurb: 'Sale price + basis + state → deferred capital gains vs. straight sale. Live in any of the 50 states.',
    audience: 'Real estate investors',
    time: '45 seconds',
    icon: 'building',
    group: 'Tax',
  },
  {
    title: 'R&D Credit Estimator',
    href: '/tools/r-and-d-credit/',
    blurb: 'Qualified engineering wages → federal R&D credit (ASC method). Note Section 174 capitalization impact.',
    audience: 'Tech startups · SaaS',
    time: '60 seconds',
    icon: 'sparkles',
    group: 'Tax',
  },
] as const;
---

<BaseLayout
  rawTitle="Free CPA Tools & Calculators | Alpine Mar"
  description="Free, no-signup calculators for tax savings, runway, R&D credit, 1031 exchanges, S-Corp election, and quarterly estimates — built by Alpine Mar CPAs."
>
  <!-- ═══════════════ Hero ═══════════════ -->
  <section class="grain-light relative overflow-hidden bg-paper pt-14 lg:pt-20">
    <div class="absolute inset-0" aria-hidden="true">
      <div class="grid-pattern-dark absolute inset-0 opacity-60"></div>
      <div class="float-slow absolute -right-24 -top-24 h-[480px] w-[480px] rounded-full bg-teal-500/12 blur-[150px]"></div>
    </div>
    <Mountains tone="light" class="absolute bottom-0 left-0 h-48 w-full opacity-80" />
    <div class="pointer-events-none absolute -bottom-4 right-2 select-none lg:right-10" aria-hidden="true">
      <span class="text-outline block leading-none text-hero-xl">{String(tools.length).padStart(2, '0')}</span>
    </div>

    <Container width="xl" class="relative pb-20 lg:pb-28">
      <div class="max-w-3xl" data-reveal data-speed="slow">
        <Eyebrow tone="dark">Free tools · No signup</Eyebrow>
        <h1 class="mt-7 text-navy-900 text-hero-lg">
          Run the numbers <span class="italic text-teal-600">first.</span>
        </h1>
        <p class="mt-8 max-w-2xl text-xl leading-relaxed text-navy-700">
          Free CPA-built calculators for the questions we get most often. Use them as a sanity check —
          then bring the real numbers to a 30-minute consultation.
        </p>
      </div>
    </Container>
  </section>

  <!-- ═══════════════ Tool grid ═══════════════ -->
  <section class="border-t border-line bg-paper py-20 lg:py-24">
    <Container width="xl">
      <div class="grid border-l border-t border-line sm:grid-cols-2 lg:grid-cols-3" data-stagger>
        {tools.map((t, i) => (
          <a href={t.href} class="group flex flex-col gap-6 border-b border-r border-line bg-paper p-8 transition-colors duration-300 hover:bg-white lg:p-9">
            <div class="flex items-center justify-between">
              <span class="flex size-12 items-center justify-center border border-teal-500 text-teal-700 transition-colors group-hover:bg-teal-500 group-hover:text-navy-950">
                <Icon name={t.icon} class="h-5 w-5" />
              </span>
              <span class="font-mono text-xs uppercase tracking-[0.16em] text-navy-300">{String(i + 1).padStart(2, '0')} / {String(tools.length).padStart(2, '0')}</span>
            </div>
            <div>
              <p class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-teal-700">{t.group} · {t.time}</p>
              <h2 class="mt-3 text-2xl tracking-[-0.01em] text-navy-900 transition-colors group-hover:text-teal-700">{t.title}</h2>
            </div>
            <p class="flex-1 text-[0.95rem] leading-relaxed text-navy-600">{t.blurb}</p>
            <div class="flex items-end justify-between gap-4 border-t border-line pt-5">
              <span class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-navy-400">{t.audience}</span>
              <span class="inline-flex items-center gap-2 font-mono text-[0.7rem] uppercase tracking-[0.12em] text-teal-700">
                Open <Icon name="arrow-right" class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" />
              </span>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <CtaSection variant="default" eyebrow="Need the real number?" />
</BaseLayout>

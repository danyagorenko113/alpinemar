---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import ToolExplainer from '@/components/ToolExplainer.astro';

const fields = [
  { id: 'price', label: 'Sale price',                sub: 'What buyer is paying for the property.',                                      value: 1500000, presets: [500000, 1000000, 1500000, 3000000, 5000000] },
  { id: 'basis', label: 'Adjusted basis',            sub: 'Original cost − accumulated depreciation + improvements.',                    value: 600000,  presets: [200000, 400000, 600000, 1000000, 1500000] },
  { id: 'depr',  label: 'Accumulated depreciation',  sub: 'Total depreciation taken over hold period. Recaptured at up to 25%.',         value: 250000,  presets: [50000, 150000, 250000, 500000, 750000] },
];

const states = [
  { v: 0,  label: 'FL · TX · No-tax' },
  { v: 5,  label: 'Mid (5%)' },
  { v: 13, label: 'CA · NY (13%)' },
];
---

<BaseLayout
  rawTitle="1031 Exchange Savings Calculator | Alpine Mar"
  description="See how much capital-gains tax you can defer with a 1031 exchange on investment real estate. Free, Florida-aware, no signup."
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-12 text-white md:pt-16 md:pb-16">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-2 font-display text-[13px] text-white/70">
          <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li><a href="/tools/" class="transition-colors hover:text-scooter">Tools</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li class="font-medium text-white">1031 Exchange Savings</li>
        </ol>
      </nav>
      <div class="max-w-2xl">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[40px] md:text-[48px]">1031 Exchange Savings</h1>
        <p class="mt-4 font-display text-[15px] leading-[1.55] text-white/75">How much capital gains tax you defer by rolling proceeds into a like-kind investment property.</p>
        <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Free · No signup · Directional estimate only</p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ CALCULATOR ═════════════ -->
  <section class="relative bg-paper py-16 md:py-20">
    <Container width="wide">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">

        <form id="x-form" class="flex flex-col gap-8 lg:col-span-7">
          {fields.map((f, i) => (
            <div class="rounded-[6px] border border-line bg-white p-7">
              <div class="flex items-center gap-3">
                <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step {String(i + 1).padStart(2, '0')}</span>
                <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">{f.label}</span>
              </div>
              <label class="mt-5 block">
                <span class="font-display text-[16px] font-medium text-[var(--color-text-head)]">{f.label}</span>
                <p class="mt-1 font-display text-[13px] text-[var(--color-text-body)]">{f.sub}</p>
                <div class="mt-4 flex items-baseline gap-2 border-b-2 border-line transition-colors focus-within:border-scooter">
                  <span class="font-display text-[28px] text-[var(--color-text-body)]">$</span>
                  <input id={f.id} type="number" inputmode="numeric" min="0" step="1000" value={f.value} class="w-full bg-transparent py-2 font-display text-[28px] font-medium text-[var(--color-text-head)] focus:outline-none" />
                  <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">USD</span>
                </div>
              </label>
              <div class="mt-4 flex flex-wrap gap-1.5">
                {f.presets.map((v) => (
                  <button type="button" data-preset-field={f.id} data-preset-value={v} class="rounded-[4px] border border-line bg-white px-3 py-1 font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)] transition-colors hover:border-[#12122D] hover:text-scooter">${(v / 1000).toLocaleString()}k</button>
                ))}
              </div>
            </div>
          ))}

          <div class="rounded-[6px] border border-line bg-white p-7">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step 04</span>
              <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">State</span>
            </div>
            <p class="mt-5 font-display text-[16px] font-medium text-[var(--color-text-head)]">State capital gains rate</p>
            <div class="mt-5 grid grid-cols-1 gap-2.5 sm:grid-cols-3">
              {states.map((opt) => (
                <label class="group flex cursor-pointer items-center gap-3 rounded-[4px] border border-line bg-white px-4 py-3 transition-colors hover:border-[#12122D] has-[:checked]:border-delft has-[:checked]:bg-[#12122D]">
                  <input type="radio" name="x-state" value={opt.v} class="peer accent-scooter" checked={opt.v === 0} />
                  <span class="font-display text-[14px] font-medium text-[var(--color-text-head)] group-has-[:checked]:text-white">{opt.label}</span>
                </label>
              ))}
            </div>
          </div>
        </form>

        <aside class="lg:col-span-5">
          <div class="sticky top-28 overflow-hidden rounded-[6px] border border-line">
            <div class="bg-paper p-7">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Straight sale · tax bill</p>
              <p class="mt-2 font-display text-[36px] font-medium tracking-[-0.02em] text-[var(--color-text-head)]"><span id="x-straight">—</span></p>
              <ul class="mt-5 space-y-2 font-display text-[13px] text-[var(--color-text-body)]">
                <li class="flex justify-between"><span>Federal capital gains</span><span id="x-fed" class="text-[var(--color-text-head)]">—</span></li>
                <li class="flex justify-between"><span>Depreciation recapture</span><span id="x-recap" class="text-[var(--color-text-head)]">—</span></li>
                <li class="flex justify-between"><span>State tax</span><span id="x-state-tax" class="text-[var(--color-text-head)]">—</span></li>
                <li class="flex justify-between border-t border-line pt-2"><span>NIIT (3.8%)</span><span id="x-niit" class="text-[var(--color-text-head)]">—</span></li>
              </ul>
            </div>

            <div class="bg-scooter p-7 text-white">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-white/85">1031 exchange · deferred</p>
              <p class="mt-2 font-display text-[44px] font-medium tracking-[-0.02em] text-white"><span id="x-deferred">—</span></p>
              <p class="mt-3 font-display text-[13px] leading-[1.5] text-white/90">Stays in the next property as additional purchasing power. Compounds across multiple exchanges ("swap till you drop").</p>
            </div>

            <div class="bg-white p-7">
              <a href="/contact/?service=Real%20Estate%20CPA%20Services" class="group inline-flex w-full items-center justify-center gap-2 rounded-[6px] bg-delft px-5 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter">
                Plan the exchange
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
              </a>
              <p class="mt-3 text-center font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-body)]">45-day ID · 180-day close · state deferral varies (CA clawback, NY pickup)</p>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <ToolExplainer
    heading="How a 1031 exchange defers your capital gains"
    intro={[
      "A Section 1031 'like-kind' exchange lets you sell an investment property and reinvest the proceeds into another, deferring the capital-gains and depreciation-recapture tax you would otherwise owe on the sale. The tax is not erased — it is deferred, potentially indefinitely, as you roll from property to property.",
      "This calculator compares the tax on a straight sale against a 1031 exchange, using your sale price, adjusted basis, and state, so you can see the size of the deferral before you commit to the timeline.",
    ]}
    faqs={[
      { q: "Does a 1031 eliminate the tax or just defer it?", a: "It defers it. You carry the deferred gain into the replacement property's basis. Many investors keep deferring across exchanges; heirs may receive a stepped-up basis, but that is a planning question for your CPA." },
      { q: "What are the deadlines?", a: "Strict ones: you have 45 days from the sale to identify replacement property and 180 days to close. Miss either and the exchange fails and the gain becomes taxable." },
      { q: "What qualifies as like-kind?", a: "For real estate, most investment or business property is like-kind to other investment real estate. Personal residences and property held mainly for resale do not qualify." },
    ]}
  />

  <!-- ═════════════ FINAL CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">Selling soon? Plan the exchange before you sign the listing.</h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Request a Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <script>
    function initExchangeCalculator() {
      const form = document.getElementById('x-form') as HTMLFormElement | null;
      if (!form || form.dataset.calculatorBound === '1') return;
      form.dataset.calculatorBound = '1';

      const $ = <T extends Element = HTMLElement>(s: string) => document.querySelector(s) as T | null;
      const price = $('#price') as HTMLInputElement | null;
      const basis = $('#basis') as HTMLInputElement | null;
      const depr  = $('#depr')  as HTMLInputElement | null;
      const fed = $('#x-fed'), recap = $('#x-recap'), st = $('#x-state-tax'), niit = $('#x-niit');
      const straight = $('#x-straight'), deferred = $('#x-deferred');

      function calc() {
        const p = Math.max(0, +(price?.value || 0));
        const b = Math.max(0, +(basis?.value || 0));
        const d = Math.max(0, +(depr?.value || 0));
        const stateRate = (+(document.querySelector('input[name="x-state"]:checked') as HTMLInputElement)?.value || 0) / 100;
        const totalGain = Math.max(0, p - b);
        const longTermGain = Math.max(0, totalGain - d);
        const fedTax = longTermGain * 0.20;
        const recapTax = Math.min(d, totalGain) * 0.25;
        const niitTax = longTermGain * 0.038;
        const stateTax = totalGain * stateRate;
        const totalTax = fedTax + recapTax + niitTax + stateTax;

        if (fed) fed.textContent = '$' + Math.round(fedTax).toLocaleString();
        if (recap) recap.textContent = '$' + Math.round(recapTax).toLocaleString();
        if (st) st.textContent = '$' + Math.round(stateTax).toLocaleString();
        if (niit) niit.textContent = '$' + Math.round(niitTax).toLocaleString();
        if (straight) straight.textContent = '$' + Math.round(totalTax).toLocaleString();
        if (deferred) deferred.textContent = '$' + Math.round(totalTax).toLocaleString();
      }

      form.querySelectorAll('input').forEach((el) => el.addEventListener('input', calc));
      form.querySelectorAll('[data-preset-field]').forEach((button) => button.addEventListener('click', () => {
        const id = (button as HTMLElement).dataset.presetField!;
        const value = (button as HTMLElement).dataset.presetValue!;
        const input = document.getElementById(id) as HTMLInputElement | null;
        if (input) { input.value = value; calc(); }
      }));
      calc();
    }

    document.addEventListener('astro:page-load', initExchangeCalculator);
  </script>
</BaseLayout>

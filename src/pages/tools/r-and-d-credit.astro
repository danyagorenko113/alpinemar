---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import ToolExplainer from '@/components/ToolExplainer.astro';

const claimOpts = [
  { v: 'first',   label: 'Yes · first claim ever',  sub: 'ASC at 6% of QREs' },
  { v: 'ongoing', label: 'No · we claimed before',  sub: 'ASC at 14% above half-of-base' },
];
---

<BaseLayout
  rawTitle="R&amp;D Tax Credit Calculator (ASC Method) | Alpine Mar"
  description="Free R&D tax credit estimator for tech and SaaS startups. Uses the Alternative Simplified Credit method. Section 174 capitalization aware."
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-12 text-white md:pt-16 md:pb-16">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-2 font-display text-[13px] text-white/70">
          <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li><a href="/tools/" class="transition-colors hover:text-scooter">Tools</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li class="font-medium text-white">R&amp;D Credit Estimator</li>
        </ol>
      </nav>
      <div class="max-w-2xl">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[40px] md:text-[48px]">R&amp;D Credit Estimator</h1>
        <p class="mt-4 font-display text-[15px] leading-[1.55] text-white/75">Qualified research wages + supplies → estimated federal R&amp;D credit using the simplified credit method (ASC).</p>
        <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Free · No signup · Directional estimate only</p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ CALCULATOR ═════════════ -->
  <section class="relative bg-paper py-16 md:py-20">
    <Container width="wide">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">

        <form id="rd-form" class="flex flex-col gap-8 lg:col-span-7">
          <div class="rounded-[6px] border border-line bg-white p-7">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step 01</span>
              <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">Wages</span>
            </div>
            <label class="mt-5 block">
              <span class="font-display text-[16px] font-medium text-[var(--color-text-head)]">Qualified engineering wages</span>
              <p class="mt-1 font-display text-[13px] text-[var(--color-text-body)]">W-2 payroll for engineers + product + DevOps doing eligible R&amp;D work. Skip back-office and sales.</p>
              <div class="mt-4 flex items-baseline gap-2 border-b-2 border-line transition-colors focus-within:border-scooter">
                <span class="font-display text-[28px] text-[var(--color-text-body)]">$</span>
                <input id="wages" type="number" inputmode="numeric" min="0" step="10000" value="800000" class="w-full bg-transparent py-2 font-display text-[28px] font-medium text-[var(--color-text-head)] focus:outline-none" />
                <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">USD / yr</span>
              </div>
            </label>
          </div>

          <div class="rounded-[6px] border border-line bg-white p-7">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step 02</span>
              <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">Contractors</span>
            </div>
            <label class="mt-5 block">
              <span class="font-display text-[16px] font-medium text-[var(--color-text-head)]">Contract research (1099 + agency)</span>
              <p class="mt-1 font-display text-[13px] text-[var(--color-text-body)]">External engineers / agencies on a US-based contract. Foreign contractors don't qualify.</p>
              <div class="mt-4 flex items-baseline gap-2 border-b-2 border-line transition-colors focus-within:border-scooter">
                <span class="font-display text-[28px] text-[var(--color-text-body)]">$</span>
                <input id="contract" type="number" inputmode="numeric" min="0" step="10000" value="120000" class="w-full bg-transparent py-2 font-display text-[28px] font-medium text-[var(--color-text-head)] focus:outline-none" />
                <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">USD / yr</span>
              </div>
            </label>
          </div>

          <div class="rounded-[6px] border border-line bg-white p-7">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step 03</span>
              <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">Claim type</span>
            </div>
            <p class="mt-5 font-display text-[16px] font-medium text-[var(--color-text-head)]">First-time claim?</p>
            <p class="mt-1 font-display text-[13px] text-[var(--color-text-body)]">First-year claimants get 6% ASC; ongoing claimants get 14% above half-of-base.</p>
            <div class="mt-5 grid grid-cols-1 gap-2.5 sm:grid-cols-2">
              {claimOpts.map((opt) => (
                <label class="group flex cursor-pointer items-start gap-3 rounded-[4px] border border-line bg-white px-4 py-3 transition-colors hover:border-[#12122D] has-[:checked]:border-delft has-[:checked]:bg-[#12122D]">
                  <input type="radio" name="claim-type" value={opt.v} class="peer mt-1 accent-scooter" checked={opt.v === 'first'} />
                  <span>
                    <span class="block font-display text-[14px] font-medium leading-tight text-[var(--color-text-head)] group-has-[:checked]:text-white">{opt.label}</span>
                    <span class="mt-1 block font-mono text-[10px] uppercase tracking-[0.12em] text-[var(--color-text-body)] group-has-[:checked]:text-scooter">{opt.sub}</span>
                  </span>
                </label>
              ))}
            </div>
          </div>
        </form>

        <aside class="lg:col-span-5">
          <div class="sticky top-28 overflow-hidden rounded-[6px] border border-line">
            <div class="bg-paper p-7">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Qualified Research Expenses (QREs)</p>
              <p class="mt-2 font-display text-[28px] font-medium tracking-[-0.02em] text-[var(--color-text-head)]"><span id="rd-qre">—</span></p>
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-body)]">Wages + 65% of contractor spend</p>
            </div>
            <div class="bg-[#12122D] p-7 text-white">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Estimated federal R&amp;D credit</p>
              <p class="mt-2 font-display text-[56px] font-medium tracking-[-0.02em] text-white"><span id="rd-credit">—</span></p>
              <p class="mt-3 font-display text-[13px] text-white/75">Dollar-for-dollar offset against federal income tax. Pre-revenue startups can offset up to $500k of FICA payroll tax (PATH Act).</p>
            </div>
            <div class="bg-amber-100 p-7 text-amber-900">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-amber-700">Section 174 watch-out</p>
              <p class="mt-3 font-display text-[13px] leading-[1.55] text-amber-900">Since 2022, R&amp;D wages have been capitalized + amortized (5 years US / 15 foreign) under §174. The OBBB Act (2025) restored immediate expensing for US R&amp;D from 2026 onward — making the credit even more valuable. Foreign R&amp;D remains capitalized.</p>
            </div>
            <div class="bg-white p-7">
              <a href="/contact/?service=Tax%20Strategy" class="group inline-flex w-full items-center justify-center gap-2 rounded-[6px] bg-delft px-5 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter">
                Claim it properly
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
              </a>
              <p class="mt-3 text-center font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-body)]">Simplified ASC model · actual credit can differ ±40% based on 3-year history</p>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <ToolExplainer
    heading="How the R&D credit estimate works"
    intro={[
      "The federal Research & Development credit rewards companies for qualified work to develop or improve products, software, and processes. This tool estimates the credit under the Alternative Simplified Credit (ASC) method, driven mainly by your qualified engineering and development wages.",
      "It is a directional estimate. Actual qualified research expenses (QREs) require documenting which projects and activities meet the four-part test — and Section 174 now requires capitalizing and amortizing R&D costs, which changes the cash picture even when the credit applies.",
    ]}
    faqs={[
      { q: "What counts as a qualified research expense?", a: "Primarily wages for employees doing or directly supervising qualified development work, plus supplies and a portion of contract-research costs. The work must meet the IRS four-part test (technological in nature, eliminating uncertainty, process of experimentation, permitted purpose)." },
      { q: "What is the ASC method?", a: "The Alternative Simplified Credit is 14% of QREs above 50% of your average QREs for the prior three years — simpler than the regular method, and what this estimator uses." },
      { q: "Can a pre-revenue startup use the credit?", a: "Yes. Qualified small businesses can apply up to $500,000 of the credit against payroll taxes rather than income tax, which is valuable when you are not yet profitable." },
      { q: "What changed with Section 174?", a: "R&D costs must now be capitalized and amortized (5 years domestic, 15 foreign) rather than deducted immediately. The credit still applies, but the deduction timing affects your cash taxes — worth modeling with a CPA." },
    ]}
  />

  <!-- ═════════════ FINAL CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">Leaving the R&amp;D credit on the table is expensive.</h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Request a Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <script>
    function initResearchCreditCalculator() {
      const form = document.getElementById('rd-form') as HTMLFormElement | null;
      if (!form || form.dataset.calculatorBound === '1') return;
      form.dataset.calculatorBound = '1';

      const wages = document.getElementById('wages') as HTMLInputElement | null;
      const contract = document.getElementById('contract') as HTMLInputElement | null;
      const qre = document.getElementById('rd-qre');
      const credit = document.getElementById('rd-credit');

      function calc() {
        const w = Math.max(0, +(wages?.value || 0));
        const c = Math.max(0, +(contract?.value || 0));
        const qres = w + c * 0.65;
        const firstClaim = (document.querySelector('input[name="claim-type"]:checked') as HTMLInputElement)?.value === 'first';
        const credAmt = firstClaim ? qres * 0.06 : qres * 0.14 * 0.5;
        if (qre) qre.textContent = '$' + Math.round(qres).toLocaleString();
        if (credit) credit.textContent = '$' + Math.round(credAmt).toLocaleString();
      }

      form.querySelectorAll('input').forEach((el) => el.addEventListener('input', calc));
      calc();
    }

    document.addEventListener('astro:page-load', initResearchCreditCalculator);
  </script>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Icon from '@/components/Icon.astro';
import Mountains from '@/components/Mountains.astro';
import CtaSection from '@/components/CtaSection.astro';
---

<BaseLayout
  rawTitle="R&D Tax Credit Calculator (ASC Method) | Alpine Mar"
  description="Free R&D tax credit estimator for tech and SaaS startups. Uses the Alternative Simplified Credit method. Section 174 capitalization aware."
>
  <section class="grain-light relative overflow-hidden bg-paper pt-14 lg:pt-20">
    <div class="absolute inset-0" aria-hidden="true">
      <div class="grid-pattern-dark absolute inset-0 opacity-60"></div>
      <div class="float-slow absolute -right-24 -top-24 h-[480px] w-[480px] rounded-full bg-teal-500/12 blur-[150px]"></div>
    </div>
    <Mountains tone="light" class="absolute bottom-0 left-0 h-40 w-full opacity-70" />
    <div class="pointer-events-none absolute -bottom-2 right-2 select-none lg:right-10" aria-hidden="true">
      <span class="text-outline block leading-none text-hero-xl">06</span>
    </div>
    <Container width="xl" class="relative pb-12 lg:pb-16">
      <nav class="flex items-center gap-2 font-mono text-xs uppercase tracking-[0.14em] text-navy-400" data-reveal data-speed="fast">
        <a href="/tools/" class="text-navy-500 hover:text-navy-900">Tools</a><span aria-hidden="true">/</span><span class="text-navy-700">R&D Credit Estimator</span>
      </nav>
      <div class="mt-7 max-w-3xl" data-reveal data-speed="slow">
        <Eyebrow tone="dark">Tool · 60 seconds · no signup</Eyebrow>
        <h1 class="mt-7 text-navy-900 text-hero-md">Federal <span class="italic text-teal-600">R&D credit</span>, estimated.</h1>
        <p class="mt-7 max-w-2xl text-lg leading-relaxed text-navy-700">
          If you pay engineers to build software, you're probably leaving an R&D credit on the table.
          Quick estimate using the ASC method (Alternative Simplified Credit) — the workable one for
          most startups without prior-year history.
        </p>
      </div>
    </Container>
  </section>

  <section class="border-t border-line bg-paper py-12 lg:py-20">
    <Container width="xl" class="grid gap-10 lg:grid-cols-12 lg:gap-x-12">
      <form id="rd-form" class="lg:col-span-7 space-y-8" data-reveal>
        <fieldset class="border-t border-navy-900 pt-6">
          <legend class="flex items-baseline gap-3">
            <span class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-teal-700">Q1 / 03</span>
            <span class="font-heading text-xl text-navy-900 sm:text-2xl">Qualified engineering wages.</span>
          </legend>
          <p class="mt-2 max-w-md text-sm text-navy-500">W-2 payroll for engineers + product + DevOps doing eligible R&D work. Skip back-office and sales.</p>
          <div class="mt-6 flex items-baseline gap-3 border-b-2 border-line focus-within:border-teal-500 transition-colors">
            <span class="font-heading text-3xl text-navy-300">$</span>
            <input id="wages" type="number" inputmode="numeric" min="0" step="10000" value="800000" class="w-full bg-transparent py-2 font-heading text-3xl font-medium text-navy-900 focus:outline-none" />
            <span class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-navy-400">USD / year</span>
          </div>
        </fieldset>

        <fieldset class="border-t border-line pt-6">
          <legend class="flex items-baseline gap-3">
            <span class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-teal-700">Q2 / 03</span>
            <span class="font-heading text-xl text-navy-900 sm:text-2xl">Contract research (1099 + agency).</span>
          </legend>
          <p class="mt-2 max-w-md text-sm text-navy-500">External engineers / agencies on a US-based contract. Foreign contractors don't qualify.</p>
          <div class="mt-6 flex items-baseline gap-3 border-b-2 border-line focus-within:border-teal-500 transition-colors">
            <span class="font-heading text-3xl text-navy-300">$</span>
            <input id="contract" type="number" inputmode="numeric" min="0" step="10000" value="120000" class="w-full bg-transparent py-2 font-heading text-3xl font-medium text-navy-900 focus:outline-none" />
            <span class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-navy-400">USD / year</span>
          </div>
        </fieldset>

        <fieldset class="border-t border-line pt-6">
          <legend class="flex items-baseline gap-3">
            <span class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-teal-700">Q3 / 03</span>
            <span class="font-heading text-xl text-navy-900 sm:text-2xl">First-time claim?</span>
          </legend>
          <p class="mt-2 max-w-md text-sm text-navy-500">First-year claimants get a different ASC rate (6%) vs. ongoing claimants (14% over half of average).</p>
          <div class="mt-6 grid gap-2 sm:grid-cols-2">
            {[
              { v: 'first', label: 'Yes · first claim ever', sub: 'ASC at 6% of QREs' },
              { v: 'ongoing', label: 'No · we claimed before', sub: 'ASC at 14% above half-of-base' },
            ].map((opt) => (
              <label class="group flex cursor-pointer items-start gap-3 border border-line bg-paper px-4 py-3 transition-colors hover:border-teal-500 has-[:checked]:border-navy-900 has-[:checked]:bg-navy-900">
                <input type="radio" name="claim-type" value={opt.v} class="peer mt-1 accent-teal-500" checked={opt.v === 'first'} />
                <span>
                  <span class="block text-sm font-medium leading-tight text-navy-900 group-has-[:checked]:text-paper">{opt.label}</span>
                  <span class="mt-1 block font-mono text-[0.62rem] uppercase tracking-[0.12em] text-navy-400 group-has-[:checked]:text-teal-300">{opt.sub}</span>
                </span>
              </label>
            ))}
          </div>
        </fieldset>
      </form>

      <aside class="lg:col-span-5" data-reveal data-from="right">
        <div class="sticky top-28 space-y-px border border-navy-900">
          <div class="bg-paper p-6 lg:p-7">
            <p class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-navy-500">Qualified Research Expenses (QREs)</p>
            <p class="mt-2 font-heading text-3xl font-semibold tracking-[-0.02em] text-navy-900"><span id="rd-qre">—</span></p>
            <p class="mt-2 font-mono text-[0.66rem] uppercase tracking-[0.16em] text-navy-400">Wages + 65% of contractor spend</p>
          </div>
          <div class="bg-navy-900 p-6 text-paper lg:p-7">
            <p class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-teal-400">Estimated federal R&D credit</p>
            <p class="mt-2 font-heading text-6xl font-semibold tracking-[-0.02em] text-white"><span id="rd-credit">—</span></p>
            <p class="mt-3 text-sm text-navy-300">Dollar-for-dollar offset against federal income tax. Pre-revenue startups: offset up to $500k of FICA payroll tax (PATH Act).</p>
          </div>
          <div class="bg-amber-100 p-6 text-navy-900">
            <p class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-amber-700">↳ Section 174 watch-out</p>
            <p class="mt-2 text-sm leading-snug">Since 2022, R&D wages have been capitalized + amortized (5 years US / 15 years foreign) under §174. The OBBB Act (2025) restored immediate expensing for US R&D from 2026 onward — making the credit even more valuable. Foreign R&D remains capitalized.</p>
          </div>
          <div class="bg-navy-50 p-6">
            <a href="/contact/?service=Tax%20Strategy" class="group inline-flex w-full items-center justify-center gap-2.5 border border-navy-900 px-6 py-3.5 font-mono text-[0.78rem] font-medium uppercase tracking-[0.08em] text-navy-900 transition-all duration-200 hover:bg-navy-900 hover:text-paper">
              Claim it properly <Icon name="arrow-right" class="h-4 w-4" />
            </a>
            <p class="mt-3 text-center font-mono text-[0.6rem] uppercase tracking-[0.14em] text-navy-400">↳ Simplified ASC model · actual credit can differ ±40% based on 3-year history</p>
            <p class="mt-2 text-center font-mono text-[0.6rem] uppercase tracking-[0.12em] text-navy-400">Estimate only · not tax advice</p>
          </div>
        </div>
      </aside>
    </Container>
  </section>

  <CtaSection variant="industry" context="SaaS" />

  <script>
    const $ = <T extends Element = HTMLElement>(s: string) => document.querySelector(s) as T | null;
    const wages = $('#wages') as HTMLInputElement | null;
    const contract = $('#contract') as HTMLInputElement | null;
    const qre = $('#rd-qre'), credit = $('#rd-credit');

    function calc() {
      const w = Math.max(0, +(wages?.value || 0));
      const c = Math.max(0, +(contract?.value || 0));
      const qres = w + c * 0.65; // 65% of contractor research per §41
      const firstClaim = (document.querySelector('input[name="claim-type"]:checked') as HTMLInputElement)?.value === 'first';
      const credAmt = firstClaim ? qres * 0.06 : qres * 0.14 * 0.5; // ASC simplified

      if (qre) qre.textContent = '$' + Math.round(qres).toLocaleString();
      if (credit) credit.textContent = '$' + Math.round(credAmt).toLocaleString();
    }

    document.querySelectorAll('#rd-form input').forEach((el) => el.addEventListener('input', calc));
    calc();
  </script>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';

const presets = [100000, 250000, 500000, 1000000, 2500000];
const entities = [
  { id: 'sole',    label: 'Sole prop / 1099',          sub: 'Schedule C · SE tax' },
  { id: 'llc',     label: 'Single-member LLC',         sub: 'Same as sole prop' },
  { id: 'scorp',   label: 'S-Corp',                    sub: 'W-2 salary + K-1' },
  { id: 'ccorp',   label: 'C-Corp',                    sub: 'Corporate 21% + dividends' },
  { id: 'partner', label: 'Partnership / multi-LLC',   sub: 'K-1 pass-through' },
  { id: 'w2',      label: 'W-2 employee',              sub: 'High earner · benefits-heavy' },
];
const states = [
  { id: 'fl',   label: 'Florida',                              rate: 0 },
  { id: 'tx',   label: 'Texas',                                rate: 0 },
  { id: 'nh',   label: 'No-tax (NV, WY, TN, SD, AK, WA)',      rate: 0 },
  { id: 'mid',  label: 'Mid (avg 5%)',                         rate: 5 },
  { id: 'high', label: 'NY · CA · NJ (10%+)',                  rate: 10 },
  { id: 'oth',  label: 'Other US state',                       rate: 5 },
];
---

<BaseLayout
  rawTitle="Tax Savings Estimator — Free Calculator | Alpine Mar"
  description="Estimate what proactive tax planning could save you. 3 questions, no signup, CPA-built. Florida-aware."
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-12 text-white md:pt-16 md:pb-16">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-2 font-display text-[13px] text-white/70">
          <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li><a href="/tools/" class="transition-colors hover:text-scooter">Tools</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li class="font-medium text-white">Tax Savings Estimator</li>
        </ol>
      </nav>
      <div class="max-w-2xl">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[40px] md:text-[48px]">Tax Savings Estimator</h1>
        <p class="mt-4 font-display text-[15px] leading-[1.55] text-white/75">Three questions. A rough estimate of what proactive tax planning could shift on your effective rate.</p>
        <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Free · No signup · Directional estimate only</p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ CALCULATOR ═════════════ -->
  <section class="relative bg-paper py-16 md:py-20">
    <Container width="wide">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">

        <form id="tax-form" class="flex flex-col gap-8 lg:col-span-7" novalidate>
          <div class="rounded-[6px] border border-line bg-white p-7">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step 01</span>
              <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">Income</span>
            </div>
            <label class="mt-5 block">
              <span class="font-display text-[16px] font-medium text-[var(--color-text-head)]">Your projected annual income</span>
              <p class="mt-1 font-display text-[13px] text-[var(--color-text-body)]">Business net income (after expenses) or total taxable comp.</p>
              <div class="mt-4 flex items-baseline gap-2 border-b-2 border-line transition-colors focus-within:border-scooter">
                <span class="font-display text-[28px] text-[var(--color-text-body)]">$</span>
                <input id="t-income" type="number" inputmode="numeric" min="0" step="1000" value="250000" class="w-full bg-transparent py-2 font-display text-[28px] font-medium text-[var(--color-text-head)] focus:outline-none" />
                <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">USD / yr</span>
              </div>
            </label>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {presets.map((v) => (
                <button type="button" data-preset-income={v} class="rounded-[4px] border border-line bg-white px-3 py-1 font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)] transition-colors hover:border-[#12122D] hover:text-scooter">${(v / 1000).toLocaleString()}k</button>
              ))}
            </div>
          </div>

          <div class="rounded-[6px] border border-line bg-white p-7">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step 02</span>
              <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">Entity</span>
            </div>
            <p class="mt-5 font-display text-[16px] font-medium text-[var(--color-text-head)]">Entity type</p>
            <p class="mt-1 font-display text-[13px] text-[var(--color-text-body)]">Drives how the income is taxed and which strategies apply.</p>
            <div class="mt-5 grid grid-cols-1 gap-2.5 sm:grid-cols-2">
              {entities.map((opt) => (
                <label class="group flex cursor-pointer items-start gap-3 rounded-[4px] border border-line bg-white px-4 py-3 transition-colors hover:border-[#12122D] has-[:checked]:border-[#1F3062] has-[:checked]:bg-[#12122D]">
                  <input type="radio" name="entity" value={opt.id} class="peer mt-1 accent-scooter" checked={opt.id === 'scorp'} />
                  <span>
                    <span class="block font-display text-[14px] font-medium leading-tight text-[var(--color-text-head)] group-has-[:checked]:text-white">{opt.label}</span>
                    <span class="mt-1 block font-mono text-[10px] uppercase tracking-[0.12em] text-[var(--color-text-body)] group-has-[:checked]:text-scooter">{opt.sub}</span>
                  </span>
                </label>
              ))}
            </div>
          </div>

          <div class="rounded-[6px] border border-line bg-white p-7">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step 03</span>
              <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">State</span>
            </div>
            <p class="mt-5 font-display text-[16px] font-medium text-[var(--color-text-head)]">State of residence</p>
            <p class="mt-1 font-display text-[13px] text-[var(--color-text-body)]">State tax + reciprocity can move 4–13% of taxable income.</p>
            <div class="mt-5 grid grid-cols-1 gap-2.5 sm:grid-cols-3">
              {states.map((opt) => (
                <label class="group flex cursor-pointer flex-col gap-1 rounded-[4px] border border-line bg-white px-4 py-3 transition-colors hover:border-[#12122D] has-[:checked]:border-[#1F3062] has-[:checked]:bg-[#12122D]">
                  <input type="radio" name="state" value={opt.id} data-rate={opt.rate} class="peer sr-only" checked={opt.id === 'fl'} />
                  <span class="font-display text-[13px] font-medium leading-tight text-[var(--color-text-head)] group-has-[:checked]:text-white">{opt.label}</span>
                  <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-[var(--color-text-body)] group-has-[:checked]:text-scooter">State rate · {opt.rate}%</span>
                </label>
              ))}
            </div>
          </div>
        </form>

        <aside class="lg:col-span-5">
          <div class="sticky top-28 rounded-[6px] bg-[#12122D] p-8 text-white">
            <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Live estimate</p>

            <p class="mt-5 font-mono text-[10px] uppercase tracking-[0.14em] text-white/55">Current effective rate</p>
            <p class="mt-2 font-display text-[48px] font-medium tracking-[-0.02em] text-white"><span id="r-current">—</span><span class="text-white/55">%</span></p>

            <p class="mt-6 font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-body)]">Achievable with planning</p>
            <p class="mt-2 font-display text-[48px] font-medium tracking-[-0.02em] text-scooter"><span id="r-target">—</span><span class="text-scooter/55">%</span></p>

            <ul class="mt-7 grid grid-cols-2 gap-2">
              <li class="rounded-[4px] bg-white/[0.06] p-4">
                <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-white/55">Annual delta</p>
                <p class="mt-1 font-display text-[22px] font-medium text-white"><span id="r-savings">—</span></p>
              </li>
              <li class="rounded-[4px] bg-white/[0.06] p-4">
                <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-white/55">5-year delta</p>
                <p class="mt-1 font-display text-[22px] font-medium text-scooter"><span id="r-savings-5y">—</span></p>
              </li>
            </ul>

            <ul id="r-strategies" class="mt-7 space-y-2.5 font-display text-[13px] leading-[1.55] text-white/75"></ul>

            <a href="/contact/?service=Tax%20Planning" class="group mt-8 inline-flex w-full items-center justify-center gap-2 rounded-[6px] bg-scooter px-5 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
              Verify this with a partner
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
            </a>
            <p class="mt-3 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-white/45">Estimate only · not tax advice</p>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- ═════════════ METHODOLOGY ═════════════ -->
  <section class="relative bg-white py-20 md:py-24">
    <Container width="wide">
      <div class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">How this works</span>
      </div>
      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-5">Math, not magic.</h2>
        <div class="flex flex-col gap-5 font-display text-[15px] leading-[1.7] text-[var(--color-text-body)] md:col-span-7">
          <p>The estimate is a marginal-rate model: federal brackets (2026) + the state rate you select + entity-specific adjustments (SE tax for sole prop / LLC, payroll-tax split for S-Corp, double tax for C-Corp). The "achievable" rate assumes typical planning levers we use on actual engagements — entity election, retirement plan layering, accountable-plan reimbursements, R&amp;D / QBI / depreciation positioning.</p>
          <p>Real numbers depend on your full situation — state nexus, deductible benefits, family structure, prior-year carryovers. The tool exists to start the conversation, not to replace one.</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ FINAL CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">Numbers worth verifying? Talk to a partner.</h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Request a Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <script>
    function initTaxSavingsCalculator() {
      const form = document.getElementById('tax-form') as HTMLFormElement | null;
      if (!form || form.dataset.calculatorBound === '1') return;
      form.dataset.calculatorBound = '1';

      const income = document.getElementById('t-income') as HTMLInputElement | null;
      const rCur = document.getElementById('r-current');
      const rTgt = document.getElementById('r-target');
      const rSav = document.getElementById('r-savings');
      const rSav5 = document.getElementById('r-savings-5y');
      const rList = document.getElementById('r-strategies');
      const playbook: Record<string, string[]> = {
        sole: ['S-Corp election to split W-2 vs distribution', 'Solo 401(k) up to $70k', 'Accountable plan for home-office + auto', 'Section 199A QBI optimisation'],
        llc: ['S-Corp election to split W-2 vs distribution', 'Solo 401(k) up to $70k', 'Accountable plan for home-office + auto', 'Section 199A QBI optimisation'],
        scorp: ['Reasonable-compensation review', 'SEP / Solo 401(k) layered with profit-sharing', 'Accountable plan reimbursements', 'Augusta rule (§280A) for home rental'],
        ccorp: ['Salary vs dividend mix to avoid double tax', 'Section 1202 QSBS positioning', 'Accountable plan reimbursements', 'R&D credit (ASC method)'],
        partner: ['Guaranteed payment vs distribution mix', 'Solo 401(k) / cash-balance plan', 'Section 199A QBI optimisation', 'State PTET election (if available)'],
        w2: ['Mega-backdoor Roth (if plan allows)', 'HSA layering + investment', 'Donor-advised fund / charitable bunching', 'Real estate professional status (if applicable)'],
      };

      function federalEffective(inc: number, entity: string) {
        let base = inc < 50_000 ? 12 : inc < 110_000 ? 18 : inc < 200_000 ? 22 : inc < 400_000 ? 28 : inc < 750_000 ? 32 : 36;
        if (entity === 'sole' || entity === 'llc') base += 9;
        if (entity === 'scorp') base += 3;
        if (entity === 'ccorp' || entity === 'partner') base += 6;
        if (entity === 'w2') base += 7.65;
        return base;
      }

      function calc() {
        const inc = Math.max(0, +(income?.value || 0));
        const entity = (document.querySelector('input[name="entity"]:checked') as HTMLInputElement)?.value || 'scorp';
        const stateRate = +(document.querySelector('input[name="state"]:checked') as HTMLInputElement)?.dataset.rate! || 0;
        const current = Math.min(45, federalEffective(inc, entity) + stateRate);
        const headroom = entity === 'w2' ? 3 : entity === 'sole' || entity === 'llc' ? 8.5 : 6.5;
        const target = Math.max(8, Math.round((current - headroom) * 10) / 10);
        const savings = Math.round((inc * (current - target)) / 100);

        if (rCur) rCur.textContent = current.toFixed(1);
        if (rTgt) rTgt.textContent = target.toFixed(1);
        if (rSav) rSav.textContent = '$' + savings.toLocaleString();
        if (rSav5) rSav5.textContent = '$' + (savings * 5).toLocaleString();
        if (rList) {
          rList.innerHTML = (playbook[entity] || playbook.scorp).map((move, i) => `
            <li class="flex items-start gap-2.5">
              <span class="mt-1.5 size-1.5 shrink-0 bg-scooter"></span>
              <span><span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-body)] mr-2">${String(i + 1).padStart(2, '0')}</span>${move}</span>
            </li>`).join('');
        }
      }

      form.querySelectorAll('input').forEach((el) => el.addEventListener('input', calc));
      form.querySelectorAll('[data-preset-income]').forEach((button) => button.addEventListener('click', () => {
        if (income) { income.value = (button as HTMLElement).dataset.presetIncome!; calc(); }
      }));
      calc();
    }

    document.addEventListener('astro:page-load', initTaxSavingsCalculator);
  </script>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import ToolExplainer from '@/components/ToolExplainer.astro';

const entities = [
  { v: 'sole',    label: 'Sole prop / 1099',     sub: 'Schedule C · SE tax applies' },
  { v: 'scorp',   label: 'S-Corp owner-employee', sub: 'Distributions · no SE' },
  { v: 'partner', label: 'Partnership K-1',       sub: 'Guaranteed payments + SE' },
  { v: 'mixed',   label: 'W-2 + side income',     sub: 'Need top-up payments only' },
];

const states = [
  { v: 0,  label: 'FL · TX · No-tax' },
  { v: 5,  label: 'Mid (5%)' },
  { v: 10, label: 'NY · CA · NJ (10%+)' },
];
---

<BaseLayout
  rawTitle="Quarterly Estimated Tax Calculator | Alpine Mar"
  description="Free quarterly tax estimator for self-employed, S-Corps, and consultants. Get your quarterly payment + all four IRS due dates."
  noindex
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-12 text-white md:pt-16 md:pb-16">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-2 font-display text-[13px] text-white/70">
          <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li><a href="/tools/" class="transition-colors hover:text-scooter">Tools</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li class="font-medium text-white">Quarterly Tax Estimator</li>
        </ol>
      </nav>
      <div class="max-w-2xl">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[40px] md:text-[48px]">Quarterly Tax Estimator</h1>
        <p class="mt-4 font-display text-[15px] leading-[1.55] text-white/75">Income, entity type, state → your next quarterly payment and all four IRS due dates. Skip the April-15 panic.</p>
        <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Free · No signup · Directional estimate only</p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ CALCULATOR ═════════════ -->
  <section class="relative bg-paper py-16 md:py-20">
    <Container width="wide">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">

        <!-- Form -->
        <form id="q-form" class="flex flex-col gap-8 lg:col-span-7">
          <!-- Q1 income -->
          <div class="rounded-[6px] border border-line bg-white p-7">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step 01</span>
              <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">Income</span>
            </div>
            <label class="mt-5 block">
              <span class="font-display text-[16px] font-medium text-[var(--color-text-head)]">Projected annual taxable income</span>
              <p class="mt-1 font-display text-[13px] text-[var(--color-text-body)]">Net of business expenses. Skip W-2 withholding if any.</p>
              <div class="mt-4 flex items-baseline gap-2 border-b-2 border-line transition-colors focus-within:border-scooter">
                <span class="font-display text-[28px] text-[var(--color-text-body)]">$</span>
                <input id="q-income" type="number" inputmode="numeric" min="0" step="1000" value="180000" class="w-full bg-transparent py-2 font-display text-[28px] font-medium text-[var(--color-text-head)] focus:outline-none" />
                <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">USD / yr</span>
              </div>
            </label>
          </div>

          <!-- Q2 entity -->
          <div class="rounded-[6px] border border-line bg-white p-7">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step 02</span>
              <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">Entity</span>
            </div>
            <p class="mt-5 font-display text-[16px] font-medium text-[var(--color-text-head)]">Entity &amp; income source</p>
            <div class="mt-5 grid grid-cols-1 gap-2.5 sm:grid-cols-2">
              {entities.map((opt) => (
                <label class="group flex cursor-pointer items-start gap-3 rounded-[4px] border border-line bg-white px-4 py-3 transition-colors hover:border-[#12122D] has-[:checked]:border-delft has-[:checked]:bg-[#12122D]">
                  <input type="radio" name="q-entity" value={opt.v} class="peer mt-1 accent-scooter" checked={opt.v === 'sole'} />
                  <span>
                    <span class="block font-display text-[14px] font-medium leading-tight text-[var(--color-text-head)] group-has-[:checked]:text-white">{opt.label}</span>
                    <span class="mt-1 block font-mono text-[10px] uppercase tracking-[0.12em] text-[var(--color-text-body)] group-has-[:checked]:text-scooter">{opt.sub}</span>
                  </span>
                </label>
              ))}
            </div>
          </div>

          <!-- Q3 state -->
          <div class="rounded-[6px] border border-line bg-white p-7">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step 03</span>
              <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">State</span>
            </div>
            <p class="mt-5 font-display text-[16px] font-medium text-[var(--color-text-head)]">State tax rate</p>
            <div class="mt-5 grid grid-cols-1 gap-2.5 sm:grid-cols-3">
              {states.map((opt) => (
                <label class="group flex cursor-pointer items-center gap-3 rounded-[4px] border border-line bg-white px-4 py-3 transition-colors hover:border-[#12122D] has-[:checked]:border-delft has-[:checked]:bg-[#12122D]">
                  <input type="radio" name="q-state" value={opt.v} class="peer accent-scooter" checked={opt.v === 0} />
                  <span class="font-display text-[14px] font-medium text-[var(--color-text-head)] group-has-[:checked]:text-white">{opt.label}</span>
                </label>
              ))}
            </div>
          </div>
        </form>

        <!-- Result aside -->
        <aside class="lg:col-span-5">
          <div class="sticky top-28 rounded-[6px] bg-[#12122D] p-8 text-white">
            <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Each quarter you owe</p>
            <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.14em] text-white/55">Approximate per-quarter payment</p>
            <p class="mt-2 font-display text-[56px] font-medium tracking-[-0.02em] text-white"><span id="q-result">—</span></p>
            <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.14em] text-white/55">Annual total <span id="q-annual" class="text-scooter">—</span></p>

            <ul id="q-dates" class="mt-6 grid grid-cols-2 gap-2"></ul>

            <p class="mt-6 font-display text-[13px] leading-[1.55] text-white/75">
              If you owe more than <span class="font-medium text-white">$1,000</span> at year-end without estimated payments, the IRS levies an underpayment penalty — currently around <span class="font-medium text-white">7-8% APR</span>.
            </p>

            <a href="/contact/?service=Tax%20Planning" class="group mt-7 inline-flex w-full items-center justify-center gap-2 rounded-[6px] bg-scooter px-5 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
              Set this up properly
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
            </a>
            <p class="mt-3 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-white/45">Estimate only · does not account for safe-harbor rules</p>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <ToolExplainer
    heading="How quarterly estimated taxes work"
    intro={[
      "If you are self-employed or your income is not fully covered by withholding, the IRS expects you to pay tax in four quarterly installments rather than all at once in April. Underpay and you can owe an underpayment penalty — even if you pay in full at filing.",
      "This estimator gives you a per-quarter target based on your expected income, so you can set money aside and avoid a surprise bill or a penalty.",
    ]}
    faqs={[
      { q: "When are quarterly taxes due?", a: "Generally April 15, June 15, September 15, and January 15 of the following year. Dates shift slightly when they fall on a weekend or holiday." },
      { q: "How do I avoid an underpayment penalty?", a: "Safe-harbor rules generally protect you if you pay at least 90% of this year's tax or 100% of last year's (110% for higher earners). Paying the calculated amount each quarter keeps you inside that." },
      { q: "Does this include self-employment tax?", a: "Estimated payments should cover both income tax and self-employment tax. Treat the result as a combined target and confirm the details with your CPA." },
    ]}
  />

  <!-- ═════════════ FINAL CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">Calculator gave you a surprise? Talk to a partner.</h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Request a Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <script>
    function initQuarterlyTaxCalculator() {
      const form = document.getElementById('q-form') as HTMLFormElement | null;
      if (!form || form.dataset.calculatorBound === '1') return;
      form.dataset.calculatorBound = '1';

      const income = document.getElementById('q-income') as HTMLInputElement | null;
      const result = document.getElementById('q-result');
      const annual = document.getElementById('q-annual');
      const dates = document.getElementById('q-dates');
      const dueDates = [
        { label: 'Q1', date: 'Apr 15' },
        { label: 'Q2', date: 'Jun 16' },
        { label: 'Q3', date: 'Sep 15' },
        { label: 'Q4', date: 'Jan 15' },
      ];

      function calc() {
        const inc = Math.max(0, +(income?.value || 0));
        const entity = (document.querySelector('input[name="q-entity"]:checked') as HTMLInputElement)?.value || 'sole';
        const stateRate = +(document.querySelector('input[name="q-state"]:checked') as HTMLInputElement)?.value || 0;

        let fed = 18;
        if (inc < 50_000) fed = 12;
        else if (inc < 110_000) fed = 18;
        else if (inc < 200_000) fed = 22;
        else if (inc < 400_000) fed = 28;
        else if (inc < 750_000) fed = 32;
        else fed = 36;

        let se = 0;
        if (entity === 'sole' || entity === 'partner') se = 12;
        if (entity === 'mixed') se = 6;

        const annualTax = Math.round((inc * (fed + stateRate + se)) / 100);
        const perQ = Math.round(annualTax / 4);
        if (result) result.textContent = '$' + perQ.toLocaleString();
        if (annual) annual.textContent = '$' + annualTax.toLocaleString() + ' / year';

        const year = new Date().getFullYear();
        if (dates) {
          dates.innerHTML = dueDates.map((d) => {
            const labelYear = d.label === 'Q4' ? year + 1 : year;
            return `<li class="rounded-[4px] bg-white/[0.06] p-3">
              <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-white/55">${d.label} · Due</p>
              <p class="mt-1 font-display text-[14px] text-white">${d.date}, ${labelYear}</p>
            </li>`;
          }).join('');
        }
      }

      form.querySelectorAll('input').forEach((el) => el.addEventListener('input', calc));
      calc();
    }

    document.addEventListener('astro:page-load', initQuarterlyTaxCalculator);
  </script>
</BaseLayout>

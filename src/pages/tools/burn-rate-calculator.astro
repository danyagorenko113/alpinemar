---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';

const presets = [250000, 500000, 1000000, 2500000, 5000000];
const growths = [
  { v: -5, label: 'Cutting (−5%/mo)' },
  { v: 0,  label: 'Flat (0%)' },
  { v: 5,  label: 'Scaling (+5%/mo)' },
  { v: 10, label: 'Growing fast (+10%)' },
];
---

<BaseLayout
  rawTitle="Burn Rate &amp; Runway Calculator | Alpine Mar"
  description="Free runway calculator. Cash on hand + monthly burn → runway in months, with thresholds that change founder behaviour."
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-12 text-white md:pt-16 md:pb-16">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-2 font-display text-[13px] text-white/70">
          <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li><a href="/tools/" class="transition-colors hover:text-scooter">Tools</a></li>
          <li aria-hidden="true" class="opacity-55">/</li>
          <li class="font-medium text-white">Burn Rate Calculator</li>
        </ol>
      </nav>
      <div class="max-w-2xl">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[40px] md:text-[48px]">Burn Rate Calculator</h1>
        <p class="mt-4 font-display text-[15px] leading-[1.55] text-white/75">Cash on hand vs. monthly burn → runway in months, with thresholds that should change your behaviour.</p>
        <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Free · No signup · Directional estimate only</p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ CALCULATOR ═════════════ -->
  <section class="relative bg-paper py-16 md:py-20">
    <Container width="wide">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">

        <form id="burn-form" class="flex flex-col gap-8 lg:col-span-7">
          <div class="rounded-[6px] border border-line bg-white p-7">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step 01</span>
              <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">Cash</span>
            </div>
            <label class="mt-5 block">
              <span class="font-display text-[16px] font-medium text-[var(--color-text-head)]">Cash on hand right now</span>
              <p class="mt-1 font-display text-[13px] text-[var(--color-text-body)]">Bank + sweep + treasuries. Anything liquid in &lt;30 days.</p>
              <div class="mt-4 flex items-baseline gap-2 border-b-2 border-line transition-colors focus-within:border-scooter">
                <span class="font-display text-[28px] text-[var(--color-text-body)]">$</span>
                <input id="cash" type="number" inputmode="numeric" min="0" step="1000" value="800000" class="w-full bg-transparent py-2 font-display text-[28px] font-medium text-[var(--color-text-head)] focus:outline-none" />
                <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">USD</span>
              </div>
            </label>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {presets.map((v) => (
                <button type="button" data-preset-cash={v} class="rounded-[4px] border border-line bg-white px-3 py-1 font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)] transition-colors hover:border-[#12122D] hover:text-scooter">${(v / 1000).toLocaleString()}k</button>
              ))}
            </div>
          </div>

          <div class="rounded-[6px] border border-line bg-white p-7">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step 02</span>
              <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">Burn</span>
            </div>
            <label class="mt-5 block">
              <span class="font-display text-[16px] font-medium text-[var(--color-text-head)]">Monthly cash burn</span>
              <p class="mt-1 font-display text-[13px] text-[var(--color-text-body)]">Net of revenue. (Expenses − collected revenue, last 3-month average.)</p>
              <div class="mt-4 flex items-baseline gap-2 border-b-2 border-line transition-colors focus-within:border-scooter">
                <span class="font-display text-[28px] text-[var(--color-text-body)]">$</span>
                <input id="burn" type="number" inputmode="numeric" min="0" step="500" value="120000" class="w-full bg-transparent py-2 font-display text-[28px] font-medium text-[var(--color-text-head)] focus:outline-none" />
                <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">USD / mo</span>
              </div>
            </label>
          </div>

          <div class="rounded-[6px] border border-line bg-white p-7">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Step 03</span>
              <span class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-body)]">Growth</span>
            </div>
            <p class="mt-5 font-display text-[16px] font-medium text-[var(--color-text-head)]">Burn growth rate</p>
            <p class="mt-1 font-display text-[13px] text-[var(--color-text-body)]">How fast burn is climbing month-over-month.</p>
            <div class="mt-5 grid grid-cols-2 gap-2 sm:grid-cols-4">
              {growths.map((g) => (
                <label class="group flex cursor-pointer flex-col gap-1 rounded-[4px] border border-line bg-white px-3 py-3 transition-colors hover:border-[#12122D] has-[:checked]:border-[#1F3062] has-[:checked]:bg-[#12122D]">
                  <input type="radio" name="growth" value={g.v} class="peer sr-only" checked={g.v === 0} />
                  <span class="font-display text-[13px] font-medium leading-tight text-[var(--color-text-head)] group-has-[:checked]:text-white">{g.label}</span>
                </label>
              ))}
            </div>
          </div>
        </form>

        <aside class="lg:col-span-5">
          <div id="result-card" class="sticky top-28 rounded-[6px] bg-[#12122D] p-8 text-white">
            <p id="zone-label" class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">Live runway</p>
            <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.14em] text-white/55">Months of runway</p>
            <p class="mt-2 font-display text-[64px] font-medium tracking-[-0.02em] text-white"><span id="r-months">—</span></p>
            <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.14em] text-white/55">Cash-out date <span id="r-date" class="text-scooter">—</span></p>

            <ul class="mt-6 grid grid-cols-3 gap-2">
              <li class="rounded-[4px] bg-white/[0.06] p-3 text-center">
                <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-white/55">&lt; 6mo</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em] text-rose-300">Raise/cut</p>
              </li>
              <li class="rounded-[4px] bg-white/[0.06] p-3 text-center">
                <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-white/55">6–18mo</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em] text-amber-300">Plan</p>
              </li>
              <li class="rounded-[4px] bg-white/[0.06] p-3 text-center">
                <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-white/55">&gt; 18mo</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em] text-scooter">Optimise</p>
              </li>
            </ul>

            <p id="r-advice" class="mt-6 font-display text-[14px] leading-[1.55] text-white/75">Enter numbers to see what zone you're in.</p>

            <a href="/contact/?service=Fractional%20CFO" class="group mt-7 inline-flex w-full items-center justify-center gap-2 rounded-[6px] bg-scooter px-5 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
              Talk to a fractional CFO
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
            </a>
            <p class="mt-3 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-white/45">Estimate only · not financial advice</p>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- ═════════════ FINAL CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">Numbers don't add up? Talk to a CFO.</h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Request a Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <script>
    function initBurnCalculator() {
      const form = document.getElementById('burn-form') as HTMLFormElement | null;
      if (!form || form.dataset.calculatorBound === '1') return;
      form.dataset.calculatorBound = '1';

      const cash = document.getElementById('cash') as HTMLInputElement | null;
      const burn = document.getElementById('burn') as HTMLInputElement | null;
      const rMonths = document.getElementById('r-months');
      const rDate = document.getElementById('r-date');
      const rAdvice = document.getElementById('r-advice');
      const zoneLabel = document.getElementById('zone-label');

      function calc() {
        const c = Math.max(0, +(cash?.value || 0));
        const b = Math.max(1, +(burn?.value || 0));
        const g = +(document.querySelector('input[name="growth"]:checked') as HTMLInputElement)?.value || 0;
        let cum = 0, k = 0;
        const factor = 1 + g / 100;
        while (cum < c && k < 360) {
          cum += b * Math.pow(factor, k);
          k++;
        }
        const months = k;

        if (rMonths) rMonths.textContent = months >= 360 ? '∞' : String(months);
        const out = new Date();
        out.setMonth(out.getMonth() + months);
        if (rDate) rDate.textContent = out.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

        let zone = 'Optimise';
        let advice = 'Sufficient runway to focus on working capital, taxes, and capital-efficient hires rather than fundraising. A fractional CFO can compress the next 12 months.';
        if (months < 6) {
          zone = 'Raise or cut';
          advice = 'Under six months. The choice narrows to: raise capital or reduce burn. A plan should be in place this month.';
        } else if (months < 18) {
          zone = 'Plan';
          advice = 'In the planning window. Time to lock the next four quarters of spend, qualify investors, and tighten unit economics before fundraising.';
        }
        if (zoneLabel) zoneLabel.textContent = zone;
        if (rAdvice) rAdvice.textContent = advice;
      }

      form.querySelectorAll('input').forEach((el) => el.addEventListener('input', calc));
      form.querySelectorAll('[data-preset-cash]').forEach((button) => button.addEventListener('click', () => {
        if (cash) { cash.value = (button as HTMLElement).dataset.presetCash!; calc(); }
      }));
      calc();
    }

    document.addEventListener('astro:page-load', initBurnCalculator);
  </script>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';

const mentions = [
  { outlet: 'Business Insider', date: '2025', headline: 'Alpine Mar CPA & Advisors Expands Globally with New Offshore Advisory Division', href: 'https://markets.businessinsider.com/news/stocks/alpine-mar-cpa-advisors-expands-globally-with-new-offshore-advisory-division-1034650336' },
  { outlet: 'International Business Times', date: '2025', headline: 'Alpine Mar CPA & Advisors Expands Globally with New Offshore Advisory Division', href: 'https://www.ibtimes.com/alpine-mar-cpa-advisors-expands-globally-new-offshore-advisory-division-3769874' },
  { outlet: 'GlobeNewswire', date: '2025', headline: 'Alpine Mar CPA & Advisors Expands Globally with New Offshore Advisory Division', href: 'https://www.globenewswire.com/news-release/2025/04/29/3069915/0/en/Alpine-Mar-CPA-Advisors-Expands-Globally-with-New-Offshore-Advisory-Division.html' },
  { outlet: 'Bloomberg Tax', date: '2024', headline: 'The Impact of the 2024 Election on Business Tax Landscape', href: 'https://news.bloombergtax.com/tax-insights-and-commentary/the-impact-of-the-2024-election-on-business-tax-landscape' },
  { outlet: 'Chicago Construction News', date: '2024', headline: 'Accounting and Tax Services for Construction Companies: How Alpine Mar CPAs & Advisors Fuels Growth', href: 'https://chicagoconstructionnews.com/accounting-and-tax-services-for-construction-companies-how-alpine-mar-cpas-advisors-fuels-growth/' },
  { outlet: 'VCWire.tech', date: '2024', headline: 'Fintech Startup Team Announces Major Expansion', href: 'https://vcwire.tech/2024/07/11/fintech-startup-team-announces-major-expansion/' },
  { outlet: 'The Real Deal', date: '2024', headline: "What's Trending in New York", href: 'https://therealdeal.com/new-york/2024/03/18/whats-trending-in-new-york/' },
  { outlet: 'Finsmes', date: '2024', headline: 'Fintech Startup Team Announces Major Expansion', href: 'https://www.finsmes.com/2024/07/fintech-startup-team-announces-major-expansion.html' },
  { outlet: 'Hypepotamus', date: '2024', headline: 'Fintech Startup Team Announces Major Expansion', href: 'https://hypepotamus.com/startup-news/fintech-startup-team-announces-major-expansion/' },
  { outlet: 'EstatePlanning.com', date: '2024', headline: 'A Spotlight on Alpine Mar CPAs & Advisors and the Art of Tax-Efficient Wealth Transfer', href: 'https://www.estateplanning.com/a-spotlight-on-alpine-mar-cpas-advisors-and-the-art-of-tax-efficient-wealth-transfer' },
  { outlet: 'Research & Development Tax Credit', date: '2025', headline: 'Increase of the R&D Tax Credit in 2025', href: 'https://research-development-tax-credit.com/news/insights-increase-of-the-rd-tax-credit-in-2025/' },
  { outlet: 'Accounting Today', date: '2025', headline: "Trump administration's policies are stressing accounting professionals", href: 'https://www.accountingtoday.com/news/trump-administrations-policies-are-stressing-accounting-professionals' },
  { outlet: 'Inman', date: '2025', headline: 'What real estate pros should know about the new tax bill', href: 'https://www.inman.com/2025/08/27/what-real-estate-pros-should-know-about-the-new-tax-bill/' },
  { outlet: 'CPA Practice Advisor', date: '2025', headline: "Key Tax Changes in Trump's Spending Bill for Accounting Professionals", href: 'https://www.cpapracticeadvisor.com/2025/07/02/key-tax-changes-in-trumps-spending-bill-for-accounting-professionals/163279/' },
  { outlet: 'Accounting Today', date: '2025', headline: 'Finding growth in times of uncertainty', href: 'https://www.accountingtoday.com/opinion/finding-growth-in-times-of-uncertainty' },
  { outlet: 'Research & Development Tax Credit', date: '2024', headline: 'Going Green with the Federal R&D Tax Credit', href: 'https://research-development-tax-credit.com/going-green-with-the-federal-rd-tax-credit/' },
];
---

<BaseLayout rawTitle="In the Media | Contributions & Appearances by Alpine Mar" description="This page provides a list of expert contributions and guest appearances by Alpine Mar advisors to various publications.">
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-16 text-white md:pt-16 md:pb-20">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="mx-auto max-w-[64ch] text-center">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[36px] md:text-[40px]">In the Media</h1>
        <p class="mt-3 font-display text-[14px] leading-[1.55] text-white/70 md:text-[15px]">Where Alpine Mar shows up in tax-industry press, podcasts, and conference programmes.</p>
      </div>
    </Container>
  </section>

  <section class="relative bg-paper py-20 md:py-24">
    <Container width="wide">
      <ul class="overflow-hidden rounded-[6px] border border-line bg-white">
        {mentions.map((m, i) => (
          <li class={i > 0 ? 'border-t border-line' : ''}>
            <a href={m.href} target="_blank" rel="noopener" class="group flex flex-col gap-2 px-7 py-6 transition-colors hover:bg-paper md:flex-row md:items-center md:gap-6">
              <div class="flex items-center gap-4 md:w-1/3">
                <span class="font-display text-[13px] font-medium text-[var(--color-text-head)]">{m.outlet}</span>
                <span class="font-mono text-[12px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">{m.date}</span>
              </div>
              <span class="font-display text-[16px] leading-[1.45] tracking-[-0.005em] text-[var(--color-text-head)] transition-colors group-hover:text-scooter md:flex-1">{m.headline}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="hidden text-[var(--color-text-body)] transition-all group-hover:translate-x-1 group-hover:text-scooter md:block"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">
          Writing about CPA-industry trends? We're happy to comment.
        </h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Press inquiries
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';

const mentions = [
  { outlet: 'Bloomberg Tax', date: 'Apr 2026', headline: 'Florida CPA boutique on the rise — Alpine Mar lands second Series-A SaaS engagement', href: '#' },
  { outlet: 'Accounting Today', date: 'Feb 2026', headline: "Pablo Martell on the future of mid-market CPAs: 'Partner-led or it doesn't work'", href: '#' },
  { outlet: 'South Florida Business Journal', date: 'Jan 2026', headline: 'Fort Lauderdale firm doubles team in 18 months on family-office demand', href: '#' },
  { outlet: 'FICPA Magazine', date: 'Nov 2025', headline: 'Inside the modern accounting stack — featuring Alpine Mar', href: '#' },
  { outlet: 'CPA Practice Advisor', date: 'Aug 2025', headline: 'How a small Florida firm is winning HNW clients from the Big-4', href: '#' },
  { outlet: 'Tax Notes Today', date: 'Jun 2025', headline: 'Multistate nexus practice spotlight — Alpine Mar opens NYC referrals', href: '#' },
];
---

<BaseLayout rawTitle="In the Media — Alpine Mar" description="Press mentions, speaking engagements, and editorial features.">
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-16 text-white md:pt-16 md:pb-20">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="mx-auto max-w-[64ch] text-center">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[36px] md:text-[40px]">In the Media</h1>
        <p class="mt-3 font-display text-[14px] leading-[1.55] text-white/70 md:text-[15px]">Where Alpine Mar shows up in tax-industry press, podcasts, and conference programmes.</p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ LIST ═════════════ -->
  <section class="relative bg-paper py-20 md:py-24">
    <Container width="wide">
      <ul class="overflow-hidden rounded-[6px] border border-line bg-white">
        {mentions.map((m, i) => (
          <li class={i > 0 ? 'border-t border-line' : ''}>
            <a href={m.href} target="_blank" rel="noopener" class="group flex flex-col gap-2 px-7 py-6 transition-colors hover:bg-paper md:flex-row md:items-center md:gap-6">
              <div class="flex items-center gap-4 md:w-1/3">
                <span class="font-display text-[13px] font-medium text-[var(--color-text-head)]">{m.outlet}</span>
                <span class="font-mono text-[12px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">{m.date}</span>
              </div>
              <span class="font-display text-[16px] leading-[1.45] tracking-[-0.005em] text-[var(--color-text-head)] transition-colors group-hover:text-scooter md:flex-1">{m.headline}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="hidden text-[var(--color-text-body)] transition-all group-hover:translate-x-1 group-hover:text-scooter md:block"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ═════════════ CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">
          Writing about CPA-industry trends? We're happy to comment.
        </h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Press inquiries
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { site } from '@/data/site';

const sections = [
  {
    title: 'What an engagement letter does',
    body: [
      "Every Alpine Mar engagement starts with a written letter that names: the partner running your file, the scope of the deliverable, the fixed fee, the timing, and what we expect from you (documents, response time on questions).",
      "We don't start work without it. It is the single source of truth if anything is ever disputed.",
    ],
  },
  {
    title: "What's in it",
    body: [
      "Scope of services — exactly what we are doing and what we are not (so there are no scope-creep surprises).",
      "Fee — fixed for known scopes, retainer for ongoing engagements. We do not bill by the hour for routine questions.",
      "Term — start date, deliverable dates, end date or renewal terms.",
      "Responsibilities — what we need from you (and by when) for us to hit our deadlines.",
      "Confidentiality and document retention — we hold engagement records for 7 years; you can request copies at any time.",
    ],
  },
  {
    title: 'What changes mid-engagement',
    body: [
      "If scope changes during an engagement we issue a short addendum (signed by both sides) before the change takes effect. No retroactive billing.",
    ],
  },
  {
    title: 'How to request a sample',
    body: [
      `Email ${site.email} and we'll send a redacted sample letter for the service you're considering — so you can see exactly what you're signing up for before the intro call.`,
    ],
  },
];
---

<BaseLayout rawTitle="Engagement Letter — Alpine Mar" description="What an Alpine Mar engagement letter covers and how the engagement starts.">
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-16 text-white md:pt-16 md:pb-20">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <Container width="wide" class="relative z-10">
      <div class="mx-auto max-w-[64ch] text-center">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[36px] md:text-[40px]">Engagement letter</h1>
        <p class="mt-3 font-display text-[14px] leading-[1.55] text-white/70 md:text-[15px]">How every Alpine Mar engagement starts — written down, fixed-fee, partner-signed.</p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ BODY ═════════════ -->
  <section class="relative bg-paper py-20 md:py-24">
    <Container width="reading">
      <div class="rounded-[6px] border border-line bg-white p-8 md:p-12">
        <div class="prose-am">
          {sections.map((s) => (
            <>
              <h2>{s.title}</h2>
              {s.body.map((p) => <p>{p}</p>)}
            </>
          ))}
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Icon from '@/components/Icon.astro';
import Mountains from '@/components/Mountains.astro';
import CtaSection from '@/components/CtaSection.astro';
import { industries } from '@/data/taxonomy';
---

<BaseLayout
  rawTitle="Industries We Service - Alpine Mar"
  description="Alpine Mar specializes in providing accounting and tax services for numerous industries."
>
  <!-- ═══════════════ Hero ═══════════════ -->
  <section class="grain-light relative overflow-hidden bg-paper pt-16 lg:pt-24">
    <div class="absolute inset-0" aria-hidden="true">
      <div class="grid-pattern-dark absolute inset-0 opacity-60"></div>
      <div class="float-slow absolute -left-24 -top-24 h-[520px] w-[520px] rounded-full bg-teal-500/12 blur-[150px]"></div>
    </div>
    <Mountains tone="light" class="absolute bottom-0 left-0 h-56 w-full opacity-80" />
    <div class="pointer-events-none absolute -bottom-4 right-2 select-none lg:right-10" aria-hidden="true">
      <span class="text-outline block text-[12rem] leading-none lg:text-[18rem]">{industries.length}</span>
    </div>
    <Container width="xl" class="relative pb-20 lg:pb-28">
      <div class="max-w-4xl" data-reveal data-speed="slow">
        <Eyebrow tone="dark">Who we service · {industries.length} specialised</Eyebrow>
        <h1 class="mt-7 text-navy-900 text-hero-lg">
          You’re experts in your field. We’re experts in <span class="italic text-teal-600">ours.</span>
        </h1>
        <p class="mt-9 max-w-2xl text-xl leading-relaxed text-navy-700">
          Your accountant should be a trusted advisor. Someone who knows what you need because they
          know who you are. At Alpine Mar, we’re committed to crafting personalized solutions powered
          by unmatched expertise, enduring personal relationships, and the latest technology.
        </p>
      </div>
      <!-- index strip -->
      <ul class="mt-14 flex flex-wrap gap-x-6 gap-y-3 border-t border-line pt-6" data-stagger>
        {industries.map((ind, i) => (
          <li>
            <a href={`#${ind.href.split('/').filter(Boolean).pop()}`} class="font-mono text-xs uppercase tracking-[0.14em] text-navy-500 transition-colors hover:text-teal-700">
              <span class="text-teal-700">{String(i + 1).padStart(2, '0')}</span> {ind.title}
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ═══════════════ Zig-zag industry rows ═══════════════ -->
  <section class="border-t border-line bg-paper pb-24 lg:pb-32">
    <Container width="xl">
      {industries.map((ind, i) => (
        <article id={ind.href.split('/').filter(Boolean).pop()} class="relative scroll-mt-28 grid items-center gap-8 border-b border-line py-16 lg:grid-cols-12 lg:gap-x-16 lg:py-24" data-reveal>
          <span class="pointer-events-none absolute right-2 top-6 select-none font-heading text-7xl font-semibold text-navy-100 lg:right-6 lg:text-[9rem]" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <figure class:list={['relative overflow-hidden lg:col-span-6', i % 2 === 1 ? 'lg:order-2' : '']}>
            <img src={ind.image} alt={ind.title} loading="lazy" class="aspect-[16/10] w-full object-cover" />
            <span class="absolute left-5 top-5 bg-paper/95 px-3 py-1.5 font-mono text-xs uppercase tracking-[0.16em] text-navy-900 backdrop-blur-sm">{String(i + 1).padStart(2, '0')} · {ind.title}</span>
          </figure>
          <div class:list={['lg:col-span-6', i % 2 === 1 ? 'lg:order-1' : '']}>
            <span class="font-mono text-[0.7rem] uppercase tracking-[0.2em] text-teal-700">Industry · {String(i + 1).padStart(2, '0')} of {String(industries.length).padStart(2, '0')}</span>
            <h2 class="mt-3 text-4xl tracking-[-0.02em] text-navy-900 sm:text-5xl">{ind.title}</h2>
            <p class="mt-6 max-w-prose text-xl leading-relaxed text-navy-700">{ind.desc}</p>
            <a href={ind.href} class="group mt-8 inline-flex items-center gap-3 font-mono text-xs uppercase tracking-[0.12em] text-teal-700">
              Explore {ind.title}
              <span class="flex size-9 items-center justify-center border border-line text-navy-400 transition-all duration-300 group-hover:border-teal-500 group-hover:bg-teal-500 group-hover:text-navy-950">
                <Icon name="arrow-right" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5" />
              </span>
            </a>
          </div>
        </article>
      ))}
    </Container>
  </section>

  <!-- ═══════════════ Can't find ═══════════════ -->
  <section class="grain relative overflow-hidden border-t border-line bg-navy-950 pt-24 pb-28 text-white lg:pt-28 lg:pb-32">
    <div class="absolute right-0 top-0 h-[400px] w-[500px] rounded-full bg-teal-500/12 blur-[150px]" aria-hidden="true"></div>
    <Container width="wide" class="relative grid items-center gap-8 lg:grid-cols-12" data-reveal>
      <div class="lg:col-span-8">
        <Eyebrow tone="light">Don’t see your industry?</Eyebrow>
        <h2 class="mt-6 text-4xl tracking-[-0.02em] text-white sm:text-5xl">Can’t find what you’re looking for?</h2>
        <p class="mt-7 max-w-xl text-xl leading-relaxed text-navy-200">
          Reach out to us to start crafting a flexible, custom solution that fits your specific
          industry and needs.
        </p>
      </div>
      <div class="lg:col-span-4 lg:justify-self-end">
        <a href="/contact/" class="group inline-flex items-center gap-3 bg-teal-500 px-7 py-4 font-mono text-[0.8rem] font-medium uppercase tracking-[0.08em] text-navy-950 transition-all duration-200 hover:bg-teal-400 active:scale-[0.98]">
          Get in touch <Icon name="arrow-right" class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" />
        </a>
      </div>
    </Container>
  </section>

  <CtaSection />
</BaseLayout>

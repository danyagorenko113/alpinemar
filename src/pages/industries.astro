---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { industries } from '@/data/taxonomy';
import { collectionPageSchema, breadcrumb } from '@/data/schema';
import { googleReviews } from '@/data/googleReviews';

const totalIndustries = industries.length;

const pillars = [
  {
    title: 'Specialized by vertical',
    body: 'Real estate, healthcare, SaaS, family office — every industry has its own playbook and we know yours by heart.',
    icon: '/icons/about/quality.svg',
  },
  {
    title: 'Benchmarks that matter',
    body: 'Beyond GAAP, we know the industry-specific KPIs investors and lenders look at — and we report on them.',
    icon: '/icons/about/innovation.svg',
  },
  {
    title: 'Network already in place',
    body: 'Lawyers, lenders, brokers and insurers we work with daily across each vertical — your call list is shorter.',
    icon: '/icons/about/collaboration.svg',
  },
];

const testimonials = googleReviews.slice(4, 10);

const partners = [
  { name: 'AICPA',  src: '/images/brand/aicpa-logo.png' },
  { name: 'FICPA',  src: '/images/brand/ficpa-logo.png' },
];

const schema = [
  collectionPageSchema({
    name: 'Industries We Service',
    description: 'Real estate, healthcare, SaaS, family office, construction, law firms, and 5 more verticals.',
    path: '/industries/',
    itemCount: industries.length,
  }),
  breadcrumb([
    { name: 'Home', path: '/' },
    { name: 'Industries', path: '/industries/' },
  ]),
];
---

<BaseLayout
  rawTitle="Industries We Service - Alpine Mar"
  description="Alpine Mar specializes in providing accounting and tax services for numerous industries."
  schema={schema}
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-16 text-white md:pt-16 md:pb-20">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mx-auto max-w-[64ch] text-center">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[36px] md:text-[40px]">
          Industries We Service
        </h1>
        <p class="mt-3 font-display text-[14px] leading-[1.55] text-white/70 md:text-[15px]">
          Your accountant should know what you need because they know who you are. We build specialized teams for the {totalIndustries} verticals we know best — so the playbooks are tested, the benchmarks are real, and you stop having to explain the basics.
        </p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ INDUSTRIES GRID ═════════════ -->
  <section class="relative bg-paper py-20 md:py-24">
    <Container width="wide">
      <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
        {industries.map((ind) => (
          <li>
            <div class="group relative flex h-full flex-col overflow-hidden rounded-[6px] border border-line bg-white transition-colors hover:border-[#12122D]">
              <div class="aspect-[5/4] w-full overflow-hidden bg-navy-50">
                <img src={ind.image} alt={ind.title} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
              </div>
              <div class="flex flex-1 flex-col p-6">
                <h3 class="font-display text-[20px] font-medium leading-[1.25] tracking-[-0.01em] text-[var(--color-text-head)]">
                  {/* Stretched link: whole card clickable, anchor text = title only. */}
                  <a href={ind.href} class="transition-colors after:absolute after:inset-0 after:content-[''] hover:text-scooter group-hover:text-scooter">{ind.title}</a>
                </h3>
                <p class="mt-3 line-clamp-3 font-display text-[14px] leading-[1.6] text-[var(--color-text-body)]">{ind.summary}</p>
                <span class="mt-auto inline-flex items-center gap-2 pt-6 font-display text-[14px] font-medium text-[var(--color-text-head)] transition-colors group-hover:text-scooter">
                  Learn more
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
                </span>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ═════════════ WHY CHOOSE US ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mb-10 flex items-center gap-3 text-white/85">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Why Choose Us</span>
      </div>

      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-7">
          A firm that knows your world,<br />not just your numbers.
        </h2>
        <div class="flex flex-col gap-4 md:col-span-5 md:pt-3">
          <p class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-head)]">What you can expect</p>
          <p class="font-display text-[15px] leading-[1.65] text-white/75">
            Beyond the books: we know the industry mechanics — revenue recognition quirks, deduction levers, regulator behavior, and the benchmarks your investors care about most.
          </p>
        </div>
      </div>

      <ul class="mt-16 grid grid-cols-1 gap-5 md:grid-cols-3">
        {pillars.map((p) => (
          <li class="flex flex-col gap-6 rounded-[6px] bg-white p-7 text-[var(--color-text-head)]">
            <span class="inline-flex size-12 items-center justify-center rounded-[6px] bg-paper">
              <img src={p.icon} alt="" aria-hidden="true" class="size-6" />
            </span>
            <h3 class="font-display text-[20px] font-medium leading-[1.25] tracking-[-0.01em]">{p.title}</h3>
            <p class="font-display text-[14px] leading-[1.6] text-[var(--color-text-body)]">{p.body}</p>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ═════════════ TESTIMONIALS ═════════════ -->
  <section class="relative bg-white py-24 md:py-32">
    <Container width="wide">
      <div class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Testimonial</span>
      </div>

      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">
          Don't just take<br />our word for it.
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
          The clearest signal that we know your industry: clients say so within the first call. Here's what that sounds like.
        </p>
      </div>

      <div class="relative mt-14">
        <div id="testi-track" class="-mx-4 flex snap-x snap-mandatory gap-5 overflow-x-auto px-4 pb-3 [scrollbar-width:none] sm:-mx-6 sm:px-6 [&::-webkit-scrollbar]:hidden">
          {testimonials.map((t) => (
            <article data-review-card class="flex h-[460px] w-[84vw] max-w-[340px] flex-none snap-center flex-col gap-5 rounded-[6px] border border-line bg-white p-6 sm:w-[50%] sm:max-w-none sm:snap-start sm:p-7 lg:w-[calc((100%-2.5rem)/3.4)]">
              <svg width="32" height="26" viewBox="0 0 32 26" fill="currentColor" aria-hidden="true" class="text-line">
                <path d="M9.6 0C4.3 0 0 4.6 0 10.3v15.7h12.5V10.3H6.4c0-2.8 1.4-5.1 3.2-5.1V0Zm19.6 0c-5.3 0-9.6 4.6-9.6 10.3v15.7H32V10.3h-6.1c0-2.8 1.4-5.1 3.2-5.1V0Z"/>
              </svg>
              <div class="flex items-center gap-1 font-display text-[13px] font-medium text-[#12122D]" aria-label="5 star Google review">
                <span aria-hidden="true">★★★★★</span>
                <span class="sr-only">5 star Google review</span>
              </div>
              <div>
                <p data-review-text class="line-clamp-6 font-display text-[14px] leading-[1.7] text-[var(--color-text-body)]">{t.quote}</p>
                <button type="button" data-review-toggle aria-expanded="false" class="mt-3 hidden items-center gap-1 font-display text-[13px] font-medium text-[#12122D] underline underline-offset-4 transition-colors hover:text-scooter">
                  See more
                </button>
              </div>
              <div class="mt-auto flex items-center gap-3 border-t border-line pt-5">
                <div class="inline-flex size-11 items-center justify-center rounded-full bg-[#12122D] font-display text-[13px] font-medium text-white">
                  {t.initials}
                </div>
                <div>
                  <p class="font-display text-[14px] font-medium text-[var(--color-text-head)]">{t.name}</p>
                  <p class="font-display text-[12px] text-[var(--color-text-body)]">Google review · {t.date}</p>
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-8 flex flex-col items-center gap-5 sm:mt-10 sm:flex-row sm:justify-between sm:gap-6">
          <div id="testi-dots" class="flex max-w-full flex-wrap items-center justify-center gap-2">
            {testimonials.map((_, i) => (
              <button type="button" data-dot={i} aria-label={`Slide ${i + 1}`} class="h-1.5 w-6 rounded-full bg-line transition-all duration-300 data-[active=1]:bg-[#12122D]"></button>
            ))}
          </div>
          <div class="flex shrink-0 items-center justify-center gap-3">
            <button type="button" id="testi-prev" aria-label="Previous" class="inline-flex size-11 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-colors hover:border-delft hover:text-delft">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M19 12H5"/><path d="m11 19-7-7 7-7"/></svg>
            </button>
            <button type="button" id="testi-next" aria-label="Next" class="inline-flex size-11 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-colors hover:border-delft hover:text-delft">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
            </button>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ PARTNER CPAs ═════════════ -->
  <section class="relative bg-white py-14 md:py-16">
    <Container width="wide">
      <div class="flex flex-col items-center gap-8 border-t border-line pt-12 md:flex-row md:gap-12">
        <p class="shrink-0 font-display text-[14px] text-[var(--color-text-body)] md:whitespace-nowrap">Partner with nationally recognized CPAs:</p>
        <div class="flex flex-1 flex-wrap items-center justify-around gap-x-12 gap-y-6">
          {partners.map((p) => (
            <img src={p.src} alt={p.name} class="h-16 w-auto grayscale opacity-80 md:h-20" loading="lazy" />
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ FINAL CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mb-16 flex items-center gap-3 text-white/85 md:mb-24">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[15px] tracking-[-0.005em]">Contact Us</span>
      </div>

      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">
          Industry-specific advice starts with a first-name introduction.
        </h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            Request a Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <script>
    function initTestimonials() {
      const track = document.getElementById('testi-track');
      if (!track || (track as any).__testiBound) return;
      (track as any).__testiBound = true;
      const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('#testi-dots [data-dot]'));
      const prev = document.getElementById('testi-prev');
      const next = document.getElementById('testi-next');
      const cards = Array.from(track.children) as HTMLElement[];
      let active = 0;
      let lockUntil = 0;
      let snapPoints: number[] = [];

      const clamp = (i: number) => Math.max(0, Math.min(snapPoints.length - 1, i));

      const setActive = (i: number) => {
        active = clamp(i);
        dots.forEach((d, idx) => { d.dataset.active = idx === active ? '1' : '0'; });
      };

      const bindReviewToggles = () => {
        track.querySelectorAll<HTMLButtonElement>('[data-review-toggle]').forEach((button) => {
          if ((button as any).__reviewToggleBound) return;
          (button as any).__reviewToggleBound = true;
          const card = button.closest<HTMLElement>('[data-review-card]');
          const text = card?.querySelector<HTMLElement>('[data-review-text]');
          const updateVisibility = () => {
            if (!text) return;
            const expanded = button.getAttribute('aria-expanded') === 'true';
            text.classList.add('line-clamp-6');
            const truncated = text.scrollHeight > text.clientHeight + 2;
            text.classList.toggle('line-clamp-6', !expanded);
            button.classList.toggle('hidden', !expanded && !truncated);
            button.classList.toggle('inline-flex', expanded || truncated);
          };
          updateVisibility();
          window.addEventListener('resize', updateVisibility);
          button.addEventListener('click', () => {
            const expanded = button.getAttribute('aria-expanded') === 'true';
            button.setAttribute('aria-expanded', expanded ? 'false' : 'true');
            button.textContent = expanded ? 'See more' : 'Show less';
            text?.classList.toggle('line-clamp-6', expanded);
            if (card) card.style.height = expanded ? '' : 'auto';
            window.setTimeout(syncDots, 0);
          });
        });
      };

      const getMaxScroll = () => Math.max(0, track.scrollWidth - track.clientWidth);

      const buildSnapPoints = () => {
        const maxScroll = getMaxScroll();
        const points: number[] = [0];

        cards.forEach((card) => {
          const left = Math.min(Math.max(card.offsetLeft - 24, 0), maxScroll);
          const duplicate = points.some((p) => Math.abs(p - left) < 6);
          if (!duplicate && left > 2 && maxScroll - left > 2) points.push(left);
        });

        if (maxScroll > 2 && !points.some((p) => Math.abs(p - maxScroll) < 6)) {
          points.push(maxScroll);
        }

        return points.sort((a, b) => a - b);
      };

      const syncDots = () => {
        snapPoints = buildSnapPoints();
        dots.forEach((dot, idx) => {
          const visible = idx < snapPoints.length;
          dot.hidden = !visible;
          dot.style.display = visible ? '' : 'none';
          dot.setAttribute('aria-label', `Slide ${idx + 1}`);
        });
        setActive(Math.min(active, snapPoints.length - 1));
      };

      bindReviewToggles();

      const scrollToIndex = (i: number) => {
        const index = clamp(i);
        const targetLeft = snapPoints[index] ?? 0;
        setActive(index);
        lockUntil = Date.now() + 520;
        track.scrollTo({ left: targetLeft, behavior: 'smooth' });
        window.setTimeout(() => {
          lockUntil = 0;
          detectActive();
        }, 540);
      };

      const detectActive = () => {
        let best = 0;
        let bestDist = Infinity;
        for (let i = 0; i < snapPoints.length; i++) {
          const d = Math.abs(track.scrollLeft - snapPoints[i]);
          if (d < bestDist) { bestDist = d; best = i; }
        }
        setActive(best);
        return best;
      };

      let raf = 0;
      track.addEventListener('scroll', () => {
        if (Date.now() < lockUntil) return;
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(detectActive);
      });
      dots.forEach((d, i) => d.addEventListener('click', () => scrollToIndex(i)));
      prev?.addEventListener('click', () => scrollToIndex(active - 1));
      next?.addEventListener('click', () => scrollToIndex(active + 1));
      window.addEventListener('resize', () => {
        syncDots();
        detectActive();
      });
      syncDots();
      setActive(0);
    }
    initTestimonials();
    document.addEventListener('astro:after-swap', initTestimonials);
  </script>
</BaseLayout>

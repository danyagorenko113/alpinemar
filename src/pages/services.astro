---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';

type Group = 'Tax' | 'Accounting' | 'Advisory' | 'Compliance';
const groupOrder: Group[] = ['Tax', 'Accounting', 'Advisory', 'Compliance'];

const SPANISH = new Set([
  'creacion-de-empresas',
  'servicios-contables',
  'servicios-tributarios-en-florida',
]);

const collection = await getCollection('services');
const services = collection
  .filter((s) => !SPANISH.has(s.id) && s.data.group)
  .map((s) => ({
    title: s.data.title.replace(/\s*Services\s*$/i, '').trim(),
    fullTitle: s.data.title,
    href: s.data.path,
    summary: s.data.summary,
    group: s.data.group as Group,
  }))
  .sort((a, b) => groupOrder.indexOf(a.group) - groupOrder.indexOf(b.group));

const totalServices = services.length;

const groupCounts = groupOrder.map((g) => ({
  name: g,
  count: services.filter((s) => s.group === g).length,
}));
---

<BaseLayout
  rawTitle="Our Services — Alpine Mar"
  description="From day-to-day accounting to high-stakes transactions and audits — explore the full range of services Alpine Mar builds around its clients."
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative isolate overflow-hidden bg-paper">
    <div class="relative h-[460px] w-full md:h-[560px]">
      <img src="/images/about/hero.jpg" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover object-center" />
      <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-b from-transparent via-white/55 to-white"></div>
      <Container width="wide" class="relative z-10 flex h-full flex-col justify-end pb-10 md:pb-14">
        <!-- Breadcrumbs -->
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex flex-wrap items-center gap-2 font-display text-[13px] text-[var(--color-text-head)]">
            <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
            <li aria-hidden="true" class="opacity-55">/</li>
            <li aria-current="page" class="font-medium">Services</li>
          </ol>
        </nav>
        <h1 data-reveal data-speed="slow" class="am-hero-display am-gradient-ink">Our Services</h1>
      </Container>
    </div>
  </section>

  <!-- ═════════════ INTRO ═════════════ -->
  <section class="relative bg-white py-20 md:py-24">
    <Container width="wide">
      <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">{totalServices} services in total</span>
      </div>

      <div data-reveal class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">
          The solutions you need, built around your business.
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
          Whatever stage you're at — early-stage, scaling, or institution-level — there's a service mapped to it. Filter by pillar or scroll the full list below.
        </p>
      </div>

      <!-- Filter chips -->
      <div data-reveal class="mt-12 flex flex-wrap items-center gap-2">
        <button data-filter="all" data-active="1" class="rounded-[6px] bg-[#1F3062] px-4 py-2 font-display text-[13px] font-medium text-white transition-colors hover:bg-scooter data-[active=0]:border data-[active=0]:border-line data-[active=0]:bg-white data-[active=0]:text-[var(--color-text-head)] data-[active=0]:hover:border-[#12122D] data-[active=0]:hover:bg-white">
          All services <span class="opacity-70">· {totalServices}</span>
        </button>
        {groupCounts.map((g) => (
          <button data-filter={g.name} data-active="0" class="rounded-[6px] bg-[#1F3062] px-4 py-2 font-display text-[13px] font-medium text-white transition-colors hover:bg-scooter data-[active=0]:border data-[active=0]:border-line data-[active=0]:bg-white data-[active=0]:text-[var(--color-text-head)] data-[active=0]:hover:border-[#12122D] data-[active=0]:hover:bg-white">
            {g.name} <span class="opacity-70">· {g.count}</span>
          </button>
        ))}
      </div>
    </Container>
  </section>

  <!-- ═════════════ SERVICES GRID ═════════════ -->
  <section class="relative bg-paper py-12 md:py-16">
    <Container width="wide">
      <ul id="services-grid" data-stagger class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => (
          <li data-group={s.group}>
            <a href={s.href} class="group flex h-full min-h-[260px] flex-col rounded-[6px] border border-line bg-white p-7 transition-colors hover:border-[#12122D]">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center gap-2 rounded-[4px] bg-paper px-3 py-1.5 font-display text-[12px] text-[var(--color-text-body)]">
                  <span class="block size-1.5 bg-[#12122D]"></span>
                  {s.group}
                </span>
              </div>
              <h3 class="mt-6 font-display text-[20px] font-medium leading-[1.25] tracking-[-0.01em] text-[var(--color-text-head)]">{s.title}</h3>
              <p class="mt-3 line-clamp-3 font-display text-[14px] leading-[1.6] text-[var(--color-text-body)]">{s.summary}</p>
              <div class="mt-auto flex items-center justify-between gap-4 pt-6">
                <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Learn more</span>
                <span class="inline-flex size-9 items-center justify-center rounded-[4px] bg-[#1F3062] text-white transition-transform group-hover:translate-x-1">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <p id="services-empty" class="hidden mt-12 text-center font-display text-[14px] text-[var(--color-text-body)]">
        No services in this pillar yet.
      </p>
    </Container>
  </section>

  <!-- ═════════════ CTA — Let's talk ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-16 flex items-center gap-3 text-white/85 md:mb-24">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[15px] tracking-[-0.005em]">Not sure where to start?</span>
      </div>

      <div data-reveal class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">
          Let's talk. We'll map the right service to your business.
        </h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-[#1F3062] px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-scooter">
            Request a Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <script>
    function initServiceFilters() {
      const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter]'));
      const cards = Array.from(document.querySelectorAll<HTMLElement>('#services-grid > li'));
      const empty = document.getElementById('services-empty');
      if (!buttons.length || !cards.length || (buttons[0] as any).__filterBound) return;
      buttons.forEach((b) => ((b as any).__filterBound = true));

      const apply = (filter: string) => {
        let visible = 0;
        cards.forEach((c) => {
          const show = filter === 'all' || c.dataset.group === filter;
          c.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        empty?.classList.toggle('hidden', visible !== 0);
      };

      buttons.forEach((b) => {
        b.addEventListener('click', () => {
          buttons.forEach((other) => { other.dataset.active = other === b ? '1' : '0'; });
          apply(b.dataset.filter || 'all');
        });
      });
    }
    initServiceFilters();
    document.addEventListener('astro:after-swap', initServiceFilters);
  </script>
</BaseLayout>

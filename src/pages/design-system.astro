          </div>
        </div>

        <!-- Info / heads-up -->
        <div class="flex items-start gap-3 rounded-[6px] border border-scooter/30 bg-scooter/8 p-5">
          <span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full bg-scooter text-white">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" x2="12" y1="8" y2="13"/><line x1="12" x2="12" y1="16" y2="16"/></svg>
          </span>
          <div>
            <p class="font-display text-[14px] font-medium text-[var(--color-text-head)]">For information only</p>
            <p class="mt-1 font-display text-[13px] leading-[1.5] text-[var(--color-text-body)]">This calculator gives a directional estimate — confirm with your CPA.</p>
          </div>
        </div>
      </div>
    </Container>
  </section>


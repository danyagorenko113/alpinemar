          <span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full bg-[#cf2e2e] text-white">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
          </span>
          <div>
            <p class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Couldn't send</p>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { getCollection } from 'astro:content';
import { site } from '@/data/site';

const insights = (await getCollection('insights'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))
  .slice(0, 4);

const services = [
  { num: '01', name: 'Tax Planning',              href: '/services/tax-planning-services/' },
  { num: '02', name: 'Outsourced Accounting',     href: '/services/outsourced-accounting-services/' },
  { num: '03', name: 'Private Client Services',   href: '/services/private-client-services/' },
  { num: '04', name: 'Transaction Advisory',      href: '/services/transaction-advisory-services/' },
  { num: '05', name: 'Audit & Attestation Services', href: '/services/audit-attestation-services/' },
];

const industries = [
  {
    name: 'High-Net-Worth Individuals',
    href: '/industries/high-net-worth-accounting-cpa/',
    img: '/images/home/ind-1.png',
    blurb:
      "We help our high-net-worth clients analyze their entity structures and various types of taxable income to strategically minimize the taxable impact.",
  },
  {
    name: 'Healthcare',
    href: '/industries/healthcare-accounting-services/',
    img: '/images/home/ind-2.png',
    blurb:
      'We recognize the complexities associated with the industry and minimize their tax expertise by using all of the available deductions.',
  },
  {
    name: 'Advertising & Marketing',
    href: '/industries/marketing-agency-accounting-services/',
    img: '/images/home/ind-3.png',
    blurb:
      'Project-cost discipline for agencies — utilisation, retainer revenue recognition, and the runway visibility creative leaders actually use.',
  },
];

const aboutPills = [
  "Experience from the world's largest organizations",
  'A fresh perspective to the accounting industry',
  'Personalized Attention',
  'Privacy and Trust',
];

const platforms = [
  { name: 'QuickBooks', src: '/images/logos/quickbooks.webp' },
  { name: 'NetSuite',   src: '/images/logos/netsuite.webp' },
  { name: 'Yardi',      src: '/images/logos/yardi.webp' },
  { name: 'Mercury',    src: '/images/logos/mercury.webp' },
];

const featured = insights[0];
const more = insights.slice(1, 4);
const slugOf = (id: string) => id.replace(/\.md$/, '').split('/').pop();
const dateFmt = (d: string | Date) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout
  rawTitle="Alpine Mar — The Florida CPA firm redefining accounting"
  description="Alpine Mar is the Florida CPA firm blending big-firm experience with a fresh perspective on tax, accounting, advisory, and audit — personalized attention for HNW individuals, healthcare, and growth-stage businesses."
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative bg-white">
    <!-- Full-width video on top -->
    <div class="relative w-full overflow-hidden">
      <video
        src="/video/hero.mp4"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        aria-hidden="true"
        class="block h-[44vh] w-full object-cover md:h-[58vh]"
      ></video>
    </div>

    <!-- Text content below -->
    <Container width="wide">
      <div data-reveal class="grid grid-cols-1 items-end gap-10 py-14 md:grid-cols-12 md:gap-16 md:py-20">
        <h1 class="am-hero-display am-gradient-ink md:col-span-7">
          The Florida CPA firm redefining accounting
        </h1>
        <div class="flex flex-col gap-8 md:col-span-5 md:pb-3">
          <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)]">
            Whether you're seeking expert tax planning services, fractional CFO services for financial guidance, reliable outsourced accounting services, or our perfect blend of industry experience, technology, and hands-on care has got you covered.
          </p>
          <a href="/about-us/" class="group inline-flex w-fit items-center gap-3 rounded-[4px] border border-line px-5 py-3 font-display text-[14px] font-medium text-[var(--color-text-head)] transition-colors hover:border-[#12122d]">
            View More
            <span class="inline-flex size-6 items-center justify-center rounded-full bg-[#12122d] text-white transition-transform group-hover:translate-x-1">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
            </span>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ TRUSTED PLATFORMS ═════════════ -->
  <section class="relative bg-paper py-10 md:py-14">
    <Container width="wide">
      <div class="flex flex-col items-center gap-8 md:flex-row md:gap-14">
        <p class="font-display text-[13px] tracking-[0.04em] text-[var(--color-text-body)] md:whitespace-nowrap">Trusted Platforms We Work With</p>
        <div class="flex flex-1 flex-wrap items-center justify-around gap-x-10 gap-y-6 opacity-70 [filter:grayscale(0.9)]">
          {platforms.map((p) => (
            <img src={p.src} alt={p.name} class="h-7 w-auto md:h-8" loading="lazy" />
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ OUR SERVICES ═════════════ -->
  <section class="relative bg-white py-24 md:py-32">
    <Container width="wide">
      <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Our Services</span>
      </div>

      <div data-reveal class="grid grid-cols-1 gap-10 border-b border-line pb-14 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-6">
          Discover a full range of services to meet <span class="text-scooter">your specific needs.</span>
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-6 md:pt-3">
          Whatever stage you're at, there's a service built for it. Take a look at what we do and find your fit.
        </p>
      </div>

      <ul>
        {services.map((s) => (
          <li data-reveal class="group border-b border-line">
            <a href={s.href} class="grid grid-cols-12 items-center gap-6 py-7 transition-colors md:py-9">
              <span class="font-display text-[28px] font-medium tabular-nums text-[var(--color-text-head)] md:col-span-1 col-span-2">{s.num}</span>
              <span class="font-display text-[28px] font-medium tracking-[-0.01em] text-[var(--color-text-head)] transition-transform duration-500 group-hover:translate-x-2 md:col-span-10 md:text-[32px] col-span-9">{s.name}</span>
              <span class="col-span-1 flex justify-end">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-[var(--color-text-head)] transition-transform group-hover:translate-x-1 group-hover:-translate-y-1">
                  <path d="M7 17 17 7"/><path d="M7 7h10v10"/>
                </svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ═════════════ ABOUT — Built different. On purpose. ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-white/80">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">About Us</span>
      </div>

      <div data-reveal class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-white md:col-span-6">
          Built different.<br />On purpose.
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-white/75 md:col-span-6 md:pt-3">
          We started Alpine Mar because we knew there was a better way to do this. More personal. More proactive. Less of the formal distance that makes most CPA relationships feel transactional. That's all what drives everything we do.
        </p>
      </div>

      <!-- Full-width image -->
      <div data-reveal class="mt-12 overflow-hidden rounded-[6px]">
        <img src="/images/about/hero.jpg" alt="Alpine Mar team meeting" class="h-[320px] w-full object-cover md:h-[420px]" loading="lazy" />
      </div>

      <!-- 4 feature pills (below image, not overlay) -->
      <ul data-stagger class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {aboutPills.map((label) => (
          <li class="flex items-center gap-3">
            <span class="flex size-5 shrink-0 items-center justify-center rounded-full bg-scooter text-white">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <span class="font-display text-[13px] text-white/85">{label}</span>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ═════════════ INDUSTRIES ═════════════ -->
  <section class="relative bg-white py-24 md:py-32">
    <Container width="wide">
      <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Industries We Service</span>
      </div>

      <div data-reveal class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">
          The firm that knows your world, not just your numbers.
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
          From healthcare to high-net-worth individuals to startups, we serve clients across some of the most complex financial landscapes there. The details change. The level of care doesn't.
        </p>
      </div>

      <div class="relative mt-14">
        <div id="aud-track" class="-mx-6 flex snap-x snap-mandatory gap-6 overflow-x-auto px-6 pb-3 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
          {industries.map((ind) => (
            <a href={ind.href} class="group flex w-[80%] flex-none snap-start flex-col gap-5 sm:w-[48%] lg:w-[calc((100%-3rem)/3)]">
              <div class="aspect-[4/3] w-full overflow-hidden rounded-[6px] bg-navy-50">
                <img src={ind.img} alt={ind.name} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
              </div>
              <h3 class="font-display text-[18px] font-medium tracking-[-0.01em] text-[var(--color-text-head)]">{ind.name}</h3>
              <p class="font-display text-[14px] leading-[1.6] text-[var(--color-text-body)]">{ind.blurb}</p>
            </a>
          ))}
        </div>

        <div class="mt-10 flex items-center justify-between gap-6">
          <div id="aud-dots" class="flex items-center gap-2">
            {industries.map((_, i) => (
              <button type="button" data-dot={i} aria-label={`Slide ${i + 1}`} class="h-1.5 w-1.5 rounded-full bg-line transition-all duration-300 data-[active=1]:w-6 data-[active=1]:bg-scooter"></button>
            ))}
          </div>
          <div class="flex items-center gap-3">
            <button type="button" id="aud-prev" aria-label="Previous" class="inline-flex size-11 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-colors hover:border-delft hover:text-delft">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M19 12H5"/><path d="m11 19-7-7 7-7"/></svg>
            </button>
            <button type="button" id="aud-next" aria-label="Next" class="inline-flex size-11 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-colors hover:border-delft hover:text-delft">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
            </button>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ CONTACT US ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-white/80">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Contact Us</span>
      </div>

      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        <!-- Left: Title + Office / Contact cards -->
        <div data-reveal class="flex flex-col gap-8 lg:col-span-6">
          <h2 class="am-h1-display am-gradient-ink-light">
            Let's get on<br />a first name basis.
          </h2>

          <div class="mt-2 grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div class="rounded-[6px] border border-white/10 bg-white/[0.04] p-6">
              <h3 class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-scooter">Our Location</h3>
              <p class="mt-4 font-display text-[14px] leading-[1.6] text-white/85">
                {site.address.street}<br />
                {site.address.city}, {site.address.state} {site.address.zip}
              </p>
            </div>
            <div class="rounded-[6px] border border-white/10 bg-white/[0.04] p-6">
              <h3 class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-scooter">Contact Information</h3>
              <p class="mt-4 font-display text-[14px] leading-[1.7] text-white/85">
                <a href={`tel:${site.phoneHref}`} class="block transition-colors hover:text-scooter">{site.phone}</a>
                <a href={`mailto:${site.email}`} class="block transition-colors hover:text-scooter">{site.email}</a>
              </p>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <form data-reveal action="/contact/" method="get" class="rounded-[6px] bg-white p-7 text-[var(--color-text-head)] md:p-9 lg:col-span-6">
          <div class="grid grid-cols-1 gap-5">
            <label class="block">
              <span class="font-display text-[13px] font-medium text-[var(--color-text-head)]">Full Name</span>
              <input name="full" type="text" placeholder="Enter your name" class="mt-2 block w-full rounded-[4px] border border-line bg-white px-4 py-3 font-display text-[14px] text-[var(--color-text-head)] placeholder:text-[var(--color-text-body)]/55 focus:border-scooter focus:outline-none focus:ring-0" />
            </label>

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <label class="block">
                <span class="font-display text-[13px] font-medium text-[var(--color-text-head)]">Email Address</span>
                <input name="email" type="email" autocomplete="email" placeholder="Enter email address" class="mt-2 block w-full rounded-[4px] border border-line bg-white px-4 py-3 font-display text-[14px] text-[var(--color-text-head)] placeholder:text-[var(--color-text-body)]/55 focus:border-scooter focus:outline-none focus:ring-0" />
              </label>
              <label class="block">
                <span class="font-display text-[13px] font-medium text-[var(--color-text-head)]">Company Name</span>
                <input name="company" type="text" placeholder="Enter company name" class="mt-2 block w-full rounded-[4px] border border-line bg-white px-4 py-3 font-display text-[14px] text-[var(--color-text-head)] placeholder:text-[var(--color-text-body)]/55 focus:border-scooter focus:outline-none focus:ring-0" />
              </label>
            </div>

            <label class="block">
              <span class="font-display text-[13px] font-medium text-[var(--color-text-head)]">Services Needed</span>
              <select name="service" class="mt-2 block w-full rounded-[4px] border border-line bg-white px-4 py-3 font-display text-[14px] text-[var(--color-text-head)] focus:border-scooter focus:outline-none focus:ring-0">
                <option value="">Select a service</option>
                {services.map((s) => <option value={s.name}>{s.name}</option>)}
              </select>
            </label>

            <label class="block">
              <span class="font-display text-[13px] font-medium text-[var(--color-text-head)]">How can we help?</span>
              <textarea name="note" rows="3" placeholder="Tell us a bit about what you're working on" class="mt-2 block w-full resize-none rounded-[4px] border border-line bg-white px-4 py-3 font-display text-[14px] text-[var(--color-text-head)] placeholder:text-[var(--color-text-body)]/55 focus:border-scooter focus:outline-none focus:ring-0"></textarea>
            </label>

            <ul class="flex flex-wrap items-center gap-x-4 gap-y-2 pt-1">
              {['Secured', 'Confidential', 'Within 1 business day'].map((label) => (
                <li class="inline-flex items-center gap-1.5 font-display text-[12px] text-[var(--color-text-body)]">
                  <span class="flex size-4 items-center justify-center rounded-full bg-scooter text-white">
                    <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  </span>
                  {label}
                </li>
              ))}
            </ul>
          </div>

          <button type="submit" class="group mt-7 inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-[#12122d]">
            Request a Consultation
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </form>
      </div>
    </Container>
  </section>

  <!-- ═════════════ LATEST INSIGHTS ═════════════ -->
  {insights.length > 0 && (
    <section class="relative bg-white py-24 md:py-32">
      <Container width="wide">
        <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
          <span class="block size-2 bg-scooter"></span>
          <span class="font-display text-[14px] tracking-[-0.005em]">Latest Insights</span>
        </div>

        <div data-reveal class="flex flex-col gap-10 md:flex-row md:items-end md:justify-between md:gap-16">
          <h2 class="am-h1-display text-[var(--color-text-head)] md:max-w-[20ch]">
            Leading the industry in helping industry leaders
          </h2>
          <a href="/blog/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-5 py-3 font-display text-[14px] font-medium text-white transition-colors hover:bg-[#12122d]">
            View All Insights
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>

        <!-- Featured large -->
        {featured && (
          <a data-reveal href={`/blog/${slugOf(featured.id)}/`} class="group mt-12 grid grid-cols-1 gap-8 overflow-hidden rounded-[6px] border border-line bg-white md:grid-cols-2 md:gap-12">
            {featured.data.heroImage && (
              <div class="aspect-[4/3] overflow-hidden md:aspect-auto">
                <img src={featured.data.heroImage} alt={featured.data.title} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
              </div>
            )}
            <div class="flex flex-col gap-4 p-6 md:p-10">
              <div class="flex items-center gap-3 font-display text-[12px] text-[var(--color-text-body)]">
                <span class="inline-flex items-center gap-1.5"><span class="block size-1.5 rounded-full bg-scooter"></span>Category</span>
                <span>{dateFmt(featured.data.date)}</span>
              </div>
              <h3 class="font-display text-[24px] font-medium leading-[1.25] tracking-[-0.01em] text-[var(--color-text-head)] md:text-[28px]">{featured.data.title}</h3>
              <p class="font-display text-[14px] leading-[1.65] text-[var(--color-text-body)]">{featured.data.description}</p>
              <span class="mt-auto inline-flex items-center gap-2 self-start rounded-[6px] bg-scooter px-4 py-2 font-display text-[13px] font-medium text-white">
                Read more
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
              </span>
            </div>
          </a>
        )}

        <!-- 3 small posts -->
        <div data-stagger class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-3">
          {more.map((p) => (
            <a href={`/blog/${slugOf(p.id)}/`} class="group flex flex-col gap-4 overflow-hidden rounded-[6px] border border-line bg-white p-5 transition-colors hover:border-scooter">
              {p.data.heroImage && (
                <div class="aspect-[16/10] overflow-hidden rounded-[4px] bg-navy-50">
                  <img src={p.data.heroImage} alt={p.data.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                </div>
              )}
              <div class="flex items-center gap-3 font-display text-[12px] text-[var(--color-text-body)]">
                <span class="inline-flex items-center gap-1.5"><span class="block size-1.5 rounded-full bg-scooter"></span>Category</span>
                <span>{dateFmt(p.data.date)}</span>
              </div>
              <h4 class="font-display text-[16px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)]">{p.data.title || 'Blog title heading will go here'}</h4>
              <span class="mt-auto inline-flex items-center gap-2 self-start rounded-[6px] bg-scooter px-3.5 py-2 font-display text-[12px] font-medium text-white">
                Read more
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
              </span>
            </a>
          ))}
        </div>
      </Container>
    </section>
  )}

  <script>
    function initAudience() {
      const track = document.getElementById('aud-track');
      if (!track || (track as any).__audBound) return;
      (track as any).__audBound = true;
      const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('#aud-dots [data-dot]'));
      const prev = document.getElementById('aud-prev');
      const next = document.getElementById('aud-next');
      const cards = track.children;
      const totalCards = cards.length;

      const setActive = (i: number) =>
        dots.forEach((d, idx) => { d.dataset.active = idx === i ? '1' : '0'; });

      const scrollToIndex = (i: number) => {
        const card = cards[i] as HTMLElement | undefined;
        if (!card) return;
        track.scrollTo({ left: card.offsetLeft - 24, behavior: 'smooth' });
      };

      const detectActive = () => {
        const center = track.scrollLeft + track.clientWidth / 2;
        let best = 0;
        let bestDist = Infinity;
        for (let i = 0; i < totalCards; i++) {
          const card = cards[i] as HTMLElement;
          const mid = card.offsetLeft + card.clientWidth / 2;
          const d = Math.abs(mid - center);
          if (d < bestDist) { bestDist = d; best = i; }
        }
        setActive(best);
        return best;
      };

      track.addEventListener('scroll', () => requestAnimationFrame(detectActive));
      dots.forEach((d, i) => d.addEventListener('click', () => scrollToIndex(i)));
      prev?.addEventListener('click', () => scrollToIndex(Math.max(0, detectActive() - 1)));
      next?.addEventListener('click', () => scrollToIndex(Math.min(totalCards - 1, detectActive() + 1)));
      setActive(0);
    }
    initAudience();
    document.addEventListener('astro:after-swap', initAudience);
  </script>
</BaseLayout>

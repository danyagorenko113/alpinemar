---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { getCollection } from 'astro:content';
import { site } from '@/data/site';

const insights = (await getCollection('insights'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))
  .slice(0, 4);

const services = [
  { num: '1', name: 'Tax Planning',                  href: '/services/tax-planning-services/',         img: '/images/home/svc-1.png' },
  { num: '2', name: 'Outsourced Accounting',         href: '/services/outsourced-accounting-services/', img: '/images/home/svc-2.png' },
  { num: '3', name: 'Private Client Services',       href: '/services/private-client-services/',       img: '/images/home/svc-3.png' },
  { num: '4', name: 'Transaction Advisory',          href: '/services/transaction-advisory-services/', img: '/images/home/svc-4.png' },
  { num: '5', name: 'Audit & Attestation Services',  href: '/services/audit-attestation-services/',    img: '/images/home/svc-5.png' },
];

const industries = [
  {
    name: 'High Net-Worth Individuals',
    href: '/industries/high-net-worth-accounting-cpa/',
    img: '/images/home/ind-1.png',
    blurb: "We help our high net-worth clients analyze their entity structures and various types of taxable income to strategically minimize the taxable impact.",
  },
  {
    name: 'Healthcare',
    href: '/industries/healthcare-accounting-services/',
    img: '/images/home/ind-2.png',
    blurb: 'We navigate the tax complexities associated with the industry and minimize their tax expense by using all of the available deductions.',
  },
  {
    name: 'Advertising & Marketing',
    href: '/industries/marketing-agency-accounting-services/',
    img: '/images/home/ind-3.png',
    blurb: 'Creative service providers trust Alpine Mar to provide a comprehensive suite of services, including financial management and strategic guidance.',
  },
  {
    name: 'Construction',
    href: '/industries/construction-cpa-services/',
    img: '/images/ind-construction.png',
    blurb: 'Job-cost accounting, multi-state nexus and contract revenue recognition for builders, GCs, and specialty trades.',
  },
  {
    name: 'Family Office',
    href: '/industries/family-office-accounting-services/',
    img: '/images/ind-family-office.png',
    blurb: 'Consolidated reporting across entities, trusts and investments — purpose-built for multi-generational wealth.',
  },
  {
    name: 'Law Firms',
    href: '/industries/law-firm-accounting-services/',
    img: '/images/ind-law-firm.png',
    blurb: 'IOLTA discipline, partner comp, and matter-level profitability reporting for plaintiff and defense practices.',
  },
  {
    name: 'Real Estate',
    href: '/industries/real-estate-cpa-services/',
    img: '/images/ind-real-estate.png',
    blurb: '1031s, cost-segregation, opportunity zones and entity structures — for sponsors, syndicators, and owner-operators.',
  },
  {
    name: 'Sports Athletes',
    href: '/industries/sports-accounting-services/',
    img: '/images/ind-sports.png',
    blurb: 'Multi-state residency, NIL income, signing bonuses and post-career planning — handled discreetly end to end.',
  },
  {
    name: 'Startups',
    href: '/industries/startup-cpa-services/',
    img: '/images/ind-startup.jpg',
    blurb: 'Cap table, R&D credits, fundraising-ready financials and a finance team that scales from pre-seed through Series C.',
  },
  {
    name: 'SaaS Companies',
    href: '/industries/saas-accounting-services/',
    img: '/images/ind-saas.jpg',
    blurb: 'ASC 606 revenue recognition, deferred revenue, ARR tracking and metrics investors actually look at.',
  },
  {
    name: 'Crypto',
    href: '/industries/crypto-cpa-services/',
    img: '/images/ind-crypto.jpg',
    blurb: 'On-chain reconciliation, DeFi and NFT cost basis, and tax-ready reporting for funds, founders, and individuals.',
  },
];

const aboutPills = [
  "Experience from the world's largest organizations",
  'A fresh perspective to the accounting industry',
  'Personalized Attention',
  'Privacy and Trust',
];

const platforms = [
  { name: 'QuickBooks',  src: '/images/logos/quickbooks.webp' },
  { name: 'NetSuite',    src: '/images/logos/netsuite-new.png' },
  { name: 'Yardi',       src: '/images/logos/yardi.webp' },
  { name: 'Mercury',     src: '/images/logos/mercury-new.png' },
  { name: 'CoinTracker', src: '/images/logos/cointracker.png' },
  { name: 'innflow',     src: '/images/logos/innflow.png' },
  { name: 'Justworks',   src: '/images/logos/justworks.png' },
  { name: 'Vestwell',    src: '/images/logos/vestwell.png' },
  { name: 'Gusto',       src: '/images/logos/gusto-new.png' },
  { name: 'Bill',        src: '/images/logos/bill.png' },
];

const featured = insights[0];
const more = insights.slice(1, 4);
const slugOf = (id: string) => id.replace(/\.md$/, '').split('/').pop();
const dateFmt = (d: string | Date) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout
  rawTitle="Alpine Mar — The Florida CPA firm redefining accounting"
  description="Alpine Mar is the Florida CPA firm blending big-firm experience with a fresh perspective on tax, accounting, advisory, and audit — personalized attention for HNW individuals, healthcare, and growth-stage businesses."
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-paper">
    <!-- Full-bleed background video -->
    <div class="absolute inset-0">
      <video
        src="/video/hero.mp4"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        aria-hidden="true"
        class="absolute inset-0 h-full w-full object-cover"
      ></video>
      <!-- Soft fade at top + bottom into paper bg for legibility -->
      <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-white/85 to-transparent"></div>
      <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-t from-white/70 to-transparent"></div>
    </div>

    <Container width="wide" class="relative">
      <div class="grid min-h-[88vh] grid-rows-[1fr_auto] gap-12 py-16 md:py-24">
        <h1 data-reveal data-speed="slow" class="am-hero-display am-gradient-ink self-start pb-2 leading-[1.02]">
          The Florida CPA<br />firm redefining<br />accounting
        </h1>

        <div data-reveal class="flex max-w-[58ch] flex-col gap-8 self-end">
          <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-head)]">
            Whether you're seeking expert tax planning services, efficient tax preparation services, fractional CFO services for financial guidance, reliable outsourced accounting services, or valuable transaction advisory services, our perfect blend of industry experience, technology, and hands-on care has got you covered.
          </p>
          <a href="/about-us/" class="group inline-flex w-fit items-center gap-2 border-b border-[#12122d] pb-1.5 font-display text-[18px] font-medium text-[#12122d] transition-colors hover:text-scooter">
            View More
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ TRUSTED PLATFORMS (infinite marquee) ═════════════ -->
  <section class="relative bg-paper py-10 md:py-14">
    <Container width="wide" class="overflow-hidden">
      <div class="flex flex-col items-center gap-8 md:flex-row md:gap-10">
        <p class="shrink-0 font-display text-[13px] tracking-[0.04em] text-[var(--color-text-body)] md:whitespace-nowrap">Trusted Platforms We Work With</p>

        <!-- Mask both ends so logos fade in/out smoothly -->
        <div class="relative w-full overflow-hidden" style="mask-image:linear-gradient(to right, transparent, black 6%, black 94%, transparent); -webkit-mask-image:linear-gradient(to right, transparent, black 6%, black 94%, transparent);">
          <div class="marquee items-center gap-12">
            {[...platforms, ...platforms].map((p) => (
              <img src={p.src} alt={p.name} class="h-7 w-auto shrink-0 md:h-8" loading="lazy" />
            ))}
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ OUR SERVICES ═════════════ -->
  <section class="relative bg-white py-24 md:py-32">
    <Container width="wide">
      <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Our Services</span>
      </div>

      <div data-reveal class="grid grid-cols-1 gap-10 border-b border-line pb-14 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-6">
          Discover a full range of services to meet your specific needs.
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-6 md:pt-3">
          Whatever stage you're at, there's a service built for it. Take a look at what we do and find your fit.
        </p>
      </div>

      <ul class="border-t border-line">
        {services.map((s) => (
          <li data-reveal class="group relative border-b border-line">
            <a href={s.href} class="relative grid grid-cols-3 items-center py-7 md:py-12">
              <span class="justify-self-start pl-2 font-display text-[28px] font-medium tabular-nums text-[#12122d] md:pl-6 md:text-[40px]">{s.num}</span>
              <span class="justify-self-center whitespace-nowrap text-left font-display text-[22px] font-medium tracking-[-0.01em] text-[#12122d] sm:text-[28px] md:min-w-[440px] md:text-[36px] lg:min-w-[540px] lg:text-[40px]">{s.name}</span>
              <span class="justify-self-end pr-2 md:pr-6">
                <!-- Default ↗ arrow -->
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="block text-[#12122d] group-hover:hidden">
                  <path d="M7 17 17 7"/><path d="M7 7h10v10"/>
                </svg>
                <!-- Hover → arrow (scooter) -->
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden text-scooter group-hover:block">
                  <path d="M5 12h14"/><path d="m13 5 7 7-7 7"/>
                </svg>
              </span>

              <!-- Hover preview image (positioned right of centered name) -->
              <img
                src={s.img}
                alt=""
                aria-hidden="true"
                class="pointer-events-none absolute right-[12%] top-1/2 hidden h-[160px] w-[280px] -translate-y-1/2 rounded-[4px] object-cover opacity-0 shadow-[0_18px_48px_-18px_rgba(18,18,45,0.45)] transition-opacity duration-300 group-hover:opacity-90 md:block lg:h-[200px] lg:w-[340px]"
                loading="lazy"
              />
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ═════════════ ABOUT — Built different. On purpose. ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122d] pt-24 text-white md:pt-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-white/80">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">About Us</span>
      </div>

      <div data-reveal class="grid grid-cols-1 gap-10 pb-20 md:grid-cols-12 md:gap-16 md:pb-28">
        <h2 class="am-h1-display text-white md:col-span-7">
          Built different.<br />On purpose.
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-white/80 md:col-span-5 md:pt-3">
          We started Alpine Mar because we knew there was a better way to do this. More personal. More proactive. Less of the formal distance that makes most CPA relationships feel transactional. That's still what drives everything we do.
        </p>
      </div>
    </Container>

    <!-- Full-bleed image with overlay pills -->
    <div data-reveal class="relative">
      <img src="/images/about/hero.jpg" alt="Alpine Mar team meeting" class="h-[420px] w-full object-cover md:h-[640px] lg:h-[720px]" loading="lazy" />
      <!-- Dark gradient at bottom for legibility -->
      <div class="pointer-events-none absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-[#12122d] via-[#12122d]/70 to-transparent"></div>

      <!-- 4 feature pills overlay at bottom of image -->
      <Container width="wide" class="absolute inset-x-0 bottom-0">
        <ul data-stagger class="grid grid-cols-1 gap-6 pb-10 sm:grid-cols-2 md:grid-cols-4 md:pb-14">
          {aboutPills.map((label) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full border-2 border-scooter">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-scooter"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="font-display text-[14px] font-medium leading-[1.4] text-white">{label}</span>
            </li>
          ))}
        </ul>
      </Container>
    </div>
    </Container>
  </section>

  <!-- ═════════════ INDUSTRIES ═════════════ -->
  <section class="relative bg-white py-24 md:py-32">
    <Container width="wide">
      <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Industries We Service</span>
      </div>

      <div data-reveal class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">
          The firm that knows your world, not just your numbers.
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
          From healthcare to high-net-worth individuals to startups, we serve clients across some of the most complex financial landscapes there. The details change. The level of care doesn't.
        </p>
      </div>

      <div class="relative mt-14">
        <div id="aud-track" class="-mx-6 flex snap-x snap-mandatory gap-6 overflow-x-auto px-6 pb-3 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
          {industries.map((ind) => (
            <a href={ind.href} class="group flex w-[80%] flex-none snap-start flex-col gap-6 sm:w-[55%] md:w-[44%] lg:w-[calc((100%-3rem)/2.6)]">
              <div class="aspect-[5/4] w-full overflow-hidden rounded-[4px] bg-navy-50">
                <img src={ind.img} alt={ind.name} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
              </div>
              <h3 class="font-display text-[22px] font-medium tracking-[-0.01em] text-[var(--color-text-head)]">{ind.name}</h3>
              <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)]">{ind.blurb}</p>
            </a>
          ))}
        </div>

        <div class="mt-10 flex items-center justify-between gap-6">
          <div id="aud-dots" class="flex items-center gap-2">
            {industries.map((_, i) => (
              <button type="button" data-dot={i} aria-label={`Slide ${i + 1}`} class="h-1.5 w-6 rounded-full bg-line transition-all duration-300 data-[active=1]:bg-[#12122d]"></button>
            ))}
          </div>
          <div class="flex items-center gap-3">
            <button type="button" id="aud-prev" aria-label="Previous" class="inline-flex size-11 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-colors hover:border-delft hover:text-delft">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M19 12H5"/><path d="m11 19-7-7 7-7"/></svg>
            </button>
            <button type="button" id="aud-next" aria-label="Next" class="inline-flex size-11 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-colors hover:border-delft hover:text-delft">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
            </button>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ CONTACT US ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122d] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div data-reveal data-speed="fast" class="mb-12 flex items-center gap-3 text-white/85">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Contact Us</span>
      </div>

      <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">
        <!-- Left: Title + Office / Contact cards -->
        <div data-reveal class="flex flex-col gap-10 lg:col-span-5">
          <h2 class="am-h1-display am-gradient-ink-light">
            Let's get on<br />a first name basis.
          </h2>

          <div class="mt-4 flex flex-col gap-5">
            <div class="rounded-[6px] bg-white/[0.05] p-7">
              <h3 class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-scooter">Our Location</h3>
              <p class="mt-6 font-display text-[15px] leading-[1.6] text-white">
                {site.address.street}<br />
                {site.address.city}, {site.address.state} {site.address.zip}
              </p>
            </div>
            <div class="rounded-[6px] bg-white/[0.05] p-7">
              <h3 class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-scooter">Contact Information</h3>
              <p class="mt-6 font-display text-[15px] leading-[1.7] text-white">
                <a href={`tel:${site.phoneHref}`} class="block transition-colors hover:text-scooter">{site.phone}</a>
                <a href={`mailto:${site.email}`} class="block transition-colors hover:text-scooter">{site.email}</a>
              </p>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <form data-reveal action="/contact/" method="get" class="rounded-[6px] bg-white p-7 text-[var(--color-text-head)] md:p-9 lg:col-span-7">
          <div class="grid grid-cols-1 gap-5">
            <label class="block">
              <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Full Name</span>
              <input name="full" type="text" placeholder="Enter your name" class="mt-2 block w-full rounded-[4px] border border-line bg-white px-4 py-3 font-display text-[14px] text-[var(--color-text-head)] placeholder:text-[var(--color-text-body)]/55 focus:border-scooter focus:outline-none focus:ring-0" />
            </label>

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <label class="block">
                <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Email Address</span>
                <input name="email" type="email" autocomplete="email" placeholder="Enter email address" class="mt-2 block w-full rounded-[4px] border border-line bg-white px-4 py-3 font-display text-[14px] text-[var(--color-text-head)] placeholder:text-[var(--color-text-body)]/55 focus:border-scooter focus:outline-none focus:ring-0" />
              </label>
              <label class="block">
                <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Phone Number</span>
                <input name="phone" type="tel" autocomplete="tel" placeholder="xxx-xxx-xxxx" class="mt-2 block w-full rounded-[4px] border border-line bg-white px-4 py-3 font-display text-[14px] text-[var(--color-text-head)] placeholder:text-[var(--color-text-body)]/55 focus:border-scooter focus:outline-none focus:ring-0" />
              </label>
            </div>

            <label class="block">
              <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Services Needed</span>
              <div class="relative mt-2">
                <select name="service" class="block w-full appearance-none rounded-[4px] border border-line bg-white px-4 py-3 pr-10 font-display text-[14px] text-[var(--color-text-head)] focus:border-scooter focus:outline-none focus:ring-0">
                  <option value="">Select a service</option>
                  {services.map((s) => <option value={s.name}>{s.name}</option>)}
                </select>
                <svg class="pointer-events-none absolute right-3.5 top-1/2 -translate-y-1/2 text-[var(--color-text-body)]" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </div>
            </label>

            <label class="block">
              <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">How can we help?</span>
              <textarea name="note" rows="3" placeholder="Type a message..." class="mt-2 block w-full resize-none rounded-[4px] border border-line bg-white px-4 py-3 font-display text-[14px] text-[var(--color-text-head)] placeholder:text-[var(--color-text-body)]/55 focus:border-scooter focus:outline-none focus:ring-0"></textarea>
            </label>

            <!-- Cloudflare Turnstile placeholder widget -->
            <div class="flex w-full max-w-[300px] items-center justify-between rounded-[4px] border border-line bg-[#fafbfc] px-3 py-2.5">
              <div class="flex items-center gap-2 text-[13px] text-[var(--color-text-head)]">
                <span class="flex size-5 items-center justify-center rounded-full bg-[#1b9c4a] text-white">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                <span class="font-display">Success!</span>
              </div>
              <div class="flex flex-col items-end">
                <div class="flex items-center gap-1 text-[10px] font-semibold text-[#f48120]">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm5 11h-4v4h-2v-4H7v-2h4V7h2v4h4v2z"/></svg>
                  CLOUDFLARE
                </div>
                <div class="text-[8px] text-[var(--color-text-body)]">Privacy · Help</div>
              </div>
            </div>
          </div>

          <button type="submit" class="group mt-7 inline-flex items-center gap-2 rounded-[6px] bg-[#1f3062] px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter">
            Request a Consultation
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </form>
      </div>
    </Container>
  </section>

  <!-- ═════════════ LATEST INSIGHTS ═════════════ -->
  {insights.length > 0 && (
    <section class="relative overflow-hidden bg-white py-24 md:py-32">
      <!-- Subtle grid pattern -->
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(18,18,45,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(18,18,45,0.035) 1px, transparent 1px); background-size: 72px 72px;"></div>

      <Container width="wide" class="relative z-10">
        <div data-reveal data-speed="fast" class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
          <span class="block size-2 bg-scooter"></span>
          <span class="font-display text-[14px] tracking-[-0.005em]">Latest Insights</span>
        </div>

        <div data-reveal class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
          <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">
            Leading the industry<br />in helping industry<br />leaders
          </h2>
          <div class="flex flex-col items-start gap-7 md:col-span-5 md:pt-3">
            <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)]">
              Practical perspectives on tax, finance, and business, written by the people who work in it every day.
            </p>
            <a href="/blog/" class="group inline-flex items-center gap-2 rounded-[6px] bg-[#1f3062] px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter">
              View All Insights
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          </div>
        </div>

        <!-- Featured large — image LEFT + content RIGHT -->
        {featured && (
          <a data-reveal href={`/blog/${slugOf(featured.id)}/`} class="group mt-16 grid grid-cols-1 overflow-hidden rounded-[6px] border border-line bg-white md:grid-cols-2">
            <div class="relative aspect-[5/4] overflow-hidden bg-navy-50 md:aspect-auto md:min-h-[480px]">
              <img src={featured.data.heroImage || '/images/about/collage-1.jpg'} alt={featured.data.title} class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            </div>
            <div class="flex flex-col gap-6 p-8 md:p-12">
              <div class="flex items-center justify-between gap-3 font-display text-[12px] text-[var(--color-text-body)]">
                <span class="inline-flex items-center gap-2 rounded-[4px] bg-paper px-3 py-1.5">
                  <span class="block size-1.5 bg-[#12122d]"></span>
                  Category
                </span>
                <span>{dateFmt(featured.data.date)}</span>
              </div>
              <h3 class="font-display text-[26px] font-medium leading-[1.2] tracking-[-0.01em] text-[var(--color-text-head)] md:text-[32px]">{featured.data.title}</h3>
              <p class="font-display text-[14px] leading-[1.65] text-[var(--color-text-body)]">{featured.data.description}</p>
              <div class="mt-auto flex items-center justify-between gap-4">
                <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Read more</span>
                <span class="inline-flex size-10 items-center justify-center rounded-[4px] bg-[#1f3062] text-white transition-transform group-hover:translate-x-1">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
                </span>
              </div>
            </div>
          </a>
        )}

        <!-- 3 small posts — text-only per Figma -->
        <div data-stagger class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-3">
          {more.map((p) => (
            <a href={`/blog/${slugOf(p.id)}/`} class="group flex min-h-[320px] flex-col rounded-[6px] border border-line bg-white p-7 transition-colors hover:border-[#12122d]">
              <div class="flex items-center justify-between gap-3 font-display text-[12px] text-[var(--color-text-body)]">
                <span class="inline-flex items-center gap-2 rounded-[4px] bg-paper px-3 py-1.5">
                  <span class="block size-1.5 bg-[#12122d]"></span>
                  Category
                </span>
                <span>{dateFmt(p.data.date)}</span>
              </div>
              <h4 class="mt-7 font-display text-[20px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)]">{p.data.title || 'Blog title heading will go here'}</h4>
              <div class="mt-auto flex items-center justify-between gap-4 pt-8">
                <span class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Read more</span>
                <span class="inline-flex size-9 items-center justify-center rounded-[4px] bg-[#1f3062] text-white transition-transform group-hover:translate-x-1">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </Container>
    </section>
  )}

  <script>
    function initAudience() {
      const track = document.getElementById('aud-track');
      if (!track || (track as any).__audBound) return;
      (track as any).__audBound = true;
      const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('#aud-dots [data-dot]'));
      const prev = document.getElementById('aud-prev');
      const next = document.getElementById('aud-next');
      const cards = track.children;
      const totalCards = cards.length;

      const setActive = (i: number) =>
        dots.forEach((d, idx) => { d.dataset.active = idx === i ? '1' : '0'; });

      const scrollToIndex = (i: number) => {
        const card = cards[i] as HTMLElement | undefined;
        if (!card) return;
        track.scrollTo({ left: card.offsetLeft - 24, behavior: 'smooth' });
      };

      const detectActive = () => {
        const center = track.scrollLeft + track.clientWidth / 2;
        let best = 0;
        let bestDist = Infinity;
        for (let i = 0; i < totalCards; i++) {
          const card = cards[i] as HTMLElement;
          const mid = card.offsetLeft + card.clientWidth / 2;
          const d = Math.abs(mid - center);
          if (d < bestDist) { bestDist = d; best = i; }
        }
        setActive(best);
        return best;
      };

      track.addEventListener('scroll', () => requestAnimationFrame(detectActive));
      dots.forEach((d, i) => d.addEventListener('click', () => scrollToIndex(i)));
      prev?.addEventListener('click', () => scrollToIndex(Math.max(0, detectActive() - 1)));
      next?.addEventListener('click', () => scrollToIndex(Math.min(totalCards - 1, detectActive() + 1)));
      setActive(0);
    }
    initAudience();
    document.addEventListener('astro:after-swap', initAudience);
  </script>
</BaseLayout>

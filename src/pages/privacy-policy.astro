---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { site } from '@/data/site';

const effective = 'January 1, 2026';

const sections = [
  {
    title: 'Website visitors',
    body: [
      "When you browse alpinemar.com we collect limited operational information: page URL, referrer, browser user-agent, IP address, and time of visit, retained in standard web-server logs for up to 90 days for security and performance monitoring.",
      "We use small amounts of browser storage (localStorage / sessionStorage) for functional purposes only — remembering whether you have dismissed the deadline ticker and similar UI state. We do not place advertising cookies or share browsing data with third-party advertisers.",
      "If you submit a contact form, we collect the information you provide (name, email, phone, message) and use it solely to respond to your inquiry. Submitted contact-form data is retained for up to 24 months for follow-up purposes; you may request deletion at any time.",
    ],
  },
  {
    title: 'Your rights',
    body: [
      "Depending on where you reside, you may have rights to access, correct, port, or delete the personal information we hold about you, and to opt out of certain processing. California, Florida, and EU/UK residents have specific statutory rights under CCPA/CPRA, the Florida Digital Bill of Rights, and GDPR/UK GDPR respectively.",
      "We do not sell or share personal information for cross-context behavioural advertising under CCPA, and we do not engage in targeted advertising under the Florida Digital Bill of Rights.",
      `To exercise any of these rights, contact us at ${site.email}. We respond to verifiable requests within the timeframes required by applicable law (45 days under CCPA, one month under GDPR).`,
    ],
  },
  {
    title: 'Our commitment',
    body: [
      "Your privacy is of the utmost importance at Alpine Mar. We collect sensitive non-public information throughout our engagements and adhere to strict security protocol during the transmitting and handling of information.",
    ],
  },
  {
    title: 'Information we collect',
    body: [
      "In the course of providing tax, accounting, and advisory services, we collect non-public personal information from a variety of sources, including: forms and documents you share with us, returns and statements we prepare on your behalf, and communications with you and authorised third parties.",
      "We do not collect more than is necessary to deliver the service you have engaged us for.",
    ],
  },
  {
    title: 'Information we share',
    body: [
      "Alpine Mar restricts access to non-public personal information to those employees who need to know to provide products and services. Information is shared only as required by law (e.g., tax authority filings made on your behalf) or with your consent.",
      "We do not disclose any non-public personal information about our clients or former clients to anyone except as permitted or required by law.",
    ],
  },
  {
    title: 'How we protect information',
    body: [
      "We maintain physical, electronic, and procedural safeguards to protect non-public personal information. These include encrypted document portals, role-based access controls, and ongoing staff training on data security.",
    ],
  },
  {
    title: 'Updates to this policy',
    body: [
      "Alpine Mar may update this privacy policy as our practices evolve or as required by law. The effective date above reflects the most recent revision. Material changes will be communicated through the website prior to taking effect.",
    ],
  },
];
---

<BaseLayout rawTitle="Privacy Policy - Alpine Mar" description="Read the privacy policy for using the Alpine Mar website.">
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-16 text-white md:pt-16 md:pb-20">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mx-auto max-w-[64ch] text-center">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[36px] md:text-[40px]">Privacy Policy</h1>
        <p class="mt-3 font-display text-[14px] leading-[1.55] text-white/70 md:text-[15px]">Effective {effective}</p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ BODY ═════════════ -->
  <section class="relative bg-paper py-20 md:py-24">
    <Container width="reading">
      <div class="rounded-[6px] border border-line bg-white p-8 md:p-12">
        <div class="prose-am">
          {sections.map((s) => (
            <>
              <h2>{s.title}</h2>
              {s.body.map((p) => <p>{p}</p>)}
            </>
          ))}
          <h2>Questions</h2>
          <p>Email <a href={`mailto:${site.email}`}>{site.email}</a> or call <a href={`tel:${site.phoneHref}`}>{site.phone}</a>. Our managing partner reviews privacy inquiries personally.</p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

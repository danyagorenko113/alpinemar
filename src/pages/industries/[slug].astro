---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import Icon from '@/components/Icon.astro';
import { allServices, industries as industryTaxonomy } from '@/data/taxonomy';
import { serviceSchema, breadcrumb } from '@/data/schema';
import { googleReviews } from '@/data/googleReviews';

export async function getStaticPaths() {
  const items = await getCollection('industries');
  return items.map((it) => ({
    params: { slug: it.data.path.replace(/^\/industries\//, '').replace(/\/$/, '') },
    props: { item: it, all: items, slug: it.data.path.replace(/^\/industries\//, '').replace(/\/$/, '') },
  }));
}

const { item, all, slug } = Astro.props;
const { Content } = await render(item);

const taxonomyEntry = industryTaxonomy.find((i) => i.href === item.data.path);

// Services we run for this industry (cross-link from frontmatter)
const linkedServices = (item.data.services ?? [])
  .map((svcSlug) => allServices.find((s) => s.href.includes(svcSlug)))
  .filter((x): x is (typeof allServices)[number] => !!x)
  .slice(0, 8);

// More industries — siblings (everything except current)
const moreIndustries = industryTaxonomy.filter((i) => i.href !== item.data.path).slice(0, 6);

// Per-section copy overrides from frontmatter (CMS "Section copy" card).
const sc = item.data.sectionCopy ?? {};

// "What you get" cards — CMS-supplied, else the four industry defaults.
const benefits = item.data.takeaways?.length ? item.data.takeaways : [
  { title: 'Industry-fluent partners',       body: `A CPA who knows your vertical from day one. No ramp-up, no "explain that again" calls.` },
  { title: 'Reporting that fits your vertical', body: 'Beyond GAAP: the metrics your investors, lenders, and operators actually care about.' },
  { title: 'Tested playbooks',               body: `We've already solved the questions you're about to ask. Faster engagements, fewer surprises.` },
  { title: 'A network already in place',     body: 'Lawyers, lenders, brokers, and insurers who already know your space. Your shortlist gets shorter.' },
];

// "Why Alpine Mar" pillars — CMS-supplied, else the firm's three.
const PILLAR_ICONS = ['/icons/about/quality.svg', '/icons/about/innovation.svg', '/icons/about/collaboration.svg'];
const defaultPillars = [
  { title: 'Specialized by vertical',  body: 'Construction, healthcare, SaaS, family office: every industry has its own playbook and we know yours.' },
  { title: 'Benchmarks that matter',   body: 'We know the industry KPIs investors and lenders look at, and we report on them.' },
  { title: 'Network already in place', body: 'Lawyers, lenders, brokers, and insurers we work with daily. Your call list is shorter.' },
];
const pillars = (item.data.pillars?.length ? item.data.pillars : defaultPillars)
  .map((p, i) => ({ ...p, icon: PILLAR_ICONS[i % PILLAR_ICONS.length] }));

const industryPhrase = item.data.title.toLowerCase().replace(/\bcpa\b/g, 'CPA');
const clientView = googleReviews[3];

const defaultFaq = [
  { q: 'How is this different from a generalist CPA firm?',  a: `We run a dedicated ${industryPhrase} practice — partners who've worked the vertical for years, benchmarks we already know, and a network of vertical-specific lawyers, lenders and operators we work with weekly.` },
  { q: 'How quickly can we start?',                          a: 'Intro call within a few business days, with scoping often started the same week.' },
  { q: 'Will I work with the same person?',                  a: 'Every engagement has partner involvement, with senior support staying close to your file instead of passing you through a queue.' },
  { q: 'Are you taking new clients in this industry?',       a: `Yes — Alpine Mar is actively onboarding ${industryPhrase} clients. We pace intake so every partner can deliver the service standard the firm is known for.` },
];
const faq = item.data.faq?.length ? item.data.faq : defaultFaq;

const heroImage = item.data.cover || taxonomyEntry?.image || '/images/about/hero.jpg';
const serviceIconByGroup: Record<string, string> = {
  Tax: 'trending-up',
  Accounting: 'file-text',
  Advisory: 'zap',
  Compliance: 'check-circle',
};

const schema = [
  serviceSchema({ name: item.data.title, description: item.data.summary, path: item.data.path }),
  breadcrumb([
    { name: 'Home', path: '/' },
    { name: 'Industries', path: '/industries/' },
    { name: item.data.title, path: item.data.path },
  ]),
];
---

<BaseLayout
  rawTitle={item.data.seo?.title ?? `${item.data.title} | Alpine Mar`}
  description={item.data.seo?.description ?? item.data.summary}
  image={item.data.cover}
  canonical={item.data.seo?.canonical}
  schema={schema}
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative isolate overflow-hidden bg-paper">
    <div class="relative h-[300px] max-h-[360px] w-full md:aspect-[12/5] md:h-auto lg:max-h-[380px]">
      <img src={heroImage} alt={item.data.coverAlt ?? ''} aria-hidden={item.data.coverAlt ? undefined : 'true'} class="absolute inset-0 h-full w-full object-cover object-center" onerror="this.src='/images/about/hero.jpg'" />
      <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-b from-transparent via-white/55 to-white"></div>

      <Container width="wide" class="relative z-10 flex h-full flex-col justify-end pb-10 md:pb-14">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="inline-flex max-w-full items-center gap-2 overflow-hidden whitespace-nowrap rounded-full bg-white/80 px-4 py-2 font-display text-[13px] font-medium text-navy-950 shadow-[0_12px_30px_-18px_rgba(18,18,45,0.6)] backdrop-blur-sm">
            <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
            <li aria-hidden="true" class="opacity-55">/</li>
            <li><a href="/industries/" class="transition-colors hover:text-scooter">Industries</a></li>
            <li aria-hidden="true" class="hidden opacity-55 sm:inline">/</li>
            <li aria-current="page" class="hidden max-w-[36ch] truncate font-medium sm:inline">{item.data.title}</li>
          </ol>
        </nav>
        <h1 class="am-hero-display am-gradient-ink max-w-[18ch]">{item.data.heroTitle ?? item.data.title}</h1>
      </Container>
    </div>
  </section>

  <!-- ═════════════ SUMMARY ═════════════ -->
  <section class="relative bg-white py-14 md:py-20">
    <Container width="wide">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <p class="font-display text-[18px] leading-[1.55] text-[var(--color-text-head)] md:col-span-8">{item.data.summary}</p>
        <div class="flex flex-col items-start gap-4 md:col-span-4 md:items-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-delft px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter">
            Request a Consultation
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ WHAT YOU GET ═════════════ -->
  <section class="relative bg-paper pt-12 pb-20 md:pt-16 md:pb-24">
    <Container width="wide">
      <div class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">{sc.benefits?.eyebrow ?? 'What you get'}</span>
      </div>
      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">{sc.benefits?.heading ?? 'A team that already speaks your language.'}</h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
          {sc.benefits?.intro ?? `The same four commitments on every ${industryPhrase} engagement.`}
        </p>
      </div>
      <ul class="mt-14 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {benefits.map((b, i) => (
          <li class="flex flex-col gap-5 rounded-[6px] border border-line bg-white p-7">
            <span class="font-mono text-[12px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="font-display text-[18px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)]">{b.title}</h3>
            <p class="font-display text-[14px] leading-[1.6] text-[var(--color-text-body)]">{b.body}</p>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ═════════════ SERVICES WE RUN FOR THIS INDUSTRY ═════════════ -->
  {linkedServices.length > 0 && (
    <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

      <Container width="wide" class="relative z-10">
        <div class="mb-10 flex items-center gap-3 text-white/85">
          <span class="block size-2 bg-scooter"></span>
          <span class="font-display text-[14px] tracking-[-0.005em]">{sc.services?.eyebrow ?? `Services we run for ${industryPhrase}`}</span>
        </div>
        <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
          <h2 class="am-h1-display am-gradient-ink-light md:col-span-7">
            {sc.services?.heading ?? 'From day-to-day books to high-stakes transactions.'}
          </h2>
          <p class="font-display text-[15px] leading-[1.65] text-white/75 md:col-span-5 md:pt-3">
            {sc.services?.intro ?? 'The most-booked services in this vertical — start with one or wrap them into a single engagement.'}
          </p>
        </div>
        <ul class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {linkedServices.map((svc) => (
            <li>
              <div class="group flex h-full min-h-[260px] flex-col rounded-[6px] border border-line bg-white p-7 text-[var(--color-text-head)] transition-colors hover:border-[#12122D]">
                <span class="inline-flex size-12 items-center justify-center rounded-[6px] bg-paper">
                  <Icon name={serviceIconByGroup[svc.group] ?? 'briefcase'} class="size-6 text-delft" />
                </span>
                <span>
                  <span class="mt-6 block font-display text-[20px] font-medium leading-[1.25] tracking-[-0.01em]">
                    <a href={svc.href} class="transition-colors hover:text-scooter group-hover:text-scooter">{svc.title}</a>
                  </span>
                  <span class="mt-3 line-clamp-3 block font-display text-[14px] leading-[1.6] text-[var(--color-text-body)]">{svc.summary}</span>
                </span>
                <span class="mt-auto inline-flex items-center gap-2 pt-6 font-display text-[14px] font-medium text-[var(--color-text-head)] transition-colors group-hover:text-scooter">
                  Learn more
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
                </span>
              </div>
            </li>
          ))}
        </ul>
      </Container>
    </section>
  )}

  <!-- ═════════════ SEO CONTENT ═════════════ -->
  <section class="relative bg-paper py-24 md:py-32">
    <Container width="wide">
      <div class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">{sc.deepdive?.eyebrow ?? 'Industry overview'}</span>
      </div>
      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">{sc.deepdive?.heading ?? 'What to know before you hire.'}</h2>
      </div>

      <div class="mt-14 rounded-[6px] border border-line bg-white p-8 md:p-12">
        <div class="prose-am prose-am--capped-media">
          <Content />
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ TESTIMONIAL ═════════════ -->
  <section class="relative bg-white py-20 md:py-24">
    <Container width="wide">
      <div class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">{sc.reviews?.eyebrow ?? 'Client view'}</span>
      </div>
      <figure class="grid grid-cols-1 gap-10 rounded-[6px] border border-line bg-paper p-10 md:grid-cols-12 md:gap-16 md:p-14">
        <svg width="48" height="40" viewBox="0 0 32 26" fill="currentColor" aria-hidden="true" class="text-line md:col-span-1">
          <path d="M9.6 0C4.3 0 0 4.6 0 10.3v15.7h12.5V10.3H6.4c0-2.8 1.4-5.1 3.2-5.1V0Zm19.6 0c-5.3 0-9.6 4.6-9.6 10.3v15.7H32V10.3h-6.1c0-2.8 1.4-5.1 3.2-5.1V0Z"/>
        </svg>
        <div class="md:col-span-11">
          <div class="mb-4 flex items-center gap-1 font-display text-[13px] font-medium text-[#12122D]" aria-label="5 star Google review">
            <span aria-hidden="true">★★★★★</span>
            <span class="sr-only">5 star Google review</span>
          </div>
          <blockquote class="font-display text-[20px] leading-[1.5] tracking-[-0.005em] text-[var(--color-text-head)] md:text-[24px]">
            {clientView.quote}
          </blockquote>
          <figcaption class="mt-8 flex items-center gap-4 border-t border-line pt-6">
            <div class="inline-flex size-12 items-center justify-center rounded-full bg-[#12122D] font-display text-[13px] font-medium text-white">
              {clientView.initials}
            </div>
            <div>
              <p class="font-display text-[14px] font-medium text-[var(--color-text-head)]">{clientView.name}</p>
              <p class="font-display text-[12px] text-[var(--color-text-body)]">Google review · {clientView.date}</p>
            </div>
          </figcaption>
        </div>
      </figure>
    </Container>
  </section>

  <!-- ═════════════ WHY ALPINE MAR (dark) ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mb-10 flex items-center gap-3 text-white/85">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">{sc.pillars?.eyebrow ?? 'Why Alpine Mar'}</span>
      </div>
      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-7">
          {sc.pillars?.heading ? sc.pillars.heading : <>A firm that knows your world,<br />not just your numbers.</>}
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-white/75 md:col-span-5 md:pt-3">
          {sc.pillars?.intro ?? 'Beyond the books: we know the industry mechanics — revenue recognition quirks, deduction levers, regulator behaviour, and the benchmarks your investors care about most.'}
        </p>
      </div>
      <ul class="mt-14 grid grid-cols-1 gap-5 md:grid-cols-3">
        {pillars.map((p) => (
          <li class="flex flex-col gap-6 rounded-[6px] bg-white p-7 text-[var(--color-text-head)]">
            <span class="inline-flex size-12 items-center justify-center rounded-[6px] bg-paper">
              <img src={p.icon} alt="" aria-hidden="true" class="size-6" />
            </span>
            <h3 class="font-display text-[20px] font-medium leading-[1.25] tracking-[-0.01em]">{p.title}</h3>
            <p class="font-display text-[14px] leading-[1.6] text-[var(--color-text-body)]">{p.body}</p>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ═════════════ MORE INDUSTRIES ═════════════ -->
  {moreIndustries.length > 0 && (
    <section class="relative bg-paper py-20 md:py-24">
      <Container width="wide">
        <div class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
          <span class="block size-2 bg-scooter"></span>
          <span class="font-display text-[14px] tracking-[-0.005em]">{sc.related?.eyebrow ?? 'More industries'}</span>
        </div>
        <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
          <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">
            {sc.related?.heading ?? "Industries we're just as fluent in:"}
          </h2>
          <a href="/industries/" class="inline-flex items-start gap-2 font-display text-[14px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter md:col-span-5 md:justify-self-end md:pt-3">
            {sc.related?.button ?? 'All industries'}
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="mt-0.5"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
        <ul class="mt-12 grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
          {moreIndustries.map((ind) => (
            <li>
              <div class="group flex h-full flex-col overflow-hidden rounded-[6px] border border-line bg-white transition-colors hover:border-[#12122D]">
                <a href={ind.href} aria-label={ind.title} tabindex="-1" class="block aspect-[12/5] max-h-[250px] w-full overflow-hidden bg-navy-50">
                  <img src={ind.image} alt={ind.title} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                </a>
                <div class="flex flex-1 flex-col p-6">
                  <h3 class="font-display text-[18px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)]">
                    <a href={ind.href} class="transition-colors hover:text-scooter group-hover:text-scooter">{ind.title}</a>
                  </h3>
                  <span class="mt-auto inline-flex items-center gap-2 pt-6 font-display text-[13px] font-medium text-[var(--color-text-head)] transition-colors group-hover:text-scooter">
                    Learn more
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
                  </span>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </Container>
    </section>
  )}

  <!-- ═════════════ FAQ ═════════════ -->
  <section id="faq" class="relative bg-white py-24 md:py-32">
    <Container width="wide">
      <div class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">{sc.faq?.eyebrow ?? 'Common questions'}</span>
      </div>
      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">{sc.faq?.heading ?? 'Before you book the call.'}</h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
          {sc.faq?.intro ?? 'Quick answers to the things most people ask before signing on.'}
        </p>
      </div>

      <div class="mt-12 overflow-hidden rounded-[6px] border border-line bg-white">
        {faq.map((item, i) => (
          <details class={`group ${i > 0 ? 'border-t border-line' : ''} px-7 py-5`} {...(i === 0 ? { open: true } : {})}>
            <summary class="flex cursor-pointer items-center justify-between gap-6 font-display text-[16px] font-medium text-[var(--color-text-head)] [&::-webkit-details-marker]:hidden">
              {item.q}
              <span class="inline-flex size-7 shrink-0 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-transform group-open:rotate-45">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
              </span>
            </summary>
            <p class="mt-4 font-display text-[14px] leading-[1.65] text-[var(--color-text-body)]">{item.a}</p>
          </details>
        ))}
      </div>
    </Container>
  </section>

  <!-- ═════════════ FINAL CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mb-16 flex items-center gap-3 text-white/85 md:mb-24">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[15px] tracking-[-0.005em]">{sc.cta?.eyebrow ?? 'Ready to start?'}</span>
      </div>
      <div class="grid grid-cols-1 items-end gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-8">{sc.cta?.heading ?? "Let's get on a first name basis."}</h2>
        <div class="md:col-span-4 md:flex md:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-6 py-4 font-display text-[15px] font-medium text-white transition-colors hover:bg-white hover:text-navy-950">
            {sc.cta?.button ?? 'Request a Consultation'}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

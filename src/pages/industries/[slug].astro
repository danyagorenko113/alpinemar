---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';
import { allServices, industries as industryTaxonomy } from '@/data/taxonomy';
import { serviceSchema, breadcrumb } from '@/data/schema';

export async function getStaticPaths() {
  const items = await getCollection('industries');
  return items.map((it) => ({
    params: { slug: it.data.path.replace(/^\/industries\//, '').replace(/\/$/, '') },
    props: { item: it, all: items, slug: it.data.path.replace(/^\/industries\//, '').replace(/\/$/, '') },
  }));
}

const { item, all, slug } = Astro.props;
const { Content } = await render(item);

const taxonomyEntry = industryTaxonomy.find((i) => i.href === item.data.path);

// Services we run for this industry (cross-link from frontmatter)
const linkedServices = (item.data.services ?? [])
  .map((svcSlug) => allServices.find((s) => s.href.includes(svcSlug)))
  .filter((x): x is (typeof allServices)[number] => !!x)
  .slice(0, 8);

// More industries — siblings (everything except current)
const moreIndustries = industryTaxonomy.filter((i) => i.href !== item.data.path).slice(0, 6);

const benefits = [
  { title: 'Industry-fluent partners', body: 'A senior CPA who knows your vertical from day one — no ramp-up, no "explain depreciation again" calls.' },
  { title: 'Vertical-specific reporting', body: 'Beyond GAAP — the KPIs your investors, lenders, and operators actually care about.' },
  { title: 'Tested playbooks',           body: "We've already solved the questions you're about to ask. Faster engagements, fewer surprises." },
  { title: 'Network on speed-dial',      body: 'Lawyers, lenders, brokers and insurers who already know the vertical. Your shortlist gets shorter.' },
];

const pillars = [
  { title: 'Specialised by vertical',  body: 'Real estate, healthcare, SaaS, family office — every industry has its own playbook and we know yours.', icon: '/icons/about/quality.svg' },
  { title: 'Benchmarks that matter',   body: "We know the industry-specific KPIs investors and lenders look at — and we report on them.",            icon: '/icons/about/innovation.svg' },
  { title: 'Network already in place', body: 'Lawyers, lenders, brokers and insurers we work with daily — your call list is shorter.',                icon: '/icons/about/collaboration.svg' },
];

const defaultFaq = [
  { q: 'How is this different from a generalist CPA firm?',  a: `We run a dedicated ${item.data.title.toLowerCase()} practice — partners who've worked the vertical for years, benchmarks we already know, and a network of vertical-specific lawyers, lenders and operators we work with weekly.` },
  { q: 'How quickly can we start?',                          a: 'Intro call within 2 business days, scoping memo + fixed fee within a week, active engagement starting inside 2 weeks of a signed letter.' },
  { q: 'Will I work with the same person?',                  a: 'Every engagement is partner-led — the senior CPA you meet on the intro is the one running your file. We do not hand off to junior teams once signed.' },
  { q: 'Are you taking new clients in this industry?',       a: `Yes — Alpine Mar is actively onboarding ${item.data.title.toLowerCase()} clients. We pace intake so every partner can deliver the service standard the firm is known for.` },
];
const faq = defaultFaq;

const heroImage = taxonomyEntry?.image || item.data.cover || '/images/about/hero.jpg';

const schema = [
  serviceSchema({ name: item.data.title, description: item.data.summary, path: item.data.path }),
  breadcrumb([
    { name: 'Home', path: '/' },
    { name: 'Industries', path: '/industries/' },
    { name: item.data.title, path: item.data.path },
  ]),
];
---

<BaseLayout
  rawTitle={item.data.seo?.title ?? `${item.data.title} | Alpine Mar`}
  description={item.data.seo?.description ?? item.data.summary}
  image={item.data.cover}
  schema={schema}
>
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative isolate overflow-hidden bg-paper">
    <div class="relative h-[380px] w-full md:h-[480px]">
      <img src={heroImage} alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover object-center" onerror="this.src='/images/about/hero.jpg'" />
      <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-b from-transparent via-white/55 to-white"></div>

      <Container width="wide" class="relative z-10 flex h-full flex-col justify-end pb-10 md:pb-14">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex flex-wrap items-center gap-2 font-display text-[13px] text-[var(--color-text-head)]">
            <li><a href="/" class="transition-colors hover:text-scooter">Home</a></li>
            <li aria-hidden="true" class="opacity-55">/</li>
            <li><a href="/industries/" class="transition-colors hover:text-scooter">Industries</a></li>
            <li aria-hidden="true" class="opacity-55">/</li>
            <li aria-current="page" class="font-medium">{item.data.title}</li>
          </ol>
        </nav>
        <h1 class="am-hero-display am-gradient-ink max-w-[18ch]">{item.data.title}</h1>
      </Container>
    </div>
  </section>

  <!-- ═════════════ SUMMARY ═════════════ -->
  <section class="relative bg-white py-14 md:py-20">
    <Container width="wide">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <p class="font-display text-[18px] leading-[1.55] text-[var(--color-text-head)] md:col-span-8">{item.data.summary}</p>
        <div class="flex flex-col items-start gap-4 md:col-span-4 md:items-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-[#1F3062] px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter">
            Request a Consultation
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ STATS BAR ═════════════ -->
  <section class="relative bg-paper py-10 md:py-12">
    <Container width="wide">
      <ul class="grid grid-cols-2 gap-y-8 border-y border-line py-10 md:grid-cols-4">
        <li class="flex flex-col items-center gap-2 px-4 text-center">
          <span class="font-display text-[40px] font-medium tracking-[-0.02em] text-[#1F3062] md:text-[48px]" data-counter data-to="6" data-suffix="+">0</span>
          <span class="font-display text-[12px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">Years in business</span>
        </li>
        <li class="flex flex-col items-center gap-2 px-4 text-center">
          <span class="font-display text-[40px] font-medium tracking-[-0.02em] text-[#1F3062] md:text-[48px]" data-counter data-to="11">0</span>
          <span class="font-display text-[12px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">Industry verticals</span>
        </li>
        <li class="flex flex-col items-center gap-2 px-4 text-center">
          <span class="font-display text-[40px] font-medium tracking-[-0.02em] text-[#1F3062] md:text-[48px]" data-counter data-to="31">0</span>
          <span class="font-display text-[12px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">Specialised services</span>
        </li>
        <li class="flex flex-col items-center gap-2 px-4 text-center">
          <span class="font-display text-[40px] font-medium tracking-[-0.02em] text-[#1F3062] md:text-[48px]" data-counter data-to="100" data-suffix="%">0</span>
          <span class="font-display text-[12px] uppercase tracking-[0.12em] text-[var(--color-text-body)]">Partner-led engagements</span>
        </li>
      </ul>
    </Container>
  </section>

  <!-- ═════════════ WHAT YOU GET ═════════════ -->
  <section class="relative bg-paper pb-20 md:pb-24">
    <Container width="wide">
      <div class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">What you get</span>
      </div>
      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">A team that already speaks your language.</h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
          The same four commitments on every {item.data.title.toLowerCase()} engagement.
        </p>
      </div>
      <ul class="mt-14 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {benefits.map((b, i) => (
          <li class="flex flex-col gap-5 rounded-[6px] border border-line bg-white p-7">
            <span class="font-mono text-[12px] uppercase tracking-[0.16em] text-[var(--color-text-body)]">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="font-display text-[18px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)]">{b.title}</h3>
            <p class="font-display text-[14px] leading-[1.6] text-[var(--color-text-body)]">{b.body}</p>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ═════════════ SERVICES WE RUN FOR THIS INDUSTRY ═════════════ -->
  {linkedServices.length > 0 && (
    <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

      <Container width="wide" class="relative z-10">
        <div class="mb-10 flex items-center gap-3 text-white/85">
          <span class="block size-2 bg-scooter"></span>
          <span class="font-display text-[14px] tracking-[-0.005em]">Services we run for {item.data.title.toLowerCase()}</span>
        </div>
        <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
          <h2 class="am-h1-display am-gradient-ink-light md:col-span-7">
            From day-to-day books to high-stakes transactions.
          </h2>
          <p class="font-display text-[15px] leading-[1.65] text-white/75 md:col-span-5 md:pt-3">
            The most-booked services in this vertical — start with one or wrap them into a single engagement.
          </p>
        </div>
        <ul class="mt-12 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {linkedServices.map((svc) => (
            <li>
              <a href={svc.href} class="group flex h-full flex-col justify-between gap-4 rounded-[6px] bg-white p-5 text-[var(--color-text-head)] transition-colors hover:bg-paper">
                <span class="font-display text-[15px] font-medium leading-[1.3] transition-colors group-hover:text-scooter">{svc.title}</span>
                <span class="inline-flex size-7 items-center justify-center rounded-[4px] bg-paper text-[var(--color-text-head)] transition-transform group-hover:translate-x-1">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </Container>
    </section>
  )}

  <!-- ═════════════ DEEP DIVE (markdown body, landing-styled) ═════════════ -->
  <section class="relative bg-paper py-24 md:py-32">
    <Container width="wide">
      <div class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Deep dive</span>
      </div>
      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">The detail, if you want it.</h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
          The full breakdown of how we approach {item.data.title.toLowerCase()} — written for clients who want to see the rigor before signing on.
        </p>
      </div>

      <div class="mt-14 grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <div class="rounded-[6px] border border-line bg-white p-8 md:col-span-9 md:p-12">
          <div class="prose-am">
            <Content />
          </div>
        </div>
        <aside class="md:col-span-3">
          <div class="sticky top-28 rounded-[6px] bg-[#12122D] p-7 text-white">
            <p class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-head)]">Quick answer</p>
            <p class="mt-5 font-display text-[15px] leading-[1.55] text-white/85">
              Skip the long read? The summary above plus the FAQ below cover 90% of what {item.data.title.toLowerCase()} clients ask before booking the intro.
            </p>
            <a href="#faq" class="mt-6 inline-flex items-center gap-2 font-display text-[13px] font-medium text-scooter transition-colors hover:text-white">
              Jump to FAQ
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
            </a>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- ═════════════ TESTIMONIAL ═════════════ -->
  <section class="relative bg-white py-20 md:py-24">
    <Container width="wide">
      <div class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Client view</span>
      </div>
      <figure class="grid grid-cols-1 gap-10 rounded-[6px] border border-line bg-paper p-10 md:grid-cols-12 md:gap-16 md:p-14">
        <svg width="48" height="40" viewBox="0 0 32 26" fill="currentColor" aria-hidden="true" class="text-line md:col-span-1">
          <path d="M9.6 0C4.3 0 0 4.6 0 10.3v15.7h12.5V10.3H6.4c0-2.8 1.4-5.1 3.2-5.1V0Zm19.6 0c-5.3 0-9.6 4.6-9.6 10.3v15.7H32V10.3h-6.1c0-2.8 1.4-5.1 3.2-5.1V0Z"/>
        </svg>
        <div class="md:col-span-11">
          <blockquote class="font-display text-[20px] leading-[1.5] tracking-[-0.005em] text-[var(--color-text-head)] md:text-[24px]">
            They knew our vertical from minute one. No explaining the basics, no "let me get back to you on that" — just answers, faster than any firm we'd used.
          </blockquote>
          <figcaption class="mt-8 flex items-center gap-4 border-t border-line pt-6">
            <div class="size-12 overflow-hidden rounded-full bg-navy-50">
              <img src="/images/team/Jennifer.jpeg" alt="" class="h-full w-full object-cover" loading="lazy" />
            </div>
            <div>
              <p class="font-display text-[14px] font-medium text-[var(--color-text-head)]">Marcus Bell</p>
              <p class="font-display text-[12px] text-[var(--color-text-body)]">{item.data.title} · Miami, FL</p>
            </div>
          </figcaption>
        </div>
      </figure>
    </Container>
  </section>

  <!-- ═════════════ WHY ALPINE MAR (dark) ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mb-10 flex items-center gap-3 text-white/85">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Why Alpine Mar</span>
      </div>
      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display am-gradient-ink-light md:col-span-7">
          A firm that knows your world,<br />not just your numbers.
        </h2>
        <p class="font-display text-[15px] leading-[1.65] text-white/75 md:col-span-5 md:pt-3">
          Beyond the books: we know the industry mechanics — revenue recognition quirks, deduction levers, regulator behaviour, and the benchmarks your investors care about most.
        </p>
      </div>
      <ul class="mt-14 grid grid-cols-1 gap-5 md:grid-cols-3">
        {pillars.map((p) => (
          <li class="flex flex-col gap-6 rounded-[6px] bg-white p-7 text-[var(--color-text-head)]">
            <span class="inline-flex size-12 items-center justify-center rounded-[6px] bg-paper">
              <img src={p.icon} alt="" aria-hidden="true" class="size-6" />
            </span>
            <h3 class="font-display text-[20px] font-medium leading-[1.25] tracking-[-0.01em]">{p.title}</h3>
            <p class="font-display text-[14px] leading-[1.6] text-[var(--color-text-body)]">{p.body}</p>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <!-- ═════════════ TALK TO A PARTNER ═════════════ -->
  <section class="relative bg-white py-20 md:py-24">
    <Container width="wide">
      <div class="grid grid-cols-1 items-center gap-10 rounded-[6px] border border-line bg-paper p-8 md:grid-cols-12 md:gap-16 md:p-12">
        <div class="md:col-span-3 md:order-1">
          <div class="aspect-square w-full max-w-[200px] overflow-hidden rounded-[6px] bg-navy-50">
            <img src="/images/team/Pablo.jpeg" alt="Pablo Martell, CPA" class="h-full w-full object-cover" loading="lazy" />
          </div>
        </div>
        <div class="md:col-span-9 md:order-2">
          <p class="font-display text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--color-text-head)]">Talk to a partner</p>
          <h2 class="mt-4 font-display text-[26px] font-medium leading-[1.2] tracking-[-0.01em] text-[var(--color-text-head)] md:text-[32px]">
            Get a partner-level answer on the first call — no sales handoff.
          </h2>
          <p class="mt-5 max-w-[58ch] font-display text-[15px] leading-[1.65] text-[var(--color-text-body)]">
            Pablo Martell, CPA — CEO &amp; Managing Partner — sits on every intro for {item.data.title.toLowerCase()}. You'll know inside 30 minutes whether we're the right fit, and what the engagement actually costs.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-4">
            <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-[#1F3062] px-6 py-3.5 font-display text-[14px] font-medium text-white transition-colors hover:bg-scooter">
              Book an intro call
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
            </a>
            <a href="/about-us/" class="inline-flex items-center gap-2 font-display text-[14px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">
              Meet the team
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═════════════ MORE INDUSTRIES ═════════════ -->
  {moreIndustries.length > 0 && (
    <section class="relative bg-paper py-20 md:py-24">
      <Container width="wide">
        <div class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
          <span class="block size-2 bg-scooter"></span>
          <span class="font-display text-[14px] tracking-[-0.005em]">More industries</span>
        </div>
        <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
          <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">
            Other verticals we know cold.
          </h2>
          <a href="/industries/" class="inline-flex items-start gap-2 font-display text-[14px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter md:col-span-5 md:justify-self-end md:pt-3">
            All industries
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="mt-0.5"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
        <ul class="mt-12 grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
          {moreIndustries.map((ind) => (
            <li>
              <a href={ind.href} class="group flex h-full flex-col overflow-hidden rounded-[6px] border border-line bg-white transition-colors hover:border-[#12122D]">
                <div class="aspect-[5/4] w-full overflow-hidden bg-navy-50">
                  <img src={ind.image} alt={ind.title} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                </div>
                <div class="flex flex-1 flex-col p-6">
                  <h3 class="font-display text-[18px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-head)] transition-colors group-hover:text-scooter">{ind.title}</h3>
                  <span class="mt-auto inline-flex items-center gap-2 pt-6 font-display text-[13px] font-medium text-[var(--color-text-head)] transition-colors group-hover:text-scooter">
                    Learn more
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
                  </span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </Container>
    </section>
  )}

  <!-- ═════════════ FAQ ═════════════ -->
  <section id="faq" class="relative bg-white py-24 md:py-32">
    <Container width="wide">
      <div class="mb-10 flex items-center gap-3 text-[var(--color-text-head)]">
        <span class="block size-2 bg-scooter"></span>
        <span class="font-display text-[14px] tracking-[-0.005em]">Common questions</span>
      </div>
      <div class="grid grid-cols-1 gap-10 md:grid-cols-12 md:gap-16">
        <h2 class="am-h1-display text-[var(--color-text-head)] md:col-span-7">Before you book the call.</h2>
        <p class="font-display text-[15px] leading-[1.65] text-[var(--color-text-body)] md:col-span-5 md:pt-3">
          Quick answers to the things most people ask before signing on.
        </p>
      </div>

      <div class="mt-12 overflow-hidden rounded-[6px] border border-line bg-white">
        {faq.map((item, i) => (
          <details class={`group ${i > 0 ? 'border-t border-line' : ''} px-7 py-5`} {...(i === 0 ? { open: true } : {})}>
            <summary class="flex cursor-pointer items-center justify-between gap-6 font-display text-[16px] font-medium text-[var(--color-text-head)] [&::-webkit-details-marker]:hidden">
              {item.q}
              <span class="inline-flex size-7 shrink-0 items-center justify-center rounded-full border border-line text-[var(--color-text-head)] transition-transform group-open:rotate-45">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
              </span>
            </summary>
            <p class="mt-4 font-display text-[14px] leading-[1.65] text-[var(--color-text-body)]">{item.a}</p>
          </details>
        ))}
      </div>
    </Container>
  </section>

  <!-- ═════════════ FINAL CTA ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] py-24 text-white md:py-32">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mb-16 flex items-center gap-3 text-white/85 md:mb-24">

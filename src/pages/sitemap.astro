---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/Container.astro';

const SPANISH = new Set(['creacion-de-empresas', 'servicios-contables', 'servicios-tributarios-en-florida']);
const services = (await getCollection('services'))
  .filter((s) => !SPANISH.has(s.id))
  .filter((s) => s.data.status !== 'draft')
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .map((s) => ({ title: s.data.title, href: s.data.path }));
const industries = (await getCollection('industries'))
  .filter((i) => i.data.status !== 'draft')
  .sort((a, b) => a.data.title.localeCompare(b.data.title))
  .map((s) => ({ title: s.data.title, href: s.data.path }));
const insights = (await getCollection('insights'))
  .filter((p) => p.data.status !== 'draft')
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))
  .slice(0, 24)
  .map((p) => ({ title: p.data.title, href: `/blog/${p.id.replace(/\.md$/, '').split('/').pop()}/` }));

const sections = [
  {
    title: 'Company',
    items: [
      { title: 'Home', href: '/' },
      { title: 'About Us', href: '/about-us/' },
      { title: 'In The Media', href: '/in-the-media/' },
      { title: 'Find Your Service', href: '/find-your-service/' },
      { title: 'Contact', href: '/contact/' },
      { title: 'Privacy Policy', href: '/privacy-policy/' },
    ],
  },
  { title: `Services (${services.length})`,    items: services },
  { title: `Industries (${industries.length})`, items: industries },
  { title: 'Latest Insights',                   items: insights },
  {
    title: 'Tools',
    items: [
      { title: 'All Tools', href: '/tools/' },
      { title: '1031 Exchange Savings', href: '/tools/1031-exchange-savings/' },
      { title: 'Burn Rate Calculator', href: '/tools/burn-rate-calculator/' },
      { title: 'R&D Credit', href: '/tools/r-and-d-credit/' },
      { title: 'S-Corp vs LLC', href: '/tools/s-corp-vs-llc/' },
      { title: 'Tax Savings Estimator', href: '/tools/tax-savings-estimator/' },
    ],
  },
  { title: 'Reports', items: [{ title: 'All Reports', href: '/reports/' }] },
];
---

<BaseLayout rawTitle="Sitemap — Alpine Mar" description="A clickable map of every page on alpinemar.com.">
  <!-- ═════════════ HERO ═════════════ -->
  <section class="relative overflow-hidden bg-[#12122D] pt-12 pb-16 text-white md:pt-16 md:pb-20">
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

    <Container width="wide" class="relative z-10">
      <div class="mx-auto max-w-[64ch] text-center">
        <h1 class="font-display text-[32px] font-medium leading-[1.15] tracking-[-0.015em] text-white sm:text-[36px] md:text-[40px]">Sitemap</h1>
        <p class="mt-3 font-display text-[14px] leading-[1.55] text-white/70 md:text-[15px]">Every page on alpinemar.com, organized by section.</p>
      </div>
    </Container>
  </section>

  <!-- ═════════════ BODY ═════════════ -->
  <section class="relative bg-paper py-20 md:py-24">
    <Container width="wide">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-2 lg:grid-cols-3">
        {sections.map((s) => (
          <div class="rounded-[6px] border border-line bg-white p-7">
            <h2 class="font-display text-[15px] font-medium tracking-[-0.01em] text-[var(--color-text-head)]">{s.title}</h2>
            <ul class="mt-6 space-y-3.5">
              {s.items.map((it) => (
                <li>
                  <a href={it.href} class="font-display text-[14px] text-[var(--color-text-body)] transition-colors hover:text-scooter">{it.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </Container>
  </section>
</BaseLayout>

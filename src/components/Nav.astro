---
import Container from './Container.astro';
import Logo from './Logo.astro';
import Button from './Button.astro';
import Icon from './Icon.astro';
import { serviceMenu, industryMenu } from '@/data/navigation';
import { site } from '@/data/site';

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
// Whole Figma redesign uses light navbar on every page вЂ” keep dark variant
// only as a fallback (no current pages need it).
const onDark = false;

const trigger = onDark
  ? 'inline-flex items-center font-body text-sm font-medium text-white/90 transition-colors hover:text-scooter cursor-pointer'
  : 'inline-flex items-center font-body text-sm font-medium text-navy-900 transition-colors hover:text-teal-700 cursor-pointer';
const chev = 'ml-1.5 inline-block transition-transform duration-200 mega-chev';

// Hot picks shown in the Services mega вЂ” most common entry points
const popularServices = [
  { name: 'Tax Planning', href: '/services/tax-planning-services/', tag: 'Tax' },
  { name: 'Fractional CFO', href: '/services/fractional-cfo-services/', tag: 'Advisory' },
  { name: 'Outsourced Accounting', href: '/services/outsourced-accounting-services/', tag: 'Accounting' },
];
---

<header
  class:list={[
    'sticky top-0 z-50 transition-colors',
    onDark
      ? 'border-b border-white/10 bg-[#0a0a1c]/55 backdrop-blur-md'
      : 'border-b border-line bg-white/95 backdrop-blur-md',
  ]}
>
  <Container width="wide" class="flex h-[78px] items-stretch justify-between gap-4 md:h-[88px] md:gap-6">
    <div class="flex items-center">
      <Logo variant={onDark ? 'light' : 'dark'} />
    </div>

    <nav class="hidden items-center gap-10 lg:flex" aria-label="Primary">
      <div class="mega-host static" data-mega="services">
        <button type="button" class={trigger} aria-haspopup="true" aria-expanded="false" data-mega-trigger>
          Services
          <svg class={chev} width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9" /></svg>
        </button>
      </div>

      <div class="mega-host static" data-mega="industries">
        <button type="button" class={trigger} aria-haspopup="true" aria-expanded="false" data-mega-trigger>
          Industries
          <svg class={chev} width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9" /></svg>
        </button>
      </div>

      <a href="/blog/" class:list={['font-display text-[15px] font-medium tracking-[-0.005em] transition-colors', onDark ? 'text-white/90 hover:text-scooter' : (isActive('/blog/') ? 'text-scooter' : 'text-[var(--color-text-head)] hover:text-scooter')]}>Insights</a>
      <a href="/about-us/" class:list={['font-display text-[15px] font-medium tracking-[-0.005em] transition-colors', onDark ? 'text-white/90 hover:text-scooter' : (isActive('/about-us/') ? 'text-scooter' : 'text-[var(--color-text-head)] hover:text-scooter')]}>About Us</a>
      <a href="/tools/" class:list={['font-display text-[15px] font-medium tracking-[-0.005em] transition-colors', onDark ? 'text-white/90 hover:text-scooter' : (isActive('/tools/') ? 'text-scooter' : 'text-[var(--color-text-head)] hover:text-scooter')]}>Tools</a>
    </nav>

    <div class="flex items-stretch gap-0">
      <button type="button" id="nav-toggle" class:list={['-mr-6 inline-grid w-[96px] place-items-center lg:hidden md:-mr-8 md:w-[104px]', onDark ? 'border-l border-white/20 text-white' : 'border-l border-line text-[var(--color-text-head)]']} aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg width="27" height="27" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
      </button>
      <a
        href="/contact/"
        class:list={[
          'hidden h-[calc(100%+1px)] -mb-px items-center gap-2 px-8 font-display text-[15px] font-medium transition-colors sm:inline-flex',
          onDark ? 'bg-scooter text-white hover:bg-white hover:text-navy-950' : 'bg-delft text-white hover:bg-scooter',
        ]}
      >
        Request a Consultation
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>
  </Container>

  <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ Services mega panel в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
  <div id="mega-services" class="mega-panel pointer-events-none absolute left-0 right-0 top-full z-40 origin-top -translate-y-1 border-b border-line bg-white opacity-0 shadow-[0_30px_60px_-30px_rgba(18,18,45,0.25)] transition-[opacity,transform] duration-200" data-mega-panel="services">
    <Container width="wide" class="max-h-[calc(100vh-5.5rem)] overflow-y-auto py-8">

      <!-- Header strip -->
      <div class="mb-8 flex flex-wrap items-end justify-between gap-6 border-b border-line pb-5">
        <div>
          <div class="flex items-center gap-3">
            <span class="block size-2 bg-scooter"></span>
            <span class="font-display text-[14px] tracking-[-0.005em] text-[var(--color-text-head)]">Services</span>
          </div>
          <p class="mt-3 font-display text-[24px] font-medium tracking-[-0.01em] text-[var(--color-text-head)]">What are you trying to solve?</p>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <a href="/find-your-service/" class="inline-flex items-center gap-2 rounded-[6px] border border-line bg-white px-4 py-2 font-display text-[13px] font-medium text-[var(--color-text-head)] transition-colors hover:border-[#12122D]">
            Take the 4-question quiz
          </a>
          <a href="/services/" class="group inline-flex items-center gap-2 rounded-[6px] bg-delft px-4 py-2 font-display text-[13px] font-medium text-white transition-colors hover:bg-scooter">
            View all
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>

      <!-- 5 categories grid -->
      <div class="grid grid-cols-2 gap-5 md:grid-cols-3 lg:grid-cols-5">
        {serviceMenu.map((group) => (
          <div class="flex flex-col rounded-[6px] border border-line bg-white p-5 transition-colors hover:border-[#12122D]">
            <a href={group.href} class="flex items-baseline gap-2">
              <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-scooter">{group.label}</span>
            </a>
            <p class="mt-3 line-clamp-2 font-display text-[12.5px] leading-[1.5] text-[var(--color-text-body)]">{group.blurb}</p>
            {/* Render every service link directly — no "+ N more" behind a
                click. Links hidden until interaction are discounted by search
                engines, so all service pages must be in the crawlable markup. */}
            <ul class="mt-4 space-y-2 border-t border-line pt-3">
              {group.items.map((it) => (
                <li>
                  <a href={it.href} class="block font-display text-[13px] leading-tight text-[var(--color-text-head)] transition-colors hover:text-scooter">{it.name}</a>
                  {'desc' in it && (
                    <span class="mt-0.5 line-clamp-1 block font-display text-[11px] leading-snug text-[var(--color-text-body)]">{(it as any).desc}</span>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Popular row + CTA -->
      <div class="mt-8 grid grid-cols-1 gap-6 border-t border-line pt-6 lg:grid-cols-12">
        <div class="lg:col-span-8">
          <p class="font-display text-[12px] font-medium uppercase tracking-[0.08em] text-scooter">Most requested</p>
          <ul class="mt-4 flex flex-wrap gap-2">
            {popularServices.map((p) => (
              <li>
                <a href={p.href} class="group/p inline-flex items-center gap-2 rounded-[6px] border border-line bg-white px-3.5 py-1.5 font-display text-[13px] text-[var(--color-text-head)] transition-colors hover:border-[#12122D]">
                  <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-scooter">{p.tag}</span>
                  <span class="block h-3 w-px bg-line"></span>
                  {p.name}
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover/p:translate-x-0.5"><path d="m9 18 6-6-6-6"/></svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="flex items-center lg:col-span-4 lg:justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2 rounded-[6px] bg-scooter px-5 py-2.5 font-display text-[13px] font-medium text-white transition-colors hover:bg-[#12122D]">
            Request consultation
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </Container>
  </div>

  <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ Industries mega panel в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
  <div id="mega-industries" class="mega-panel pointer-events-none absolute left-0 right-0 top-full z-40 origin-top -translate-y-1 border-b border-line bg-white opacity-0 shadow-[0_30px_60px_-30px_rgba(18,18,45,0.25)] transition-[opacity,transform] duration-200" data-mega-panel="industries">
    <Container width="wide" class="max-h-[calc(100vh-5.5rem)] overflow-y-auto py-8">

      <div class="mb-8 flex flex-wrap items-end justify-between gap-6 border-b border-line pb-5">
        <div>
          <div class="flex items-center gap-3">
            <span class="block size-2 bg-scooter"></span>
            <span class="font-display text-[14px] tracking-[-0.005em] text-[var(--color-text-head)]">Industries</span>
          </div>
          <p class="mt-3 font-display text-[24px] font-medium tracking-[-0.01em] text-[var(--color-text-head)]">Built for your sector.</p>
        </div>
        <a href="/industries/" class="group inline-flex items-center gap-2 rounded-[6px] bg-delft px-4 py-2 font-display text-[13px] font-medium text-white transition-colors hover:bg-scooter">
          View all
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {industryMenu.map((ind, i) => (
          <div class="group/ind flex h-full flex-col gap-2.5 rounded-[6px] border border-line bg-white p-5 transition-colors hover:border-[#12122D]">
            <div class="flex items-center justify-between gap-3">
              {/* Anchor text = industry name only. No stretched/whole-card link. */}
              <a href={ind.href} class="font-display text-[15px] font-medium leading-tight tracking-[-0.005em] text-[var(--color-text-head)] transition-colors hover:text-scooter group-hover/ind:text-scooter">{ind.name}</a>
              <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-body)]">{String(i + 1).padStart(2, '0')}</span>
            </div>
            <p class="line-clamp-2 font-display text-[12.5px] leading-[1.5] text-[var(--color-text-body)]">{ind.desc}</p>
            <span class="mt-auto inline-flex items-center gap-1.5 font-display text-[12px] font-medium text-[var(--color-text-head)] transition-colors group-hover/ind:text-scooter">
              Learn more
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover/ind:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
            </span>
          </div>
        ))}
        <a href="/industries/" class="group/ind flex items-center justify-center gap-2 rounded-[6px] bg-[#12122D] p-5 text-white transition-colors hover:bg-scooter">
          <span class="font-display text-[14px] font-medium">View all 11 industries</span>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true" class="transition-transform group-hover/ind:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </Container>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden max-h-[calc(100dvh-5rem)] overflow-y-auto border-t border-line bg-white lg:hidden">
    <Container width="wide" class="flex flex-col py-4">
      <details class="group border-b border-line">
        <summary class="flex cursor-pointer items-center justify-between py-3.5 font-display text-[15px] font-medium text-[var(--color-text-head)]">
          Services
          <span class="inline-flex size-6 items-center justify-center rounded-full border border-line">
            <svg class="transition-transform duration-200 group-open:rotate-180" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </span>
        </summary>
        <div class="pb-5">
          {serviceMenu.map((group) => (
            <div class="mt-5 first:mt-3">
              <a href={group.href} class="font-mono text-[11px] uppercase tracking-[0.14em] text-scooter transition-colors hover:text-[#12122D]">{group.label}</a>
              {/* All service links rendered directly — no collapse — so every
                  page is in the crawlable markup and visible without a click. */}
              <ul class="mt-3 space-y-2 border-l border-line pl-4">
                {group.items.map((it) => (
                  <li>
                    <a href={it.href} class="block font-display text-[14px] text-[var(--color-text-body)] transition-colors hover:text-scooter">{it.name}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
          <a href="/services/" class="mt-5 inline-flex items-center gap-2 font-display text-[13px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">
            View all services
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </details>
      <details class="group border-b border-line">
        <summary class="flex cursor-pointer items-center justify-between py-3.5 font-display text-[15px] font-medium text-[var(--color-text-head)]">
          Industries
          <span class="inline-flex size-6 items-center justify-center rounded-full border border-line">
            <svg class="transition-transform duration-200 group-open:rotate-180" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </span>
        </summary>
        <div class="grid grid-cols-1 gap-2 pb-5 sm:grid-cols-2">
          {industryMenu.map((ind) => (
            <a href={ind.href} class="font-display text-[14px] text-[var(--color-text-body)] py-1.5 transition-colors hover:text-scooter">{ind.name}</a>
          ))}
          <a href="/industries/" class="mt-3 inline-flex items-center gap-2 font-display text-[13px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter sm:col-span-2">
            View all 11 industries
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </details>
      <a href="/find-your-service/" class="border-b border-line py-3.5 font-display text-[15px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">Find your service quiz</a>
      <a href="/blog/" class="border-b border-line py-3.5 font-display text-[15px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">Insights</a>
      <a href="/about-us/" class="border-b border-line py-3.5 font-display text-[15px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">About Us</a>
      <a href="/tools/" class="border-b border-line py-3.5 font-display text-[15px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">Tools</a>
      <a href="/contact/" class="border-b border-line py-3.5 font-display text-[15px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">Contact</a>
      <a href={site.clientPortal} target="_blank" rel="noopener" class="flex items-center justify-between py-3.5 font-display text-[15px] font-medium text-[var(--color-text-head)] transition-colors hover:text-scooter">
        Client Portal
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" class="text-[var(--color-text-body)]"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
      </a>
      <Button href="/contact/" variant="primary" class="mt-4 w-full">Request a Consultation</Button>
    </Container>
  </div>
</header>

<style>
  /* Mega panel вЂ” animated visibility controlled by JS via [data-open] */
  .mega-panel { visibility: hidden; }
  .mega-panel[data-open="1"] {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  /* Spin chevron when its host is open */
  .mega-host[data-open="1"] .mega-chev { transform: rotate(180deg); }
  /* Bridge вЂ” invisible vertical strip above the panel that keeps hover alive */
  .mega-panel::before {
    content: "";
    position: absolute;
    inset: -16px 0 auto 0;
    height: 16px;
    pointer-events: auto;
  }
</style>

<script>
  // JS-driven mega menu with hover bridge + small close delay.
  // Open on hover/focus of trigger or panel. Close after 200 ms once cursor
  // leaves BOTH. Esc closes immediately.
  //
  // Re-binds on each Astro View-Transition swap so the menu keeps working
  // when navigating between pages.

  function bindMega() {
    const hosts = document.querySelectorAll<HTMLElement>('.mega-host');
    if (!hosts.length) return;
    const panels = new Map<string, HTMLElement>();
    document.querySelectorAll<HTMLElement>('[data-mega-panel]').forEach((p) => {
      panels.set(p.dataset.megaPanel!, p);
    });

    const closeTimers = new Map<string, number>();
    let activeKey: string | null = null;

    function clearCloseTimers() {
      closeTimers.forEach((timer) => clearTimeout(timer));
      closeTimers.clear();
    }

    function open(key: string) {
      activeKey = key;
      clearCloseTimers();
      panels.forEach((p, k) => { p.dataset.open = k === key ? '1' : '0'; });
      hosts.forEach((h) => {
        const isThis = h.dataset.mega === key;
        h.dataset.open = isThis ? '1' : '0';
        h.querySelector('[data-mega-trigger]')?.setAttribute('aria-expanded', String(isThis));
      });
    }

    function closeAll() {
      activeKey = null;
      clearCloseTimers();
      panels.forEach((p) => { p.dataset.open = '0'; });
      hosts.forEach((h) => {
        h.dataset.open = '0';
        h.querySelector('[data-mega-trigger]')?.setAttribute('aria-expanded', 'false');
      });
    }

    function scheduleClose(key: string) {
      clearTimeout(closeTimers.get(key));
      const t = window.setTimeout(() => {
        if (activeKey !== key) return;
        const host = document.querySelector(`.mega-host[data-mega="${key}"]`) as HTMLElement | null;
        const panel = panels.get(key);
        const stillHovered = host?.matches(':hover') || panel?.matches(':hover');
        if (!stillHovered) closeAll();
      }, 200);
      closeTimers.set(key, t);
    }

    function cancelClose(key: string) {
      clearTimeout(closeTimers.get(key));
    }

    hosts.forEach((host) => {
      const key = host.dataset.mega!;
      host.addEventListener('mouseenter', () => { cancelClose(key); open(key); });
      host.addEventListener('mouseleave', () => scheduleClose(key));
      host.addEventListener('focusin', () => { cancelClose(key); open(key); });
      host.addEventListener('focusout', (e) => {
        const next = e.relatedTarget as Node | null;
        const panel = panels.get(key);
        if (!host.contains(next) && !panel?.contains(next)) scheduleClose(key);
      });
    });

    panels.forEach((panel, key) => {
      panel.addEventListener('mouseenter', () => cancelClose(key));
      panel.addEventListener('mouseleave', () => scheduleClose(key));
      panel.addEventListener('focusin', () => cancelClose(key));
      panel.addEventListener('focusout', (e) => {
        const next = e.relatedTarget as Node | null;
        const host = document.querySelector(`.mega-host[data-mega="${key}"]`) as HTMLElement | null;
        if (!panel.contains(next) && !host?.contains(next)) scheduleClose(key);
      });
    });
  }

  bindMega();
  document.addEventListener('astro:after-swap', bindMega);

  // Escape closes any open mega вЂ” global, single binding
  if (!(window as any).__navEscBound) {
    (window as any).__navEscBound = true;
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      document.querySelectorAll<HTMLElement>('[data-mega-panel]').forEach((p) => { p.dataset.open = '0'; });
      document.querySelectorAll<HTMLElement>('.mega-host').forEach((h) => {
        h.dataset.open = '0';
        h.querySelector('[data-mega-trigger]')?.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // Mobile toggle вЂ” delegated so it survives swaps
  if (!(window as any).__navMobileBound) {
    (window as any).__navMobileBound = true;
    document.addEventListener('click', (e) => {
      const t = (e.target as HTMLElement | null)?.closest('#nav-toggle');
      if (!t) return;
      const menu = document.getElementById('mobile-menu');
      const open = menu?.classList.toggle('hidden') === false;
      t.setAttribute('aria-expanded', String(open));
    });
  }
</script>

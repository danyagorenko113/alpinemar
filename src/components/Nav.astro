---
import Container from './Container.astro';
import Logo from './Logo.astro';
import Button from './Button.astro';
import Icon from './Icon.astro';
import { serviceMenu, industryMenu } from '@/data/navigation';
import { site } from '@/data/site';

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
const onDark = path === '/';

const trigger = onDark
  ? 'inline-flex items-center font-body text-sm font-medium text-white/90 transition-colors hover:text-scooter cursor-pointer'
  : 'inline-flex items-center font-body text-sm font-medium text-navy-900 transition-colors hover:text-teal-700 cursor-pointer';
const chev = 'ml-1.5 inline-block transition-transform duration-200 mega-chev';

// Hot picks shown in the Services mega — most common entry points
const popularServices = [
  { name: 'Tax Planning', href: '/services/tax-planning-services/', tag: 'Tax' },
  { name: 'Fractional CFO', href: '/services/fractional-cfo-services/', tag: 'Advisory' },
  { name: 'Outsourced Accounting', href: '/services/outsourced-accounting-services/', tag: 'Accounting' },
];
---

<header
  class:list={[
    'sticky top-0 z-50 transition-colors',
    onDark
      ? 'border-b border-white/10 bg-[#0a0a1c]/55 backdrop-blur-md'
      : 'border-b border-line bg-paper/85 backdrop-blur-md',
  ]}
>
  <Container width="wide" class="flex h-20 items-center justify-between gap-6">
    <Logo variant={onDark ? 'light' : 'dark'} />

    <nav class="hidden items-center gap-8 lg:flex" aria-label="Primary">
      <!-- Services mega trigger -->
      <div class="mega-host static" data-mega="services">
        <button type="button" class={trigger} aria-haspopup="true" aria-expanded="false" data-mega-trigger>
          Services
          <svg class={chev} width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9" /></svg>
        </button>
      </div>

      <!-- Industries mega trigger -->
      <div class="mega-host static" data-mega="industries">
        <button type="button" class={trigger} aria-haspopup="true" aria-expanded="false" data-mega-trigger>
          Industries
          <svg class={chev} width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9" /></svg>
        </button>
      </div>

      <a href="/blog/" class:list={['font-body text-sm font-medium transition-colors', onDark ? 'text-white/90 hover:text-scooter' : (isActive('/blog/') ? 'text-teal-700' : 'text-navy-900 hover:text-teal-700')]}>Insights</a>
      <a href="/about-us/" class:list={['font-body text-sm font-medium transition-colors', onDark ? 'text-white/90 hover:text-scooter' : (isActive('/about-us/') ? 'text-teal-700' : 'text-navy-900 hover:text-teal-700')]}>About Us</a>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={site.clientPortal}
        target="_blank"
        rel="noopener"
        class:list={[
          'hidden items-center gap-1.5 rounded-full px-3.5 py-1.5 font-body text-xs transition-colors xl:inline-flex',
          onDark
            ? 'border border-white/20 text-white/85 hover:border-white/50 hover:text-white'
            : 'border border-line text-navy-700 hover:border-navy-900 hover:text-navy-900',
        ]}
      >
        Client Portal
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
      </a>
      {onDark ? (
        <a href="/contact/" class="hidden items-center gap-2 rounded-full bg-white px-5 py-2.5 font-body text-sm font-medium text-navy-900 transition-colors hover:bg-scooter hover:text-white sm:inline-flex">
          Get in touch
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
        </a>
      ) : (
        <Button href="/contact/" variant="primary" arrow class="hidden sm:inline-flex">Request Consultation</Button>
      )}
      <button type="button" id="nav-toggle" class:list={['inline-flex size-11 items-center justify-center lg:hidden', onDark ? 'border border-white/20 text-white' : 'border border-line text-navy-900']} aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
      </button>
    </div>
  </Container>

  <!-- ═══════════════ Services mega panel ═══════════════ -->
  <div id="mega-services" class="mega-panel pointer-events-none absolute left-0 right-0 top-full z-40 origin-top -translate-y-1 border-y border-line bg-paper opacity-0 transition-[opacity,transform] duration-200" data-mega-panel="services">
    <Container width="wide" class="py-10">
      <!-- Header strip -->
      <div class="mb-8 flex items-end justify-between gap-6 border-b border-line pb-4">
        <div>
          <p class="font-mono text-[0.7rem] uppercase tracking-[0.2em] text-teal-700">Services · 31 specialised offerings</p>
          <p class="mt-2 font-heading text-2xl tracking-[-0.01em] text-navy-900">What can we run for you?</p>
        </div>
        <div class="flex items-center gap-5 text-xs">
          <a href="/find-your-service/" class="inline-flex items-center gap-2 border border-line bg-paper px-4 py-2 font-mono uppercase tracking-[0.12em] text-navy-900 transition-colors hover:border-navy-900">
            <Icon name="sparkles" class="h-3.5 w-3.5 text-teal-700" /> Take the 4-question quiz
          </a>
          <a href="/services/" class="inline-flex items-center gap-2 font-mono uppercase tracking-[0.12em] text-teal-700 transition-colors hover:text-teal-600">View all <Icon name="arrow-right" class="h-3.5 w-3.5" /></a>
        </div>
      </div>

      <!-- 5 categories grid -->
      <div class="grid grid-cols-5 gap-x-6">
        {serviceMenu.map((group) => (
          <div class="flex flex-col">
            <a href="/services/" class="flex items-center gap-2.5">
              <span class="flex size-8 items-center justify-center rounded-full bg-teal-500 text-navy-950">
                <Icon name={group.icon} class="h-4 w-4" />
              </span>
              <span class="font-heading text-sm font-medium tracking-[-0.005em] text-navy-900">{group.label}</span>
            </a>
            <p class="mt-2.5 line-clamp-2 text-[0.72rem] leading-snug text-navy-500">{group.blurb}</p>
            <ul class="mt-4 space-y-2.5 border-t border-line pt-4">
              {group.items.slice(0, 7).map((it) => (
                <li>
                  <a href={it.href} class="group/link block">
                    <span class="block text-[0.82rem] leading-tight text-navy-900 transition-colors group-hover/link:text-teal-700">{it.name}</span>
                    {'desc' in it && (
                      <span class="mt-0.5 line-clamp-1 text-[0.68rem] leading-snug text-navy-400">{(it as any).desc}</span>
                    )}
                  </a>
                </li>
              ))}
              {group.items.length > 7 && (
                <li>
                  <a href="/services/" class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-teal-700">+ {group.items.length - 7} more →</a>
                </li>
              )}
            </ul>
          </div>
        ))}
      </div>

      <!-- Popular row + CTA -->
      <div class="mt-9 grid grid-cols-12 gap-6 border-t border-line pt-6">
        <div class="col-span-8">
          <p class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-navy-500">Most-requested</p>
          <ul class="mt-3 flex flex-wrap gap-1.5">
            {popularServices.map((p) => (
              <li>
                <a href={p.href} class="group/p inline-flex items-center gap-2 border border-line bg-paper px-3.5 py-1.5 text-[0.78rem] text-navy-900 transition-colors hover:border-navy-900 hover:bg-navy-50">
                  <span class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-teal-700">{p.tag}</span>
                  <span class="block h-3 w-px bg-line"></span>
                  {p.name}
                  <Icon name="arrow-right" class="h-3 w-3 text-navy-400 transition-transform group-hover/p:translate-x-0.5" />
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="col-span-4 flex items-center justify-end">
          <a href="/contact/" class="group inline-flex items-center gap-2.5 bg-teal-500 px-5 py-2.5 font-mono text-[0.7rem] font-medium uppercase tracking-[0.1em] text-navy-950 transition-all duration-200 hover:bg-teal-400">
            Request consultation <Icon name="arrow-right" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </Container>
  </div>

  <!-- ═══════════════ Industries mega panel ═══════════════ -->
  <div id="mega-industries" class="mega-panel pointer-events-none absolute left-0 right-0 top-full z-40 origin-top -translate-y-1 border-y border-line bg-paper opacity-0 transition-[opacity,transform] duration-200" data-mega-panel="industries">
    <Container width="wide" class="py-10">
      <div class="mb-8 flex items-end justify-between gap-6 border-b border-line pb-4">
        <div>
          <p class="font-mono text-[0.7rem] uppercase tracking-[0.2em] text-teal-700">Industries · 11 specialised verticals</p>
          <p class="mt-2 font-heading text-2xl tracking-[-0.01em] text-navy-900">Built for your sector.</p>
        </div>
        <a href="/industries/" class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.12em] text-teal-700 transition-colors hover:text-teal-600">View all <Icon name="arrow-right" class="h-3.5 w-3.5" /></a>
      </div>

      <div class="grid grid-cols-4 gap-px border-l border-t border-line bg-line">
        {industryMenu.map((ind, i) => (
          <a href={ind.href} class="group/ind flex items-start gap-4 border-b border-r border-line bg-paper p-4 transition-colors hover:bg-navy-50">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-teal-500 text-navy-950 transition-colors group-hover/ind:bg-teal-500 group-hover/ind:text-navy-950">
              <Icon name={ind.icon} class="h-4 w-4" />
            </span>
            <span class="flex-1">
              <span class="flex items-center justify-between gap-2">
                <span class="font-heading text-sm font-medium leading-tight text-navy-900 transition-colors group-hover/ind:text-teal-700">{ind.name}</span>
                <span class="font-mono text-[0.6rem] uppercase tracking-[0.14em] text-navy-300">{String(i + 1).padStart(2, '0')}</span>
              </span>
              <span class="mt-1 block text-[0.7rem] leading-snug text-navy-500">{ind.desc}</span>
            </span>
          </a>
        ))}
        <!-- "All industries" CTA tile fills the last cell -->
        <a href="/industries/" class="group/ind flex items-center justify-center gap-3 border-b border-r border-line bg-navy-900 p-4 text-paper transition-colors hover:bg-navy-800">
          <span class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-teal-300">View all 11 →</span>
        </a>
      </div>
    </Container>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden max-h-[calc(100dvh-5rem)] overflow-y-auto border-t border-line bg-paper lg:hidden">
    <Container width="wide" class="flex flex-col py-4">
      <details class="border-b border-line">
        <summary class="flex cursor-pointer items-center justify-between py-3.5 font-body text-sm font-medium text-navy-900">Services <span class="font-mono text-xs text-navy-400">+</span></summary>
        <div class="pb-4">
          {serviceMenu.map((group) => (
            <div class="mt-4 first:mt-2">
              <div class="flex items-center gap-2">
                <span class="flex size-6 items-center justify-center rounded-full bg-teal-500 text-navy-950"><Icon name={group.icon} class="h-3 w-3" /></span>
                <span class="font-mono text-[0.66rem] uppercase tracking-[0.14em] text-teal-700">{group.label}</span>
              </div>
              <ul class="mt-2.5 space-y-2 border-l border-line pl-3.5">
                {group.items.map((it) => <li><a href={it.href} class="block text-sm text-navy-700">{it.name}</a></li>)}
              </ul>
            </div>
          ))}
          <a href="/services/" class="mt-4 inline-block font-mono text-xs uppercase tracking-[0.12em] text-teal-700">View all services →</a>
        </div>
      </details>
      <details class="border-b border-line">
        <summary class="flex cursor-pointer items-center justify-between py-3.5 font-body text-sm font-medium text-navy-900">Industries <span class="font-mono text-xs text-navy-400">+</span></summary>
        <div class="grid grid-cols-2 gap-2 pb-4">
          {industryMenu.map((ind) => (
            <a href={ind.href} class="flex items-center gap-2 py-1.5 text-sm text-navy-700">
              <span class="flex size-5 items-center justify-center text-teal-700"><Icon name={ind.icon} class="h-3 w-3" /></span>
              {ind.name}
            </a>
          ))}
        </div>
      </details>
      <a href="/blog/" class="border-b border-line py-3.5 font-body text-sm font-medium text-navy-900">Insights</a>
      <a href="/about-us/" class="border-b border-line py-3.5 font-body text-sm font-medium text-navy-900">About Us</a>
      <a href="/contact/" class="border-b border-line py-3.5 font-body text-sm font-medium text-navy-900">Contact</a>
      <a href={site.clientPortal} target="_blank" rel="noopener" class="flex items-center justify-between py-3.5 font-body text-sm font-medium text-navy-900">
        Client Portal
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" class="text-navy-400"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
      </a>
      <Button href="/contact/" variant="primary" class="mt-3 w-full">Request Consultation</Button>
    </Container>
  </div>
</header>

<style>
  /* Mega panel — animated visibility controlled by JS via [data-open] */
  .mega-panel { visibility: hidden; }
  .mega-panel[data-open="1"] {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  /* Spin chevron when its host is open */
  .mega-host[data-open="1"] .mega-chev { transform: rotate(180deg); }
  /* Bridge — invisible vertical strip above the panel that keeps hover alive */
  .mega-panel::before {
    content: "";
    position: absolute;
    inset: -16px 0 auto 0;
    height: 16px;
    pointer-events: auto;
  }
</style>

<script>
  // JS-driven mega menu with hover bridge + small close delay.
  // Open on hover/focus of trigger or panel. Close after 200 ms once cursor
  // leaves BOTH. Esc closes immediately.
  //
  // Re-binds on each Astro View-Transition swap so the menu keeps working
  // when navigating between pages.

  function bindMega() {
    const hosts = document.querySelectorAll<HTMLElement>('.mega-host');
    if (!hosts.length) return;
    const panels = new Map<string, HTMLElement>();
    document.querySelectorAll<HTMLElement>('[data-mega-panel]').forEach((p) => {
      panels.set(p.dataset.megaPanel!, p);
    });

    const closeTimers = new Map<string, number>();

    function open(key: string) {
      panels.forEach((p, k) => { p.dataset.open = k === key ? '1' : '0'; });
      hosts.forEach((h) => {
        const isThis = h.dataset.mega === key;
        h.dataset.open = isThis ? '1' : '0';
        h.querySelector('[data-mega-trigger]')?.setAttribute('aria-expanded', String(isThis));
      });
    }

    function closeAll() {
      panels.forEach((p) => { p.dataset.open = '0'; });
      hosts.forEach((h) => {
        h.dataset.open = '0';
        h.querySelector('[data-mega-trigger]')?.setAttribute('aria-expanded', 'false');
      });
    }

    function scheduleClose(key: string) {
      clearTimeout(closeTimers.get(key));
      const t = window.setTimeout(() => {
        const host = document.querySelector(`.mega-host[data-mega="${key}"]`) as HTMLElement | null;
        const panel = panels.get(key);
        const stillHovered = host?.matches(':hover') || panel?.matches(':hover');
        if (!stillHovered) closeAll();
      }, 200);
      closeTimers.set(key, t);
    }

    function cancelClose(key: string) {
      clearTimeout(closeTimers.get(key));
    }

    hosts.forEach((host) => {
      const key = host.dataset.mega!;
      host.addEventListener('mouseenter', () => { cancelClose(key); open(key); });
      host.addEventListener('mouseleave', () => scheduleClose(key));
      host.addEventListener('focusin', () => { cancelClose(key); open(key); });
      host.addEventListener('focusout', (e) => {
        const next = e.relatedTarget as Node | null;
        const panel = panels.get(key);
        if (!host.contains(next) && !panel?.contains(next)) scheduleClose(key);
      });
    });

    panels.forEach((panel, key) => {
      panel.addEventListener('mouseenter', () => cancelClose(key));
      panel.addEventListener('mouseleave', () => scheduleClose(key));
      panel.addEventListener('focusin', () => cancelClose(key));
      panel.addEventListener('focusout', (e) => {
        const next = e.relatedTarget as Node | null;
        const host = document.querySelector(`.mega-host[data-mega="${key}"]`) as HTMLElement | null;
        if (!panel.contains(next) && !host?.contains(next)) scheduleClose(key);
      });
    });
  }

  bindMega();
  document.addEventListener('astro:after-swap', bindMega);

  // Escape closes any open mega — global, single binding
  if (!(window as any).__navEscBound) {
    (window as any).__navEscBound = true;
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      document.querySelectorAll<HTMLElement>('[data-mega-panel]').forEach((p) => { p.dataset.open = '0'; });
      document.querySelectorAll<HTMLElement>('.mega-host').forEach((h) => {
        h.dataset.open = '0';
        h.querySelector('[data-mega-trigger]')?.setAttribute('aria-expanded', 'false');
      });
    });
  }

  // Mobile toggle — delegated so it survives swaps
  if (!(window as any).__navMobileBound) {
    (window as any).__navMobileBound = true;
    document.addEventListener('click', (e) => {
      const t = (e.target as HTMLElement | null)?.closest('#nav-toggle');
      if (!t) return;
      const menu = document.getElementById('mobile-menu');
      const open = menu?.classList.toggle('hidden') === false;
      t.setAttribute('aria-expanded', String(open));
    });
  }
</script>

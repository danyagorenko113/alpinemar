---
// Animated mountain/ocean scene — replaces the static photo on the home hero.
// Pure SVG + CSS keyframes; no third-party video. Layered alpine ridges drift
// at different speeds, an ocean wave breathes underneath, and a sky gradient
// gently shifts hue. Respects prefers-reduced-motion.
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={['animated-hero relative overflow-hidden aspect-[4/3] w-full', className]} aria-hidden="true">
  <!-- Sky gradient with slow hue shift -->
  <div class="absolute inset-0 anim-sky"></div>

  <!-- Sun / accent disc -->
  <div class="absolute right-[15%] top-[18%] size-20 rounded-full bg-teal-400/40 blur-md anim-sun"></div>

  <!-- Mountain layers -->
  <svg class="absolute inset-x-0 bottom-[26%] h-[60%] w-full" viewBox="0 0 800 400" preserveAspectRatio="none">
    <!-- furthest ridge — pale -->
    <g class="anim-ridge-far">
      <path d="M0 400 V230 L100 170 L210 215 L320 145 L430 200 L560 130 L690 195 L800 160 V400 Z" fill="#c2c2d2"/>
    </g>
    <!-- middle ridge — mountain blue -->
    <g class="anim-ridge-mid">
      <path d="M0 400 V270 L120 200 L240 250 L360 170 L500 230 L640 165 L800 220 V400 Z" fill="#5e5e7d"/>
    </g>
    <!-- nearest ridge — alpine navy -->
    <g class="anim-ridge-near">
      <path d="M0 400 V320 L140 240 L280 290 L420 220 L560 280 L700 245 L800 270 V400 Z" fill="#1b1b3d"/>
    </g>
    <!-- ridge highlight stroke -->
    <path d="M0 230 L100 170 L210 215 L320 145 L430 200 L560 130 L690 195 L800 160" stroke="#33bbdc" stroke-width="1.2" stroke-opacity="0.45" fill="none"/>
  </svg>

  <!-- Ocean / wave area -->
  <svg class="absolute inset-x-0 bottom-0 h-[28%] w-full" viewBox="0 0 800 180" preserveAspectRatio="none">
    <!-- Reflection band — gradient -->
    <defs>
      <linearGradient id="sea-grad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%"   stop-color="#33bbdc" stop-opacity="0.55"/>
        <stop offset="100%" stop-color="#12122d" stop-opacity="0.95"/>
      </linearGradient>
    </defs>
    <rect x="0" y="0" width="800" height="180" fill="url(#sea-grad)"/>
    <!-- Wave 1 -->
    <path class="anim-wave-a" d="M0 60 C 120 80 200 30 340 50 S 600 80 800 50 L 800 180 L 0 180 Z" fill="#33bbdc" fill-opacity="0.35"/>
    <!-- Wave 2 -->
    <path class="anim-wave-b" d="M0 90 C 140 110 260 70 400 88 S 660 108 800 88 L 800 180 L 0 180 Z" fill="#12122d" fill-opacity="0.55"/>
    <!-- Wave foam highlights -->
    <path class="anim-wave-c" d="M0 64 C 140 84 240 36 380 56 S 620 84 800 56" stroke="#ffffff" stroke-width="0.6" stroke-opacity="0.4" fill="none"/>
  </svg>

  <!-- Subtle grain -->
  <div class="grain absolute inset-0 opacity-[0.04]"></div>

  <!-- Corner tick — preserves Alpine Mar editorial language -->
  <div class="absolute -left-3 -top-3 hidden size-16 border-l border-t border-teal-500 lg:block"></div>
</div>

<style>
  .animated-hero { background: #fbfbfa; }
  .anim-sky {
    background:
      radial-gradient(ellipse at 70% 0%, rgba(51, 187, 220, 0.25), transparent 60%),
      linear-gradient(180deg, #e6e6ec 0%, #f4f4f7 55%, #fbfbfa 100%);
    animation: am-sky 24s ease-in-out infinite alternate;
  }
  @keyframes am-sky {
    0%   { filter: hue-rotate(0deg)   saturate(1); }
    100% { filter: hue-rotate(-8deg)  saturate(1.08); }
  }

  .anim-sun { animation: am-sun-drift 28s ease-in-out infinite alternate; }
  @keyframes am-sun-drift {
    0%   { transform: translate(0, 0)         scale(1); opacity: 0.55; }
    100% { transform: translate(-30px, 14px)  scale(1.06); opacity: 0.72; }
  }

  .anim-ridge-far  { transform-box: fill-box; animation: am-ridge-far  60s ease-in-out infinite alternate; }
  .anim-ridge-mid  { transform-box: fill-box; animation: am-ridge-mid  44s ease-in-out infinite alternate; }
  .anim-ridge-near { transform-box: fill-box; animation: am-ridge-near 32s ease-in-out infinite alternate; }

  @keyframes am-ridge-far  { from { transform: translateX(0); }    to { transform: translateX(-12px); } }
  @keyframes am-ridge-mid  { from { transform: translateX(0); }    to { transform: translateX(18px); } }
  @keyframes am-ridge-near { from { transform: translateX(0); }    to { transform: translateX(-10px); } }

  /* Wave morphing — translate + tiny scaleY for breathing motion */
  .anim-wave-a { animation: am-wave-a 10s ease-in-out infinite alternate; transform-origin: 50% 100%; }
  .anim-wave-b { animation: am-wave-b 13s ease-in-out infinite alternate; transform-origin: 50% 100%; }
  .anim-wave-c { animation: am-wave-c 10s ease-in-out infinite alternate; transform-origin: 50% 100%; }
  @keyframes am-wave-a { from { transform: translate(0, 0)    scaleY(1); } to { transform: translate(-18px, 4px)  scaleY(1.04); } }
  @keyframes am-wave-b { from { transform: translate(0, 0)    scaleY(1); } to { transform: translate(22px, -2px) scaleY(0.97); } }
  @keyframes am-wave-c { from { transform: translate(0, 0); }              to { transform: translate(-22px, 3px); } }

  /* Reduced motion — freeze all animations */
  @media (prefers-reduced-motion: reduce) {
    .anim-sky, .anim-sun, .anim-ridge-far, .anim-ridge-mid, .anim-ridge-near,
    .anim-wave-a, .anim-wave-b, .anim-wave-c {
      animation: none !important;
    }
  }
</style>

---
// Explanatory / SEO copy block for the calculator pages: a short intro, an
// optional "how to use it" list, and an FAQ. Keeps body copy consistent across
// every tool page.
import Container from '@/components/Container.astro';

interface Step {
  title: string;
  body: string;
}
interface FAQ {
  q: string;
  a: string;
}
interface Props {
  heading?: string;
  intro: string[];
  steps?: Step[];
  faqs?: FAQ[];
}

const { heading = 'About this calculator', intro, steps = [], faqs = [] } = Astro.props;
---

<section class="relative border-t border-line bg-paper py-16 md:py-20">
  <Container width="reading">
    <h2 class="font-display text-[24px] font-medium leading-[1.2] tracking-[-0.01em] text-[var(--color-text-head)] md:text-[28px]">
      {heading}
    </h2>
    <div class="mt-6 space-y-4">
      {intro.map((p) => (
        <p class="font-display text-[15px] leading-[1.7] text-[var(--color-text-body)]">{p}</p>
      ))}
    </div>

    {steps.length > 0 && (
      <ol class="mt-10 space-y-5 border-t border-line pt-8">
        {steps.map((s, i) => (
          <li class="flex gap-4">
            <span class="mt-0.5 flex size-7 shrink-0 items-center justify-center rounded-full bg-delft font-mono text-[12px] font-medium text-white">
              {String(i + 1)}
            </span>
            <div>
              <p class="font-display text-[15px] font-medium text-[var(--color-text-head)]">{s.title}</p>
              <p class="mt-1 font-display text-[14px] leading-[1.6] text-[var(--color-text-body)]">{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
    )}

    {faqs.length > 0 && (
      <div class="mt-10 border-t border-line pt-8">
        <h3 class="font-mono text-[12px] uppercase tracking-[0.14em] text-scooter">Frequently asked</h3>
        <dl class="mt-6 space-y-6">
          {faqs.map((f) => (
            <div>
              <dt class="font-display text-[16px] font-medium text-[var(--color-text-head)]">{f.q}</dt>
              <dd class="mt-2 font-display text-[14px] leading-[1.7] text-[var(--color-text-body)]">{f.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    )}
  </Container>
</section>

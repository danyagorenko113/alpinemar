---
interface Props {
  as?: keyof HTMLElementTagNameMap;
  class?: string;
  width?: 'default' | 'narrow' | 'wide' | 'xl';
}
const { as = 'div', class: className = '', width = 'default' } = Astro.props;
const Tag = as as any;
const widths = {
  narrow: 'max-w-3xl',
  default: 'max-w-6xl',
  wide: 'max-w-7xl',
  xl: 'max-w-[88rem]',
};
---

<Tag class:list={['mx-auto w-full px-6 md:px-8', widths[width], className]}>
  <slot />
</Tag>

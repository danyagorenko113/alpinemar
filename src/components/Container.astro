---
interface Props {
  as?: keyof HTMLElementTagNameMap;
  class?: string;
  width?: 'reading' | 'narrow' | 'default' | 'wide' | 'xl';
}
const { as = 'div', class: className = '', width = 'default' } = Astro.props;
const Tag = as as any;
const widths = {
  reading: 'max-w-[720px]', // blog body, long-form prose
  narrow:  'max-w-3xl',     // focused sales pages
  default: 'max-w-6xl',
  wide:    'max-w-7xl',     // every redesign section uses this
  xl:      'max-w-[88rem]',
};
---

<Tag class:list={['mx-auto w-full px-6 md:px-8', widths[width], className]}>
  <slot />
</Tag>

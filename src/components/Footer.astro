---
import Container from './Container.astro';
import { site } from '@/data/site';

const year = 2026;

const quicklinks = [
  { name: 'Insights',     href: '/blog/' },
  { name: 'About Us',     href: '/about-us/' },
  { name: 'In The Media', href: '/in-the-media/' },
  { name: 'HTML Sitemap', href: '/sitemap/' },
];

const footerServices = [
  { name: 'Tax Planning',                                  href: '/services/tax-planning-services/' },
  { name: 'Outsourced Accounting',                         href: '/services/outsourced-accounting-services/' },
  { name: 'Entity Structuring',                            href: '/services/business-structure-consulting/' },
  { name: 'Fractional CFO',                                href: '/services/fractional-cfo-services/' },
  { name: 'SMB Tax Services',                              href: '/services/small-business-tax-services/' },
  { name: 'S Corp CPA Services',                           href: '/services/s-corp-cpa-services/' },
  { name: 'Financial Statement Preparation',               href: '/services/financial-statement-preparation-services/' },
  { name: 'Outsourced Bookkeeping',                        href: '/services/outsourced-bookkeeping-services/' },
  { name: 'Accounting Software Implementation',            href: '/services/accounting-software-implementation/' },
  { name: 'Transaction Advisory Services',                 href: '/services/transaction-advisory-services/' },
  { name: 'Payroll Compliance Services',                   href: '/services/payroll-compliance-services/' },
  { name: 'Financial Modeling Services',                   href: '/services/financial-modeling-services/' },
  { name: 'Multistate Tax Services',                       href: '/services/multistate-tax-services/' },
  { name: 'Creación de Empresas',                          href: '/services/creacion-de-empresas/' },
  { name: 'Servicios Tributarios en Florida',              href: '/services/servicios-tributarios-en-florida/' },
  { name: 'Servicios Contables y Tenedoria de Libros',     href: '/services/servicios-contables/' },
];

const footerIndustries = [
  { name: 'Construction',              href: '/industries/construction-cpa-services/' },
  { name: 'Family Office',             href: '/industries/family-office-accounting-services/' },
  { name: 'Healthcare',                href: '/industries/healthcare-accounting-services/' },
  { name: 'High Net Worth Individuals', href: '/industries/high-net-worth-accounting-cpa/' },
  { name: 'Law Firms',                 href: '/industries/law-firm-accounting-services/' },
  { name: 'Marketing Agencies',        href: '/industries/marketing-agency-accounting-services/' },
  { name: 'Real Estate',               href: '/industries/real-estate-cpa-services/' },
  { name: 'Sports Athletes',           href: '/industries/sports-accounting-services/' },
  { name: 'Startups',                  href: '/industries/startup-cpa-services/' },
  { name: 'SaaS Companies',            href: '/industries/saas-accounting-services/' },
  { name: 'Crypto',                    href: '/industries/crypto-cpa-services/' },
];
---

<footer class="relative overflow-hidden bg-white text-[var(--color-text-head)]">
  <!-- Grid pattern background -->
  <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(18,18,45,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(18,18,45,0.04) 1px, transparent 1px); background-size: 72px 72px;"></div>

  <Container width="wide" class="relative z-10 pt-20 pb-10">
    <!-- 4-col content -->
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4 lg:gap-10">
      <!-- Quicklinks -->
      <nav aria-label="Quicklinks">
        <h2 class="font-display text-[15px] font-medium tracking-[-0.01em] text-[var(--color-text-head)]">Quicklinks</h2>
        <ul class="mt-7 space-y-3.5 text-[14px]">
          {quicklinks.map((i) => (
            <li><a href={i.href} class="font-display text-[var(--color-text-body)] transition-colors hover:text-scooter">{i.name}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Services -->
      <nav aria-label="Services">
        <h2 class="font-display text-[15px] font-medium tracking-[-0.01em] text-[var(--color-text-head)]">Services</h2>
        <ul class="mt-7 space-y-3.5 text-[14px]">
          {footerServices.map((i) => (
            <li><a href={i.href} class="font-display text-[var(--color-text-body)] transition-colors hover:text-scooter">{i.name}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Industries -->
      <nav aria-label="Industries">
        <h2 class="font-display text-[15px] font-medium tracking-[-0.01em] text-[var(--color-text-head)]">Industries</h2>
        <ul class="mt-7 space-y-3.5 text-[14px]">
          {footerIndustries.map((i) => (
            <li><a href={i.href} class="font-display text-[var(--color-text-body)] transition-colors hover:text-scooter">{i.name}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Contact Details -->
      <div>
        <h2 class="font-display text-[15px] font-medium tracking-[-0.01em] text-[var(--color-text-head)]">Contact Details</h2>
        <ul class="mt-7 space-y-5 text-[14px]">
          <li>
            <p class="font-display text-[var(--color-text-body)]">Phone: <a href={`tel:${site.phoneHref}`} class="transition-colors hover:text-scooter">{site.phone}</a></p>
          </li>
          <li>
            <p class="font-display text-[var(--color-text-body)]">Email: <a href={`mailto:${site.email}`} class="transition-colors hover:text-scooter">{site.email}</a></p>
          </li>
          <li>
            <p class="font-display text-[var(--color-text-body)]">Address: {site.address.street}<br />{site.address.city}, {site.address.state} {site.address.zip}</p>
          </li>
        </ul>
      </div>
    </div>

    <!-- AICPA / FICPA membership strip -->
    <div class="mt-14 flex flex-col gap-6 border-t border-line pt-8 md:flex-row md:items-center md:justify-between">
      <p class="max-w-xl font-display text-[13px] leading-relaxed text-[var(--color-text-body)]">
        Members of the American Institute of Certified Public Accountants<br class="hidden md:inline" /> and the Florida Institute of Certified Public Accountants.
      </p>
      <div class="flex items-center gap-8">
        <img src="/images/brand/ficpa-logo.png" alt="FICPA" width="80" height="80" class="h-12 w-auto opacity-60 grayscale" loading="lazy" />
        <img src="/images/brand/aicpa-logo.png" alt="AICPA" width="160" height="80" class="h-12 w-auto opacity-60 grayscale" loading="lazy" />
      </div>
    </div>

    <!-- Copyright + socials -->
    <div class="mt-8 flex flex-col gap-4 text-[13px] sm:flex-row sm:items-center sm:justify-between">
      <p class="font-display text-[var(--color-text-body)]">© {year} {site.name}. All rights reserved.</p>
      <div class="flex items-center gap-5">
        <a href="https://x.com/" target="_blank" rel="noopener" aria-label="X" class="text-[var(--color-text-body)] transition-colors hover:text-scooter">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://instagram.com/" target="_blank" rel="noopener" aria-label="Instagram" class="text-[var(--color-text-body)] transition-colors hover:text-scooter">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
        <a href="https://linkedin.com/" target="_blank" rel="noopener" aria-label="LinkedIn" class="text-[var(--color-text-body)] transition-colors hover:text-scooter">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 1 1 8.3 6.5a1.78 1.78 0 0 1-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0 0 13 14.19a.66.66 0 0 0 0 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 0 1 2.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
        </a>
      </div>
    </div>
  </Container>

  <!-- Big "Alpine Mar" wordmark banner -->
  <div class="relative overflow-hidden">
    <img src="/images/brand/alpine-mar-wordmark.svg" alt="Alpine Mar" class="block w-full" />
  </div>
</footer>

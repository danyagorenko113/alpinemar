---
// "Summarize this for me" button on blog posts.
// UI-only stub — clicking generates 3 bullets + 1 actionable from the article
// excerpt + first headings (mocked, deterministic). Production should POST to
// /api/summarize and stream from Claude.
interface Props {
  excerpt: string;
  title: string;
}
const { excerpt, title } = Astro.props;
---

<div class="mt-10 border-t border-line pt-6" data-reveal>
  <div class="flex items-start justify-between gap-4">
    <div class="flex items-center gap-3">
      <span class="block h-px w-8 bg-teal-500"></span>
      <p class="font-mono text-[0.7rem] uppercase tracking-[0.2em] text-teal-700">In a hurry?</p>
    </div>
    <span class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-navy-400">↳ Automated summary · verify with a CPA</span>
  </div>

  <div class="mt-5 border border-line bg-navy-50/40 p-6">
    <div id="summary-cta" class="flex flex-wrap items-center justify-between gap-4">
      <div>
        <p class="font-heading text-xl tracking-[-0.01em] text-navy-900">Summarize this for me.</p>
        <p class="mt-2 text-sm text-navy-600">3 bullets, 1 action — about 8 seconds.</p>
      </div>
      <button
        id="summary-trigger"
        type="button"
        data-magnetic
        class="group inline-flex items-center gap-2.5 bg-navy-900 px-6 py-3 font-mono text-[0.78rem] font-medium uppercase tracking-[0.08em] text-paper transition-all duration-200 hover:bg-navy-800"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9.94 14.34 12 21l2.06-6.66L21 12l-6.94-2.34L12 3l-2.06 6.66L3 12z"/>
        </svg>
        Summarize
      </button>
    </div>

    <div id="summary-loading" class="hidden mt-4 flex items-center gap-3 text-sm text-navy-600">
      <span class="size-2 animate-pulse bg-teal-500"></span>
      <span>Reading the article…</span>
    </div>

    <div id="summary-output" class="hidden mt-6 space-y-5">
      <div>
        <p class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-teal-700">Key points</p>
        <ul id="summary-bullets" class="mt-3 space-y-2 text-[0.95rem] leading-relaxed text-navy-800"></ul>
      </div>
      <div class="border-t border-line pt-5">
        <p class="font-mono text-[0.66rem] uppercase tracking-[0.18em] text-teal-700">Your next move</p>
        <p id="summary-action" class="mt-3 font-heading text-lg italic tracking-[-0.01em] text-navy-900">—</p>
      </div>
      <p class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-navy-400">↳ Automated summary · not tax advice · verify with a CPA before acting</p>
    </div>
  </div>
</div>

<script define:vars={{ EXCERPT: excerpt, TITLE: title }}>
  const trigger = document.getElementById('summary-trigger');
  const cta = document.getElementById('summary-cta');
  const loading = document.getElementById('summary-loading');
  const output = document.getElementById('summary-output');
  const bullets = document.getElementById('summary-bullets');
  const action = document.getElementById('summary-action');

  // Local fallback summary — generated from article structure (h2s + excerpt).
  // Real production: POST to /api/summarize with article body, stream Claude.
  function buildFallback() {
    const h2s = Array.from(document.querySelectorAll('article h2'))
      .map((h) => (h.textContent || '').trim())
      .filter((t) => t && t.length < 90)
      .slice(0, 3);

    const fallbackBullets = h2s.length >= 3 ? h2s : [
      EXCERPT.split('. ')[0] + '.',
      h2s[0] || 'Read the full article for the framework.',
      h2s[1] || 'Examples and edge cases follow in-line.',
    ];

    const titleLower = TITLE.toLowerCase();
    let act = 'Schedule an intro call with an Alpine Mar CPA to apply this to your situation.';
    if (titleLower.includes('tax')) act = 'Run our Tax Savings Estimator with your numbers, then book an intro call.';
    else if (titleLower.includes('burn') || titleLower.includes('runway')) act = 'Use our Burn Rate Calculator with your real cash + burn to see your zone.';
    else if (titleLower.includes('s-corp') || titleLower.includes('llc') || titleLower.includes('structure')) act = 'Try the S-Corp vs LLC calculator to see whether election pays for you.';
    else if (titleLower.includes('1031') || titleLower.includes('real estate')) act = 'Run the 1031 Exchange calculator before you sign that PSA.';
    else if (titleLower.includes('r&d') || titleLower.includes('r and d')) act = 'Estimate your federal R&D credit with the calculator, then file before deadline.';

    return { bullets: fallbackBullets, action: act };
  }

  trigger?.addEventListener('click', async () => {
    cta?.classList.add('hidden');
    loading?.classList.remove('hidden');

    // Simulate latency for credibility
    await new Promise((r) => setTimeout(r, 1100));

    const { bullets: list, action: act } = buildFallback();
    if (bullets) {
      bullets.innerHTML = list.map((b, i) => `
        <li class="flex items-start gap-3">
          <span class="mt-1.5 size-1.5 shrink-0 bg-teal-500"></span>
          <span><span class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-teal-700 mr-2">${String(i + 1).padStart(2, '0')}</span>${b}</span>
        </li>
      `).join('');
    }
    if (action) action.textContent = act;
    loading?.classList.add('hidden');
    output?.classList.remove('hidden');
  });
</script>

---
import Icon from './Icon.astro';

interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'white' | 'ghost' | 'link';
  type?: 'button' | 'submit';
  arrow?: boolean;
  class?: string;
}
const {
  href,
  variant = 'primary',
  type = 'button',
  arrow = false,
  class: className = '',
} = Astro.props;

const base =
  'group inline-flex items-center justify-center gap-2.5 font-mono font-medium uppercase tracking-[0.08em] transition-[color,background-color,border-color,box-shadow,transform] duration-200 active:scale-[0.98] disabled:opacity-50 disabled:pointer-events-none';

const variants = {
  primary: 'bg-teal-500 px-7 py-4 text-[0.8rem] text-navy-950 hover:bg-teal-400',
  secondary: 'border border-line px-7 py-4 text-[0.8rem] text-navy-700 hover:border-navy-900 hover:text-navy-900',
  white: 'bg-white px-7 py-4 text-[0.8rem] text-navy-900 hover:bg-teal-500 hover:text-navy-950',
  ghost: 'border border-white/25 px-7 py-4 text-[0.8rem] text-white hover:border-teal-400 hover:text-teal-400',
  link: 'text-[0.8rem] uppercase tracking-[0.06em] text-teal-700 hover:text-teal-600',
};

const classes = [base, variants[variant], className];
const Tag = href ? 'a' : 'button';
---

<Tag class:list={classes} {...href ? { href } : { type }}>
  <slot />
  {arrow && <Icon name="arrow-right" class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" />}
</Tag>

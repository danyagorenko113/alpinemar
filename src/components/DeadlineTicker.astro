---
// Sticky compact bar above nav — counts days until next IRS deadline.
// Hardcoded calendar (extended through 2027 for safety) is computed in
// the browser to pick the next deadline relative to "today".
// Dismissable via localStorage; re-appears after 7 days.
---

<div
  id="deadline-ticker"
  class="relative z-[60] hidden border-b border-white/10 bg-navy-950 text-paper"
  role="status"
>
  <div class="mx-auto flex max-w-[88rem] items-center gap-3 px-6 py-2 md:px-8">
    <span class="flex size-1.5 shrink-0 animate-pulse rounded-full bg-teal-400" aria-hidden="true"></span>
    <p class="flex flex-1 flex-wrap items-baseline gap-x-3 gap-y-1 font-mono text-[0.66rem] uppercase tracking-[0.14em] text-navy-300">
      <span class="text-teal-400">Next IRS deadline</span>
      <span id="dl-label" class="text-white">—</span>
      <span class="hidden sm:inline text-navy-400">·</span>
      <span id="dl-date" class="hidden sm:inline text-white">—</span>
      <span class="text-navy-400">·</span>
      <span id="dl-countdown" class="font-medium text-teal-300">—</span>
    </p>
    <a href="/tools/quarterly-tax-estimator/" class="hidden border-l border-white/10 pl-3 font-mono text-[0.66rem] uppercase tracking-[0.14em] text-teal-300 transition-colors hover:text-teal-200 sm:inline-block">
      Estimate yours →
    </a>
    <button
      type="button"
      id="dl-dismiss"
      class="ml-2 inline-flex size-6 shrink-0 items-center justify-center text-navy-400 transition-colors hover:text-white"
      aria-label="Dismiss notification"
    >
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
    </button>
  </div>
</div>

<script is:inline>
  function initDeadlineTicker() {
    // IRS deadlines through 2027 — most-relevant ones for owner-operators.
    // Format: [Mon-DD-YYYY, label]
    const cal = [
      ['01-15', 'Q4 estimated tax due'],
      ['01-31', '1099-NEC & W-2 filing'],
      ['03-15', 'S-Corp & partnership returns'],
      ['04-15', 'Individual + C-Corp returns · Q1 estimates'],
      ['06-16', 'Q2 estimated tax'],
      ['09-15', 'Q3 estimates · extended pass-throughs'],
      ['10-15', 'Extended individual + C-Corp'],
    ];
    const today = new Date();
    today.setHours(0,0,0,0);
    const year = today.getFullYear();

    // Build full list across this year + next
    const all = [];
    for (const yr of [year, year + 1, year + 2]) {
      for (const [md, label] of cal) {
        const [m, d] = md.split('-').map(Number);
        all.push({ d: new Date(yr, m - 1, d), label });
      }
    }
    const next = all.find((x) => x.d >= today);
    if (!next) return;

    const days = Math.ceil((next.d - today) / 86400000);
    const label = document.getElementById('dl-label');
    const date = document.getElementById('dl-date');
    const countdown = document.getElementById('dl-countdown');
    const bar = document.getElementById('deadline-ticker');
    if (!label || !date || !countdown || !bar) return;

    label.textContent = next.label;
    date.textContent = next.d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    countdown.textContent = days === 0 ? 'TODAY' : days === 1 ? '1 day' : `${days} days`;

    // Dismissal
    const dismissedAt = +localStorage.getItem('dl_dismissed_at') || 0;
    const SEVEN_DAYS = 7 * 86400000;
    if (Date.now() - dismissedAt < SEVEN_DAYS) return; // stay hidden
    bar.classList.remove('hidden');
    document.getElementById('dl-dismiss')?.addEventListener('click', () => {
      bar.classList.add('hidden');
      localStorage.setItem('dl_dismissed_at', String(Date.now()));
    });
  }
  initDeadlineTicker();
  document.addEventListener('astro:after-swap', initDeadlineTicker);
</script>

---
import Container from './Container.astro';
import { site } from '@/data/site';

const path = Astro.url.pathname;
const onDark = path === '/';
---

<div
  class:list={[
    'relative z-50 hidden border-b py-2.5 text-[12.5px] tracking-[-0.005em] md:block',
    onDark ? 'border-white/10 bg-[#0a0a1c]/85 text-white/85 backdrop-blur-md' : 'border-line bg-white text-navy-700',
  ]}
>
  <Container width="wide" class="flex items-center justify-between gap-6">
    <div class="flex items-center gap-6">
      <a href={`tel:${site.phone.replace(/[^\d+]/g, '')}`} class="inline-flex items-center gap-2 transition-colors hover:text-scooter">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/>
        </svg>
        <span class="font-medium">{site.phone}</span>
      </a>
      <span class="hidden items-center gap-2 lg:inline-flex">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        Miami, Fort Lauderdale, New York City
      </span>
    </div>

    <div class="flex items-center gap-5">
      <a href={site.itPortal} target="_blank" rel="noopener" class="hidden items-center gap-1.5 transition-colors hover:text-scooter md:inline-flex">
        IT Portal
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
      </a>
      <a
        href={site.clientPortal}
        target="_blank"
        rel="noopener"
        class:list={[
          'inline-flex items-center gap-1.5 rounded-full px-3 py-1 transition-colors',
          onDark ? 'bg-white/10 hover:bg-white/15' : 'border border-line hover:border-navy-900',
        ]}
      >
        Client Portal
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
      </a>
    </div>
  </Container>
</div>

---
// Cmd-K / Ctrl-K everywhere search.
// Builds a static index at build-time from services / industries / insights
// collections plus hand-curated tools & static pages.
import { getCollection } from 'astro:content';
import { industries } from '@/data/taxonomy';

type Entry = { kind: string; title: string; href: string; summary?: string; tag?: string };

const services = await getCollection('services');
const posts = await getCollection('insights');
const indItems = await getCollection('industries');

const index: Entry[] = [
  // Tools
  { kind: 'Tool', title: 'Tax Savings Estimator', href: '/tools/tax-savings-estimator/', summary: '3 questions, live current vs achievable rate' },
  { kind: 'Tool', title: 'Burn Rate Calculator', href: '/tools/burn-rate-calculator/', summary: 'Cash + monthly burn → runway in months' },
  { kind: 'Tool', title: 'Quarterly Tax Estimator', href: '/tools/quarterly-tax-estimator/', summary: 'Income + entity → 4 IRS payment dates' },
  { kind: 'Tool', title: 'S-Corp vs LLC', href: '/tools/s-corp-vs-llc/', summary: 'Side-by-side tax delta, break-even slider' },
  { kind: 'Tool', title: '1031 Exchange Savings', href: '/tools/1031-exchange-savings/', summary: 'Deferred capital gains on RE sale' },
  { kind: 'Tool', title: 'R&D Credit Estimator', href: '/tools/r-and-d-credit/', summary: 'Federal R&D credit via ASC method' },
  { kind: 'Tool', title: 'Find your service (4-question quiz)', href: '/find-your-service/', summary: 'Recommended Alpine Mar service bundle' },

  // Static pages
  { kind: 'Page', title: 'Home', href: '/' },
  { kind: 'Page', title: 'About Us', href: '/about-us/', summary: 'Team, values, comparison vs Big 4 / traditional CPA' },
  { kind: 'Page', title: 'All services', href: '/services/' },
  { kind: 'Page', title: 'All industries', href: '/industries/' },
  { kind: 'Page', title: 'Insights / Blog', href: '/blog/' },
  { kind: 'Page', title: 'In the Media', href: '/in-the-media/' },
  { kind: 'Page', title: 'Contact', href: '/contact/' },
  { kind: 'Page', title: 'Privacy Policy', href: '/privacy-policy/' },
];

for (const s of services) {
  if (s.id.startsWith('servicios-') || s.id === 'creacion-de-empresas') continue;
  index.push({ kind: 'Service', title: s.data.title, href: s.data.path, summary: s.data.summary, tag: s.data.group });
}
for (const ind of indItems) {
  const tx = industries.find((i) => i.href === ind.data.path);
  index.push({ kind: 'Industry', title: ind.data.title, href: ind.data.path, summary: tx?.desc ?? ind.data.summary });
}
for (const p of posts) {
  index.push({ kind: 'Insight', title: p.data.title, href: `/blog/${p.id}/`, summary: p.data.excerpt, tag: (p.data.tags ?? [])[0] });
}
---

<button
  type="button"
  id="cmdk-launcher"
  class="fixed bottom-6 left-6 z-50 hidden items-center gap-2 rounded-[6px] border border-line bg-white/95 px-3.5 py-2.5 font-display text-[12px] font-medium text-[var(--color-text-head)] shadow-[0_12px_40px_-12px_rgba(18,18,45,0.18)] backdrop-blur transition-colors hover:border-[#12122D] lg:inline-flex"
  aria-haspopup="dialog"
  aria-controls="cmdk-panel"
>
  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
  Search
  <kbd class="ml-1 inline-flex items-center gap-0.5 rounded-[4px] border border-line bg-paper px-1.5 py-0.5 font-mono text-[10px] uppercase text-[var(--color-text-body)]">⌘K</kbd>
</button>

<div
  id="cmdk-panel"
  class="fixed inset-0 z-[80] hidden items-start justify-center bg-[#0a0a1c]/55 p-4 pt-[14vh] backdrop-blur-md"
  role="dialog"
  aria-modal="true"
  aria-label="Search Alpine Mar"
>
  <div class="w-full max-w-2xl overflow-hidden rounded-[6px] border border-line bg-white shadow-[0_30px_80px_-20px_rgba(18,18,45,0.45)]">
    <header class="relative flex items-center gap-3 border-b border-line px-5 py-4">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" class="text-[var(--color-text-body)]" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input
        id="cmdk-input"
        type="search"
        autocomplete="off"
        placeholder="Search services, industries, articles, tools…"
        class="flex-1 bg-transparent font-display text-[15px] text-[var(--color-text-head)] placeholder:text-[var(--color-text-body)]/55 focus:outline-none"
      />
      <kbd class="hidden rounded-[4px] border border-line bg-paper px-2 py-0.5 font-mono text-[10px] uppercase tracking-[0.12em] text-[var(--color-text-body)] sm:inline-block">ESC</kbd>
    </header>
    <div class="max-h-[60vh] overflow-y-auto" id="cmdk-list">
      <!-- populated by JS -->
    </div>
    <footer class="flex items-center justify-between gap-3 border-t border-line bg-paper px-5 py-3 font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-body)]">
      <span class="flex items-center gap-3">
        <span class="flex items-center gap-1.5"><kbd class="rounded-[3px] border border-line bg-white px-1.5 py-0.5">↑↓</kbd>navigate</span>
        <span class="flex items-center gap-1.5"><kbd class="rounded-[3px] border border-line bg-white px-1.5 py-0.5">↵</kbd>open</span>
      </span>
      <span>{index.length} entries</span>
    </footer>
  </div>
</div>

<script define:vars={{ INDEX: index }}>
  (() => {
    // Resolve elements dynamically so we always see the latest DOM nodes
    // (Astro View Transition swaps replace the DOM tree).
    const $ = (sel) => document.querySelector(sel);
    const launcher = () => $('#cmdk-launcher');
    const panel    = () => $('#cmdk-panel');
    const input    = () => $('#cmdk-input');
    const list     = () => $('#cmdk-list');

    // Reveal launcher after a short delay so it doesn't compete with hero
    function revealLauncher(delay) { setTimeout(() => launcher()?.classList.remove('hidden'), delay); }
    revealLauncher(1200);
    document.addEventListener('astro:after-swap', () => revealLauncher(0));

    let activeIdx = 0;
    let filtered = [...INDEX];

    function score(item, q) {
      if (!q) return 0;
      const hay = (item.title + ' ' + (item.summary || '') + ' ' + (item.kind || '') + ' ' + (item.tag || '')).toLowerCase();
      let s = 0;
      const tokens = q.toLowerCase().split(/\s+/).filter(Boolean);
      for (const t of tokens) {
        const idx = hay.indexOf(t);
        if (idx < 0) return -1;
        s += 100 - Math.min(idx, 99);
        if (item.title.toLowerCase().startsWith(t)) s += 80;
        if (item.title.toLowerCase().includes(' ' + t)) s += 40;
      }
      return s;
    }

    function render() {
      const l = list(); if (!l) return;
      l.innerHTML = filtered.length
        ? filtered.slice(0, 30).map((item, i) => `
            <a href="${item.href}" data-idx="${i}"
               class="cmdk-row flex items-center gap-4 border-b border-line px-5 py-3.5 transition-colors ${i === activeIdx ? 'bg-[#12122D] text-white' : 'hover:bg-paper'}">
              <span class="font-mono text-[10px] uppercase tracking-[0.16em] ${i === activeIdx ? 'text-scooter' : 'text-[var(--color-text-body)]'}">${item.kind}</span>
              <span class="flex-1 truncate">
                <span class="block truncate font-display text-[14px] font-medium ${i === activeIdx ? 'text-white' : 'text-[var(--color-text-head)]'}">${item.title}</span>
                ${item.summary ? `<span class="mt-0.5 block truncate font-display text-[12px] ${i === activeIdx ? 'text-white/65' : 'text-[var(--color-text-body)]'}">${item.summary}</span>` : ''}
              </span>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" class="${i === activeIdx ? 'text-scooter' : 'text-[var(--color-text-body)]'}"><line x1="5" x2="19" y1="12" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          `).join('')
        : `<div class="px-5 py-14 text-center">
             <p class="font-display text-[14px] text-[var(--color-text-head)]">No results.</p>
             <p class="mt-2 font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-text-body)]">Try <span class="text-[#1F3062]">"tax planning"</span> or <span class="text-[#1F3062]">"runway"</span></p>
           </div>`;
    }

    function search(q) {
      if (!q.trim()) { filtered = [...INDEX]; activeIdx = 0; render(); return; }
      const scored = INDEX.map((it) => ({ it, s: score(it, q) })).filter((x) => x.s > 0);
      scored.sort((a, b) => b.s - a.s);
      filtered = scored.map((x) => x.it);
      activeIdx = 0;
      render();
    }

    function open() {
      const p = panel(), i = input(); if (!p) return;
      p.classList.remove('hidden');
      p.classList.add('flex');
      requestAnimationFrame(() => { i?.focus(); (i)?.select?.(); });
    }
    function close() {
      const p = panel(); if (!p) return;
      p.classList.add('hidden');
      p.classList.remove('flex');
    }

    // Event-delegation handlers — survive any number of view transition swaps
    document.addEventListener('click', (e) => {
      const t = e.target;
      if (t?.closest?.('#cmdk-launcher')) { e.preventDefault(); open(); return; }
      const p = panel();
      if (p && !p.classList.contains('hidden') && e.target === p) close();
    });
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        const p = panel();
        p?.classList.contains('hidden') ? open() : close();
        return;
      }
      const p = panel();
      if (!p || p.classList.contains('hidden')) return;
      if (e.key === 'Escape') { close(); return; }
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        activeIdx = Math.min(activeIdx + 1, Math.min(filtered.length, 30) - 1);
        render();
        document.querySelector('.cmdk-row.bg-\\[\\#12122D\\]')?.scrollIntoView({ block: 'nearest' });
      }
      if (e.key === 'ArrowUp') {
        e.preventDefault();
        activeIdx = Math.max(activeIdx - 1, 0);
        render();
        document.querySelector('.cmdk-row.bg-\\[\\#12122D\\]')?.scrollIntoView({ block: 'nearest' });
      }
      if (e.key === 'Enter') {
        e.preventDefault();
        const href = filtered[activeIdx]?.href;
        if (href) window.location.href = href;
      }
    });
    document.addEventListener('input', (e) => {
      if ((e.target)?.id === 'cmdk-input') search((e.target).value);
    });

    render();
    document.addEventListener('astro:after-swap', render);
  })();
</script>

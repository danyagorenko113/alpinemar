---
// Real Alpine Mar lock-up — sourced from the firm's WordPress upload library
// (Logo-Alpin-Mar-web.png) and stored at /public/images/brand/.
// For dark backgrounds (footer), we invert the navy-on-transparent PNG to white.
interface Props {
  class?: string;
  variant?: 'dark' | 'light';
}
const { class: className = '', variant = 'dark' } = Astro.props;
const filter = variant === 'light' ? 'brightness-0 invert' : '';
---

<a href="/" class:list={['inline-flex items-center', className]} aria-label="Alpine Mar — home">
  <img
    src="/images/brand/logo-web.png"
    alt="Alpine Mar · CPAs &amp; Advisors"
    width="180"
    height="50"
    class:list={['h-[46px] w-auto lg:h-12', filter]}
    loading="eager"
    decoding="async"
  />
</a>

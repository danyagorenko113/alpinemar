---
interface Props {
  class?: string;
  variant?: 'dark' | 'light';
}
const { class: className = '', variant = 'dark' } = Astro.props;
const text = variant === 'light' ? 'text-white' : 'text-navy';
const sub = variant === 'light' ? 'text-white/60' : 'text-mountain/60';
---

<a href="/" class:list={['group inline-flex items-center gap-2.5', className]} aria-label="Alpine Mar — home">
  <svg width="34" height="34" viewBox="0 0 34 34" fill="none" aria-hidden="true" class="shrink-0">
    <circle cx="17" cy="17" r="17" fill="#12122D" />
    <path d="M7 21l5-8 3.2 5L18 13l9 8H7z" fill="#33BBDC" />
    <path d="M7 24c2.5-1.6 4-1.6 6.5 0s4 1.6 6.5 0 4-1.6 6.5 0" stroke="#fff" stroke-width="1.4" stroke-linecap="round" fill="none" opacity="0.85" />
  </svg>
  <span class="flex flex-col leading-none">
    <span class:list={['font-heading text-lg font-bold tracking-tight', text]}>Alpine Mar</span>
    <span class:list={['mt-0.5 text-[9px] font-mono font-medium uppercase tracking-[0.22em]', sub]}>CPAs &amp; Advisors</span>
  </span>
</a>

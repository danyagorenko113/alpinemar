---
// Custom cursor: dot + halo ring.
// Magnetic pull: any element with [data-magnetic] (or a `button[type=submit]`,
// or an .am-magnet class) gently pulls the cursor towards its centre.
// Only enabled on (hover: hover) + (pointer: fine) devices.
---

<div id="cursor-dot" class="pointer-events-none fixed left-0 top-0 z-[100] hidden size-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-teal-500 mix-blend-difference will-change-transform"></div>
<div id="cursor-ring" class="pointer-events-none fixed left-0 top-0 z-[99] hidden size-9 -translate-x-1/2 -translate-y-1/2 rounded-full border border-navy-900/30 mix-blend-difference transition-[width,height,background-color,border-color] duration-200 ease-out will-change-transform"></div>

<style>
  /* When cursor is active, hide native cursor on hover-capable devices */
  @media (hover: hover) and (pointer: fine) {
    html.has-custom-cursor, html.has-custom-cursor * { cursor: none !important; }
    html.has-custom-cursor #cursor-dot,
    html.has-custom-cursor #cursor-ring { display: block; }
  }
  /* Cursor "hover state" */
  #cursor-ring.is-link  { width: 44px; height: 44px; border-color: var(--color-teal-500); }
  #cursor-ring.is-input { width: 4px; height: 24px; border-radius: 0; background: var(--color-teal-500); border-color: var(--color-teal-500); }
</style>

<script>
  (() => {
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (localStorage.getItem('am_cursor') === 'off') return;
    const dot = document.getElementById('cursor-dot');
    const ring = document.getElementById('cursor-ring');
    if (!dot || !ring) return;

    document.documentElement.classList.add('has-custom-cursor');

    let mx = window.innerWidth / 2, my = window.innerHeight / 2;
    let rx = mx, ry = my;
    let magnet: { el: HTMLElement; cx: number; cy: number } | null = null;

    window.addEventListener('mousemove', (e) => {
      mx = e.clientX;
      my = e.clientY;
    }, { passive: true });

    // Hover state — links + magnetic buttons
    const hoverable = 'a, button, input, textarea, select, label, [role="button"], [data-magnetic], .am-magnet';
    document.addEventListener('mouseover', (e) => {
      const t = e.target as HTMLElement;
      if (t.closest?.(hoverable)) {
        ring.classList.add('is-link');
        if (t.matches?.('input, textarea, select') || t.closest?.('input, textarea, select')) {
          ring.classList.add('is-input');
        }
        // Magnetic source
        const mEl = t.closest?.('[data-magnetic], .am-magnet') as HTMLElement | null;
        if (mEl) {
          const r = mEl.getBoundingClientRect();
          magnet = { el: mEl, cx: r.left + r.width / 2, cy: r.top + r.height / 2 };
        }
      }
    });
    document.addEventListener('mouseout', () => {
      ring.classList.remove('is-link', 'is-input');
      magnet = null;
      // Also undo any translate on the previous magnet element
      document.querySelectorAll<HTMLElement>('[data-magnetic],.am-magnet').forEach((el) => {
        el.style.transform = '';
      });
    });

    // RAF loop — smooth ring + dot, apply magnetic offset to ring + button
    function frame() {
      // Smooth ring towards cursor
      rx += (mx - rx) * 0.18;
      ry += (my - ry) * 0.18;

      // Magnetic pull (towards element centre)
      let dotX = mx, dotY = my, ringX = rx, ringY = ry;
      if (magnet) {
        const r = magnet.el.getBoundingClientRect();
        magnet.cx = r.left + r.width / 2;
        magnet.cy = r.top + r.height / 2;
        const dx = magnet.cx - mx;
        const dy = magnet.cy - my;
        const dist = Math.hypot(dx, dy);
        const radius = Math.max(r.width, r.height) * 0.85;
        if (dist < radius) {
          const pull = 1 - dist / radius;
          // Snap cursor towards centre
          dotX = mx + dx * 0.45 * pull;
          dotY = my + dy * 0.45 * pull;
          ringX = rx + dx * 0.55 * pull;
          ringY = ry + dy * 0.55 * pull;
          // Push the button slightly toward the cursor too
          magnet.el.style.transform = `translate(${-dx * 0.18 * pull}px, ${-dy * 0.18 * pull}px)`;
        } else {
          magnet.el.style.transform = '';
        }
      }
      dot.style.transform = `translate(${dotX}px, ${dotY}px) translate(-50%, -50%)`;
      ring.style.transform = `translate(${ringX}px, ${ringY}px) translate(-50%, -50%)`;
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  })();
</script>

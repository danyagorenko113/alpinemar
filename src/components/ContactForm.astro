---
// HubSpot-embedded consultation form (Portal 42958375, region na1). The form
// itself — fields, validation, spam protection, notifications — is managed in
// HubSpot; we keep the surrounding card + heading for visual continuity.
const HS = { region: 'na1', portalId: '42958375', formId: '1636ed35-b770-47ad-87c7-127ccaa449d0' };
const formId = Astro.props.id ?? 'consult-form';
const targetId = `${formId}-hs`;
---

<div class="rounded-[10px] border border-line bg-white p-7 text-[var(--color-text-head)] shadow-[0_24px_80px_-60px_rgba(18,18,45,0.45)] lg:p-10">
  <p class="font-display text-[13px] font-medium uppercase tracking-[0.1em] text-scooter">Request a consultation</p>
  <h2 class="mt-3 font-display text-[26px] font-medium tracking-[-0.02em] text-navy-900">Let’s get on a first name basis.</h2>

  <div
    id={targetId}
    class="hs-form-target mt-8"
    data-hs-region={HS.region}
    data-hs-portal={HS.portalId}
    data-hs-form={HS.formId}
  >
    <!-- HubSpot renders the form here -->
    <p class="hs-form-loading font-display text-[14px] text-[var(--color-text-body)]">Loading form…</p>
  </div>

  <noscript>
    <p class="mt-6 font-display text-[14px] text-[var(--color-text-body)]">
      Please enable JavaScript to load the form, or email
      <a href="mailto:hello@alpinemar.com" class="text-scooter underline">hello@alpinemar.com</a>.
    </p>
  </noscript>
</div>

<script>
  // Load the HubSpot embed script once, then render every form target on the page.
  function loadHubSpot(): Promise<void> {
    return new Promise((resolve) => {
      if ((window as any).hbspt) return resolve();
      const existing = document.querySelector('script[data-hs-embed]');
      if (existing) {
        existing.addEventListener('load', () => resolve(), { once: true });
        return;
      }
      const s = document.createElement('script');
      s.src = 'https://js.hsforms.net/forms/embed/v2.js';
      s.defer = true;
      s.setAttribute('data-hs-embed', '');
      s.addEventListener('load', () => resolve(), { once: true });
      document.head.appendChild(s);
    });
  }

  async function renderHubSpotForms() {
    const targets = document.querySelectorAll<HTMLElement>('.hs-form-target[data-hs-form]');
    if (!targets.length) return;
    await loadHubSpot();
    targets.forEach((el) => {
      if (el.dataset.hsRendered === '1' || !el.id) return;
      el.dataset.hsRendered = '1';
      (window as any).hbspt.forms.create({
        region: el.dataset.hsRegion,
        portalId: el.dataset.hsPortal,
        formId: el.dataset.hsForm,
        target: '#' + el.id,
        onFormReady: () => el.querySelector('.hs-form-loading')?.remove(),
      });
    });
  }

  // Call directly (initial load) + on view-transition navigations. The
  // hsRendered guard prevents a double render.
  renderHubSpotForms();
  document.addEventListener('astro:page-load', renderHubSpotForms);
</script>

---
// Soft sound design with user toggle.
// Uses Web Audio API to synthesize subtle stings:
//  - teal-ping on primary CTA hover
//  - soft whoosh on view transition
// Off by default. Toggle persisted in localStorage. Button rendered in footer
// via the floating fab AND a header-mounted toggle when found.
---

<button
  type="button"
  id="sound-toggle"
  class="fixed bottom-6 left-[12rem] z-50 hidden items-center gap-2 border border-line bg-paper/95 backdrop-blur px-3 py-2 font-mono text-[0.66rem] uppercase tracking-[0.14em] text-navy-700 shadow-[0_12px_40px_rgba(10,10,28,0.08)] transition-colors hover:border-navy-900 lg:flex"
  aria-pressed="false"
  aria-label="Toggle sound effects"
>
  <span id="sound-icon" aria-hidden="true">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
  </span>
  <span id="sound-label">Sound: off</span>
</button>

<script>
  (() => {
    let enabled = localStorage.getItem('am_sound') === '1';
    const btn = document.getElementById('sound-toggle');
    const icon = document.getElementById('sound-icon');
    const label = document.getElementById('sound-label');
    if (!btn || !icon || !label) return;
    setTimeout(() => btn.classList.remove('hidden'), 1500);

    let ctx: AudioContext | null = null;
    function audio() {
      if (!ctx && enabled) ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
      return ctx;
    }

    const ON_SVG  = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>';
    const OFF_SVG = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>';

    function sync() {
      icon.innerHTML = enabled ? ON_SVG : OFF_SVG;
      label.textContent = enabled ? 'Sound: on' : 'Sound: off';
      btn.setAttribute('aria-pressed', String(enabled));
      btn.dataset.on = enabled ? '1' : '0';
    }
    sync();

    function ping(freq: number, dur: number, type: OscillatorType = 'sine', startGain = 0.05) {
      const a = audio(); if (!a) return;
      const t = a.currentTime;
      const osc = a.createOscillator();
      const gain = a.createGain();
      osc.type = type;
      osc.frequency.setValueAtTime(freq, t);
      osc.frequency.exponentialRampToValueAtTime(freq * 0.6, t + dur);
      gain.gain.setValueAtTime(startGain, t);
      gain.gain.exponentialRampToValueAtTime(0.0001, t + dur);
      osc.connect(gain).connect(a.destination);
      osc.start(t);
      osc.stop(t + dur);
    }

    btn.addEventListener('click', () => {
      enabled = !enabled;
      localStorage.setItem('am_sound', enabled ? '1' : '0');
      sync();
      if (enabled) ping(720, 0.18, 'sine', 0.06); // confirmation chirp
    });

    // CTA-hover teal ping
    document.addEventListener('mouseenter', (e) => {
      if (!enabled) return;
      const t = e.target as HTMLElement | null;
      if (!t || !t.closest) return;
      if (t.matches?.('button[type=submit], [data-magnetic], .am-magnet') ||
          t.closest?.('button[type=submit], [data-magnetic], .am-magnet')) {
        ping(880, 0.08, 'sine', 0.04);
      }
    }, true);

    // Page-transition whoosh — Astro emits `astro:before-swap`
    document.addEventListener('astro:before-swap', () => {
      if (!enabled) return;
      ping(180, 0.32, 'sine', 0.05);
    });
  })();
</script>

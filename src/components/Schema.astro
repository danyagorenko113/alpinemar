---
// Renders one <script type="application/ld+json"> per item. Accepts structured
// objects (stringified here) and/or raw JSON-LD strings (passed through, used
// for CMS-managed schema overrides).
interface Props {
  data?: unknown | unknown[];
  raw?: string[];
}
const { data, raw = [] } = Astro.props;
const items = (Array.isArray(data) ? data : data ? [data] : []).filter(Boolean);
const rawItems = raw.filter((s) => s && s.trim());
// Escape `<` so a `</script>` inside any value can't break out of the tag
// (JSON stays valid — < is a legal escape). Guards against stored XSS.
const safe = (s: string) => s.replace(/</g, '\\u003c');
---
{items.map((d) => <script type="application/ld+json" set:html={safe(JSON.stringify(d))} />)}
{rawItems.map((s) => <script type="application/ld+json" set:html={safe(s)} />)}

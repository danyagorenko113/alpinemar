---
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';
import SEO from '@/components/SEO.astro';
import Nav from '@/components/Nav.astro';
import TopBar from '@/components/TopBar.astro';
import Footer from '@/components/Footer.astro';
import Schema from '@/components/Schema.astro';
import DeadlineTicker from '@/components/DeadlineTicker.astro';
import CmdKSearch from '@/components/CmdKSearch.astro';
import Glossary from '@/components/Glossary.astro';
import { orgSchema, websiteSchema } from '@/data/schema';

interface Props {
  title?: string;
  rawTitle?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  schema?: unknown | unknown[];
}
const { title, rawTitle, description, image, noindex, schema } = Astro.props;
const pageSchema = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      document.documentElement.classList.add('js');
      // Seasonal tint — set [data-season] for hero accent + watermark colour.
      (() => {
        const m = new Date().getMonth();
        const s = m < 2 || m === 11 ? 'winter'
                : m < 5            ? 'spring'
                : m < 8            ? 'summer'
                :                    'autumn';
        document.documentElement.dataset.season = s;
      })();
    </script>
    <meta name="theme-color" content="#fbfbfa" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon.png" />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&display=swap" />
    <meta name="generator" content={Astro.generator} />
    <SEO {title} {rawTitle} {description} {image} {noindex} />
    <Schema data={[orgSchema, websiteSchema, ...pageSchema]} />
    <ClientRouter fallback="swap" />
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col">
    <DeadlineTicker />
    <TopBar />
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CmdKSearch />
    <Glossary />

    <script>
      // Scroll reveal — adds .is-visible when elements enter the viewport.
      // Re-runs after every Astro view-transition swap so newly-mounted nodes
      // are observed.
      function initReveals() {
        const reveals = document.querySelectorAll('[data-reveal], [data-stagger]');
        if (!reveals.length) return;
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0, rootMargin: '0px 0px -10% 0px' }
        );
        reveals.forEach((el) => {
          if ((el as any).__revealBound) return;
          (el as any).__revealBound = true;
          io.observe(el);
        });
        // Safety net: never leave content hidden if the observer doesn't fire.
        setTimeout(() => {
          reveals.forEach((el) => {
            const r = el.getBoundingClientRect();
            if (r.top < window.innerHeight) el.classList.add('is-visible');
          });
        }, 1400);
      }
      initReveals();
      document.addEventListener('astro:after-swap', initReveals);

      // Smooth <details> open/close — site-wide accordion polish.
      // Wraps each non-summary child in an animated container and animates
      // height + opacity via Web Animations API. Falls back to native if WAA
      // is unavailable or the user prefers reduced motion.
      function enhanceDetails(root: ParentNode = document) {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        root.querySelectorAll<HTMLDetailsElement>('details').forEach((d) => {
          if ((d as any).__amSmooth) return;
          (d as any).__amSmooth = true;
          const summary = d.querySelector('summary');
          if (!summary) return;

          // Gather the body — every non-summary child wrapped in one container
          let body = d.querySelector<HTMLElement>(':scope > .am-details-body');
          if (!body) {
            body = document.createElement('div');
            body.className = 'am-details-body';
            body.style.overflow = 'hidden';
            const kids = Array.from(d.children).filter((c) => c !== summary);
            kids.forEach((k) => body!.appendChild(k));
            d.appendChild(body);
          }

          summary.addEventListener('click', (e) => {
            if (reduced || !(body as any).animate) return; // native behaviour
            e.preventDefault();
            const open = d.open;
            const target = open ? 0 : body!.scrollHeight;
            const from = open ? body!.scrollHeight : 0;
            if (!open) d.open = true;
            const anim = body!.animate(
              [
                { height: from + 'px', opacity: open ? 1 : 0 },
                { height: target + 'px', opacity: open ? 0 : 1 },
              ],
              { duration: 320, easing: 'cubic-bezier(0.22, 1, 0.36, 1)' }
            );
            anim.onfinish = () => {
              if (open) d.open = false;
              body!.style.height = '';
              body!.style.opacity = '';
            };
          });
        });
      }
      enhanceDetails();
      document.addEventListener('astro:after-swap', () => enhanceDetails());

      // Count-up for [data-counter] (value held in data-to, optional data-suffix/prefix).
      // Re-runs after every Astro view-transition swap; uses a per-element
      // __counterBound guard so a counter can't fire twice.
      function initCounters() {
        const counters = document.querySelectorAll<HTMLElement>('[data-counter]');
        if (!counters.length) return;
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const run = (el: HTMLElement) => {
          if ((el as any).__counterDone) return;
          (el as any).__counterDone = true;
          const to = Number(el.dataset.to || '0');
          const suffix = el.dataset.suffix || '';
          const prefix = el.dataset.prefix || '';
          if (reduced) {
            el.textContent = `${prefix}${to.toLocaleString()}${suffix}`;
            return;
          }
          const start = performance.now();
          const dur = 1600;
          const tick = (now: number) => {
            const p = Math.min((now - start) / dur, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = `${prefix}${Math.round(eased * to).toLocaleString()}${suffix}`;
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        };
        const cio = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                run(entry.target as HTMLElement);
                cio.unobserve(entry.target);
              }
            }
          },
          { threshold: 0, rootMargin: '0px 0px -80px 0px' }
        );
        counters.forEach((el) => {
          if ((el as any).__counterBound) return;
          (el as any).__counterBound = true;
          // Counters already in the viewport at bind time → run immediately
          // (IntersectionObserver may not fire if the page was scrolled past).
          const r = el.getBoundingClientRect();
          if (r.top < window.innerHeight && r.bottom > 0) {
            run(el);
          } else {
            cio.observe(el);
          }
        });
        // Final safety net: anything still on "0" after 1.6 s, run now.
        setTimeout(() => {
          counters.forEach((el) => {
            const r = el.getBoundingClientRect();
            if (r.top < window.innerHeight && el.textContent === '0') run(el);
          });
        }, 1600);
      }
      initCounters();
      document.addEventListener('astro:after-swap', initCounters);
    </script>
  </body>
</html>
